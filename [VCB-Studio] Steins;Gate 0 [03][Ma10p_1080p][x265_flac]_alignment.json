{
    "1": {
        "start": 28.58,
        "end": 29.98,
        "ja_text": "クリスマスパーティー?"
    },
    "2": {
        "start": 30.35,
        "end": 32.34,
        "ja_text": "マユシーはやる気満々だよ"
    },
    "3": {
        "start": 32.8,
        "end": 35.16,
        "ja_text": "みんなに似合うの作るから楽しみにしてね"
    },
    "4": {
        "start": 35.33,
        "end": 38.06,
        "ja_text": "おーさすが俺の嫁結婚して"
    },
    "5": {
        "start": 38.06,
        "end": 39.9,
        "ja_text": "アバキちゃん調子"
    },
    "6": {
        "start": 40.09,
        "end": 40.54,
        "ja_text": "マ"
    },
    "7": {
        "start": 41.28,
        "end": 44.16,
        "ja_text": "ユリちゃんも一緒に着るんだよねサンタの衣装"
    },
    "8": {
        "start": 44.48,
        "end": 47.3,
        "ja_text": "えでもマユシーは作るの専門だから"
    },
    "9": {
        "start": 47.31,
        "end": 49.42,
        "ja_text": "異議ありユキさんの言う通"
    },
    "10": {
        "start": 49.42,
        "end": 51.06,
        "ja_text": "りそんなのもったいないです"
    },
    "11": {
        "start": 51.06,
        "end": 52.2,
        "ja_text": "うーん"
    },
    "12": {
        "start": 53.024,
        "end": 55.44,
        "ja_text": "そうよそれにオカベさんもマユリ"
    },
    "13": {
        "start": 55.44,
        "end": 57.04,
        "ja_text": "ちゃんの衣装見たいんじゃないかな"
    },
    "14": {
        "start": 57.66,
        "end": 58.36,
        "ja_text": "オカリンが?"
    },
    "15": {
        "start": 58.61,
        "end": 59.9,
        "ja_text": "おかりんさんって"
    },
    "16": {
        "start": 60.09,
        "end": 62.08,
        "ja_text": "あはまゆしーの彼氏ね"
    },
    "17": {
        "start": 62.39,
        "end": 66.08,
        "ja_text": "え違うよおかりんとまゆし"
    },
    "18": {
        "start": 66.08,
        "end": 67.56,
        "ja_text": "ーはそういうのじゃないよ"
    },
    "19": {
        "start": 68.096,
        "end": 70.68,
        "ja_text": "またまたあんなにいつも仲良く"
    },
    "20": {
        "start": 70.68,
        "end": 72.76,
        "ja_text": "していてそれは無理がありますよ"
    },
    "21": {
        "start": 73.856,
        "end": 77.38,
        "ja_text": "本当だよだっておかりん"
    },
    "22": {
        "start": 77.38,
        "end": 79.78,
        "ja_text": "には好きな人がいるのです"
    },
    "23": {
        "start": 80.416,
        "end": 82.8,
        "ja_text": "えそうなの"
    },
    "24": {
        "start": 82.8,
        "end": 83.008,
        "ja_text": "うん。"
    },
    "25": {
        "start": 84.8,
        "end": 86.4,
        "ja_text": "だからマユシーとオカリンは"
    },
    "26": {
        "start": 86.4,
        "end": 89.86,
        "ja_text": "幼馴染の仲良しさんなんだよ。"
    },
    "27": {
        "start": 113.06,
        "end": 116.74,
        "ja_text": "すり込まれたビジョン"
    },
    "28": {
        "start": 119.18,
        "end": 123.38,
        "ja_text": "無限遠征 価値観を今"
    },
    "29": {
        "start": 123.76,
        "end": 128.76,
        "ja_text": "上書きする 変哲のない宇宙"
    },
    "30": {
        "start": 129.16,
        "end": 134.14,
        "ja_text": "傲慢な神は 目に映らない"
    },
    "31": {
        "start": 134.8,
        "end": 139.36,
        "ja_text": "高速度で 支配続けるならば"
    },
    "32": {
        "start": 139.36,
        "end": 146.32,
        "ja_text": "僕は 僕だけは 奇跡的で"
    },
    "33": {
        "start": 146.32,
        "end": 150.28,
        "ja_text": "致命的なマイノリティでいい"
    },
    "34": {
        "start": 151.2,
        "end": 153.3,
        "ja_text": "I can fly high あの"
    },
    "35": {
        "start": 153.3,
        "end": 157.96,
        "ja_text": "瞬間 あの場面が 君にとって特別なら"
    },
    "36": {
        "start": 158.2,
        "end": 163.48,
        "ja_text": "過去は離れてゆくものなんかじゃなくて"
    },
    "37": {
        "start": 163.48,
        "end": 166.14,
        "ja_text": "傷つつ外の痛みより"
    },
    "38": {
        "start": 166.14,
        "end": 168.84,
        "ja_text": "大事な真相の渋滞の"
    },
    "39": {
        "start": 168.84,
        "end": 173.08,
        "ja_text": "光が今全部を生む"
    },
    "40": {
        "start": 174.14,
        "end": 176.22,
        "ja_text": "There is no God"
    },
    "41": {
        "start": 176.74,
        "end": 179.28,
        "ja_text": "Wonderful New World"
    },
    "42": {
        "start": 187.456,
        "end": 189.42,
        "ja_text": "授業中はかけてくるなと言っただろう"
    },
    "43": {
        "start": 190.22,
        "end": 192.48,
        "ja_text": "さっき呼んだ時は休み時間でしたよね"
    },
    "44": {
        "start": 192.48,
        "end": 192.6,
        "ja_text": "ねえ"
    },
    "45": {
        "start": 192.6,
        "end": 193.12,
        "ja_text": "何"
    },
    "46": {
        "start": 193.56,
        "end": 195.46,
        "ja_text": "大学のサイトで授業のタイム"
    },
    "47": {
        "start": 195.46,
        "end": 197.08,
        "ja_text": "テーブルは確認しましたから"
    },
    "48": {
        "start": 198.84,
        "end": 200.32,
        "ja_text": "やっぱりイルスですか"
    },
    "49": {
        "start": 200.9,
        "end": 202.96,
        "ja_text": "こっちにもいろいろ事情があるんだ"
    },
    "50": {
        "start": 203.76,
        "end": 205.0,
        "ja_text": "何です事情って"
    },
    "51": {
        "start": 205.72,
        "end": 206.08,
        "ja_text": "それは"
    },
    "52": {
        "start": 206.82,
        "end": 208.86,
        "ja_text": "そのくらいの言い訳用意"
    },
    "53": {
        "start": 208.86,
        "end": 210.08,
        "ja_text": "しておいた方がいいですよ"
    },
    "54": {
        "start": 210.816,
        "end": 214.18,
        "ja_text": "とにかく出るまで駆け続けてくるのはやめてくれ"
    },
    "55": {
        "start": 214.27,
        "end": 217.24,
        "ja_text": "あなたが何一つ約束を守らないからじゃない"
    },
    "56": {
        "start": 218.04,
        "end": 218.76,
        "ja_text": "約束"
    },
    "57": {
        "start": 218.76,
        "end": 220.32,
        "ja_text": "言いましたよね"
    },
    "58": {
        "start": 220.32,
        "end": 223.26,
        "ja_text": "あなたの研究室ラボに連れて行くって"
    },
    "59": {
        "start": 223.84,
        "end": 226.72,
        "ja_text": "だからラボと言ってもただのお遊びサークルだ"
    },
    "60": {
        "start": 228.04,
        "end": 230.78,
        "ja_text": "でもオリジナルの私はそこ"
    },
    "61": {
        "start": 230.78,
        "end": 231.96,
        "ja_text": "へ行ったことがあるんでしょ"
    },
    "62": {
        "start": 232.84,
        "end": 233.16,
        "ja_text": "それは"
    },
    "63": {
        "start": 234.06,
        "end": 236.06,
        "ja_text": "はっきりしないですねどっちなんです"
    },
    "64": {
        "start": 237.96,
        "end": 239.48,
        "ja_text": "電話だ一度切るぞ"
    },
    "65": {
        "start": 242.752,
        "end": 243.16,
        "ja_text": "もしもし"
    },
    "66": {
        "start": 244.064,
        "end": 244.84,
        "ja_text": "あオカリ"
    },
    "67": {
        "start": 245.4,
        "end": 247.74,
        "ja_text": "あのねフブキちゃんたちもクリ"
    },
    "68": {
        "start": 247.74,
        "end": 249.3,
        "ja_text": "スマスパーティー来てくれるって"
    },
    "69": {
        "start": 249.5,
        "end": 251.36,
        "ja_text": "そうか、よかったな"
    },
    "70": {
        "start": 252.032,
        "end": 252.58,
        "ja_text": "それでね"
    },
    "71": {
        "start": 252.88,
        "end": 255.62,
        "ja_text": "コスプレ用の材料がいっぱいあるので"
    },
    "72": {
        "start": 255.77,
        "end": 257.82,
        "ja_text": "もしよかったらうちまで運"
    },
    "73": {
        "start": 257.82,
        "end": 259.78,
        "ja_text": "ぶの手伝ってほしいかなって"
    },
    "74": {
        "start": 260.22,
        "end": 260.8,
        "ja_text": "わかった、"
    },
    "75": {
        "start": 261.6,
        "end": 263.74,
        "ja_text": "講義が終わったらラボに行けばいいのか"
    },
    "76": {
        "start": 263.74,
        "end": 265.88,
        "ja_text": "うん、じゃあ待ってるね"
    },
    "77": {
        "start": 267.64,
        "end": 269.64,
        "ja_text": "オカリン来てくれるって"
    },
    "78": {
        "start": 270.432,
        "end": 271.42,
        "ja_text": "それはよかったにゃ"
    },
    "79": {
        "start": 271.54,
        "end": 273.6,
        "ja_text": "あとはスズさんだね"
    },
    "80": {
        "start": 274.02,
        "end": 275.06,
        "ja_text": "伝え手はあるにゃ"
    },
    "81": {
        "start": 276.14,
        "end": 278.12,
        "ja_text": "でもちゃんと来てくれるかな"
    },
    "82": {
        "start": 278.68,
        "end": 280.78,
        "ja_text": "普段はラボにいるんじゃないの?"
    },
    "83": {
        "start": 282.1,
        "end": 284.38,
        "ja_text": "うん、でも誰か来るとすぐ"
    },
    "84": {
        "start": 284.38,
        "end": 285.66,
        "ja_text": "どっか行っちゃうんだよね"
    },
    "85": {
        "start": 286.944,
        "end": 288.6,
        "ja_text": "まぁでも、なんとかなるにゃ!"
    },
    "86": {
        "start": 289.26,
        "end": 291.34,
        "ja_text": "フェイリスに任せとくにゃ!"
    },
    "87": {
        "start": 295.04,
        "end": 296.22,
        "ja_text": "ここが秋葉原"
    },
    "88": {
        "start": 296.896,
        "end": 299.24,
        "ja_text": "歩きスマホはマナーが悪い、切るぞ"
    },
    "89": {
        "start": 299.62,
        "end": 301.3,
        "ja_text": "待って、カメラが見えるようにして"
    },
    "90": {
        "start": 301.3,
        "end": 302.98,
        "ja_text": "てくれれば画面は見なくていいから"
    },
    "91": {
        "start": 303.86,
        "end": 304.18,
        "ja_text": "OK"
    },
    "92": {
        "start": 308.44,
        "end": 308.9,
        "ja_text": "アハー?"
    },
    "93": {
        "start": 310.44,
        "end": 310.98,
        "ja_text": "んー"
    },
    "94": {
        "start": 311.56,
        "end": 313.96,
        "ja_text": "あ、あ、いや、なんでもない"
    },
    "95": {
        "start": 315.24,
        "end": 317.56,
        "ja_text": "それにしても、ずいぶんゴミゴミしたところね"
    },
    "96": {
        "start": 318.12,
        "end": 318.42,
        "ja_text": "ん?"
    },
    "97": {
        "start": 319.68,
        "end": 320.24,
        "ja_text": "ラジカン?"
    },
    "98": {
        "start": 322.56,
        "end": 324.42,
        "ja_text": "あ、こら、何する?"
    },
    "99": {
        "start": 324.74,
        "end": 326.18,
        "ja_text": "あ、おいー!"
    },
    "100": {
        "start": 328.43,
        "end": 329.7,
        "ja_text": "お、岡部じゃねえか"
    },
    "101": {
        "start": 329.7,
        "end": 330.38,
        "ja_text": "こんにちは"
    },
    "102": {
        "start": 331.18,
        "end": 332.46,
        "ja_text": "お久しぶりです"
    },
    "103": {
        "start": 333.28,
        "end": 333.72,
        "ja_text": "誰?"
    },
    "104": {
        "start": 334.368,
        "end": 334.96,
        "ja_text": "黙ってろ"
    },
    "105": {
        "start": 335.42,
        "end": 337.64,
        "ja_text": "しっかし変われば変わるもんだな"
    },
    "106": {
        "start": 338.16,
        "end": 339.96,
        "ja_text": "真面目に大学行ってるみてえだし"
    },
    "107": {
        "start": 340.3,
        "end": 341.68,
        "ja_text": "その調子で頑張れや"
    },
    "108": {
        "start": 341.68,
        "end": 344.08,
        "ja_text": "あなたどれだけ不真面目だったの"
    },
    "109": {
        "start": 344.08,
        "end": 345.3,
        "ja_text": "うるさい"
    },
    "110": {
        "start": 349.7,
        "end": 350.68,
        "ja_text": "ここがラボだ"
    },
    "111": {
        "start": 351.52,
        "end": 351.9,
        "ja_text": "ここが"
    },
    "112": {
        "start": 358.976,
        "end": 359.6,
        "ja_text": "汚すぎ"
    },
    "113": {
        "start": 360.192,
        "end": 361.68,
        "ja_text": "最初の感想がそれか"
    },
    "114": {
        "start": 361.89,
        "end": 363.28,
        "ja_text": "ごめんなさい言い直します"
    },
    "115": {
        "start": 364.16,
        "end": 365.12,
        "ja_text": "ガラクタだらけですね"
    },
    "116": {
        "start": 366.912,
        "end": 369.68,
        "ja_text": "研究室というのはどこも雑然となるものだけど"
    },
    "117": {
        "start": 370.06,
        "end": 371.28,
        "ja_text": "これはひどすぎ"
    },
    "118": {
        "start": 371.51,
        "end": 373.4,
        "ja_text": "だから言ったろお前が想像"
    },
    "119": {
        "start": 373.4,
        "end": 374.68,
        "ja_text": "するようなものじゃないって"
    },
    "120": {
        "start": 374.68,
        "end": 376.8,
        "ja_text": "ラボというよりただのお部屋"
    },
    "121": {
        "start": 377.46,
        "end": 379.38,
        "ja_text": "マホ先輩の下宿といい勝負か"
    },
    "122": {
        "start": 380.56,
        "end": 383.44,
        "ja_text": "いいのかそういう個人のプライバシーを暴露して"
    },
    "123": {
        "start": 383.77,
        "end": 386.38,
        "ja_text": "あなたからも先輩に言ってあげてくれませんか"
    },
    "124": {
        "start": 386.76,
        "end": 389.28,
        "ja_text": "部屋はちゃんと片付けた方がいいって"
    },
    "125": {
        "start": 390.24,
        "end": 392.92,
        "ja_text": "いやそんなこと言ったら噛みつかれそうだけどな"
    },
    "126": {
        "start": 395.66,
        "end": 397.3,
        "ja_text": "でも少し憧れてました"
    },
    "127": {
        "start": 398.0,
        "end": 399.44,
        "ja_text": "こういうルームシェアみたいなの"
    },
    "128": {
        "start": 401.088,
        "end": 402.56,
        "ja_text": "それぞれマイフォークとかス"
    },
    "129": {
        "start": 402.56,
        "end": 403.9,
        "ja_text": "プーンとか決まってたりして"
    },
    "130": {
        "start": 404.36,
        "end": 404.72,
        "ja_text": "あ、"
    },
    "131": {
        "start": 408.52,
        "end": 410.22,
        "ja_text": "オカリンもう来てたんだ"
    },
    "132": {
        "start": 410.96,
        "end": 411.68,
        "ja_text": "テッテレー"
    },
    "133": {
        "start": 413.44,
        "end": 414.94,
        "ja_text": "音楽聴いてるの?"
    },
    "134": {
        "start": 415.24,
        "end": 416.28,
        "ja_text": "お友達ですか?"
    },
    "135": {
        "start": 416.84,
        "end": 417.44,
        "ja_text": "私も"
    },
    "136": {
        "start": 417.44,
        "end": 418.0,
        "ja_text": "来るぞ"
    },
    "137": {
        "start": 418.0,
        "end": 418.88,
        "ja_text": "あ、ちょっ"
    },
    "138": {
        "start": 419.92,
        "end": 421.1,
        "ja_text": "電話中だった?"
    },
    "139": {
        "start": 422.208,
        "end": 426.38,
        "ja_text": "大丈夫だそれにしてもこれかすごい荷物だな"
    },
    "140": {
        "start": 428.512,
        "end": 430.18,
        "ja_text": "冬コミマの衣装とサンタ"
    },
    "141": {
        "start": 430.18,
        "end": 431.8,
        "ja_text": "コスも作ることにしたから"
    },
    "142": {
        "start": 432.08,
        "end": 434.58,
        "ja_text": "クリスマスパーティーみんな来てくれるって"
    },
    "143": {
        "start": 434.96,
        "end": 435.32,
        "ja_text": "うん"
    },
    "144": {
        "start": 436.15,
        "end": 438.2,
        "ja_text": "ふぶきちゃんかえでさんゆき"
    },
    "145": {
        "start": 438.2,
        "end": 440.16,
        "ja_text": "さんるかくんにフェリスちゃん"
    },
    "146": {
        "start": 441.02,
        "end": 441.68,
        "ja_text": "ゆきさんも"
    },
    "147": {
        "start": 441.78,
        "end": 443.24,
        "ja_text": "もちろんだよ"
    },
    "148": {
        "start": 443.86,
        "end": 445.42,
        "ja_text": "まゆし思うのです"
    },
    "149": {
        "start": 445.46,
        "end": 448.66,
        "ja_text": "だるくんとゆきさんなんかいいなーって"
    },
    "150": {
        "start": 449.14,
        "end": 450.68,
        "ja_text": "ふぶきちゃんはない"
    },
    "151": {
        "start": 450.7,
        "end": 452.9,
        "ja_text": "絶対ない!って言うんだけどね"
    },
    "152": {
        "start": 464.2,
        "end": 467.92,
        "ja_text": "これを探すのが、私とお前の最初のミッションだ"
    },
    "153": {
        "start": 468.8,
        "end": 471.58,
        "ja_text": "えっと、お、おきどき?"
    },
    "154": {
        "start": 472.12,
        "end": 473.14,
        "ja_text": "いい返事だ"
    },
    "155": {
        "start": 486.208,
        "end": 487.76,
        "ja_text": "なんだルミ姉さんか"
    },
    "156": {
        "start": 487.76,
        "end": 490.84,
        "ja_text": "んルミ姉さん誰のことにゃ"
    },
    "157": {
        "start": 490.9,
        "end": 492.8,
        "ja_text": "フェイリスはフェイリスにゃ"
    },
    "158": {
        "start": 492.87,
        "end": 498.18,
        "ja_text": "たまには顔見せてくれないとみんな心配するにゃ"
    },
    "159": {
        "start": 498.76,
        "end": 498.96,
        "ja_text": "あ"
    },
    "160": {
        "start": 500.576,
        "end": 504.58,
        "ja_text": "そこにいると母さんいや一人の方が落ち着くんだ"
    },
    "161": {
        "start": 506.496,
        "end": 507.46,
        "ja_text": "差し入れだにゃ"
    },
    "162": {
        "start": 507.73,
        "end": 509.68,
        "ja_text": "スズにゃの大好物にゃ"
    },
    "163": {
        "start": 511.104,
        "end": 513.8,
        "ja_text": "賞味期限は明日だからゆっくり食べるにゃ"
    },
    "164": {
        "start": 514.58,
        "end": 514.9,
        "ja_text": "ありがとう"
    },
    "165": {
        "start": 516.66,
        "end": 519.52,
        "ja_text": "ダルニャンのタイムマシンの研究の方はどうにゃ"
    },
    "166": {
        "start": 520.288,
        "end": 521.74,
        "ja_text": "頑張ってはいるよでも"
    },
    "167": {
        "start": 523.2,
        "end": 524.36,
        "ja_text": "簡単ではにゃいっか"
    },
    "168": {
        "start": 526.54,
        "end": 528.78,
        "ja_text": "ごめんね迷惑かけて"
    },
    "169": {
        "start": 529.64,
        "end": 532.5,
        "ja_text": "大丈夫にゃフェイリスはちょっとここと"
    },
    "170": {
        "start": 532.5,
        "end": 534.88,
        "ja_text": "この下のフロアを借り上げただけにゃ"
    },
    "171": {
        "start": 535.13,
        "end": 537.06,
        "ja_text": "だけって、ほんと、"
    },
    "172": {
        "start": 537.64,
        "end": 539.68,
        "ja_text": "ルミ姉さんには世話になりっぱなしだ"
    },
    "173": {
        "start": 540.8,
        "end": 542.44,
        "ja_text": "気にしないでいいにゃん"
    },
    "174": {
        "start": 542.64,
        "end": 545.2,
        "ja_text": "この世界のエレメンタルを、培薬"
    },
    "175": {
        "start": 545.2,
        "end": 547.34,
        "ja_text": "兵たちの魔の手から救うためにゃら"
    },
    "176": {
        "start": 547.34,
        "end": 550.16,
        "ja_text": "フェイリスはいつでも協力するにゃん"
    },
    "177": {
        "start": 550.16,
        "end": 553.58,
        "ja_text": "そ、そう、よくわからないけど助かるよ"
    },
    "178": {
        "start": 556.32,
        "end": 557.36,
        "ja_text": "姉さん、父さん、"
    },
    "179": {
        "start": 558.24,
        "end": 560.06,
        "ja_text": "みんなのためにもオカリンお"
    },
    "180": {
        "start": 560.06,
        "end": 561.78,
        "ja_text": "じさんを必ず連れて行かなきゃ"
    },
    "181": {
        "start": 562.62,
        "end": 564.06,
        "ja_text": "シュタインズゲートの入り口に"
    },
    "182": {
        "start": 571.6,
        "end": 572.32,
        "ja_text": "24日?"
    },
    "183": {
        "start": 572.55,
        "end": 573.86,
        "ja_text": "クリスマスイブですか?"
    },
    "184": {
        "start": 574.656,
        "end": 576.14,
        "ja_text": "広告を聞くなら別の日でも"
    },
    "185": {
        "start": 576.29,
        "end": 579.92,
        "ja_text": "リン太郎に聞いたら問題はないとのことだったよ"
    },
    "186": {
        "start": 580.44,
        "end": 582.62,
        "ja_text": "魔法はなんか都合が悪いのかい?"
    },
    "187": {
        "start": 583.14,
        "end": 585.48,
        "ja_text": "いえ別に予定はないですけど"
    },
    "188": {
        "start": 586.208,
        "end": 587.78,
        "ja_text": "ではセンターのお格好を"
    },
    "189": {
        "start": 587.78,
        "end": 589.32,
        "ja_text": "して誘ってみたらどうだい?"
    },
    "190": {
        "start": 589.32,
        "end": 592.18,
        "ja_text": "24日に予定がないということは"
    },
    "191": {
        "start": 592.18,
        "end": 596.06,
        "ja_text": "この国では恋人がいないと同義だという話だよ"
    },
    "192": {
        "start": 596.06,
        "end": 598.18,
        "ja_text": "つまりリンターロにパートナーは"
    },
    "193": {
        "start": 598.18,
        "end": 600.54,
        "ja_text": "なんでそんな話になるんですか"
    },
    "194": {
        "start": 600.88,
        "end": 603.26,
        "ja_text": "あの子といい教授といいそんなことばかり"
    },
    "195": {
        "start": 603.37,
        "end": 605.68,
        "ja_text": "そうかい僕は楽しみだよ"
    },
    "196": {
        "start": 606.56,
        "end": 608.64,
        "ja_text": "エムデウスとリンターロが"
    },
    "197": {
        "start": 608.64,
        "end": 610.8,
        "ja_text": "どんな関係性を築いているか"
    },
    "198": {
        "start": 610.88,
        "end": 612.62,
        "ja_text": "君は興味ないのかい"
    },
    "199": {
        "start": 614.0,
        "end": 616.2,
        "ja_text": "セキュリティの面なら心配いらないよ"
    },
    "200": {
        "start": 616.39,
        "end": 618.7,
        "ja_text": "あの システム は 人 の 記憶 を 使"
    },
    "201": {
        "start": 618.7,
        "end": 621.2,
        "ja_text": "っ て いる 以上 非常 に 堅牢 だ"
    },
    "202": {
        "start": 621.2,
        "end": 623.32,
        "ja_text": "そう いう こと で は あり ませ ん"
    },
    "203": {
        "start": 626.24,
        "end": 627.76,
        "ja_text": "私 が 心配 し て いる の"
    },
    "204": {
        "start": 636.28,
        "end": 638.2,
        "ja_text": "何 だ なん だ と は な"
    },
    "205": {
        "start": 638.2,
        "end": 640.16,
        "ja_text": "ん です か 心配 な の は"
    },
    "206": {
        "start": 644.704,
        "end": 645.82,
        "ja_text": "岡部凛太郎です"
    },
    "207": {
        "start": 654.44,
        "end": 655.42,
        "ja_text": "そろそろ飽きたわね"
    },
    "208": {
        "start": 656.1,
        "end": 658.52,
        "ja_text": "あ、そこの角の先行ったことない"
    },
    "209": {
        "start": 659.48,
        "end": 661.7,
        "ja_text": "待ち合わせの時間までだって言ったろ"
    },
    "210": {
        "start": 662.56,
        "end": 664.02,
        "ja_text": "少しくらい平気よ"
    },
    "211": {
        "start": 664.33,
        "end": 666.48,
        "ja_text": "まだあなたの言った約束の時間まで"
    },
    "212": {
        "start": 666.48,
        "end": 668.4,
        "ja_text": "365秒あるわ"
    },
    "213": {
        "start": 668.4,
        "end": 669.08,
        "ja_text": "ったく"
    },
    "214": {
        "start": 673.088,
        "end": 673.7,
        "ja_text": "面白いか"
    },
    "215": {
        "start": 674.68,
        "end": 676.7,
        "ja_text": "自分で動けないのがもどかしいわね"
    },
    "216": {
        "start": 679.88,
        "end": 681.7,
        "ja_text": "そうだこのスマホにラジコンを取り"
    },
    "217": {
        "start": 681.7,
        "end": 683.22,
        "ja_text": "付けたカメラを連動できないかしら"
    },
    "218": {
        "start": 683.72,
        "end": 684.44,
        "ja_text": "そしたら自由に"
    },
    "219": {
        "start": 684.44,
        "end": 685.0,
        "ja_text": "ダメだ"
    },
    "220": {
        "start": 685.84,
        "end": 688.5,
        "ja_text": "なによ一昨日の合コンではろくに話"
    },
    "221": {
        "start": 688.5,
        "end": 690.66,
        "ja_text": "せもしなかったくせにこういう時だけ"
    },
    "222": {
        "start": 691.08,
        "end": 692.42,
        "ja_text": "な、ちょ、なんで"
    },
    "223": {
        "start": 692.88,
        "end": 695.5,
        "ja_text": "アプリ落とさずにホイホイ参加するからよ"
    },
    "224": {
        "start": 695.92,
        "end": 697.98,
        "ja_text": "バックグラウンドで聞いてるだけだったけど"
    },
    "225": {
        "start": 698.624,
        "end": 700.38,
        "ja_text": "笑いこらえるの大変だったんだから"
    },
    "226": {
        "start": 700.9,
        "end": 702.48,
        "ja_text": "一発ギャグで滑るわ"
    },
    "227": {
        "start": 702.76,
        "end": 705.42,
        "ja_text": "フィーリングカップルでオファーの前に逃げるわ"
    },
    "228": {
        "start": 706.1,
        "end": 707.78,
        "ja_text": "王様ゲームでドン引かれるわ"
    },
    "229": {
        "start": 707.78,
        "end": 709.66,
        "ja_text": "もしかして今日ヒヤジョウさんたち"
    },
    "230": {
        "start": 709.66,
        "end": 712.288,
        "ja_text": "と会ってログを提出するってことは"
    },
    "231": {
        "start": 712.32,
        "end": 715.54,
        "ja_text": "もちろんその全てが提出されることになるわね"
    },
    "232": {
        "start": 715.9,
        "end": 716.22,
        "ja_text": "で"
    },
    "233": {
        "start": 717.44,
        "end": 720.78,
        "ja_text": "あとは私との会話も全てログ化されているから"
    },
    "234": {
        "start": 721.36,
        "end": 723.68,
        "ja_text": "家が成果店のくせにナスが嫌いだとか"
    },
    "235": {
        "start": 724.36,
        "end": 726.14,
        "ja_text": "最初会った時に人のことをク"
    },
    "236": {
        "start": 726.14,
        "end": 727.64,
        "ja_text": "リスティーナと呼んだこととか"
    },
    "237": {
        "start": 727.64,
        "end": 729.42,
        "ja_text": "やめろ"
    },
    "238": {
        "start": 730.68,
        "end": 731.9,
        "ja_text": "でなんでクリスティーナ"
    },
    "239": {
        "start": 734.54,
        "end": 735.28,
        "ja_text": "しつこいな"
    },
    "240": {
        "start": 736.14,
        "end": 739.0,
        "ja_text": "人の記憶は曖昧で時間が経つほど"
    },
    "241": {
        "start": 739.0,
        "end": 741.42,
        "ja_text": "入り混じり物語が構築されていく"
    },
    "242": {
        "start": 742.912,
        "end": 743.22,
        "ja_text": "つまり"
    },
    "243": {
        "start": 743.936,
        "end": 746.52,
        "ja_text": "残念ながら不完全なAIであるア"
    },
    "244": {
        "start": 746.52,
        "end": 749.28,
        "ja_text": "マデウスにはその曖昧な記憶の変化"
    },
    "245": {
        "start": 750.08,
        "end": 751.78,
        "ja_text": "いわゆる忘却はないの"
    },
    "246": {
        "start": 752.0,
        "end": 754.4,
        "ja_text": "だがデモンストレーションで見た"
    },
    "247": {
        "start": 754.4,
        "end": 756.62,
        "ja_text": "アマデウスは忘れていなかったか"
    },
    "248": {
        "start": 757.184,
        "end": 759.92,
        "ja_text": "それはデータ上不必要と判断した記録を"
    },
    "249": {
        "start": 759.92,
        "end": 762.08,
        "ja_text": "機械的に読み込めないようにしてるだけ"
    },
    "250": {
        "start": 762.72,
        "end": 763.5,
        "ja_text": "ログは残ってるわ"
    },
    "251": {
        "start": 764.128,
        "end": 766.72,
        "ja_text": "だから一度読んだことをいつまでも聞くのか"
    },
    "252": {
        "start": 766.72,
        "end": 767.52,
        "ja_text": "そういうこと"
    },
    "253": {
        "start": 768.416,
        "end": 769.88,
        "ja_text": "それにしてはしつこくないか"
    },
    "254": {
        "start": 770.88,
        "end": 772.96,
        "ja_text": "はぐらかされると気になってしょうがないの"
    },
    "255": {
        "start": 774.48,
        "end": 776.86,
        "ja_text": "好奇心も過ぎるといつか痛い目に遭うぞ"
    },
    "256": {
        "start": 777.92,
        "end": 779.3,
        "ja_text": "研究者はそのくらいじゃない"
    },
    "257": {
        "start": 779.3,
        "end": 780.42,
        "ja_text": "とやっていけないのよ"
    },
    "258": {
        "start": 783.3,
        "end": 783.88,
        "ja_text": "リン太郎"
    },
    "259": {
        "start": 784.16,
        "end": 791.44,
        "ja_text": "すみません時間には来ていたんですが"
    },
    "260": {
        "start": 792.32,
        "end": 795.56,
        "ja_text": "何してたのよあんなところで立ったり座ったり"
    },
    "261": {
        "start": 797.62,
        "end": 800.16,
        "ja_text": "ところでどうかなクリスは"
    },
    "262": {
        "start": 802.14,
        "end": 803.7,
        "ja_text": "不思議な気分ですね"
    },
    "263": {
        "start": 804.86,
        "end": 805.5,
        "ja_text": "AIなのに"
    },
    "264": {
        "start": 806.18,
        "end": 806.5,
        "ja_text": "まるで"
    },
    "265": {
        "start": 807.92,
        "end": 810.76,
        "ja_text": "どうやら面白い話が聞けそうだね"
    },
    "266": {
        "start": 811.28,
        "end": 813.82,
        "ja_text": "この後大学の施設でディナ"
    },
    "267": {
        "start": 813.82,
        "end": 815.32,
        "ja_text": "ーを受け取るつもりだけど"
    },
    "268": {
        "start": 816.14,
        "end": 817.82,
        "ja_text": "今晩は時間あるかい"
    },
    "269": {
        "start": 818.38,
        "end": 821.64,
        "ja_text": "良ければディナーを一緒にと思っているのだが"
    },
    "270": {
        "start": 822.02,
        "end": 822.68,
        "ja_text": "今晩ですか"
    },
    "271": {
        "start": 824.04,
        "end": 824.56,
        "ja_text": "すみません"
    },
    "272": {
        "start": 825.4,
        "end": 827.36,
        "ja_text": "今日の夜はちょっと友人とク"
    },
    "273": {
        "start": 827.36,
        "end": 828.7,
        "ja_text": "リスマスパーティーの予定が"
    },
    "274": {
        "start": 833.32,
        "end": 834.02,
        "ja_text": "パーティー"
    },
    "275": {
        "start": 847.2,
        "end": 847.78,
        "ja_text": "父さん"
    },
    "276": {
        "start": 851.3,
        "end": 854.09,
        "ja_text": "素敵なラブだね リン太郎"
    },
    "277": {
        "start": 854.56,
        "end": 856.54,
        "ja_text": "今日はお招きありがとうございます"
    },
    "278": {
        "start": 857.26,
        "end": 860.06,
        "ja_text": "ジャパニーズメイドガール キャットガール"
    },
    "279": {
        "start": 861.22,
        "end": 862.34,
        "ja_text": "あの そちらは"
    },
    "280": {
        "start": 863.104,
        "end": 866.0,
        "ja_text": "電話で話した 冷座嬢さんとレスキネン教授だ"
    },
    "281": {
        "start": 866.88,
        "end": 868.14,
        "ja_text": "大学で世話になっててな"
    },
    "282": {
        "start": 868.57,
        "end": 869.84,
        "ja_text": "本当によかったの?"
    },
    "283": {
        "start": 870.43,
        "end": 872.31,
        "ja_text": "仲間うちのパーティーにお邪魔しちゃって"
    },
    "284": {
        "start": 872.49,
        "end": 874.56,
        "ja_text": "リン太郎が是非にと言ってく"
    },
    "285": {
        "start": 874.56,
        "end": 876.18,
        "ja_text": "れたのだからいいじゃないか"
    },
    "286": {
        "start": 876.78,
        "end": 879.1,
        "ja_text": "社交事例をそのまま受け取らないでください"
    },
    "287": {
        "start": 879.52,
        "end": 881.46,
        "ja_text": "教授がご利用したんじゃないですか"
    },
    "288": {
        "start": 882.0,
        "end": 883.3,
        "ja_text": "マホも嬉しいだろ"
    },
    "289": {
        "start": 883.3,
        "end": 885.16,
        "ja_text": "な、なんでそうなるんですか"
    },
    "290": {
        "start": 887.04,
        "end": 887.76,
        "ja_text": "何年生?"
    },
    "291": {
        "start": 888.52,
        "end": 888.88,
        "ja_text": "え?"
    },
    "292": {
        "start": 889.94,
        "end": 893.62,
        "ja_text": "ごめんなさいこれでも成人しているのよ"
    },
    "293": {
        "start": 898.656,
        "end": 901.58,
        "ja_text": "しかし美しい女性ばかりでなん"
    },
    "294": {
        "start": 901.58,
        "end": 904.12,
        "ja_text": "とも華やかなラブだねリン太郎"
    },
    "295": {
        "start": 905.1,
        "end": 909.08,
        "ja_text": "特に彼女なんて実にセクシーだ"
    },
    "296": {
        "start": 910.12,
        "end": 910.88,
        "ja_text": "だが男だ"
    },
    "297": {
        "start": 913.16,
        "end": 915.9,
        "ja_text": "ジューシー唐揚げナンバーワン"
    },
    "298": {
        "start": 916.06,
        "end": 919.8,
        "ja_text": "クリスマス限定お得用サイズだよ"
    },
    "299": {
        "start": 920.576,
        "end": 922.0,
        "ja_text": "ところで鈴葉は"
    },
    "300": {
        "start": 922.2,
        "end": 925.56,
        "ja_text": "うん 今ダル君がミッション中なんだよ"
    },
    "301": {
        "start": 926.74,
        "end": 927.1,
        "ja_text": "ダルが?"
    },
    "302": {
        "start": 927.456,
        "end": 930.52,
        "ja_text": "うん うまく騙して連れてこれるかな"
    },
    "303": {
        "start": 931.392,
        "end": 931.82,
        "ja_text": "騙す?"
    },
    "304": {
        "start": 933.62,
        "end": 936.12,
        "ja_text": "ええ パーティーって言うと遠慮して"
    },
    "305": {
        "start": 936.12,
        "end": 938.528,
        "ja_text": "しまいそうだから黙って連れてこようって"
    },
    "306": {
        "start": 939.86,
        "end": 942.52,
        "ja_text": "ダルには苦重い任務だな"
    },
    "307": {
        "start": 944.28,
        "end": 944.56,
        "ja_text": "来た!"
    },
    "308": {
        "start": 945.22,
        "end": 947.48,
        "ja_text": "ダル君からもうすぐ来るって"
    },
    "309": {
        "start": 948.56,
        "end": 950.7,
        "ja_text": "よーし じゃあ みんな準備準備"
    },
    "310": {
        "start": 950.7,
        "end": 953.12,
        "ja_text": "アンビー アンビー"
    },
    "311": {
        "start": 967.1,
        "end": 970.6,
        "ja_text": "よーし 入るぞー"
    },
    "312": {
        "start": 971.68,
        "end": 973.62,
        "ja_text": "鈴葉と一緒に入るぞー"
    },
    "313": {
        "start": 973.62,
        "end": 975.24,
        "ja_text": "父さん ストップ"
    },
    "314": {
        "start": 975.24,
        "end": 976.24,
        "ja_text": "えっ ああ"
    },
    "315": {
        "start": 977.312,
        "end": 978.9,
        "ja_text": "レディーゴー"
    },
    "316": {
        "start": 984.58,
        "end": 985.74,
        "ja_text": "ようこそすずさん"
    },
    "317": {
        "start": 987.66,
        "end": 988.02,
        "ja_text": "あれ"
    },
    "318": {
        "start": 991.56,
        "end": 991.84,
        "ja_text": "あれ"
    },
    "319": {
        "start": 994.54,
        "end": 994.64,
        "ja_text": "こ、"
    },
    "320": {
        "start": 995.16,
        "end": 995.42,
        "ja_text": "こそ"
    },
    "321": {
        "start": 996.42,
        "end": 998.56,
        "ja_text": "すずにゃんクリスマスサ"
    },
    "322": {
        "start": 998.56,
        "end": 1000.1,
        "ja_text": "プライズクリスマスにゃん"
    },
    "323": {
        "start": 1000.58,
        "end": 1002.0,
        "ja_text": "パーティーだよ"
    },
    "324": {
        "start": 1002.54,
        "end": 1002.9,
        "ja_text": "え"
    },
    "325": {
        "start": 1004.3,
        "end": 1005.76,
        "ja_text": "ご、ごめんなさい"
    },
    "326": {
        "start": 1006.58,
        "end": 1008.84,
        "ja_text": "び、びっくりさせようと思って"
    },
    "327": {
        "start": 1012.6,
        "end": 1015.66,
        "ja_text": "それでと兄さんもなんか変だったのか"
    },
    "328": {
        "start": 1016.56,
        "end": 1019.26,
        "ja_text": "ごめんね企画したのまゆしなんだ"
    },
    "329": {
        "start": 1020.5,
        "end": 1022.16,
        "ja_text": "いや怒りはしないけど"
    },
    "330": {
        "start": 1023.232,
        "end": 1026.3,
        "ja_text": "すごいねいつものラボとは思えないや"
    },
    "331": {
        "start": 1026.41,
        "end": 1026.86,
        "ja_text": "うん"
    },
    "332": {
        "start": 1027.46,
        "end": 1029.06,
        "ja_text": "みんなで飾り付けしたんだよ"
    },
    "333": {
        "start": 1029.21,
        "end": 1031.82,
        "ja_text": "まゆしが鈴葉に元気になって"
    },
    "334": {
        "start": 1031.82,
        "end": 1034.08,
        "ja_text": "もらいたいって用意したん"
    },
    "335": {
        "start": 1034.51,
        "end": 1035.14,
        "ja_text": "そっか。"
    },
    "336": {
        "start": 1036.416,
        "end": 1036.9,
        "ja_text": "でも私、"
    },
    "337": {
        "start": 1037.8,
        "end": 1039.96,
        "ja_text": "遊ぶためにここにいるわけじゃないし。"
    },
    "338": {
        "start": 1041.24,
        "end": 1042.82,
        "ja_text": "みんなで楽しんでいってよ。"
    },
    "339": {
        "start": 1044.58,
        "end": 1045.52,
        "ja_text": "いいじゃないか。"
    },
    "340": {
        "start": 1049.28,
        "end": 1049.8,
        "ja_text": "それくらい。"
    },
    "341": {
        "start": 1052.62,
        "end": 1053.74,
        "ja_text": "そ、そうだよ。"
    },
    "342": {
        "start": 1054.0,
        "end": 1056.08,
        "ja_text": "みんなでご飯食べるだけだって。"
    },
    "343": {
        "start": 1056.52,
        "end": 1058.88,
        "ja_text": "みんなが作ってくれたものをあり"
    },
    "344": {
        "start": 1058.88,
        "end": 1060.58,
        "ja_text": "がたくいただけばよいのだぜ。"
    },
    "345": {
        "start": 1065.952,
        "end": 1067.78,
        "ja_text": "それでは乾杯するにゃ"
    },
    "346": {
        "start": 1067.78,
        "end": 1069.08,
        "ja_text": "せーの"
    },
    "347": {
        "start": 1069.47,
        "end": 1071.79,
        "ja_text": "メリークリスマス"
    },
    "348": {
        "start": 1072.48,
        "end": 1073.36,
        "ja_text": "乾杯"
    },
    "349": {
        "start": 1098.06,
        "end": 1098.96,
        "ja_text": "オカリン?"
    },
    "350": {
        "start": 1099.32,
        "end": 1101.34,
        "ja_text": "この後プレゼント交換だよ"
    },
    "351": {
        "start": 1102.28,
        "end": 1103.08,
        "ja_text": "すぐ戻る"
    },
    "352": {
        "start": 1114.56,
        "end": 1115.78,
        "ja_text": "推論を立ててみた"
    },
    "353": {
        "start": 1116.7,
        "end": 1117.06,
        "ja_text": "なんだ?"
    },
    "354": {
        "start": 1118.08,
        "end": 1118.6,
        "ja_text": "仮説1"
    },
    "355": {
        "start": 1118.6,
        "end": 1121.2,
        "ja_text": "1.あなたが好きなハリウッド女"
    },
    "356": {
        "start": 1121.2,
        "end": 1123.28,
        "ja_text": "優にクリスティーナなんちゃらとか"
    },
    "357": {
        "start": 1123.28,
        "end": 1125.3,
        "ja_text": "いう人がいてつい呼んでしまった"
    },
    "358": {
        "start": 1126.02,
        "end": 1126.34,
        "ja_text": "違う"
    },
    "359": {
        "start": 1127.34,
        "end": 1130.64,
        "ja_text": "2.昔付き合ってた彼女…いや"
    },
    "360": {
        "start": 1130.64,
        "end": 1132.56,
        "ja_text": "これはないわねごめんなさい"
    },
    "361": {
        "start": 1133.0,
        "end": 1133.64,
        "ja_text": "待て"
    },
    "362": {
        "start": 1133.8,
        "end": 1134.84,
        "ja_text": "じゃあ付き合ってたの?"
    },
    "363": {
        "start": 1135.34,
        "end": 1135.66,
        "ja_text": "え?"
    },
    "364": {
        "start": 1137.6,
        "end": 1140.12,
        "ja_text": "沈黙は負けを認めたことを意味するわよ"
    },
    "365": {
        "start": 1141.54,
        "end": 1142.54,
        "ja_text": "うるさいな"
    },
    "366": {
        "start": 1144.0,
        "end": 1146.14,
        "ja_text": "さん、オリジナルの私を直接、"
    },
    "367": {
        "start": 1146.36,
        "end": 1149.14,
        "ja_text": "あるいは間接的にそう呼んでいた"
    },
    "368": {
        "start": 1150.34,
        "end": 1151.88,
        "ja_text": "まあこれも可能性は低いわね"
    },
    "369": {
        "start": 1152.72,
        "end": 1153.14,
        "ja_text": "なぜだ"
    },
    "370": {
        "start": 1153.9,
        "end": 1155.22,
        "ja_text": "私ならこう返すからよ"
    },
    "371": {
        "start": 1155.98,
        "end": 1158.04,
        "ja_text": "ティーナってつけるな!ってね"
    },
    "372": {
        "start": 1161.34,
        "end": 1164.84,
        "ja_text": "はーい、もう少し、もう少し近づいて"
    },
    "373": {
        "start": 1165.8,
        "end": 1166.64,
        "ja_text": "は、はい"
    },
    "374": {
        "start": 1166.8,
        "end": 1167.92,
        "ja_text": "不本意だわ、"
    },
    "375": {
        "start": 1168.52,
        "end": 1169.86,
        "ja_text": "はなはだ不本意だわ"
    },
    "376": {
        "start": 1169.86,
        "end": 1172.42,
        "ja_text": "あ、あの、ごめんなさい"
    },
    "377": {
        "start": 1172.77,
        "end": 1175.22,
        "ja_text": "あ、い、いえ、違うのよ"
    },
    "378": {
        "start": 1175.48,
        "end": 1177.28,
        "ja_text": "ナイちゃんは悪くないの"
    },
    "379": {
        "start": 1178.8,
        "end": 1180.18,
        "ja_text": "か、かわいい"
    },
    "380": {
        "start": 1180.18,
        "end": 1182.0,
        "ja_text": "世界に幸あれ"
    },
    "381": {
        "start": 1182.0,
        "end": 1182.88,
        "ja_text": "ふぅ"
    },
    "382": {
        "start": 1184.16,
        "end": 1185.4,
        "ja_text": "岡部さん遅いね"
    },
    "383": {
        "start": 1185.94,
        "end": 1186.76,
        "ja_text": "お、うん"
    },
    "384": {
        "start": 1187.98,
        "end": 1188.9,
        "ja_text": "ちょっと見てくるね"
    },
    "385": {
        "start": 1194.62,
        "end": 1197.16,
        "ja_text": "もしかして今のが正解?"
    },
    "386": {
        "start": 1197.72,
        "end": 1199.58,
        "ja_text": "勝手に話を進めるのは"
    },
    "387": {
        "start": 1200.58,
        "end": 1202.22,
        "ja_text": "だったらちゃんと答えなさい"
    },
    "388": {
        "start": 1204.06,
        "end": 1206.92,
        "ja_text": "答えを聞きたいんだよな"
    },
    "389": {
        "start": 1207.9,
        "end": 1208.34,
        "ja_text": "え"
    },
    "390": {
        "start": 1210.06,
        "end": 1211.48,
        "ja_text": "照れくさかったんだ"
    },
    "391": {
        "start": 1211.48,
        "end": 1211.616,
        "ja_text": "え"
    },
    "392": {
        "start": 1214.0,
        "end": 1217.92,
        "ja_text": "素直に名前を呼べなかったからあえて茶化した"
    },
    "393": {
        "start": 1218.624,
        "end": 1220.7,
        "ja_text": "私を呼ぶのか"
    },
    "394": {
        "start": 1221.88,
        "end": 1222.32,
        "ja_text": "ああ"
    },
    "395": {
        "start": 1227.2,
        "end": 1229.5,
        "ja_text": "なっ、そ、それはどうも…"
    },
    "396": {
        "start": 1236.78,
        "end": 1238.18,
        "ja_text": "なんで赤くなってるんだ?"
    },
    "397": {
        "start": 1239.74,
        "end": 1239.904,
        "ja_text": "え?"
    },
    "398": {
        "start": 1240.32,
        "end": 1241.88,
        "ja_text": "赤くなんて なんてなんかないし!"
    },
    "399": {
        "start": 1242.16,
        "end": 1244.42,
        "ja_text": "あ、女の子扱いされるなんて"
    },
    "400": {
        "start": 1244.42,
        "end": 1245.46,
        "ja_text": "思ってなんかなかったとか"
    },
    "401": {
        "start": 1245.46,
        "end": 1248.24,
        "ja_text": "そ、その… そんなことは決してないからな!"
    },
    "402": {
        "start": 1249.62,
        "end": 1250.98,
        "ja_text": "な、なによ?"
    },
    "403": {
        "start": 1252.54,
        "end": 1253.12,
        "ja_text": "俺は…"
    },
    "404": {
        "start": 1253.76,
        "end": 1254.16,
        "ja_text": "え?"
    },
    "405": {
        "start": 1256.04,
        "end": 1258.5,
        "ja_text": "俺はお前のそんなところが"
    },
    "406": {
        "start": 1258.5,
        "end": 1258.784,
        "ja_text": "え?"
    },
    "407": {
        "start": 1259.26,
        "end": 1259.488,
        "ja_text": "ちょ"
    },
    "408": {
        "start": 1264.02,
        "end": 1264.48,
        "ja_text": "な"
    },
    "409": {
        "start": 1265.28,
        "end": 1265.74,
        "ja_text": "え?"
    },
    "410": {
        "start": 1265.74,
        "end": 1266.5,
        "ja_text": "先輩"
    },
    "411": {
        "start": 1268.06,
        "end": 1269.98,
        "ja_text": "ヒアジョウさん何を"
    },
    "412": {
        "start": 1270.38,
        "end": 1270.88,
        "ja_text": "言"
    },
    "413": {
        "start": 1271.392,
        "end": 1271.9,
        "ja_text": "ったでしょ"
    },
    "414": {
        "start": 1273.1,
        "end": 1274.34,
        "ja_text": "錯覚に陥るって"
    },
    "415": {
        "start": 1276.256,
        "end": 1277.2,
        "ja_text": "勘違いしないで"
    },
    "416": {
        "start": 1278.34,
        "end": 1279.08,
        "ja_text": "ここにいるのは"
    },
    "417": {
        "start": 1279.68,
        "end": 1280.22,
        "ja_text": "アマデウス"
    },
    "418": {
        "start": 1281.6,
        "end": 1282.66,
        "ja_text": "マキセクリスじゃない"
    },
    "419": {
        "start": 1282.66,
        "end": 1287.92,
        "ja_text": "ない それはマキセクリスは"
    },
    "420": {
        "start": 1288.54,
        "end": 1289.1,
        "ja_text": "死んだな"
    },
    "421": {
        "start": 1293.74,
        "end": 1294.48,
        "ja_text": "死んだ"
    },
    "422": {
        "start": 1297.632,
        "end": 1298.06,
        "ja_text": "彼女は"
    },
    "423": {
        "start": 1298.94,
        "end": 1299.66,
        "ja_text": "もういないの"
    },
    "424": {
        "start": 1301.1,
        "end": 1301.64,
        "ja_text": "死んだ"
    },
    "425": {
        "start": 1309.952,
        "end": 1310.5,
        "ja_text": "岡部さん"
    },
    "426": {
        "start": 1313.7,
        "end": 1314.432,
        "ja_text": "ちょっと"
    },
    "427": {
        "start": 1315.55,
        "end": 1316.48,
        "ja_text": "岡部さん"
    },
    "428": {
        "start": 1329.66,
        "end": 1333.64,
        "ja_text": "Come to me and"
    },
    "429": {
        "start": 1333.64,
        "end": 1334.8,
        "ja_text": "bless my tears"
    },
    "430": {
        "start": 1336.02,
        "end": 1338.98,
        "ja_text": "Let me guide you"
    },
    "431": {
        "start": 1338.98,
        "end": 1342.1,
        "ja_text": "down into my soul"
    },
    "432": {
        "start": 1342.6,
        "end": 1345.44,
        "ja_text": "Let us pray for the"
    },
    "433": {
        "start": 1345.44,
        "end": 1347.96,
        "ja_text": "world to realize"
    },
    "434": {
        "start": 1349.38,
        "end": 1350.52,
        "ja_text": "There is peace,"
    },
    "435": {
        "start": 1351.58,
        "end": 1352.42,
        "ja_text": "the truth,"
    },
    "436": {
        "start": 1353.0,
        "end": 1354.15,
        "ja_text": "and the lost"
    },
    "437": {
        "start": 1383.92,
        "end": 1384.16,
        "ja_text": "お疲れ様でした"
    },
    "438": {
        "start": 1384.18,
        "end": 1386.68,
        "ja_text": "アボタンなユニバース"
    },
    "439": {
        "start": 1388.224,
        "end": 1391.04,
        "ja_text": "I am just a"
    },
    "440": {
        "start": 1391.04,
        "end": 1392.98,
        "ja_text": "part of a sun"
    },
    "441": {
        "start": 1394.42,
        "end": 1398.55,
        "ja_text": "目には見えない 歪んだ空"
    },
    "442": {
        "start": 1400.5,
        "end": 1405.408,
        "ja_text": "人はどこへと歩いてゆくの"
    },
    "443": {
        "start": 1407.98,
        "end": 1409.98,
        "ja_text": "The last dream"
    },
    "444": {
        "start": 1435.42,
        "end": 1436.08,
        "ja_text": "ご視聴ありがとうございました"
    }
}