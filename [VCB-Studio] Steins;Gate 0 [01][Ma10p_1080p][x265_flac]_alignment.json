{
    "1": {
        "start": 15.68,
        "end": 18.26,
        "ja_text": "キモいとき、アニメのセリフをはじめ、「キモ"
    },
    "2": {
        "start": 21.29,
        "end": 22.42,
        "ja_text": "いとき、アニメのセリフをはじめ、"
    },
    "3": {
        "start": 22.5,
        "end": 29.98,
        "ja_text": "戦闘時の叫び声などが含まれます。"
    },
    "4": {
        "start": 32.94,
        "end": 33.9,
        "ja_text": "もしもし"
    },
    "5": {
        "start": 34.592,
        "end": 35.52,
        "ja_text": "もあの時"
    },
    "6": {
        "start": 37.9,
        "end": 39.5,
        "ja_text": "この手を伸ばしていたら"
    },
    "7": {
        "start": 40.74,
        "end": 43.2,
        "ja_text": "この未来は変わったのかな"
    },
    "8": {
        "start": 43.2,
        "end": 43.54,
        "ja_text": "かな あ"
    },
    "9": {
        "start": 57.42,
        "end": 60.96,
        "ja_text": "の日私の彦星様が復活してい"
    },
    "10": {
        "start": 60.96,
        "end": 64.5,
        "ja_text": "れば全ては変わっていたかもしれない も"
    },
    "11": {
        "start": 67.52,
        "end": 68.46,
        "ja_text": "しもあのとき"
    },
    "12": {
        "start": 70.0,
        "end": 70.96,
        "ja_text": "この手を伸ばして"
    },
    "13": {
        "start": 70.96,
        "end": 71.36,
        "ja_text": "ていたら"
    },
    "14": {
        "start": 98.15,
        "end": 99.0,
        "ja_text": "あ"
    },
    "15": {
        "start": 100.224,
        "end": 100.74,
        "ja_text": "なたは"
    },
    "16": {
        "start": 101.52,
        "end": 102.73,
        "ja_text": "過去へ降りて行きます"
    },
    "17": {
        "start": 103.648,
        "end": 104.26,
        "ja_text": "どんどん"
    },
    "18": {
        "start": 105.2,
        "end": 106.7,
        "ja_text": "どんどん降りて行くと"
    },
    "19": {
        "start": 107.0,
        "end": 108.5,
        "ja_text": "光が見えます"
    },
    "20": {
        "start": 109.76,
        "end": 111.42,
        "ja_text": "光は何色ですか"
    },
    "21": {
        "start": 111.98,
        "end": 112.5,
        "ja_text": "赤"
    },
    "22": {
        "start": 113.48,
        "end": 114.64,
        "ja_text": "その光の中に"
    },
    "23": {
        "start": 114.98,
        "end": 116.94,
        "ja_text": "あなたの大切な人が立っています"
    },
    "24": {
        "start": 116.94,
        "end": 119.46,
        "ja_text": "あなたの家族ですか"
    },
    "25": {
        "start": 120.72,
        "end": 121.24,
        "ja_text": "いや"
    },
    "26": {
        "start": 122.74,
        "end": 123.56,
        "ja_text": "では友人"
    },
    "27": {
        "start": 123.72,
        "end": 124.9,
        "ja_text": "恋人ですか"
    },
    "28": {
        "start": 125.86,
        "end": 127.12,
        "ja_text": "友人ですらない"
    },
    "29": {
        "start": 127.12,
        "end": 128.46,
        "ja_text": "俺と"
    },
    "30": {
        "start": 128.46,
        "end": 129.78,
        "ja_text": "あいつは"
    },
    "31": {
        "start": 139.02,
        "end": 140.32,
        "ja_text": "あ、オカリー"
    },
    "32": {
        "start": 145.54,
        "end": 145.64,
        "ja_text": "なんだ、"
    },
    "33": {
        "start": 146.24,
        "end": 147.94,
        "ja_text": "外で待ってなくてもいいって言っただろ"
    },
    "34": {
        "start": 148.17,
        "end": 149.184,
        "ja_text": "えへへ、"
    },
    "35": {
        "start": 150.64,
        "end": 151.12,
        "ja_text": "どうだった?"
    },
    "36": {
        "start": 152.22,
        "end": 155.16,
        "ja_text": "あ、うん、まあ、催眠療法って"
    },
    "37": {
        "start": 155.16,
        "end": 157.0,
        "ja_text": "言っても大したことはなかったな"
    },
    "38": {
        "start": 157.16,
        "end": 158.62,
        "ja_text": "特に問題ないってさ"
    },
    "39": {
        "start": 158.62,
        "end": 159.456,
        "ja_text": "ほんと?"
    },
    "40": {
        "start": 161.26,
        "end": 162.52,
        "ja_text": "ああ、しばらくカウンセ"
    },
    "41": {
        "start": 162.52,
        "end": 163.7,
        "ja_text": "リングは必要みたいだけど"
    },
    "42": {
        "start": 164.3,
        "end": 167.06,
        "ja_text": "まゆりが言う通り受診してみてよかったよ"
    },
    "43": {
        "start": 167.88,
        "end": 168.52,
        "ja_text": "よかった"
    },
    "44": {
        "start": 169.58,
        "end": 172.38,
        "ja_text": "なんかオカリン最近ずっと辛そうだったから"
    },
    "45": {
        "start": 173.06,
        "end": 173.92,
        "ja_text": "心配かけたな"
    },
    "46": {
        "start": 174.5,
        "end": 174.84,
        "ja_text": "ううん"
    },
    "47": {
        "start": 175.88,
        "end": 176.74,
        "ja_text": "飯食べていくか"
    },
    "48": {
        "start": 177.5,
        "end": 178.24,
        "ja_text": "おごるぞ"
    },
    "49": {
        "start": 181.056,
        "end": 183.54,
        "ja_text": "それなら秋葉まで行っていいかな"
    },
    "50": {
        "start": 184.96,
        "end": 187.02,
        "ja_text": "さっきLINEでルカ君とフ"
    },
    "51": {
        "start": 187.02,
        "end": 188.34,
        "ja_text": "ェリスちゃんに誘われたんだ"
    },
    "52": {
        "start": 189.088,
        "end": 190.28,
        "ja_text": "秋葉原か"
    },
    "53": {
        "start": 191.78,
        "end": 192.22,
        "ja_text": "いや"
    },
    "54": {
        "start": 196.24,
        "end": 197.94,
        "ja_text": "いいよ行こう"
    },
    "55": {
        "start": 200.02,
        "end": 200.9,
        "ja_text": "よかった"
    },
    "56": {
        "start": 201.78,
        "end": 203.42,
        "ja_text": "じゃあみんなにも連絡するね"
    },
    "57": {
        "start": 204.48,
        "end": 206.62,
        "ja_text": "フェリスちゃんあのねあのね"
    },
    "58": {
        "start": 208.5,
        "end": 209.92,
        "ja_text": "もう12月か"
    },
    "59": {
        "start": 212.42,
        "end": 213.1,
        "ja_text": "あの夏から"
    },
    "60": {
        "start": 215.136,
        "end": 215.52,
        "ja_text": "早いな"
    },
    "61": {
        "start": 229.98,
        "end": 232.34,
        "ja_text": "ここで待ってるって言ってたんだけど"
    },
    "62": {
        "start": 233.86,
        "end": 235.62,
        "ja_text": "ルカ君フェリスちゃん"
    },
    "63": {
        "start": 237.22,
        "end": 238.34,
        "ja_text": "こんにちはまゆりちゃん"
    },
    "64": {
        "start": 238.944,
        "end": 240.16,
        "ja_text": "おーきょうまん"
    },
    "65": {
        "start": 241.56,
        "end": 243.88,
        "ja_text": "しばらくぶりだなルカ子フェリス"
    },
    "66": {
        "start": 244.6,
        "end": 245.52,
        "ja_text": "オカフェさん"
    },
    "67": {
        "start": 245.86,
        "end": 246.92,
        "ja_text": "きょうまん"
    },
    "68": {
        "start": 247.12,
        "end": 248.32,
        "ja_text": "会いたかったにおいがある"
    },
    "69": {
        "start": 248.32,
        "end": 251.12,
        "ja_text": "おーいこれよせよ"
    },
    "70": {
        "start": 254.784,
        "end": 257.3,
        "ja_text": "それからその狂魔ってのもやめてくれ"
    },
    "71": {
        "start": 258.02,
        "end": 258.42,
        "ja_text": "なんで"
    },
    "72": {
        "start": 259.04,
        "end": 259.96,
        "ja_text": "黒歴史だからだ"
    },
    "73": {
        "start": 261.152,
        "end": 263.06,
        "ja_text": "それはつまり中世魔術師同"
    },
    "74": {
        "start": 263.06,
        "end": 265.26,
        "ja_text": "盟がひた隠しにする暗黒歴史"
    },
    "75": {
        "start": 265.26,
        "end": 265.88,
        "ja_text": "違う"
    },
    "76": {
        "start": 266.36,
        "end": 268.18,
        "ja_text": "何かすごく懐かしいです"
    },
    "77": {
        "start": 268.4,
        "end": 270.78,
        "ja_text": "僕時々ラボに顔を出すんですけど"
    },
    "78": {
        "start": 270.78,
        "end": 272.46,
        "ja_text": "岡部さんには会えなかったから"
    },
    "79": {
        "start": 273.056,
        "end": 274.3,
        "ja_text": "いろいろ忙しくてな"
    },
    "80": {
        "start": 274.3,
        "end": 277.6,
        "ja_text": "まさか青の組織にあるあのプロジェクトが"
    },
    "81": {
        "start": 277.6,
        "end": 279.92,
        "ja_text": "いや、大学のゼミが忙しくてな"
    },
    "82": {
        "start": 279.95,
        "end": 280.54,
        "ja_text": "にゃー"
    },
    "83": {
        "start": 281.22,
        "end": 282.3,
        "ja_text": "それにサークルとか"
    },
    "84": {
        "start": 282.48,
        "end": 283.2,
        "ja_text": "にゃにゃ"
    },
    "85": {
        "start": 283.84,
        "end": 285.16,
        "ja_text": "岡部さんがサークル?"
    },
    "86": {
        "start": 285.76,
        "end": 287.88,
        "ja_text": "UFOとかユーマの研究をしてるとか"
    },
    "87": {
        "start": 288.72,
        "end": 290.26,
        "ja_text": "いや、テニスサークルだ"
    },
    "88": {
        "start": 291.84,
        "end": 292.64,
        "ja_text": "えーーー"
    },
    "89": {
        "start": 294.02,
        "end": 297.56,
        "ja_text": "大学のゼミの準教授がテニスサークルの顧問でな"
    },
    "90": {
        "start": 298.048,
        "end": 299.62,
        "ja_text": "それでキョウマがテニス"
    },
    "91": {
        "start": 300.06,
        "end": 301.64,
        "ja_text": "目指せウィンブルドンだね"
    },
    "92": {
        "start": 302.68,
        "end": 305.12,
        "ja_text": "じゃあ、その練習もあって忙しかったんですね"
    },
    "93": {
        "start": 305.12,
        "end": 307.68,
        "ja_text": "いや、練習はそんなには"
    },
    "94": {
        "start": 308.52,
        "end": 309.94,
        "ja_text": "じゃあ何してるにゃ?"
    },
    "95": {
        "start": 310.72,
        "end": 312.9,
        "ja_text": "何って、ご、ご、合コンとか"
    },
    "96": {
        "start": 312.9,
        "end": 314.86,
        "ja_text": "ご、コン!?"
    },
    "97": {
        "start": 314.86,
        "end": 316.56,
        "ja_text": "えええええええ!?"
    },
    "98": {
        "start": 317.088,
        "end": 318.56,
        "ja_text": "岡部さんが合コン!?"
    },
    "99": {
        "start": 318.56,
        "end": 320.88,
        "ja_text": "にゃんというか、痛いというか、痛々しい"
    },
    "100": {
        "start": 320.88,
        "end": 322.98,
        "ja_text": "というか、それを通り越してキモい!そう!"
    },
    "101": {
        "start": 323.2,
        "end": 324.64,
        "ja_text": "どういうことですか!?"
    },
    "102": {
        "start": 325.26,
        "end": 327.64,
        "ja_text": "ひどいこと言うなよ、俺だ"
    },
    "103": {
        "start": 327.64,
        "end": 329.0,
        "ja_text": "って普通の大学生なんだぞ"
    },
    "104": {
        "start": 329.29,
        "end": 330.98,
        "ja_text": "だらくにゃ、だらくにゃ、"
    },
    "105": {
        "start": 331.24,
        "end": 332.68,
        "ja_text": "今日も一体どういうことにゃ?"
    },
    "106": {
        "start": 332.79,
        "end": 334.18,
        "ja_text": "すごいでさ、オカメさん"
    },
    "107": {
        "start": 334.24,
        "end": 335.6,
        "ja_text": "あ、ユキさんだ"
    },
    "108": {
        "start": 336.7,
        "end": 337.94,
        "ja_text": "何か事件かにゃん"
    },
    "109": {
        "start": 337.96,
        "end": 341.18,
        "ja_text": "ううん、秋葉に来てるならちょっと見"
    },
    "110": {
        "start": 341.18,
        "end": 343.16,
        "ja_text": "せたいものがあるから会えないかって"
    },
    "111": {
        "start": 344.44,
        "end": 344.92,
        "ja_text": "ラボで"
    },
    "112": {
        "start": 357.7,
        "end": 360.02,
        "ja_text": "大丈夫だ、行こう"
    },
    "113": {
        "start": 361.42,
        "end": 362.68,
        "ja_text": "ぐぬぬぬ"
    },
    "114": {
        "start": 363.72,
        "end": 365.3,
        "ja_text": "こんなん戦争だろう"
    },
    "115": {
        "start": 365.3,
        "end": 367.42,
        "ja_text": "炎上必死だろう"
    },
    "116": {
        "start": 367.73,
        "end": 369.26,
        "ja_text": "リア充メッセピンは"
    },
    "117": {
        "start": 369.26,
        "end": 371.34,
        "ja_text": "ぼっちの味方じゃなかったのかよ"
    },
    "118": {
        "start": 371.34,
        "end": 374.0,
        "ja_text": "パルテノン氏と夫婦だったってなんなん"
    },
    "119": {
        "start": 374.944,
        "end": 375.58,
        "ja_text": "父さん"
    },
    "120": {
        "start": 375.8,
        "end": 379.38,
        "ja_text": "すでにアットチャンネルもツイポも炎上中"
    },
    "121": {
        "start": 379.38,
        "end": 380.02,
        "ja_text": "しまった"
    },
    "122": {
        "start": 380.38,
        "end": 382.14,
        "ja_text": "僕としたことが乗り遅れた"
    },
    "123": {
        "start": 382.14,
        "end": 384.02,
        "ja_text": "このビッグウェーブに"
    },
    "124": {
        "start": 385.28,
        "end": 386.76,
        "ja_text": "話を聞きなさい"
    },
    "125": {
        "start": 389.62,
        "end": 392.82,
        "ja_text": "す、鈴葉、やめてくれないと父さん怒っちゃうぞ"
    },
    "126": {
        "start": 392.84,
        "end": 394.92,
        "ja_text": "怒られてるのは父さんのほう"
    },
    "127": {
        "start": 394.92,
        "end": 396.38,
        "ja_text": "はい、すいません"
    },
    "128": {
        "start": 397.952,
        "end": 398.66,
        "ja_text": "まったく、"
    },
    "129": {
        "start": 399.9,
        "end": 401.56,
        "ja_text": "一日中ゴロゴロして食べ"
    },
    "130": {
        "start": 401.56,
        "end": 403.18,
        "ja_text": "るかネットかゲームばかり"
    },
    "131": {
        "start": 403.872,
        "end": 406.52,
        "ja_text": "でもタイムマシーンの研究って大変なんだよ"
    },
    "132": {
        "start": 406.64,
        "end": 408.42,
        "ja_text": "しかも目の前に本物がある"
    },
    "133": {
        "start": 408.42,
        "end": 409.92,
        "ja_text": "のに触っちゃダメとか言うし"
    },
    "134": {
        "start": 410.48,
        "end": 413.18,
        "ja_text": "父さんが未来で開発するものだからね"
    },
    "135": {
        "start": 413.86,
        "end": 415.94,
        "ja_text": "今の父さんが見たらタイムパラド"
    },
    "136": {
        "start": 415.94,
        "end": 417.84,
        "ja_text": "ックスが起きる可能性があるんだよ"
    },
    "137": {
        "start": 418.6,
        "end": 420.92,
        "ja_text": "未来の僕が発明するならいいじゃん"
    },
    "138": {
        "start": 421.4,
        "end": 422.6,
        "ja_text": "明日から頑張るきり"
    },
    "139": {
        "start": 423.48,
        "end": 426.06,
        "ja_text": "そのためには今から頑張らなきゃいけないの"
    },
    "140": {
        "start": 427.4,
        "end": 429.4,
        "ja_text": "未来の父さんもいつもそんな"
    },
    "141": {
        "start": 429.4,
        "end": 431.18,
        "ja_text": "こと言って母さんに怒られてた"
    },
    "142": {
        "start": 431.25,
        "end": 433.46,
        "ja_text": "叱られるという名のご褒美"
    },
    "143": {
        "start": 433.46,
        "end": 435.6,
        "ja_text": "父さん"
    },
    "144": {
        "start": 435.71,
        "end": 437.46,
        "ja_text": "はい何でもないでござる"
    },
    "145": {
        "start": 438.08,
        "end": 440.3,
        "ja_text": "未来の父さんはいつも言っていたんだよ"
    },
    "146": {
        "start": 440.78,
        "end": 443.2,
        "ja_text": "ここは最低最悪の世界戦だけど"
    },
    "147": {
        "start": 444.02,
        "end": 446.32,
        "ja_text": "私が誕生したことだけは最高だって"
    },
    "148": {
        "start": 447.42,
        "end": 449.84,
        "ja_text": "私はオカリンおじさんを説得して"
    },
    "149": {
        "start": 450.432,
        "end": 452.58,
        "ja_text": "そんな未来を変えるためにここに来たんだ"
    },
    "150": {
        "start": 454.08,
        "end": 456.16,
        "ja_text": "なのにあの日以来オカリンお"
    },
    "151": {
        "start": 456.16,
        "end": 457.66,
        "ja_text": "じさんここにも来なくなって"
    },
    "152": {
        "start": 461.8,
        "end": 462.8,
        "ja_text": "誰か来る"
    },
    "153": {
        "start": 466.13,
        "end": 467.46,
        "ja_text": "まさかオカリン"
    },
    "154": {
        "start": 468.38,
        "end": 469.58,
        "ja_text": "違うブーツの音"
    },
    "155": {
        "start": 469.58,
        "end": 470.88,
        "ja_text": "おっと、母さんだ!"
    },
    "156": {
        "start": 473.632,
        "end": 474.32,
        "ja_text": "隠れる、鈴葉!"
    },
    "157": {
        "start": 474.46,
        "end": 475.18,
        "ja_text": "おきどき!"
    },
    "158": {
        "start": 483.44,
        "end": 484.58,
        "ja_text": "はい、どうぞ!"
    },
    "159": {
        "start": 487.26,
        "end": 487.36,
        "ja_text": "こんにちは!"
    },
    "160": {
        "start": 491.46,
        "end": 494.12,
        "ja_text": "あ、天音師、どうして急に?"
    },
    "161": {
        "start": 496.16,
        "end": 496.56,
        "ja_text": "あれ?"
    },
    "162": {
        "start": 496.9,
        "end": 497.78,
        "ja_text": "真由里ちゃんは?"
    },
    "163": {
        "start": 497.78,
        "end": 500.12,
        "ja_text": "まゆし、今日はまだだけど"
    },
    "164": {
        "start": 501.16,
        "end": 502.56,
        "ja_text": "少し早かったかな"
    },
    "165": {
        "start": 503.22,
        "end": 505.64,
        "ja_text": "ここで待ち合わせしようってさっき"
    },
    "166": {
        "start": 505.64,
        "end": 506.62,
        "ja_text": "そうなん?"
    },
    "167": {
        "start": 507.08,
        "end": 508.6,
        "ja_text": "待たせてもらっていいですか?"
    },
    "168": {
        "start": 508.94,
        "end": 510.42,
        "ja_text": "あ、あ、まあ…"
    },
    "169": {
        "start": 510.42,
        "end": 511.04,
        "ja_text": "ありがとうございます"
    },
    "170": {
        "start": 512.86,
        "end": 515.22,
        "ja_text": "あの、今日は妹さんはお留守ですか?"
    },
    "171": {
        "start": 515.88,
        "end": 516.68,
        "ja_text": "え、妹?"
    },
    "172": {
        "start": 517.44,
        "end": 517.82,
        "ja_text": "誰の?"
    },
    "173": {
        "start": 518.592,
        "end": 520.58,
        "ja_text": "誰って、橋田さんの…"
    },
    "174": {
        "start": 520.74,
        "end": 521.24,
        "ja_text": "僕?"
    },
    "175": {
        "start": 521.62,
        "end": 524.44,
        "ja_text": "僕に二次元以外の妹なんていな…"
    },
    "176": {
        "start": 524.44,
        "end": 527.04,
        "ja_text": "あ、す、鈴葉のことでござるか?"
    },
    "177": {
        "start": 527.76,
        "end": 528.86,
        "ja_text": "他にいるんですか?"
    },
    "178": {
        "start": 529.08,
        "end": 529.248,
        "ja_text": "あ、"
    },
    "179": {
        "start": 529.76,
        "end": 531.42,
        "ja_text": "いや、いない"
    },
    "180": {
        "start": 534.3,
        "end": 536.08,
        "ja_text": "トゥットゥルー"
    },
    "181": {
        "start": 537.664,
        "end": 538.92,
        "ja_text": "マユリちゃん"
    },
    "182": {
        "start": 539.58,
        "end": 541.02,
        "ja_text": "トゥットゥルー、ユキさん"
    },
    "183": {
        "start": 541.42,
        "end": 542.18,
        "ja_text": "ニャンニャン"
    },
    "184": {
        "start": 542.25,
        "end": 544.54,
        "ja_text": "フェイリスさんも、ルカさんも"
    },
    "185": {
        "start": 544.54,
        "end": 546.62,
        "ja_text": "フェイリスターン"
    },
    "186": {
        "start": 551.28,
        "end": 554.04,
        "ja_text": "ここは、変わってないな"
    },
    "187": {
        "start": 557.04,
        "end": 557.8,
        "ja_text": "オカリン"
    },
    "188": {
        "start": 562.66,
        "end": 563.54,
        "ja_text": "入っても"
    },
    "189": {
        "start": 567.1,
        "end": 569.98,
        "ja_text": "幻覚や記憶障害といったものが確認されており"
    },
    "190": {
        "start": 569.98,
        "end": 573.3,
        "ja_text": "じ、自分のラボで遠慮とかねーよ"
    },
    "191": {
        "start": 574.464,
        "end": 575.38,
        "ja_text": "それもそうか"
    },
    "192": {
        "start": 575.9,
        "end": 578.62,
        "ja_text": "はー!ユキさんその服かわいい"
    },
    "193": {
        "start": 579.04,
        "end": 580.26,
        "ja_text": "まゆりちゃんにそう言って"
    },
    "194": {
        "start": 580.26,
        "end": 581.88,
        "ja_text": "ほしくて着てきたんだよ"
    },
    "195": {
        "start": 582.2,
        "end": 584.28,
        "ja_text": "わー!フェーリスにも見せてにゃー"
    },
    "196": {
        "start": 584.8,
        "end": 586.18,
        "ja_text": "飲み物はドクペで"
    },
    "197": {
        "start": 586.52,
        "end": 587.76,
        "ja_text": "あ、ちょ、オカリン"
    },
    "198": {
        "start": 587.76,
        "end": 588.72,
        "ja_text": "ど、どこへ?"
    },
    "199": {
        "start": 589.3,
        "end": 589.9,
        "ja_text": "どこって?"
    },
    "200": {
        "start": 590.1,
        "end": 591.08,
        "ja_text": "いや、ちょっとトイレ"
    },
    "201": {
        "start": 591.08,
        "end": 591.48,
        "ja_text": "いや"
    },
    "202": {
        "start": 591.48,
        "end": 592.02,
        "ja_text": "いやっ…"
    },
    "203": {
        "start": 618.3,
        "end": 619.76,
        "ja_text": "おかしい!"
    },
    "204": {
        "start": 621.48,
        "end": 623.3,
        "ja_text": "うっ、つつつつ…"
    },
    "205": {
        "start": 625.1,
        "end": 626.88,
        "ja_text": "すずさん…"
    },
    "206": {
        "start": 628.12,
        "end": 629.62,
        "ja_text": "ど、どうも…"
    },
    "207": {
        "start": 638.56,
        "end": 639.6,
        "ja_text": "じゃーん!"
    },
    "208": {
        "start": 640.84,
        "end": 641.92,
        "ja_text": "かわいい!"
    },
    "209": {
        "start": 642.38,
        "end": 643.76,
        "ja_text": "いいにゃいいにゃん!"
    },
    "210": {
        "start": 643.78,
        "end": 645.5,
        "ja_text": "大好物です!ありがとうございます!"
    },
    "211": {
        "start": 647.46,
        "end": 647.712,
        "ja_text": "あれ?"
    },
    "212": {
        "start": 648.32,
        "end": 649.12,
        "ja_text": "オカリンは?"
    },
    "213": {
        "start": 649.856,
        "end": 651.4,
        "ja_text": "鈴葉さんと屋上行ったよ"
    },
    "214": {
        "start": 652.32,
        "end": 654.0,
        "ja_text": "何か話したいことがあるって"
    },
    "215": {
        "start": 655.232,
        "end": 655.76,
        "ja_text": "そっか"
    },
    "216": {
        "start": 662.34,
        "end": 665.02,
        "ja_text": "わざわざ隠れなくてもよかったんじゃないか"
    },
    "217": {
        "start": 666.16,
        "end": 667.88,
        "ja_text": "ダルの妹ということにしてるんだから"
    },
    "218": {
        "start": 668.8,
        "end": 669.92,
        "ja_text": "逆に怪しまれるだろう"
    },
    "219": {
        "start": 670.496,
        "end": 671.28,
        "ja_text": "そうなんだけど"
    },
    "220": {
        "start": 671.88,
        "end": 674.54,
        "ja_text": "母さん思った以上に私と仲良くしたがるんだ"
    },
    "221": {
        "start": 674.76,
        "end": 677.24,
        "ja_text": "ユキさんとダルが初めて顔を合わせたのは"
    },
    "222": {
        "start": 677.43,
        "end": 678.6,
        "ja_text": "夏の小見間"
    },
    "223": {
        "start": 679.14,
        "end": 680.8,
        "ja_text": "マユ姉さんのコスプレ仲間で"
    },
    "224": {
        "start": 680.8,
        "end": 682.84,
        "ja_text": "ここに出入りするようになって"
    },
    "225": {
        "start": 693.216,
        "end": 694.14,
        "ja_text": "顔を合わせちゃった"
    },
    "226": {
        "start": 697.04,
        "end": 700.36,
        "ja_text": "いずれ自分が産むことになる未来の娘"
    },
    "227": {
        "start": 701.58,
        "end": 704.06,
        "ja_text": "何か感じるものがあったのかもな"
    },
    "228": {
        "start": 707.2,
        "end": 710.44,
        "ja_text": "父さんはいずれ説明するって言ってくれてるけど"
    },
    "229": {
        "start": 713.504,
        "end": 716.0,
        "ja_text": "しかし本当に誰が彼女と"
    },
    "230": {
        "start": 718.22,
        "end": 720.14,
        "ja_text": "私がここにいるってことは少"
    },
    "231": {
        "start": 720.14,
        "end": 722.1,
        "ja_text": "なくともその未来は変わってない"
    },
    "232": {
        "start": 731.52,
        "end": 732.48,
        "ja_text": "平和だね"
    },
    "233": {
        "start": 735.06,
        "end": 737.1,
        "ja_text": "私が物心ついた時には"
    },
    "234": {
        "start": 737.72,
        "end": 740.12,
        "ja_text": "もうこんな光景は写真とか映"
    },
    "235": {
        "start": 740.12,
        "end": 741.8,
        "ja_text": "像の中にしか存在しなかった"
    },
    "236": {
        "start": 743.776,
        "end": 745.58,
        "ja_text": "第三次世界大戦"
    },
    "237": {
        "start": 745.75,
        "end": 749.04,
        "ja_text": "父さんたちはタイムマシン開発のことで"
    },
    "238": {
        "start": 749.25,
        "end": 751.28,
        "ja_text": "反政府組織とみなされてた"
    },
    "239": {
        "start": 751.59,
        "end": 754.44,
        "ja_text": "ダルトをユキさんと3人で逃げていたのか"
    },
    "240": {
        "start": 755.02,
        "end": 755.64,
        "ja_text": "ううん"
    },
    "241": {
        "start": 756.52,
        "end": 759.14,
        "ja_text": "母さんは軍の無人機から私を守ろうとして"
    },
    "242": {
        "start": 759.2,
        "end": 760.86,
        "ja_text": "機銃操舎で死んだから"
    },
    "243": {
        "start": 765.84,
        "end": 768.24,
        "ja_text": "この目でズタズタにされてく母さんを見た"
    },
    "244": {
        "start": 769.504,
        "end": 771.22,
        "ja_text": "全身で母さんの血を浴びた"
    },
    "245": {
        "start": 775.38,
        "end": 776.36,
        "ja_text": "オカリンおじさん"
    },
    "246": {
        "start": 778.4,
        "end": 781.06,
        "ja_text": "この世界線の行き着く先は地獄しかないんだ"
    },
    "247": {
        "start": 783.08,
        "end": 784.88,
        "ja_text": "タイムマシン争奪戦によって"
    },
    "248": {
        "start": 785.44,
        "end": 787.68,
        "ja_text": "国と国が争い人がたくさん死ぬ"
    },
    "249": {
        "start": 788.52,
        "end": 790.38,
        "ja_text": "恐怖と絶望しかない世界なんだ"
    },
    "250": {
        "start": 791.3,
        "end": 792.42,
        "ja_text": "57 億 の 人 の 命"
    },
    "251": {
        "start": 792.42,
        "end": 793.32,
        "ja_text": "が かかっ てる ん だ"
    },
    "252": {
        "start": 794.82,
        "end": 795.28,
        "ja_text": "未来 は"
    },
    "253": {
        "start": 797.42,
        "end": 798.1,
        "ja_text": "お願い だ よ"
    },
    "254": {
        "start": 799.24,
        "end": 800.26,
        "ja_text": "ほか りん おじさん"
    },
    "255": {
        "start": 802.28,
        "end": 802.78,
        "ja_text": "無理 だ"
    },
    "256": {
        "start": 803.56,
        "end": 806.38,
        "ja_text": "おじさん 俺 は 何 度 と なく"
    },
    "257": {
        "start": 806.4,
        "end": 807.76,
        "ja_text": "世界 線 を 漂流 し て き た"
    },
    "258": {
        "start": 808.96,
        "end": 810.58,
        "ja_text": "ここ と は 違う 世界 線 で"
    },
    "259": {
        "start": 810.66,
        "end": 812.14,
        "ja_text": "タイム マシン に 運命 を"
    },
    "260": {
        "start": 812.22,
        "end": 813.32,
        "ja_text": "翻弄 さ れる 人 たち を"
    },
    "261": {
        "start": 813.84,
        "end": 815.14,
        "ja_text": "お前 の 結末 の 一"
    },
    "262": {
        "start": 815.14,
        "end": 815.94,
        "ja_text": "つ さえ 見 て き た"
    },
    "263": {
        "start": 817.08,
        "end": 818.78,
        "ja_text": "何 度 も 何 度 も 繰り返し た ん だ"
    },
    "264": {
        "start": 820.62,
        "end": 823.24,
        "ja_text": "そして人にできることには限りがあると知った"
    },
    "265": {
        "start": 824.48,
        "end": 826.68,
        "ja_text": "何をしても無力なんだ"
    },
    "266": {
        "start": 828.92,
        "end": 831.06,
        "ja_text": "すでに世界線を変えたことがある"
    },
    "267": {
        "start": 832.02,
        "end": 832.92,
        "ja_text": "そう言っていたよね"
    },
    "268": {
        "start": 833.8,
        "end": 834.78,
        "ja_text": "おじさん"
    },
    "269": {
        "start": 835.34,
        "end": 836.16,
        "ja_text": "だったら"
    },
    "270": {
        "start": 836.16,
        "end": 837.0,
        "ja_text": "ダメだ"
    },
    "271": {
        "start": 837.67,
        "end": 839.82,
        "ja_text": "過去改変をして世界線を移動するのは"
    },
    "272": {
        "start": 840.32,
        "end": 842.86,
        "ja_text": "この宇宙の仕組みから逸脱することなんだ"
    },
    "273": {
        "start": 843.08,
        "end": 844.78,
        "ja_text": "人間が手を出していい領"
    },
    "274": {
        "start": 844.78,
        "end": 846.42,
        "ja_text": "域じゃない神の領域なんだ"
    },
    "275": {
        "start": 846.94,
        "end": 849.02,
        "ja_text": "触れれば必ず罰を受けることになる"
    },
    "276": {
        "start": 849.3,
        "end": 850.02,
        "ja_text": "残酷な"
    },
    "277": {
        "start": 850.19,
        "end": 852.34,
        "ja_text": "目を覚えたくなるような罰を"
    },
    "278": {
        "start": 853.34,
        "end": 854.48,
        "ja_text": "それが答えなの?"
    },
    "279": {
        "start": 861.62,
        "end": 862.6,
        "ja_text": "まだ時間はある"
    },
    "280": {
        "start": 865.64,
        "end": 866.7,
        "ja_text": "考え直してほしい"
    },
    "281": {
        "start": 867.98,
        "end": 868.46,
        "ja_text": "私は"
    },
    "282": {
        "start": 870.624,
        "end": 871.4,
        "ja_text": "諦めないから"
    },
    "283": {
        "start": 873.66,
        "end": 876.44,
        "ja_text": "スズさん結局戻ってこなかったね"
    },
    "284": {
        "start": 877.16,
        "end": 877.62,
        "ja_text": "ああ"
    },
    "285": {
        "start": 877.62,
        "end": 877.78,
        "ja_text": "ああ"
    },
    "286": {
        "start": 879.04,
        "end": 880.76,
        "ja_text": "喧嘩したわけじゃないんだよね"
    },
    "287": {
        "start": 881.66,
        "end": 882.56,
        "ja_text": "そういうわけじゃない"
    },
    "288": {
        "start": 883.52,
        "end": 883.92,
        "ja_text": "そっか"
    },
    "289": {
        "start": 885.632,
        "end": 885.76,
        "ja_text": "ふう"
    },
    "290": {
        "start": 886.82,
        "end": 888.7,
        "ja_text": "一段と寒くなってきたね"
    },
    "291": {
        "start": 894.9,
        "end": 898.2,
        "ja_text": "今日は久しぶりにラボが賑やかで楽しかったな"
    },
    "292": {
        "start": 899.48,
        "end": 899.9,
        "ja_text": "そうか"
    },
    "293": {
        "start": 900.54,
        "end": 900.76,
        "ja_text": "うん"
    },
    "294": {
        "start": 902.4,
        "end": 904.56,
        "ja_text": "なんか最近はラボに行くと"
    },
    "295": {
        "start": 904.56,
        "end": 907.02,
        "ja_text": "とても寂しい気持ちになってたんだ"
    },
    "296": {
        "start": 909.056,
        "end": 909.88,
        "ja_text": "誰がいるだろう"
    },
    "297": {
        "start": 910.44,
        "end": 910.88,
        "ja_text": "うん"
    },
    "298": {
        "start": 911.936,
        "end": 913.46,
        "ja_text": "それに昔はまゆし"
    },
    "299": {
        "start": 914.01,
        "end": 917.02,
        "ja_text": "毎日一人でオカリンのことラボで待ってたから"
    },
    "300": {
        "start": 917.84,
        "end": 919.78,
        "ja_text": "全然寂しいはずないんだけど"
    },
    "301": {
        "start": 920.66,
        "end": 921.1,
        "ja_text": "でも"
    },
    "302": {
        "start": 922.2,
        "end": 923.54,
        "ja_text": "なんでかわからないけど"
    },
    "303": {
        "start": 923.58,
        "end": 926.08,
        "ja_text": "泣きたくなるくらい寂しくなるんだ"
    },
    "304": {
        "start": 927.52,
        "end": 930.16,
        "ja_text": "前はもっと賑やかだったのになって"
    },
    "305": {
        "start": 932.288,
        "end": 932.94,
        "ja_text": "錯覚だ"
    },
    "306": {
        "start": 933.48,
        "end": 933.76,
        "ja_text": "え?"
    },
    "307": {
        "start": 934.592,
        "end": 937.34,
        "ja_text": "錯覚だよ あのラボに出入"
    },
    "308": {
        "start": 937.34,
        "end": 939.24,
        "ja_text": "りしていたのは俺とお前と"
    },
    "309": {
        "start": 940.18,
        "end": 941.4,
        "ja_text": "だるくらいのものだったの"
    },
    "310": {
        "start": 944.864,
        "end": 945.4,
        "ja_text": "そうだよね"
    },
    "311": {
        "start": 954.02,
        "end": 954.56,
        "ja_text": "どうしたの"
    },
    "312": {
        "start": 956.32,
        "end": 956.46,
        "ja_text": "ああ"
    },
    "313": {
        "start": 957.52,
        "end": 960.14,
        "ja_text": "明日秋葉でビクトルコンドリア大学"
    },
    "314": {
        "start": 960.14,
        "end": 962.64,
        "ja_text": "のセミナーがあって その前にゼミ"
    },
    "315": {
        "start": 962.64,
        "end": 964.24,
        "ja_text": "の教授と話しておきたかったんだが"
    },
    "316": {
        "start": 965.02,
        "end": 966.56,
        "ja_text": "みんなで集まって飲んでるみたいなんだ"
    },
    "317": {
        "start": 968.04,
        "end": 968.46,
        "ja_text": "そっか"
    },
    "318": {
        "start": 969.06,
        "end": 971.02,
        "ja_text": "すっかりリア充さんだね"
    },
    "319": {
        "start": 972.42,
        "end": 974.68,
        "ja_text": "マユシーは一人でも大丈夫だよ"
    },
    "320": {
        "start": 975.94,
        "end": 976.2,
        "ja_text": "そっか"
    },
    "321": {
        "start": 977.02,
        "end": 977.92,
        "ja_text": "じゃあ悪いけど"
    },
    "322": {
        "start": 1005.42,
        "end": 1006.88,
        "ja_text": "人工知能革命"
    },
    "323": {
        "start": 1008.42,
        "end": 1009.74,
        "ja_text": "ビクトルコンドリア大学"
    },
    "324": {
        "start": 1010.58,
        "end": 1012.64,
        "ja_text": "アレクシス・レスキネン教授か"
    },
    "325": {
        "start": 1018.76,
        "end": 1021.88,
        "ja_text": "あいつのいた大学"
    },
    "326": {
        "start": 1027.47,
        "end": 1029.68,
        "ja_text": "私死ぬのかな"
    },
    "327": {
        "start": 1030.21,
        "end": 1032.74,
        "ja_text": "死にたくないよ"
    },
    "328": {
        "start": 1074.84,
        "end": 1075.82,
        "ja_text": "ちょっと あなた"
    },
    "329": {
        "start": 1078.63,
        "end": 1080.54,
        "ja_text": "そこの 君"
    },
    "330": {
        "start": 1083.09,
        "end": 1084.94,
        "ja_text": "スタッフルームってどこかしら"
    },
    "331": {
        "start": 1091.67,
        "end": 1093.8,
        "ja_text": "ここ大学のセミナー会場だけど"
    },
    "332": {
        "start": 1094.84,
        "end": 1096.4,
        "ja_text": "そんなの分かってるわよ"
    },
    "333": {
        "start": 1096.57,
        "end": 1098.58,
        "ja_text": "もう何度も何度も"
    },
    "334": {
        "start": 1098.58,
        "end": 1099.26,
        "ja_text": "何度も"
    },
    "335": {
        "start": 1099.46,
        "end": 1101.36,
        "ja_text": "この場所に来てからそれ言"
    },
    "336": {
        "start": 1101.36,
        "end": 1103.08,
        "ja_text": "われるのあなたで4回目なの"
    },
    "337": {
        "start": 1103.82,
        "end": 1108.0,
        "ja_text": "ビクトルコンドリア大学脳科学研究所"
    },
    "338": {
        "start": 1109.34,
        "end": 1111.06,
        "ja_text": "分かった拾ってくれた"
    },
    "339": {
        "start": 1111.06,
        "end": 1112.18,
        "ja_text": "それも4回目!"
    },
    "340": {
        "start": 1114.4,
        "end": 1116.74,
        "ja_text": "ビクトルコンドリア大学の…"
    },
    "341": {
        "start": 1118.432,
        "end": 1119.24,
        "ja_text": "中学生?"
    },
    "342": {
        "start": 1119.42,
        "end": 1120.9,
        "ja_text": "寝ぼけるのは夜にして!"
    },
    "343": {
        "start": 1121.06,
        "end": 1123.62,
        "ja_text": "大学に中学生がいるわけないでしょ"
    },
    "344": {
        "start": 1124.82,
        "end": 1125.76,
        "ja_text": "21歳…"
    },
    "345": {
        "start": 1126.24,
        "end": 1128.66,
        "ja_text": "つまり立派な成人女性よ!"
    },
    "346": {
        "start": 1129.088,
        "end": 1132.0,
        "ja_text": "中学生でも小学生でも幼稚園児でもなく!"
    },
    "347": {
        "start": 1133.216,
        "end": 1133.68,
        "ja_text": "何か?"
    },
    "348": {
        "start": 1134.432,
        "end": 1134.84,
        "ja_text": "しかし…"
    },
    "349": {
        "start": 1135.68,
        "end": 1136.14,
        "ja_text": "いや…"
    },
    "350": {
        "start": 1138.368,
        "end": 1139.28,
        "ja_text": "悪かった…"
    },
    "351": {
        "start": 1140.14,
        "end": 1140.56,
        "ja_text": "謝る"
    },
    "352": {
        "start": 1143.2,
        "end": 1143.84,
        "ja_text": "まあいいわ"
    },
    "353": {
        "start": 1144.52,
        "end": 1146.68,
        "ja_text": "どこの国に行っても同じこと言われるから"
    },
    "354": {
        "start": 1147.424,
        "end": 1147.94,
        "ja_text": "だろうな"
    },
    "355": {
        "start": 1148.768,
        "end": 1149.5,
        "ja_text": "何か言った"
    },
    "356": {
        "start": 1149.5,
        "end": 1151.16,
        "ja_text": "いや別に"
    },
    "357": {
        "start": 1154.02,
        "end": 1154.94,
        "ja_text": "そっちじゃない"
    },
    "358": {
        "start": 1155.7,
        "end": 1156.52,
        "ja_text": "スタッフルームだろ"
    },
    "359": {
        "start": 1156.85,
        "end": 1159.48,
        "ja_text": "一度出てそこの通路の扉の奥だ"
    },
    "360": {
        "start": 1163.64,
        "end": 1164.0,
        "ja_text": "ありがとう"
    },
    "361": {
        "start": 1167.56,
        "end": 1168.44,
        "ja_text": "21歳か"
    },
    "362": {
        "start": 1169.08,
        "end": 1170.7,
        "ja_text": "誰が見たらゴーフォーロリ"
    },
    "363": {
        "start": 1170.7,
        "end": 1172.3,
        "ja_text": "キタコレーとか叫びそうだな"
    },
    "364": {
        "start": 1176.48,
        "end": 1177.14,
        "ja_text": "キリュウ"
    },
    "365": {
        "start": 1177.92,
        "end": 1178.36,
        "ja_text": "モエカ"
    },
    "366": {
        "start": 1181.62,
        "end": 1182.34,
        "ja_text": "どうして"
    },
    "367": {
        "start": 1183.54,
        "end": 1184.6,
        "ja_text": "モエカがここに"
    },
    "368": {
        "start": 1186.04,
        "end": 1186.52,
        "ja_text": "まさか"
    },
    "369": {
        "start": 1186.9,
        "end": 1187.26,
        "ja_text": "また"
    },
    "370": {
        "start": 1187.26,
        "end": 1188.94,
        "ja_text": "落ち着け"
    },
    "371": {
        "start": 1189.05,
        "end": 1190.5,
        "ja_text": "ここはデータ世界線だ"
    },
    "372": {
        "start": 1191.64,
        "end": 1192.88,
        "ja_text": "あの世界線とは違う"
    },
    "373": {
        "start": 1195.136,
        "end": 1195.88,
        "ja_text": "違うんだ"
    },
    "374": {
        "start": 1205.632,
        "end": 1205.94,
        "ja_text": "あれは"
    },
    "375": {
        "start": 1207.5,
        "end": 1208.18,
        "ja_text": "さっき"
    },
    "376": {
        "start": 1214.68,
        "end": 1215.28,
        "ja_text": "皆さんこんにちは"
    },
    "377": {
        "start": 1217.44,
        "end": 1219.48,
        "ja_text": "本日は私のセミナーに集ま"
    },
    "378": {
        "start": 1219.48,
        "end": 1220.66,
        "ja_text": "ってくださって感謝します"
    },
    "379": {
        "start": 1221.62,
        "end": 1224.72,
        "ja_text": "ビクトルコンドリア大学農科学研"
    },
    "380": {
        "start": 1224.72,
        "end": 1226.92,
        "ja_text": "究所のアレクシス・レスキネンです"
    },
    "381": {
        "start": 1227.7,
        "end": 1230.94,
        "ja_text": "通訳とアシスタントは私 冷谷城真穂が務めます"
    },
    "382": {
        "start": 1233.216,
        "end": 1238.4,
        "ja_text": "本日のテーマは人工知能革命としましたが"
    },
    "383": {
        "start": 1238.4,
        "end": 1241.72,
        "ja_text": "その話に入る前に一つの論"
    },
    "384": {
        "start": 1241.72,
        "end": 1242.98,
        "ja_text": "文を紹介したいと思います"
    },
    "385": {
        "start": 1245.82,
        "end": 1248.8,
        "ja_text": "この論文は我が研究所の女"
    },
    "386": {
        "start": 1248.8,
        "end": 1250.58,
        "ja_text": "性研究員が発表したものです"
    },
    "387": {
        "start": 1251.56,
        "end": 1253.26,
        "ja_text": "人の記憶は大脳皮質"
    },
    "388": {
        "start": 1253.26,
        "end": 1256.74,
        "ja_text": "とりわけ即答用に記憶される"
    },
    "389": {
        "start": 1257.26,
        "end": 1258.88,
        "ja_text": "フラッシュメモリのようなもの"
    },
    "390": {
        "start": 1258.88,
        "end": 1260.26,
        "ja_text": "として捉えることができます"
    },
    "391": {
        "start": 1261.52,
        "end": 1264.3,
        "ja_text": "脳はニューロンと呼ばれる細胞の間を"
    },
    "392": {
        "start": 1264.3,
        "end": 1266.74,
        "ja_text": "電気信号が伝わることで働きます"
    },
    "393": {
        "start": 1267.52,
        "end": 1270.26,
        "ja_text": "極論すれば記憶は電気信号"
    },
    "394": {
        "start": 1270.26,
        "end": 1271.82,
        "ja_text": "のパターンによって蓄積し"
    },
    "395": {
        "start": 1272.34,
        "end": 1273.5,
        "ja_text": "作られているといえます"
    },
    "396": {
        "start": 1275.648,
        "end": 1278.9,
        "ja_text": "この理論を提唱した彼女は"
    },
    "397": {
        "start": 1279.48,
        "end": 1282.4,
        "ja_text": "残念ながら18歳にして個人となりましたが"
    },
    "398": {
        "start": 1283.12,
        "end": 1284.94,
        "ja_text": "私たちはその理論をもとに"
    },
    "399": {
        "start": 1285.696,
        "end": 1287.58,
        "ja_text": "あるシステムの構築に成功しました"
    },
    "400": {
        "start": 1288.36,
        "end": 1290.88,
        "ja_text": "それが人間の記憶をデータ"
    },
    "401": {
        "start": 1290.88,
        "end": 1292.46,
        "ja_text": "化して保存するシステムです"
    },
    "402": {
        "start": 1295.86,
        "end": 1297.66,
        "ja_text": "これまでのようなプログラムによ"
    },
    "403": {
        "start": 1297.66,
        "end": 1299.62,
        "ja_text": "る擬似人格を作り上げるのではなく"
    },
    "404": {
        "start": 1300.2,
        "end": 1301.94,
        "ja_text": "データ化した人の記憶をベ"
    },
    "405": {
        "start": 1301.94,
        "end": 1304.12,
        "ja_text": "ースに人工知能を作り上げる"
    },
    "406": {
        "start": 1304.9,
        "end": 1306.96,
        "ja_text": "人間同様の感情と記憶"
    },
    "407": {
        "start": 1307.904,
        "end": 1309.54,
        "ja_text": "心を持つ人工知能"
    },
    "408": {
        "start": 1310.912,
        "end": 1313.42,
        "ja_text": "天才 マキセ・クリスの基礎理"
    },
    "409": {
        "start": 1313.42,
        "end": 1315.14,
        "ja_text": "論をもとに構築されたシステム"
    },
    "410": {
        "start": 1315.808,
        "end": 1318.04,
        "ja_text": "それがこれからデモンスト"
    },
    "411": {
        "start": 1318.04,
        "end": 1319.42,
        "ja_text": "レーションする人工知能"
    },
    "412": {
        "start": 1322.66,
        "end": 1323.28,
        "ja_text": "アマデウス"
    },
    "413": {
        "start": 1344.62,
        "end": 1351.46,
        "ja_text": "傘を持たず涙の雨なら"
    },
    "414": {
        "start": 1352.32,
        "end": 1356.86,
        "ja_text": "優しすぎる嘘に書き換えた"
    },
    "415": {
        "start": 1357.56,
        "end": 1362.2,
        "ja_text": "箱に閉じ込めた空の断片が"
    },
    "416": {
        "start": 1362.82,
        "end": 1367.38,
        "ja_text": "未来のパズルにはまってくれない"
    },
    "417": {
        "start": 1367.53,
        "end": 1373.68,
        "ja_text": "限界の推論はノイズ吐き出して"
    },
    "418": {
        "start": 1373.95,
        "end": 1376.86,
        "ja_text": "神さえも欺くロジック"
    },
    "419": {
        "start": 1376.86,
        "end": 1379.16,
        "ja_text": "約束のあの場所へ"
    },
    "420": {
        "start": 1379.59,
        "end": 1385.9,
        "ja_text": "僕らは宇宙をまだ知らない ゼロのゲート開くよ"
    },
    "421": {
        "start": 1386.13,
        "end": 1390.42,
        "ja_text": "全ては粒となり再生する"
    },
    "422": {
        "start": 1390.44,
        "end": 1393.32,
        "ja_text": "それなら途切れそうな意"
    },
    "423": {
        "start": 1393.32,
        "end": 1396.82,
        "ja_text": "識も 繋ぎ止めてみせるよ"
    },
    "424": {
        "start": 1396.82,
        "end": 1400.56,
        "ja_text": "あの時間 あの場所で 君"
    },
    "425": {
        "start": 1429.72,
        "end": 1433.04,
        "ja_text": "ご視聴ありがとうございました"
    }
}