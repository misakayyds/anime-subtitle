{
    "1": {
        "start": 4.94,
        "end": 7.58,
        "ja_text": "次回"
    },
    "2": {
        "start": 30.0,
        "end": 33.68,
        "ja_text": "これ、何かのサプライズ?"
    },
    "3": {
        "start": 50.26,
        "end": 51.14,
        "ja_text": "まさか、"
    },
    "4": {
        "start": 52.3,
        "end": 53.46,
        "ja_text": "やはりお前なのか"
    },
    "5": {
        "start": 55.2,
        "end": 56.64,
        "ja_text": "キリュウモエか"
    },
    "6": {
        "start": 90.016,
        "end": 96.76,
        "ja_text": "価値観を今上書きする 変哲のない宇宙"
    },
    "7": {
        "start": 97.81,
        "end": 102.16,
        "ja_text": "傲慢な神は目に映らない"
    },
    "8": {
        "start": 103.05,
        "end": 107.4,
        "ja_text": "高速度で支配続けるならば"
    },
    "9": {
        "start": 107.4,
        "end": 111.72,
        "ja_text": "僕は 僕だけは"
    },
    "10": {
        "start": 113.06,
        "end": 118.28,
        "ja_text": "奇跡的で致命的なマイノリティでいい"
    },
    "11": {
        "start": 119.424,
        "end": 120.9,
        "ja_text": "I can fly high"
    },
    "12": {
        "start": 120.9,
        "end": 123.44,
        "ja_text": "あの瞬間 あの場面が"
    },
    "13": {
        "start": 123.44,
        "end": 126.04,
        "ja_text": "君にとって特別なら"
    },
    "14": {
        "start": 126.12,
        "end": 131.48,
        "ja_text": "過去へ離れてゆくものなんかじゃなくて"
    },
    "15": {
        "start": 131.48,
        "end": 135.54,
        "ja_text": "傷つくことの痛みより大事なシーン"
    },
    "16": {
        "start": 135.54,
        "end": 141.14,
        "ja_text": "そのすべての光が今 ゼロを生む"
    },
    "17": {
        "start": 141.98,
        "end": 144.3,
        "ja_text": "There is no God,"
    },
    "18": {
        "start": 144.42,
        "end": 147.34,
        "ja_text": "wonderful new world"
    },
    "19": {
        "start": 163.08,
        "end": 163.44,
        "ja_text": "騒ぐな"
    },
    "20": {
        "start": 166.84,
        "end": 168.02,
        "ja_text": "黄色6205"
    },
    "21": {
        "start": 168.02,
        "end": 168.98,
        "ja_text": "OK"
    },
    "22": {
        "start": 169.92,
        "end": 170.94,
        "ja_text": "黄色6205"
    },
    "23": {
        "start": 171.72,
        "end": 172.38,
        "ja_text": "確保します"
    },
    "24": {
        "start": 173.32,
        "end": 174.72,
        "ja_text": "カバンさん"
    },
    "25": {
        "start": 176.46,
        "end": 179.04,
        "ja_text": "いや助けてまゆりさん"
    },
    "26": {
        "start": 179.37,
        "end": 180.36,
        "ja_text": "かかりさん"
    },
    "27": {
        "start": 180.7,
        "end": 182.6,
        "ja_text": "だめだ今抵抗しては"
    },
    "28": {
        "start": 185.62,
        "end": 188.06,
        "ja_text": "やだ離して"
    },
    "29": {
        "start": 202.4,
        "end": 204.94,
        "ja_text": "2回で騒ぐなって言ってんだろ"
    },
    "30": {
        "start": 206.66,
        "end": 207.9,
        "ja_text": "ブラウシー"
    },
    "31": {
        "start": 218.06,
        "end": 218.38,
        "ja_text": "おかがりさん!"
    },
    "32": {
        "start": 226.1,
        "end": 226.74,
        "ja_text": "待て!"
    },
    "33": {
        "start": 232.38,
        "end": 233.26,
        "ja_text": "待て!"
    },
    "34": {
        "start": 238.48,
        "end": 240.42,
        "ja_text": "お、お父さーん!"
    },
    "35": {
        "start": 242.688,
        "end": 243.54,
        "ja_text": "もう大丈夫だ。"
    },
    "36": {
        "start": 244.08,
        "end": 245.82,
        "ja_text": "お父さんがついてるからな。"
    },
    "37": {
        "start": 249.056,
        "end": 250.68,
        "ja_text": "説明してもらおうか、岡部"
    },
    "38": {
        "start": 252.42,
        "end": 253.94,
        "ja_text": "あの連中はなんだ"
    },
    "39": {
        "start": 254.98,
        "end": 255.36,
        "ja_text": "それは"
    },
    "40": {
        "start": 257.6,
        "end": 258.5,
        "ja_text": "ただいま"
    },
    "41": {
        "start": 259.98,
        "end": 262.24,
        "ja_text": "飲み物いっぱい買ってきましたけど"
    },
    "42": {
        "start": 262.24,
        "end": 265.46,
        "ja_text": "どうしたの、みんなそんな怖い顔して"
    },
    "43": {
        "start": 266.54,
        "end": 268.18,
        "ja_text": "うわ、なにこれ、テレビ"
    },
    "44": {
        "start": 268.31,
        "end": 269.78,
        "ja_text": "足元気をつけて"
    },
    "45": {
        "start": 270.56,
        "end": 272.18,
        "ja_text": "ホウキとチリトリは"
    },
    "46": {
        "start": 281.08,
        "end": 283.78,
        "ja_text": "マユリたち3人、無事帰宅したそうだ"
    },
    "47": {
        "start": 284.64,
        "end": 286.5,
        "ja_text": "マホタンもオフィスに着いたって"
    },
    "48": {
        "start": 287.328,
        "end": 289.34,
        "ja_text": "今日は念のため農研に泊まるってさ"
    },
    "49": {
        "start": 290.272,
        "end": 291.84,
        "ja_text": "そうか、よかった"
    },
    "50": {
        "start": 292.8,
        "end": 293.62,
        "ja_text": "なあオカリン"
    },
    "51": {
        "start": 294.06,
        "end": 297.2,
        "ja_text": "あいつらカガリタンを狙ってたよな"
    },
    "52": {
        "start": 297.8,
        "end": 298.16,
        "ja_text": "ああ"
    },
    "53": {
        "start": 299.52,
        "end": 300.38,
        "ja_text": "ということはさ"
    },
    "54": {
        "start": 300.92,
        "end": 302.78,
        "ja_text": "カガリタンが未来から来た"
    },
    "55": {
        "start": 302.78,
        "end": 304.46,
        "ja_text": "って知ってるってことかな"
    },
    "56": {
        "start": 306.52,
        "end": 306.9,
        "ja_text": "やっぱ"
    },
    "57": {
        "start": 308.62,
        "end": 312.0,
        "ja_text": "行方不明の間に何かあったんかな"
    },
    "58": {
        "start": 313.18,
        "end": 313.86,
        "ja_text": "かもな"
    },
    "59": {
        "start": 315.296,
        "end": 316.6,
        "ja_text": "セルンのラウンダー"
    },
    "60": {
        "start": 317.04,
        "end": 319.72,
        "ja_text": "かつてタイムマシンの研究を進めた"
    },
    "61": {
        "start": 319.72,
        "end": 322.58,
        "ja_text": "俺たちを捕捉し 襲撃してきた組織"
    },
    "62": {
        "start": 325.3,
        "end": 325.74,
        "ja_text": "待てよ"
    },
    "63": {
        "start": 326.816,
        "end": 327.96,
        "ja_text": "世界線が変わっても"
    },
    "64": {
        "start": 328.4,
        "end": 331.38,
        "ja_text": "おそらくはセルンの秋葉原でのボスは天皇寺"
    },
    "65": {
        "start": 332.192,
        "end": 334.58,
        "ja_text": "敵ならば俺たちを助けるのは変だ"
    },
    "66": {
        "start": 335.72,
        "end": 337.08,
        "ja_text": "だとするとあのライダースーツ"
    },
    "67": {
        "start": 337.08,
        "end": 338.78,
        "ja_text": "の女はキリュウ・モイカではなく"
    },
    "68": {
        "start": 340.16,
        "end": 340.5,
        "ja_text": "別の"
    },
    "69": {
        "start": 342.24,
        "end": 344.14,
        "ja_text": "でも未だに信じられんよ"
    },
    "70": {
        "start": 344.84,
        "end": 348.86,
        "ja_text": "この空き場で日本で銃で襲われるなんてさ"
    },
    "71": {
        "start": 350.02,
        "end": 351.74,
        "ja_text": "これってやっぱ鈴羽の言ってた"
    },
    "72": {
        "start": 354.38,
        "end": 357.08,
        "ja_text": "実はラボに戻ったらみんな待ってて"
    },
    "73": {
        "start": 357.08,
        "end": 360.64,
        "ja_text": "ドッキリ大成功ちゃっちゃらーみたいなことには"
    },
    "74": {
        "start": 361.96,
        "end": 363.56,
        "ja_text": "気持ちはわかる"
    },
    "75": {
        "start": 364.86,
        "end": 368.0,
        "ja_text": "だが紛れもなく現実なんだ"
    },
    "76": {
        "start": 368.84,
        "end": 370.72,
        "ja_text": "俺は知っている覚えている"
    },
    "77": {
        "start": 371.16,
        "end": 373.62,
        "ja_text": "何度となく繰り返したあの場面"
    },
    "78": {
        "start": 374.624,
        "end": 376.36,
        "ja_text": "硝煙と悲鳴と"
    },
    "79": {
        "start": 377.16,
        "end": 377.58,
        "ja_text": "血の"
    },
    "80": {
        "start": 379.42,
        "end": 380.56,
        "ja_text": "どうしたん"
    },
    "81": {
        "start": 381.632,
        "end": 383.22,
        "ja_text": "悪い少し休む"
    },
    "82": {
        "start": 384.0,
        "end": 384.52,
        "ja_text": "いや"
    },
    "83": {
        "start": 386.38,
        "end": 387.34,
        "ja_text": "これもあれかね"
    },
    "84": {
        "start": 388.3,
        "end": 390.96,
        "ja_text": "シュタインズゲートの選択つやつ"
    },
    "85": {
        "start": 391.62,
        "end": 393.42,
        "ja_text": "シュタインズゲートか"
    },
    "86": {
        "start": 394.5,
        "end": 396.38,
        "ja_text": "今思えば痛々しい響きだ"
    },
    "87": {
        "start": 397.056,
        "end": 400.52,
        "ja_text": "ほらまだふらついてんじゃん"
    },
    "88": {
        "start": 401.056,
        "end": 402.02,
        "ja_text": "肩貸してやるよ"
    },
    "89": {
        "start": 402.848,
        "end": 403.52,
        "ja_text": "いいって"
    },
    "90": {
        "start": 404.12,
        "end": 405.24,
        "ja_text": "遠慮するなよ"
    },
    "91": {
        "start": 407.776,
        "end": 411.34,
        "ja_text": "なあ今日みたいなことまたあるんかな"
    },
    "92": {
        "start": 412.704,
        "end": 413.62,
        "ja_text": "そうならないよ"
    },
    "93": {
        "start": 414.76,
        "end": 415.94,
        "ja_text": "これから考えるしかない"
    },
    "94": {
        "start": 420.46,
        "end": 423.26,
        "ja_text": "おかけになった電話番号は電"
    },
    "95": {
        "start": 423.264,
        "end": 424.92,
        "ja_text": "波の届かないところにあるか"
    },
    "96": {
        "start": 425.22,
        "end": 427.82,
        "ja_text": "電源が入っていないためおつなぎできません"
    },
    "97": {
        "start": 430.26,
        "end": 434.0,
        "ja_text": "もうこんな大変な時にどこ行ってんのよ教授は"
    },
    "98": {
        "start": 439.1,
        "end": 442.24,
        "ja_text": "何度やってもアマデウス本体にアクセスできない"
    },
    "99": {
        "start": 443.04,
        "end": 444.92,
        "ja_text": "どうなってるのよこれ"
    },
    "100": {
        "start": 462.54,
        "end": 462.9,
        "ja_text": "これ"
    },
    "101": {
        "start": 462.9,
        "end": 463.22,
        "ja_text": "もしもし"
    },
    "102": {
        "start": 464.416,
        "end": 465.8,
        "ja_text": "鈴葉、僕だけど、"
    },
    "103": {
        "start": 466.5,
        "end": 467.09,
        "ja_text": "そっちどう?"
    },
    "104": {
        "start": 467.8,
        "end": 469.5,
        "ja_text": "思った以上にセキュリティがし"
    },
    "105": {
        "start": 469.5,
        "end": 471.54,
        "ja_text": "っかりしてるんだね、この神社"
    },
    "106": {
        "start": 472.26,
        "end": 474.22,
        "ja_text": "ルカ氏のパパが心配しようなんか"
    },
    "107": {
        "start": 474.84,
        "end": 477.62,
        "ja_text": "いろいろ昔から設置してたみたいなんだよね"
    },
    "108": {
        "start": 478.2,
        "end": 480.96,
        "ja_text": "時々夜中に侵入しようとする人がいるって"
    },
    "109": {
        "start": 481.6,
        "end": 483.28,
        "ja_text": "それにしても厳重すぎない?"
    },
    "110": {
        "start": 483.936,
        "end": 486.48,
        "ja_text": "まあまあそこにオカリンが頼まれたりで"
    },
    "111": {
        "start": 486.48,
        "end": 489.54,
        "ja_text": "いろいろ僕が魔改造した結果そうなったってか"
    },
    "112": {
        "start": 490.54,
        "end": 492.88,
        "ja_text": "とにかく私も見てみたけど"
    },
    "113": {
        "start": 492.99,
        "end": 494.94,
        "ja_text": "これなら少し安心はできるかな"
    },
    "114": {
        "start": 495.68,
        "end": 496.11,
        "ja_text": "オッケー"
    },
    "115": {
        "start": 496.98,
        "end": 499.52,
        "ja_text": "そんじゃ何かあったらすぐに連絡よこすのだぜ"
    },
    "116": {
        "start": 500.5,
        "end": 502.52,
        "ja_text": "うん、父さんたちの方こそ気をつけて"
    },
    "117": {
        "start": 502.92,
        "end": 504.32,
        "ja_text": "私より弱いんだから"
    },
    "118": {
        "start": 505.088,
        "end": 506.208,
        "ja_text": "そこはもっと"
    },
    "119": {
        "start": 506.38,
        "end": 509.42,
        "ja_text": "パパはドジでノルマで貧弱なブタなのだ"
    },
    "120": {
        "start": 511.64,
        "end": 512.94,
        "ja_text": "あ、おかえりなさい"
    },
    "121": {
        "start": 513.6,
        "end": 514.3,
        "ja_text": "カガリは?"
    },
    "122": {
        "start": 515.06,
        "end": 516.22,
        "ja_text": "よほど怖かったのか"
    },
    "123": {
        "start": 517.056,
        "end": 518.38,
        "ja_text": "さっきやっと寝てくれて"
    },
    "124": {
        "start": 519.808,
        "end": 520.2,
        "ja_text": "そっか"
    },
    "125": {
        "start": 522.272,
        "end": 524.04,
        "ja_text": "ルカ兄さんも疲れてるだろ"
    },
    "126": {
        "start": 524.672,
        "end": 525.34,
        "ja_text": "寝たほうがいい"
    },
    "127": {
        "start": 526.02,
        "end": 527.64,
        "ja_text": "セキュリティは問題なさそうだから"
    },
    "128": {
        "start": 528.36,
        "end": 529.24,
        "ja_text": "安心していいよ"
    },
    "129": {
        "start": 532.96,
        "end": 535.18,
        "ja_text": "鈴葉さん、寝ないんですか?"
    },
    "130": {
        "start": 535.776,
        "end": 537.0,
        "ja_text": "私はこのままでいい"
    },
    "131": {
        "start": 537.18,
        "end": 539.34,
        "ja_text": "何かあってもすぐに対処できる"
    },
    "132": {
        "start": 540.72,
        "end": 543.14,
        "ja_text": "そんな、それじゃ疲れが取れないですよ"
    },
    "133": {
        "start": 543.18,
        "end": 545.02,
        "ja_text": "平気だ、慣れてる"
    },
    "134": {
        "start": 546.784,
        "end": 547.32,
        "ja_text": "ママ、"
    },
    "135": {
        "start": 548.86,
        "end": 549.28,
        "ja_text": "ママ、"
    },
    "136": {
        "start": 549.98,
        "end": 551.04,
        "ja_text": "行っちゃいやだよ"
    },
    "137": {
        "start": 553.28,
        "end": 554.08,
        "ja_text": "ママ"
    },
    "138": {
        "start": 557.86,
        "end": 560.84,
        "ja_text": "エル・プサイ・ゴンガリー"
    },
    "139": {
        "start": 563.36,
        "end": 566.06,
        "ja_text": "あの、少し聞いてもいいですか"
    },
    "140": {
        "start": 570.98,
        "end": 571.38,
        "ja_text": "何?"
    },
    "141": {
        "start": 574.46,
        "end": 577.46,
        "ja_text": "その、鈴葉さんはどうして岡部さんの"
    },
    "142": {
        "start": 577.46,
        "end": 579.78,
        "ja_text": "こと、オカリンおじさんって呼ぶんですか"
    },
    "143": {
        "start": 581.18,
        "end": 582.98,
        "ja_text": "どうしてマユリちゃんのこと"
    },
    "144": {
        "start": 583.36,
        "end": 585.1,
        "ja_text": "マユ姉さんって呼ぶんですか"
    },
    "145": {
        "start": 585.9,
        "end": 586.84,
        "ja_text": "フェリスさんのこと"
    },
    "146": {
        "start": 587.48,
        "end": 589.58,
        "ja_text": "ルミ姉さんって呼ぶんですか"
    },
    "147": {
        "start": 591.02,
        "end": 591.76,
        "ja_text": "僕のこと"
    },
    "148": {
        "start": 592.42,
        "end": 593.24,
        "ja_text": "ルカ兄さんって"
    },
    "149": {
        "start": 593.86,
        "end": 594.54,
        "ja_text": "呼ぶんですか"
    },
    "150": {
        "start": 599.26,
        "end": 599.78,
        "ja_text": "カガリさん"
    },
    "151": {
        "start": 600.84,
        "end": 602.8,
        "ja_text": "さっきママって言ってましたよね"
    },
    "152": {
        "start": 604.2,
        "end": 605.98,
        "ja_text": "でも寝つく前別の名前を"
    },
    "153": {
        "start": 605.98,
        "end": 607.5,
        "ja_text": "一度だけ言っていたんです"
    },
    "154": {
        "start": 608.72,
        "end": 609.632,
        "ja_text": "まゆりママって"
    },
    "155": {
        "start": 612.832,
        "end": 615.2,
        "ja_text": "それってまゆりちゃんのことですよね"
    },
    "156": {
        "start": 616.06,
        "end": 617.26,
        "ja_text": "どうしてママなんですか"
    },
    "157": {
        "start": 621.78,
        "end": 623.3,
        "ja_text": "知らないほうがいい"
    },
    "158": {
        "start": 624.82,
        "end": 628.46,
        "ja_text": "そうやってまた僕だけかやの外なんですか"
    },
    "159": {
        "start": 629.792,
        "end": 631.94,
        "ja_text": "岡部さんもまゆりちゃんもずっとつらそうで"
    },
    "160": {
        "start": 632.736,
        "end": 635.28,
        "ja_text": "橋田さんもフェリスさんもみんな何か隠していて"
    },
    "161": {
        "start": 635.57,
        "end": 638.54,
        "ja_text": "確かに僕じゃ役に立てないかもしれない"
    },
    "162": {
        "start": 640.096,
        "end": 642.36,
        "ja_text": "それでも僕だって"
    },
    "163": {
        "start": 643.1,
        "end": 644.84,
        "ja_text": "同じ悩みを共有したい"
    },
    "164": {
        "start": 646.14,
        "end": 646.84,
        "ja_text": "ルカ兄さん"
    },
    "165": {
        "start": 648.34,
        "end": 649.12,
        "ja_text": "教えても"
    },
    "166": {
        "start": 649.856,
        "end": 650.62,
        "ja_text": "らえませんか"
    },
    "167": {
        "start": 654.24,
        "end": 655.8,
        "ja_text": "オカリンおじさんがさ"
    },
    "168": {
        "start": 656.82,
        "end": 659.16,
        "ja_text": "ルカ兄さんにだけ話さない理由"
    },
    "169": {
        "start": 660.08,
        "end": 661.66,
        "ja_text": "なんとなくわかる気がするんだ"
    },
    "170": {
        "start": 662.9,
        "end": 663.28,
        "ja_text": "理由"
    },
    "171": {
        "start": 664.62,
        "end": 666.96,
        "ja_text": "ルカ兄さんにだけは純粋に"
    },
    "172": {
        "start": 666.96,
        "end": 668.66,
        "ja_text": "この世界の人間でいてほしい"
    },
    "173": {
        "start": 670.0,
        "end": 671.72,
        "ja_text": "今というこの時間の中だけ"
    },
    "174": {
        "start": 671.72,
        "end": 673.12,
        "ja_text": "の存在でいてほしいんだ"
    },
    "175": {
        "start": 674.208,
        "end": 675.86,
        "ja_text": "それがオカリンおじさん"
    },
    "176": {
        "start": 675.86,
        "end": 679.14,
        "ja_text": "にとっての多分救いなんだ"
    },
    "177": {
        "start": 680.66,
        "end": 681.38,
        "ja_text": "救い"
    },
    "178": {
        "start": 682.14,
        "end": 682.5,
        "ja_text": "ああ"
    },
    "179": {
        "start": 683.86,
        "end": 684.22,
        "ja_text": "そんな"
    },
    "180": {
        "start": 686.176,
        "end": 688.08,
        "ja_text": "そんな風に言われたら僕"
    },
    "181": {
        "start": 691.56,
        "end": 692.68,
        "ja_text": "もう寝た方がいい"
    },
    "182": {
        "start": 693.34,
        "end": 694.08,
        "ja_text": "おやすみ"
    },
    "183": {
        "start": 705.18,
        "end": 706.26,
        "ja_text": "やっと来やがったか"
    },
    "184": {
        "start": 707.4,
        "end": 709.18,
        "ja_text": "で、昨日のあれは一体なんだ"
    },
    "185": {
        "start": 713.28,
        "end": 713.7,
        "ja_text": "大丈夫だ"
    },
    "186": {
        "start": 714.92,
        "end": 716.44,
        "ja_text": "考え通りなら行けるはずだ"
    },
    "187": {
        "start": 717.08,
        "end": 717.36,
        "ja_text": "どうした"
    },
    "188": {
        "start": 718.592,
        "end": 719.96,
        "ja_text": "説明しに来たんじゃねえのか"
    },
    "189": {
        "start": 723.52,
        "end": 725.22,
        "ja_text": "その前に一つ確認したい"
    },
    "190": {
        "start": 725.82,
        "end": 727.47,
        "ja_text": "あれはあなたの差し金じゃないですね"
    },
    "191": {
        "start": 729.24,
        "end": 730.26,
        "ja_text": "どういう意味だ"
    },
    "192": {
        "start": 731.1,
        "end": 733.02,
        "ja_text": "なんで俺があんな真似しなくちゃなんねえ"
    },
    "193": {
        "start": 734.28,
        "end": 735.04,
        "ja_text": "わかりませんか"
    },
    "194": {
        "start": 736.864,
        "end": 738.32,
        "ja_text": "わかるわけねえだろ女も"
    },
    "195": {
        "start": 738.816,
        "end": 740.98,
        "ja_text": "くだれねえこと言ってると家賃あげるぞ"
    },
    "196": {
        "start": 741.824,
        "end": 744.42,
        "ja_text": "それはあなたがラウンダーだからですよ"
    },
    "197": {
        "start": 744.84,
        "end": 746.54,
        "ja_text": "ミスターフェルディナントブラウン"
    },
    "198": {
        "start": 747.2,
        "end": 747.66,
        "ja_text": "それとも"
    },
    "199": {
        "start": 748.78,
        "end": 750.26,
        "ja_text": "FBと呼んだ方がいいですか"
    },
    "200": {
        "start": 754.08,
        "end": 755.9,
        "ja_text": "どうしたのお父さん"
    },
    "201": {
        "start": 756.54,
        "end": 756.98,
        "ja_text": "ん"
    },
    "202": {
        "start": 757.84,
        "end": 760.06,
        "ja_text": "急に怖い感じしたから"
    },
    "203": {
        "start": 761.12,
        "end": 763.84,
        "ja_text": "そうかお父さんはいつも通りだぞ"
    },
    "204": {
        "start": 764.36,
        "end": 765.74,
        "ja_text": "いい子だから外で"
    },
    "205": {
        "start": 766.74,
        "end": 768.8,
        "ja_text": "そこでアニメでも見てな"
    },
    "206": {
        "start": 769.09,
        "end": 771.24,
        "ja_text": "ヘッドホン使って音出していいから"
    },
    "207": {
        "start": 771.39,
        "end": 774.78,
        "ja_text": "やはり"
    },
    "208": {
        "start": 775.7,
        "end": 776.9,
        "ja_text": "知られたくはないですよね"
    },
    "209": {
        "start": 779.28,
        "end": 781.7,
        "ja_text": "昨日俺たちを襲ったライダースーツの女"
    },
    "210": {
        "start": 783.14,
        "end": 784.32,
        "ja_text": "あれはあなたの部下のキリ"
    },
    "211": {
        "start": 784.32,
        "end": 785.28,
        "ja_text": "ュウ・モエカではなかった"
    },
    "212": {
        "start": 786.22,
        "end": 787.92,
        "ja_text": "つまりあれはラウンダーではない"
    },
    "213": {
        "start": 788.94,
        "end": 789.24,
        "ja_text": "別の"
    },
    "214": {
        "start": 792.512,
        "end": 793.84,
        "ja_text": "一応聞いといてやるが"
    },
    "215": {
        "start": 794.28,
        "end": 796.48,
        "ja_text": "お前のそれはどっからのネタだ"
    },
    "216": {
        "start": 797.6,
        "end": 799.04,
        "ja_text": "話してもどうせ信じません"
    },
    "217": {
        "start": 800.64,
        "end": 801.96,
        "ja_text": "いいから聞かせろや"
    },
    "218": {
        "start": 804.608,
        "end": 807.44,
        "ja_text": "そのくらいの覚悟は決めてきたって顔だぜ"
    },
    "219": {
        "start": 808.4,
        "end": 808.736,
        "ja_text": "え?"
    },
    "220": {
        "start": 812.52,
        "end": 814.22,
        "ja_text": "そ、それで警察には?"
    },
    "221": {
        "start": 814.976,
        "end": 817.8,
        "ja_text": "それがオカリンさんがちょっと待ってくれって"
    },
    "222": {
        "start": 818.368,
        "end": 821.46,
        "ja_text": "だからって拳銃持ってたんでしょ?"
    },
    "223": {
        "start": 822.08,
        "end": 824.68,
        "ja_text": "とにかく事情は聞いてくるから"
    },
    "224": {
        "start": 825.36,
        "end": 826.54,
        "ja_text": "行くってラボに?"
    },
    "225": {
        "start": 827.36,
        "end": 830.52,
        "ja_text": "連続で狙うバカもいないだろうって橋田さんが"
    },
    "226": {
        "start": 830.52,
        "end": 834.6,
        "ja_text": "フラグ…いえ、私も行ければよかったんだけど"
    },
    "227": {
        "start": 834.79,
        "end": 835.84,
        "ja_text": "どうしたの?"
    },
    "228": {
        "start": 835.9,
        "end": 836.58,
        "ja_text": "その腕"
    },
    "229": {
        "start": 836.58,
        "end": 840.3,
        "ja_text": "昨日ちょっとね、転んじゃって"
    },
    "230": {
        "start": 842.52,
        "end": 845.22,
        "ja_text": "タイムマシンに世界戦ね"
    },
    "231": {
        "start": 845.92,
        "end": 848.78,
        "ja_text": "とてもじゃないが信じられる話じゃねえな"
    },
    "232": {
        "start": 849.78,
        "end": 851.3,
        "ja_text": "最初にそう言ったはずだ"
    },
    "233": {
        "start": 851.904,
        "end": 853.3,
        "ja_text": "まあな、だが"
    },
    "234": {
        "start": 854.68,
        "end": 856.18,
        "ja_text": "俺に関してはその通りさ"
    },
    "235": {
        "start": 856.84,
        "end": 858.58,
        "ja_text": "お前の話はほぼ完璧だ"
    },
    "236": {
        "start": 859.14,
        "end": 860.6,
        "ja_text": "打つ気味悪いくらいだぜ"
    },
    "237": {
        "start": 862.016,
        "end": 863.68,
        "ja_text": "セルンの機密保持が絶対だ"
    },
    "238": {
        "start": 863.68,
        "end": 864.7,
        "ja_text": "ということは知っています"
    },
    "239": {
        "start": 866.18,
        "end": 867.76,
        "ja_text": "任務に失敗した者だけでなく"
    },
    "240": {
        "start": 868.8,
        "end": 871.09,
        "ja_text": "達成した者まで処分されるということも"
    },
    "241": {
        "start": 871.82,
        "end": 873.24,
        "ja_text": "そこまで知ってんのかよ"
    },
    "242": {
        "start": 873.92,
        "end": 874.4,
        "ja_text": "だったら"
    },
    "243": {
        "start": 874.4,
        "end": 876.8,
        "ja_text": "でもこれは任務とは関係ない"
    },
    "244": {
        "start": 877.55,
        "end": 879.32,
        "ja_text": "機密だって漏洩したわけじゃない"
    },
    "245": {
        "start": 880.34,
        "end": 881.9,
        "ja_text": "俺が最初から知っていただけだ"
    },
    "246": {
        "start": 882.94,
        "end": 884.96,
        "ja_text": "だから処分の対象にはならないはずだ"
    },
    "247": {
        "start": 886.2,
        "end": 887.04,
        "ja_text": "気弁だな"
    },
    "248": {
        "start": 887.04,
        "end": 889.3,
        "ja_text": "ああ、だが間違っちゃいない"
    },
    "249": {
        "start": 890.23,
        "end": 892.66,
        "ja_text": "確かにセルンからは何も言われてねえ"
    },
    "250": {
        "start": 893.44,
        "end": 894.7,
        "ja_text": "俺がラウンダーだってこと"
    },
    "251": {
        "start": 894.7,
        "end": 896.76,
        "ja_text": "をおめえが黙ってらすむ話だ"
    },
    "252": {
        "start": 897.7,
        "end": 899.2,
        "ja_text": "で、何が目的だ?"
    },
    "253": {
        "start": 900.096,
        "end": 901.54,
        "ja_text": "そんな話をぶちまけてきた"
    },
    "254": {
        "start": 901.54,
        "end": 903.56,
        "ja_text": "ってことはあるんだろう?"
    },
    "255": {
        "start": 905.184,
        "end": 906.3,
        "ja_text": "あなたに頼みがある"
    },
    "256": {
        "start": 907.264,
        "end": 909.3,
        "ja_text": "シーナ・カガリ、昨日狙"
    },
    "257": {
        "start": 909.3,
        "end": 910.72,
        "ja_text": "われた女性を守ってほしい"
    },
    "258": {
        "start": 911.392,
        "end": 913.74,
        "ja_text": "あのジョーちゃんは何になぜ狙われてる?"
    },
    "259": {
        "start": 914.94,
        "end": 915.5,
        "ja_text": "分かりません"
    },
    "260": {
        "start": 916.608,
        "end": 917.62,
        "ja_text": "話になんねえな"
    },
    "261": {
        "start": 918.3,
        "end": 920.06,
        "ja_text": "聞かなかったことにしてやるから"
    },
    "262": {
        "start": 920.06,
        "end": 920.46,
        "ja_text": "ダメだ"
    },
    "263": {
        "start": 921.56,
        "end": 923.3,
        "ja_text": "もしまた昨日のようなことがあったら"
    },
    "264": {
        "start": 924.352,
        "end": 925.26,
        "ja_text": "娘さんはどうなる"
    },
    "265": {
        "start": 926.72,
        "end": 928.42,
        "ja_text": "また危険にさらされるかもしれない"
    },
    "266": {
        "start": 929.1,
        "end": 929.6,
        "ja_text": "てめえ"
    },
    "267": {
        "start": 930.04,
        "end": 931.8,
        "ja_text": "苗を人質にするつもりか"
    },
    "268": {
        "start": 932.44,
        "end": 933.26,
        "ja_text": "殺すぞ"
    },
    "269": {
        "start": 934.144,
        "end": 935.46,
        "ja_text": "協力しようと言ってるんです"
    },
    "270": {
        "start": 936.12,
        "end": 937.34,
        "ja_text": "あなただって一人では"
    },
    "271": {
        "start": 937.86,
        "end": 939.88,
        "ja_text": "娘さんを守りきれないかもしれない"
    },
    "272": {
        "start": 941.06,
        "end": 943.22,
        "ja_text": "こっちにはデメリットしかねえじゃねえか"
    },
    "273": {
        "start": 943.22,
        "end": 944.7,
        "ja_text": "そんなことないよ"
    },
    "274": {
        "start": 945.408,
        "end": 946.74,
        "ja_text": "出せるものはある"
    },
    "275": {
        "start": 948.72,
        "end": 950.96,
        "ja_text": "おめえら来てたのか"
    },
    "276": {
        "start": 951.7,
        "end": 954.38,
        "ja_text": "私とカガリをバイトとしてここに置いてくれれば"
    },
    "277": {
        "start": 954.74,
        "end": 956.1,
        "ja_text": "手間はかからないだろ"
    },
    "278": {
        "start": 957.54,
        "end": 960.68,
        "ja_text": "おめえらがビルから出て行く方が手っ取り早いな"
    },
    "279": {
        "start": 961.98,
        "end": 963.58,
        "ja_text": "そうすりゃ俺とナイが巻き込ま"
    },
    "280": {
        "start": 963.58,
        "end": 967.02,
        "ja_text": "二人とも昨日襲った連中を目撃してるしされてる"
    },
    "281": {
        "start": 968.896,
        "end": 971.86,
        "ja_text": "それが何を意味するかわからないわけないよね"
    },
    "282": {
        "start": 973.28,
        "end": 976.84,
        "ja_text": "お父さんよくわからないけど"
    },
    "283": {
        "start": 977.58,
        "end": 981.02,
        "ja_text": "昨日みたいなことは怖いから嫌だな"
    },
    "284": {
        "start": 982.016,
        "end": 982.46,
        "ja_text": "ナエ"
    },
    "285": {
        "start": 985.1,
        "end": 988.06,
        "ja_text": "でもお父さんが私を守るために"
    },
    "286": {
        "start": 988.5,
        "end": 990.7,
        "ja_text": "無茶して怪我するのはもっと嫌なの"
    },
    "287": {
        "start": 991.95,
        "end": 995.28,
        "ja_text": "だから私は鈴葉お姉ちゃんたちと一緒がいいな"
    },
    "288": {
        "start": 996.16,
        "end": 996.52,
        "ja_text": "ナエ"
    },
    "289": {
        "start": 1000.08,
        "end": 1003.12,
        "ja_text": "言っとくなバイト代は一人分しか出せねえぞ"
    },
    "290": {
        "start": 1003.54,
        "end": 1005.62,
        "ja_text": "こっちたらそんな余分な金やねえんだ"
    },
    "291": {
        "start": 1006.4,
        "end": 1007.232,
        "ja_text": "お父さん"
    },
    "292": {
        "start": 1008.84,
        "end": 1009.78,
        "ja_text": "渋いねえ"
    },
    "293": {
        "start": 1012.02,
        "end": 1013.66,
        "ja_text": "文句があんなら家賃あげんぞこら"
    },
    "294": {
        "start": 1014.64,
        "end": 1015.9,
        "ja_text": "いえありがとうございます"
    },
    "295": {
        "start": 1016.74,
        "end": 1017.32,
        "ja_text": "天皇おじさん"
    },
    "296": {
        "start": 1018.5,
        "end": 1019.32,
        "ja_text": "それより岡部"
    },
    "297": {
        "start": 1019.86,
        "end": 1023.02,
        "ja_text": "おめえは早く連中が何者か突き止めろ"
    },
    "298": {
        "start": 1023.7,
        "end": 1024.1,
        "ja_text": "じゃねえと"
    },
    "299": {
        "start": 1024.82,
        "end": 1026.16,
        "ja_text": "対策の打ちようがねえ"
    },
    "300": {
        "start": 1027.14,
        "end": 1027.62,
        "ja_text": "わかりました"
    },
    "301": {
        "start": 1029.8,
        "end": 1033.16,
        "ja_text": "つまりカガリさんが記憶を失っている間に"
    },
    "302": {
        "start": 1033.16,
        "end": 1036.128,
        "ja_text": "何らかの犯罪に巻き込まれたかもしれないと"
    },
    "303": {
        "start": 1036.76,
        "end": 1037.16,
        "ja_text": "ああ"
    },
    "304": {
        "start": 1038.12,
        "end": 1040.54,
        "ja_text": "だったらなんで警察に言わないんです"
    },
    "305": {
        "start": 1041.92,
        "end": 1043.2,
        "ja_text": "それはほらえっと"
    },
    "306": {
        "start": 1044.06,
        "end": 1046.04,
        "ja_text": "警察を怯えるんよね彼女"
    },
    "307": {
        "start": 1046.04,
        "end": 1048.92,
        "ja_text": "もしかしたら警察とかも"
    },
    "308": {
        "start": 1048.92,
        "end": 1050.54,
        "ja_text": "その犯罪に関わってるとか"
    },
    "309": {
        "start": 1050.54,
        "end": 1053.42,
        "ja_text": "うーん釈然としないな"
    },
    "310": {
        "start": 1054.92,
        "end": 1055.7,
        "ja_text": "とにかくだ"
    },
    "311": {
        "start": 1056.28,
        "end": 1058.08,
        "ja_text": "連中の狙いはカガリ一人だ"
    },
    "312": {
        "start": 1058.56,
        "end": 1059.02,
        "ja_text": "とはいえ"
    },
    "313": {
        "start": 1059.68,
        "end": 1061.28,
        "ja_text": "みんなもしばらくはこの辺には"
    },
    "314": {
        "start": 1061.28,
        "end": 1062.76,
        "ja_text": "近づかない方がいいだろうな"
    },
    "315": {
        "start": 1063.84,
        "end": 1063.94,
        "ja_text": "そんな"
    },
    "316": {
        "start": 1066.1,
        "end": 1067.84,
        "ja_text": "でもカガリさんはどうするんです"
    },
    "317": {
        "start": 1068.672,
        "end": 1069.86,
        "ja_text": "狙われてるんですよね"
    },
    "318": {
        "start": 1070.92,
        "end": 1072.22,
        "ja_text": "ボディガードを二人つけた"
    },
    "319": {
        "start": 1073.088,
        "end": 1074.24,
        "ja_text": "心強い二人をな"
    },
    "320": {
        "start": 1074.7,
        "end": 1077.68,
        "ja_text": "スズさんと店長さんなら頼りになるね"
    },
    "321": {
        "start": 1078.22,
        "end": 1080.56,
        "ja_text": "もちろんこちらからも連中が何者なのか"
    },
    "322": {
        "start": 1081.07,
        "end": 1083.2,
        "ja_text": "何が目的なのかを調べるつもりだ"
    },
    "323": {
        "start": 1084.26,
        "end": 1086.06,
        "ja_text": "ま、それは僕の仕事かな"
    },
    "324": {
        "start": 1087.04,
        "end": 1089.48,
        "ja_text": "秋葉の自警団にも見回りを強化"
    },
    "325": {
        "start": 1089.48,
        "end": 1091.18,
        "ja_text": "してもらうようお願いしたから"
    },
    "326": {
        "start": 1091.28,
        "end": 1094.04,
        "ja_text": "早々変な動きはできないはずにゃん"
    },
    "327": {
        "start": 1095.18,
        "end": 1098.18,
        "ja_text": "あの、僕にも何か手伝えることはありませんか"
    },
    "328": {
        "start": 1098.9,
        "end": 1100.24,
        "ja_text": "かがりさんが大変なのに"
    },
    "329": {
        "start": 1101.0,
        "end": 1103.48,
        "ja_text": "僕、岡部さんの力にもなれないなんて"
    },
    "330": {
        "start": 1104.22,
        "end": 1106.08,
        "ja_text": "まゆしもできることないかな"
    },
    "331": {
        "start": 1107.14,
        "end": 1108.92,
        "ja_text": "ルカコはかがりさんを自宅"
    },
    "332": {
        "start": 1108.92,
        "end": 1110.0,
        "ja_text": "で囲まってくれてるだろう"
    },
    "333": {
        "start": 1110.56,
        "end": 1112.86,
        "ja_text": "マユリだっていろいろと助けられてる"
    },
    "334": {
        "start": 1113.26,
        "end": 1113.76,
        "ja_text": "十分だ"
    },
    "335": {
        "start": 1115.12,
        "end": 1116.7,
        "ja_text": "私たちにできることか"
    },
    "336": {
        "start": 1120.224,
        "end": 1121.68,
        "ja_text": "K6205"
    },
    "337": {
        "start": 1122.592,
        "end": 1123.78,
        "ja_text": "何ですかそれ"
    },
    "338": {
        "start": 1124.78,
        "end": 1125.62,
        "ja_text": "天のおじさんがな"
    },
    "339": {
        "start": 1129.952,
        "end": 1133.02,
        "ja_text": "そういや連中妙なことを口走ってやがったな"
    },
    "340": {
        "start": 1133.24,
        "end": 1134.04,
        "ja_text": "妙なこと"
    },
    "341": {
        "start": 1134.88,
        "end": 1135.744,
        "ja_text": "確かそう"
    },
    "342": {
        "start": 1135.9,
        "end": 1136.16,
        "ja_text": "そう、"
    },
    "343": {
        "start": 1137.08,
        "end": 1139.94,
        "ja_text": "K6205とかなんとか、"
    },
    "344": {
        "start": 1141.34,
        "end": 1142.82,
        "ja_text": "あの発音通貨、言い方は"
    },
    "345": {
        "start": 1143.5,
        "end": 1144.54,
        "ja_text": "フォネティックコードだ"
    },
    "346": {
        "start": 1144.57,
        "end": 1146.32,
        "ja_text": "フォネティックコード?"
    },
    "347": {
        "start": 1147.06,
        "end": 1150.82,
        "ja_text": "軍隊用語だよ、それも西側のな"
    },
    "348": {
        "start": 1152.544,
        "end": 1153.22,
        "ja_text": "うーん、"
    },
    "349": {
        "start": 1154.04,
        "end": 1156.76,
        "ja_text": "商品番号とかしか出てこんねえ"
    },
    "350": {
        "start": 1158.38,
        "end": 1159.66,
        "ja_text": "ケヘル番号とかは?"
    },
    "351": {
        "start": 1160.4,
        "end": 1160.96,
        "ja_text": "なんぞそれ?"
    },
    "352": {
        "start": 1161.24,
        "end": 1162.9,
        "ja_text": "モーツァルトの曲に付けら"
    },
    "353": {
        "start": 1162.9,
        "end": 1164.74,
        "ja_text": "れた番号のことなんですよ"
    },
    "354": {
        "start": 1165.44,
        "end": 1167.72,
        "ja_text": "でもモーツァルトの曲に6"
    },
    "355": {
        "start": 1167.72,
        "end": 1169.3,
        "ja_text": "000番台なんてないですし"
    },
    "356": {
        "start": 1169.48,
        "end": 1170.84,
        "ja_text": "関係なかったかな"
    },
    "357": {
        "start": 1172.92,
        "end": 1176.04,
        "ja_text": "ボルフガング・アマデウス・モーツァルト"
    },
    "358": {
        "start": 1177.44,
        "end": 1181.4,
        "ja_text": "6205じゃなくて620番の5とかは?"
    },
    "359": {
        "start": 1182.272,
        "end": 1183.6,
        "ja_text": "620番…"
    },
    "360": {
        "start": 1184.52,
        "end": 1185.68,
        "ja_text": "マテキだったかな"
    },
    "361": {
        "start": 1188.32,
        "end": 1189.6,
        "ja_text": "すごい、合ってる"
    },
    "362": {
        "start": 1190.08,
        "end": 1193.38,
        "ja_text": "えっと歌詞にフリーメイソンの競技や"
    },
    "363": {
        "start": 1193.38,
        "end": 1196.06,
        "ja_text": "シンボルが用いられていることでも有名"
    },
    "364": {
        "start": 1196.78,
        "end": 1197.72,
        "ja_text": "アマデウス"
    },
    "365": {
        "start": 1199.02,
        "end": 1202.16,
        "ja_text": "どうしたのかしらアマデウスにつながらない"
    },
    "366": {
        "start": 1204.94,
        "end": 1205.82,
        "ja_text": "オカリ"
    },
    "367": {
        "start": 1209.184,
        "end": 1210.18,
        "ja_text": "はいヒアジョーです"
    },
    "368": {
        "start": 1210.816,
        "end": 1211.76,
        "ja_text": "もしもし俺だ"
    },
    "369": {
        "start": 1212.02,
        "end": 1214.6,
        "ja_text": "オカベさんまた何かあったの"
    },
    "370": {
        "start": 1214.82,
        "end": 1216.56,
        "ja_text": "いや聞きたいことがある"
    },
    "371": {
        "start": 1217.152,
        "end": 1218.02,
        "ja_text": "手短にお願い"
    },
    "372": {
        "start": 1218.92,
        "end": 1220.14,
        "ja_text": "ちょっと今手が離せない"
    },
    "373": {
        "start": 1220.33,
        "end": 1222.6,
        "ja_text": "アマデウスはあの後どうなっている"
    },
    "374": {
        "start": 1223.22,
        "end": 1223.48,
        "ja_text": "ダメ"
    },
    "375": {
        "start": 1223.48,
        "end": 1223.86,
        "ja_text": "ア"
    },
    "376": {
        "start": 1225.12,
        "end": 1225.9,
        "ja_text": "クセスできない"
    },
    "377": {
        "start": 1226.68,
        "end": 1228.02,
        "ja_text": "もしかしたらだけれど"
    },
    "378": {
        "start": 1228.672,
        "end": 1230.24,
        "ja_text": "誰かに乗っ取られたのかも"
    },
    "379": {
        "start": 1230.64,
        "end": 1230.74,
        "ja_text": "と"
    },
    "380": {
        "start": 1231.74,
        "end": 1232.86,
        "ja_text": "りあえず今は切るわよ"
    },
    "381": {
        "start": 1233.42,
        "end": 1233.9,
        "ja_text": "また後で"
    },
    "382": {
        "start": 1236.5,
        "end": 1237.28,
        "ja_text": "オカリン"
    },
    "383": {
        "start": 1248.31,
        "end": 1249.22,
        "ja_text": "アマデウス"
    },
    "384": {
        "start": 1258.35,
        "end": 1259.04,
        "ja_text": "クリス"
    },
    "385": {
        "start": 1260.6,
        "end": 1260.704,
        "ja_text": "お願い、"
    },
    "386": {
        "start": 1261.34,
        "end": 1261.54,
        "ja_text": "助けて"
    },
    "387": {
        "start": 1267.62,
        "end": 1270.28,
        "ja_text": "レーディング、スタイラー"
    },
    "388": {
        "start": 1276.7,
        "end": 1278.56,
        "ja_text": "お疲"
    },
    "389": {
        "start": 1330.28,
        "end": 1338.04,
        "ja_text": "I am just a"
    },
    "390": {
        "start": 1338.04,
        "end": 1339.98,
        "ja_text": "part of a sun"
    },
    "391": {
        "start": 1341.4,
        "end": 1342.84,
        "ja_text": "目には見えない"
    },
    "392": {
        "start": 1343.456,
        "end": 1345.89,
        "ja_text": "歪んでる空"
    },
    "393": {
        "start": 1347.03,
        "end": 1352.4,
        "ja_text": "人はどこへと歩いてゆくの"
    },
    "394": {
        "start": 1355.16,
        "end": 1357.48,
        "ja_text": "The last day"
    },
    "395": {
        "start": 1360.28,
        "end": 1365.16,
        "ja_text": "はぁっ"
    },
    "396": {
        "start": 1386.29,
        "end": 1386.84,
        "ja_text": "ア"
    },
    "397": {
        "start": 1388.128,
        "end": 1388.76,
        "ja_text": "マデスが"
    },
    "398": {
        "start": 1388.95,
        "end": 1389.2,
        "ja_text": "誰か"
    },
    "399": {
        "start": 1389.74,
        "end": 1390.44,
        "ja_text": "消えてる"
    },
    "400": {
        "start": 1391.68,
        "end": 1392.84,
        "ja_text": "世界線が変わった"
    },
    "401": {
        "start": 1393.31,
        "end": 1394.74,
        "ja_text": "変わってしまった"
    },
    "402": {
        "start": 1398.16,
        "end": 1400.12,
        "ja_text": "誰かいるのか"
    },
    "403": {
        "start": 1401.04,
        "end": 1401.54,
        "ja_text": "誰?"
    },
    "404": {
        "start": 1402.42,
        "end": 1402.76,
        "ja_text": "マユリ?"
    },
    "405": {
        "start": 1409.0,
        "end": 1410.32,
        "ja_text": "クリス…"
    },
    "406": {
        "start": 1430.0,
        "end": 1434.66,
        "ja_text": "ご視聴ありがとうございました"
    }
}