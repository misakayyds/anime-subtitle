{
    "1": {
        "start": 8.97,
        "end": 10.3,
        "ja_text": "アニメのセリフは、アニメのセリフと"
    },
    "2": {
        "start": 10.3,
        "end": 16.39,
        "ja_text": "は異なりますが、アニメのセリフは、"
    },
    "3": {
        "start": 50.9,
        "end": 55.16,
        "ja_text": "とにかく君を無事に保護できてよかった"
    },
    "4": {
        "start": 55.26,
        "end": 56.54,
        "ja_text": "オカメ君"
    },
    "5": {
        "start": 60.01,
        "end": 60.88,
        "ja_text": "ここは……"
    },
    "6": {
        "start": 62.7,
        "end": 63.62,
        "ja_text": "一体どこですか?"
    },
    "7": {
        "start": 65.02,
        "end": 66.22,
        "ja_text": "俺の仲間たちは……"
    },
    "8": {
        "start": 78.14,
        "end": 78.56,
        "ja_text": "どうぞ"
    },
    "9": {
        "start": 105.3,
        "end": 106.14,
        "ja_text": "夢か"
    },
    "10": {
        "start": 107.08,
        "end": 107.5,
        "ja_text": "そうだ"
    },
    "11": {
        "start": 108.36,
        "end": 111.16,
        "ja_text": "世界戦変動なんてもう起こるはずがないんだ"
    },
    "12": {
        "start": 150.0,
        "end": 154.78,
        "ja_text": "上書きする変哲のない宇宙"
    },
    "13": {
        "start": 155.13,
        "end": 160.22,
        "ja_text": "傲慢な神は目に映らない"
    },
    "14": {
        "start": 160.82,
        "end": 165.38,
        "ja_text": "高速道で支配続けるならば"
    },
    "15": {
        "start": 165.38,
        "end": 169.7,
        "ja_text": "僕は 僕だけは"
    },
    "16": {
        "start": 170.54,
        "end": 176.3,
        "ja_text": "奇跡的で致命的なマイノリティでいい"
    },
    "17": {
        "start": 177.16,
        "end": 179.38,
        "ja_text": "I can fly high あの"
    },
    "18": {
        "start": 179.38,
        "end": 184.02,
        "ja_text": "瞬間 あの場面が 君にとって特別なら"
    },
    "19": {
        "start": 184.1,
        "end": 189.46,
        "ja_text": "過去へ離れてゆくものなんかじゃなくて"
    },
    "20": {
        "start": 189.46,
        "end": 193.42,
        "ja_text": "傷つくことの痛みより大事なシーン"
    },
    "21": {
        "start": 193.42,
        "end": 199.12,
        "ja_text": "その全ての光が今 ゼロを生む"
    },
    "22": {
        "start": 199.92,
        "end": 202.28,
        "ja_text": "There is no God,"
    },
    "23": {
        "start": 202.38,
        "end": 205.18,
        "ja_text": "wonderful new world"
    },
    "24": {
        "start": 208.84,
        "end": 209.34,
        "ja_text": "ちょっと大丈夫"
    },
    "25": {
        "start": 214.16,
        "end": 215.64,
        "ja_text": "これはこの感覚は"
    },
    "26": {
        "start": 216.72,
        "end": 218.18,
        "ja_text": "まさかリーディングしたいな"
    },
    "27": {
        "start": 219.2,
        "end": 220.8,
        "ja_text": "冷座さんここは"
    },
    "28": {
        "start": 222.592,
        "end": 224.36,
        "ja_text": "岡部さんのラボの屋上じゃない"
    },
    "29": {
        "start": 225.32,
        "end": 227.06,
        "ja_text": "クリスマスパーティーの途中で"
    },
    "30": {
        "start": 227.62,
        "end": 228.02,
        "ja_text": "ちょっと"
    },
    "31": {
        "start": 229.6,
        "end": 230.16,
        "ja_text": "岡部さん"
    },
    "32": {
        "start": 232.66,
        "end": 234.7,
        "ja_text": "まさかまさか"
    },
    "33": {
        "start": 235.84,
        "end": 236.5,
        "ja_text": "マヨネー"
    },
    "34": {
        "start": 251.52,
        "end": 252.96,
        "ja_text": "おかえりオカリン"
    },
    "35": {
        "start": 253.42,
        "end": 255.82,
        "ja_text": "マホさんが来たらプレゼント交換だよ"
    },
    "36": {
        "start": 264.7,
        "end": 265.06,
        "ja_text": "はぁ…"
    },
    "37": {
        "start": 278.06,
        "end": 278.6,
        "ja_text": "うん"
    },
    "38": {
        "start": 282.52,
        "end": 282.8,
        "ja_text": "ブッ!"
    },
    "39": {
        "start": 284.04,
        "end": 284.26,
        "ja_text": "おっ…"
    },
    "40": {
        "start": 284.88,
        "end": 285.14,
        "ja_text": "おっ…"
    },
    "41": {
        "start": 286.272,
        "end": 286.54,
        "ja_text": "おっ…"
    },
    "42": {
        "start": 287.296,
        "end": 287.48,
        "ja_text": "あっ…"
    },
    "43": {
        "start": 288.26,
        "end": 289.16,
        "ja_text": "おっ…"
    },
    "44": {
        "start": 289.16,
        "end": 292.032,
        "ja_text": "あっ…"
    },
    "45": {
        "start": 294.112,
        "end": 294.74,
        "ja_text": "まったく"
    },
    "46": {
        "start": 294.74,
        "end": 295.42,
        "ja_text": "へー"
    },
    "47": {
        "start": 296.92,
        "end": 297.38,
        "ja_text": "変態"
    },
    "48": {
        "start": 298.52,
        "end": 298.88,
        "ja_text": "違う"
    },
    "49": {
        "start": 299.83,
        "end": 301.72,
        "ja_text": "プレゼント交換で当たったんだ"
    },
    "50": {
        "start": 302.688,
        "end": 304.0,
        "ja_text": "ならマホ先輩にあげたら"
    },
    "51": {
        "start": 304.5,
        "end": 305.6,
        "ja_text": "着てくれるかも"
    },
    "52": {
        "start": 305.87,
        "end": 307.31,
        "ja_text": "セクハラだろそれは"
    },
    "53": {
        "start": 308.22,
        "end": 308.58,
        "ja_text": "そう?"
    },
    "54": {
        "start": 309.4,
        "end": 310.88,
        "ja_text": "案外喜ぶと思うけど"
    },
    "55": {
        "start": 313.472,
        "end": 315.26,
        "ja_text": "怒ってないのか"
    },
    "56": {
        "start": 316.6,
        "end": 319.46,
        "ja_text": "さっき屋上で話している途中で"
    },
    "57": {
        "start": 319.46,
        "end": 320.32,
        "ja_text": "切ってしまっただろ"
    },
    "58": {
        "start": 322.16,
        "end": 323.78,
        "ja_text": "ええ、でもすぐにかけな"
    },
    "59": {
        "start": 323.78,
        "end": 324.68,
        "ja_text": "おしてきてくれたじゃない"
    },
    "60": {
        "start": 325.8,
        "end": 326.68,
        "ja_text": "忘れちゃったの?"
    },
    "61": {
        "start": 327.9,
        "end": 328.86,
        "ja_text": "え、かけ、"
    },
    "62": {
        "start": 329.8,
        "end": 330.32,
        "ja_text": "なおした"
    },
    "63": {
        "start": 331.52,
        "end": 333.3,
        "ja_text": "俺にそんな記憶は"
    },
    "64": {
        "start": 337.4,
        "end": 338.96,
        "ja_text": "待たせてごめんなさい"
    },
    "65": {
        "start": 340.94,
        "end": 342.96,
        "ja_text": "メリカからの電話だったんだが"
    },
    "66": {
        "start": 343.0,
        "end": 345.5,
        "ja_text": "あちらの電波状況が悪くてね"
    },
    "67": {
        "start": 346.0,
        "end": 347.296,
        "ja_text": "手間取ってしまった"
    },
    "68": {
        "start": 348.08,
        "end": 349.74,
        "ja_text": "だいぶ遅い時間になって"
    },
    "69": {
        "start": 349.74,
        "end": 351.82,
        "ja_text": "しまって申し訳なかったね"
    },
    "70": {
        "start": 352.2,
        "end": 353.18,
        "ja_text": "ウィンターアロー"
    },
    "71": {
        "start": 353.18,
        "end": 353.92,
        "ja_text": "いえ"
    },
    "72": {
        "start": 355.55,
        "end": 358.08,
        "ja_text": "パーリーにも参加させてもらったしね"
    },
    "73": {
        "start": 358.13,
        "end": 360.44,
        "ja_text": "可愛らしいクレヨンですね教授"
    },
    "74": {
        "start": 361.2,
        "end": 361.6,
        "ja_text": "それは?"
    },
    "75": {
        "start": 363.52,
        "end": 365.6,
        "ja_text": "シーナさんが用意してくれたプレゼント"
    },
    "76": {
        "start": 365.6,
        "end": 365.72,
        "ja_text": "ウ"
    },
    "77": {
        "start": 367.16,
        "end": 369.9,
        "ja_text": "ィンターアローは何が当たったんだい?"
    },
    "78": {
        "start": 369.9,
        "end": 371.6,
        "ja_text": "あ、いや俺は"
    },
    "79": {
        "start": 371.6,
        "end": 372.74,
        "ja_text": "隠すことないじゃない"
    },
    "80": {
        "start": 372.74,
        "end": 374.5,
        "ja_text": "うるさい"
    },
    "81": {
        "start": 375.264,
        "end": 376.0,
        "ja_text": "もう切るぞ"
    },
    "82": {
        "start": 378.06,
        "end": 379.58,
        "ja_text": "だいぶフレンドリーにな"
    },
    "83": {
        "start": 379.58,
        "end": 381.16,
        "ja_text": "ってくれているみたいだね"
    },
    "84": {
        "start": 381.76,
        "end": 383.66,
        "ja_text": "あの子の口調もだいぶ砕けてるわ"
    },
    "85": {
        "start": 384.512,
        "end": 388.14,
        "ja_text": "これは本気で期待できるかもしれないよ魔法"
    },
    "86": {
        "start": 388.64,
        "end": 389.06,
        "ja_text": "期待?"
    },
    "87": {
        "start": 390.272,
        "end": 391.28,
        "ja_text": "恋愛感情"
    },
    "88": {
        "start": 392.1,
        "end": 394.336,
        "ja_text": "彼女があなたにそれを抱くんじゃないかって"
    },
    "89": {
        "start": 395.06,
        "end": 396.44,
        "ja_text": "教授は期待してるのよ"
    },
    "90": {
        "start": 397.824,
        "end": 398.4,
        "ja_text": "恋愛?"
    },
    "91": {
        "start": 400.064,
        "end": 400.42,
        "ja_text": "恋愛?"
    },
    "92": {
        "start": 400.42,
        "end": 402.0,
        "ja_text": "AIですよね"
    },
    "93": {
        "start": 403.1,
        "end": 405.88,
        "ja_text": "アマデウスは人の記憶を保持し"
    },
    "94": {
        "start": 406.08,
        "end": 409.54,
        "ja_text": "人の脳を再現するべく作られたシステムだ"
    },
    "95": {
        "start": 410.1,
        "end": 410.9,
        "ja_text": "つまり"
    },
    "96": {
        "start": 411.58,
        "end": 413.46,
        "ja_text": "プロセスと構造は同じ"
    },
    "97": {
        "start": 414.02,
        "end": 416.22,
        "ja_text": "アマデウスだって恋をする"
    },
    "98": {
        "start": 416.22,
        "end": 420.4,
        "ja_text": "いや、ぜひそうなってほしいと思ってるよ"
    },
    "99": {
        "start": 421.76,
        "end": 424.28,
        "ja_text": "もっとも、それがそうなっても"
    },
    "100": {
        "start": 424.47,
        "end": 427.42,
        "ja_text": "アマデウスは本物の彼女ではないですけどね"
    },
    "101": {
        "start": 429.32,
        "end": 432.26,
        "ja_text": "魔法はどうやらお気に召さない らしいね"
    },
    "102": {
        "start": 440.02,
        "end": 442.14,
        "ja_text": "ずいぶん仲良かったのね"
    },
    "103": {
        "start": 442.14,
        "end": 445.08,
        "ja_text": "そうでないとこの短期間で"
    },
    "104": {
        "start": 445.98,
        "end": 446.5,
        "ja_text": "アマデウス"
    },
    "105": {
        "start": 446.5,
        "end": 448.6,
        "ja_text": "とここまで親密になれないわ ど"
    },
    "106": {
        "start": 451.42,
        "end": 453.08,
        "ja_text": "のくらい仲良かったの"
    },
    "107": {
        "start": 453.82,
        "end": 457.4,
        "ja_text": "まさか恋人関係だったとか言わないわよね"
    },
    "108": {
        "start": 462.56,
        "end": 464.76,
        "ja_text": "まさか偶然セミナーで"
    },
    "109": {
        "start": 465.856,
        "end": 467.12,
        "ja_text": "それは前にも聞いた"
    },
    "110": {
        "start": 468.44,
        "end": 469.5,
        "ja_text": "本当にそれだけなの?"
    },
    "111": {
        "start": 477.9,
        "end": 478.88,
        "ja_text": "ごめん"
    },
    "112": {
        "start": 480.82,
        "end": 483.14,
        "ja_text": "ただ私の知らない彼女のことが"
    },
    "113": {
        "start": 484.1,
        "end": 485.02,
        "ja_text": "知りたかったのよね"
    },
    "114": {
        "start": 485.84,
        "end": 486.44,
        "ja_text": "クリスの"
    },
    "115": {
        "start": 486.9,
        "end": 488.34,
        "ja_text": "何も知らないのよ"
    },
    "116": {
        "start": 489.34,
        "end": 491.22,
        "ja_text": "長い付き合いだと思ってたんだけど"
    },
    "117": {
        "start": 492.88,
        "end": 495.46,
        "ja_text": "彼女の好きな言葉や数字や"
    },
    "118": {
        "start": 496.52,
        "end": 497.5,
        "ja_text": "何も知らないの"
    },
    "119": {
        "start": 499.06,
        "end": 499.36,
        "ja_text": "何も"
    },
    "120": {
        "start": 508.88,
        "end": 511.02,
        "ja_text": "みんな、最後までありがとうね"
    },
    "121": {
        "start": 511.32,
        "end": 513.92,
        "ja_text": "じゃあ、片付けも終わったし、メ"
    },
    "122": {
        "start": 513.92,
        "end": 515.8,
        "ja_text": "イクインでお茶でもしていくかにゃ"
    },
    "123": {
        "start": 515.8,
        "end": 516.78,
        "ja_text": "今から?"
    },
    "124": {
        "start": 517.376,
        "end": 519.42,
        "ja_text": "街には悪人たちが溢れているぞ"
    },
    "125": {
        "start": 519.98,
        "end": 520.62,
        "ja_text": "いいじゃない。"
    },
    "126": {
        "start": 521.12,
        "end": 524.36,
        "ja_text": "そんな中、女の子だけで乗り込むのも女子だけ"
    },
    "127": {
        "start": 524.98,
        "end": 526.48,
        "ja_text": "だが、男だー"
    },
    "128": {
        "start": 526.66,
        "end": 527.16,
        "ja_text": "あ、"
    },
    "129": {
        "start": 528.48,
        "end": 529.26,
        "ja_text": "すみません。"
    },
    "130": {
        "start": 530.08,
        "end": 530.7,
        "ja_text": "僕この後、"
    },
    "131": {
        "start": 531.24,
        "end": 533.16,
        "ja_text": "家にお客さんが来ることになってて"
    },
    "132": {
        "start": 533.16,
        "end": 534.34,
        "ja_text": "え、そうなの?"
    },
    "133": {
        "start": 534.5,
        "end": 535.68,
        "ja_text": "クリスマスなのに?"
    },
    "134": {
        "start": 535.79,
        "end": 538.56,
        "ja_text": "うん、お父さんのお客さんなんだけど"
    },
    "135": {
        "start": 539.44,
        "end": 541.14,
        "ja_text": "僕も同席してほしいって"
    },
    "136": {
        "start": 541.61,
        "end": 543.04,
        "ja_text": "ごめんね、まゆりちゃん"
    },
    "137": {
        "start": 543.64,
        "end": 546.12,
        "ja_text": "ううん、今日は久しぶり"
    },
    "138": {
        "start": 546.12,
        "end": 547.74,
        "ja_text": "にみんなでラボに集まれて"
    },
    "139": {
        "start": 547.95,
        "end": 550.2,
        "ja_text": "まゆしーは楽しかったのです"
    },
    "140": {
        "start": 550.88,
        "end": 552.58,
        "ja_text": "そういえば、橋田さんたちも?"
    },
    "141": {
        "start": 553.22,
        "end": 556.64,
        "ja_text": "だるくんは、すずさんと少しお話があるんだって"
    },
    "142": {
        "start": 557.38,
        "end": 559.38,
        "ja_text": "兄弟の話って言ってたけど"
    },
    "143": {
        "start": 561.056,
        "end": 563.92,
        "ja_text": "羊の毛って聞いた時にはどうかと思ったけど"
    },
    "144": {
        "start": 564.01,
        "end": 566.04,
        "ja_text": "意外と暖かいもんだね"
    },
    "145": {
        "start": 569.3,
        "end": 570.06,
        "ja_text": "よかったじゃない"
    },
    "146": {
        "start": 570.72,
        "end": 572.26,
        "ja_text": "母さん誘って行ってきなよ"
    },
    "147": {
        "start": 573.02,
        "end": 573.58,
        "ja_text": "誘う?"
    },
    "148": {
        "start": 573.92,
        "end": 574.02,
        "ja_text": "うん"
    },
    "149": {
        "start": 575.0,
        "end": 576.7,
        "ja_text": "二人見てるとじれったいからさ"
    },
    "150": {
        "start": 577.64,
        "end": 579.52,
        "ja_text": "今日だってろくに話してないじゃん"
    },
    "151": {
        "start": 580.832,
        "end": 582.42,
        "ja_text": "ギャラリーが多いところで"
    },
    "152": {
        "start": 582.47,
        "end": 585.18,
        "ja_text": "そんなリア充滅世用的なこと僕はちょっと"
    },
    "153": {
        "start": 588.12,
        "end": 589.4,
        "ja_text": "それで話って何?"
    },
    "154": {
        "start": 590.18,
        "end": 591.84,
        "ja_text": "わざわざ出かけるのやめてまで"
    },
    "155": {
        "start": 592.44,
        "end": 592.8,
        "ja_text": "うん"
    },
    "156": {
        "start": 592.8,
        "end": 595.86,
        "ja_text": "うん、前から気になってたんで聞くけどさ"
    },
    "157": {
        "start": 597.12,
        "end": 600.54,
        "ja_text": "鈴葉、父さんの目見て正直に答えてほしい"
    },
    "158": {
        "start": 601.888,
        "end": 602.528,
        "ja_text": "何があった?"
    },
    "159": {
        "start": 603.232,
        "end": 603.7,
        "ja_text": "何って?"
    },
    "160": {
        "start": 604.47,
        "end": 606.2,
        "ja_text": "ここんとこラボにもラジカ"
    },
    "161": {
        "start": 606.2,
        "end": 607.8,
        "ja_text": "ンにもいない時間が多いよね"
    },
    "162": {
        "start": 608.78,
        "end": 609.46,
        "ja_text": "どこ行ってる?"
    },
    "163": {
        "start": 611.62,
        "end": 612.48,
        "ja_text": "なんでもないよ"
    },
    "164": {
        "start": 613.248,
        "end": 616.32,
        "ja_text": "鈴葉がなんでもないという時は何かある時だ"
    },
    "165": {
        "start": 621.56,
        "end": 622.62,
        "ja_text": "いいから話してみ"
    },
    "166": {
        "start": 626.96,
        "end": 628.82,
        "ja_text": "人をさ探してるんだ"
    },
    "167": {
        "start": 629.3,
        "end": 629.7,
        "ja_text": "人?"
    },
    "168": {
        "start": 631.3,
        "end": 634.22,
        "ja_text": "タイムマシンで一緒に未来から来た子がいるんだ"
    },
    "169": {
        "start": 634.22,
        "end": 634.4,
        "ja_text": "え?"
    },
    "170": {
        "start": 636.032,
        "end": 637.68,
        "ja_text": "でもはぐれてしまった"
    },
    "171": {
        "start": 638.88,
        "end": 641.18,
        "ja_text": "1998年の秋葉原で"
    },
    "172": {
        "start": 644.352,
        "end": 645.32,
        "ja_text": "そんな話が"
    },
    "173": {
        "start": 646.76,
        "end": 648.52,
        "ja_text": "別れた時10歳と言ってたな"
    },
    "174": {
        "start": 649.7,
        "end": 651.62,
        "ja_text": "今生きていれば22歳か"
    },
    "175": {
        "start": 652.64,
        "end": 654.6,
        "ja_text": "ずっと探すわけにもいかんくて"
    },
    "176": {
        "start": 655.28,
        "end": 656.62,
        "ja_text": "タイムトラベルで降りるたび"
    },
    "177": {
        "start": 656.62,
        "end": 658.3,
        "ja_text": "に探してはいたらしいんだけど"
    },
    "178": {
        "start": 659.584,
        "end": 660.94,
        "ja_text": "諦めかけていたところ"
    },
    "179": {
        "start": 661.88,
        "end": 664.16,
        "ja_text": "最近ネットの写真で見つけたらしくて"
    },
    "180": {
        "start": 664.992,
        "end": 667.4,
        "ja_text": "その子がこれと似たものをつけてたんだって"
    },
    "181": {
        "start": 668.08,
        "end": 670.28,
        "ja_text": "それで一人で探してたということか"
    },
    "182": {
        "start": 671.36,
        "end": 672.2,
        "ja_text": "その子の名前は?"
    },
    "183": {
        "start": 673.48,
        "end": 674.32,
        "ja_text": "聞いたんだろ?"
    },
    "184": {
        "start": 678.5,
        "end": 680.1,
        "ja_text": "シーナ・カガリ"
    },
    "185": {
        "start": 681.4,
        "end": 682.2,
        "ja_text": "シーナ?"
    },
    "186": {
        "start": 682.96,
        "end": 683.96,
        "ja_text": "おい、まさか"
    },
    "187": {
        "start": 684.12,
        "end": 684.52,
        "ja_text": "うん、"
    },
    "188": {
        "start": 685.44,
        "end": 686.22,
        "ja_text": "マユシの娘"
    },
    "189": {
        "start": 686.22,
        "end": 687.86,
        "ja_text": "父親は?"
    },
    "190": {
        "start": 688.416,
        "end": 691.424,
        "ja_text": "違う違う、実の子供じゃないんだって"
    },
    "191": {
        "start": 692.32,
        "end": 694.38,
        "ja_text": "戦災孤児だったのを未来の"
    },
    "192": {
        "start": 694.38,
        "end": 695.872,
        "ja_text": "マユシが引き取ったんだって"
    },
    "193": {
        "start": 698.464,
        "end": 699.46,
        "ja_text": "そういうことか"
    },
    "194": {
        "start": 701.28,
        "end": 704.92,
        "ja_text": "鈴葉の話じゃ2036年の僕やまゆ"
    },
    "195": {
        "start": 704.92,
        "end": 707.52,
        "ja_text": "しはタイムマシンの開発をめぐって"
    },
    "196": {
        "start": 708.04,
        "end": 710.32,
        "ja_text": "治安部隊に追われていたらしくてね"
    },
    "197": {
        "start": 711.12,
        "end": 711.8,
        "ja_text": "父さん"
    },
    "198": {
        "start": 712.32,
        "end": 714.56,
        "ja_text": "俺たちのことはいい治安部隊"
    },
    "199": {
        "start": 714.56,
        "end": 716.32,
        "ja_text": "がそこまで来てるだから早く"
    },
    "200": {
        "start": 717.856,
        "end": 719.82,
        "ja_text": "鈴ちゃんかがりんお願い"
    },
    "201": {
        "start": 721.76,
        "end": 723.82,
        "ja_text": "まゆ姉さんわかった"
    },
    "202": {
        "start": 724.66,
        "end": 725.06,
        "ja_text": "いや!"
    },
    "203": {
        "start": 725.74,
        "end": 728.56,
        "ja_text": "ママと一緒じゃなきゃイヤだ!ママ!"
    },
    "204": {
        "start": 729.44,
        "end": 731.0,
        "ja_text": "大丈夫だよ、かがりちゃん"
    },
    "205": {
        "start": 731.0,
        "end": 731.62,
        "ja_text": "イヤ!"
    },
    "206": {
        "start": 733.02,
        "end": 734.06,
        "ja_text": "ゼネちゃんが一緒だから"
    },
    "207": {
        "start": 734.848,
        "end": 737.32,
        "ja_text": "ママと一緒にいる!ママ!"
    },
    "208": {
        "start": 737.86,
        "end": 738.52,
        "ja_text": "ママ!"
    },
    "209": {
        "start": 740.72,
        "end": 744.14,
        "ja_text": "その後、2010年に来る前、19"
    },
    "210": {
        "start": 744.14,
        "end": 747.88,
        "ja_text": "75年から1998年に立ち寄って、"
    },
    "211": {
        "start": 749.2,
        "end": 751.12,
        "ja_text": "そこではぐれてしまったらしいんよ"
    },
    "212": {
        "start": 752.98,
        "end": 756.34,
        "ja_text": "なおかりん、探すの協力してくれるん?"
    },
    "213": {
        "start": 757.312,
        "end": 758.7,
        "ja_text": "こんなこと頼める筋じゃ"
    },
    "214": {
        "start": 758.7,
        "end": 759.16,
        "ja_text": "分かった"
    },
    "215": {
        "start": 760.22,
        "end": 760.62,
        "ja_text": "本当?"
    },
    "216": {
        "start": 766.976,
        "end": 768.48,
        "ja_text": "第三次世界大戦、"
    },
    "217": {
        "start": 769.28,
        "end": 770.496,
        "ja_text": "戦災故事か"
    },
    "218": {
        "start": 771.84,
        "end": 774.14,
        "ja_text": "しかし幼女とはいえマユリの娘とは"
    },
    "219": {
        "start": 775.58,
        "end": 777.58,
        "ja_text": "25年後でもあいつは優しいんだな"
    },
    "220": {
        "start": 780.06,
        "end": 782.6,
        "ja_text": "あれは一体何だったんだ"
    },
    "221": {
        "start": 788.06,
        "end": 790.88,
        "ja_text": "あれが世界線の変動によるものだとしたら"
    },
    "222": {
        "start": 792.58,
        "end": 795.648,
        "ja_text": "何者かが電話レンジのようなものを作った"
    },
    "223": {
        "start": 796.66,
        "end": 796.98,
        "ja_text": "あるいは"
    },
    "224": {
        "start": 797.18,
        "end": 799.44,
        "ja_text": "日本政府はロシアに対し"
    },
    "225": {
        "start": 800.08,
        "end": 803.08,
        "ja_text": "8月に亡命した中橋博士についての会見を"
    },
    "226": {
        "start": 804.3,
        "end": 805.14,
        "ja_text": "何か用?"
    },
    "227": {
        "start": 806.35,
        "end": 808.48,
        "ja_text": "いやちょっと相談に乗ってほしくてな"
    },
    "228": {
        "start": 809.632,
        "end": 810.36,
        "ja_text": "迷惑だったか"
    },
    "229": {
        "start": 811.008,
        "end": 814.78,
        "ja_text": "別にあんたと話すことは私のためにもなるんだし"
    },
    "230": {
        "start": 816.18,
        "end": 817.28,
        "ja_text": "でどうかした"
    },
    "231": {
        "start": 820.576,
        "end": 822.6,
        "ja_text": "12年前に消息不明にな"
    },
    "232": {
        "start": 822.6,
        "end": 823.88,
        "ja_text": "った人を探しているんだが"
    },
    "233": {
        "start": 823.88,
        "end": 825.2,
        "ja_text": "いい方法はないか"
    },
    "234": {
        "start": 826.88,
        "end": 827.48,
        "ja_text": "詳しく教えて"
    },
    "235": {
        "start": 829.84,
        "end": 831.6,
        "ja_text": "いや情報も何もないんだ"
    },
    "236": {
        "start": 832.56,
        "end": 834.32,
        "ja_text": "それで方法と言われてもね"
    },
    "237": {
        "start": 835.24,
        "end": 837.48,
        "ja_text": "一番いいのは警察行くことね"
    },
    "238": {
        "start": 837.58,
        "end": 838.7,
        "ja_text": "だよな"
    },
    "239": {
        "start": 839.84,
        "end": 841.52,
        "ja_text": "それはできないって顔ね"
    },
    "240": {
        "start": 842.656,
        "end": 844.84,
        "ja_text": "あとは新聞や更新所使うとか"
    },
    "241": {
        "start": 845.16,
        "end": 847.96,
        "ja_text": "アメリカではダウジングとか投資とか"
    },
    "242": {
        "start": 848.27,
        "end": 849.96,
        "ja_text": "テレビに出演したいなら"
    },
    "243": {
        "start": 849.96,
        "end": 852.16,
        "ja_text": "教授に頼んで推薦するわよ"
    },
    "244": {
        "start": 852.74,
        "end": 854.08,
        "ja_text": "言ってみただけだ"
    },
    "245": {
        "start": 857.5,
        "end": 859.9,
        "ja_text": "マキセ・クリスは死んだの"
    },
    "246": {
        "start": 862.56,
        "end": 863.54,
        "ja_text": "すまない"
    },
    "247": {
        "start": 863.72,
        "end": 864.9,
        "ja_text": "一度切る"
    },
    "248": {
        "start": 875.552,
        "end": 876.7,
        "ja_text": "2000年問題"
    },
    "249": {
        "start": 877.54,
        "end": 878.92,
        "ja_text": "ちゃんと勉強した"
    },
    "250": {
        "start": 878.92,
        "end": 880.5,
        "ja_text": "施設でちょっと"
    },
    "251": {
        "start": 880.81,
        "end": 883.72,
        "ja_text": "公表されてないけど問題だったのは"
    },
    "252": {
        "start": 883.8,
        "end": 886.02,
        "ja_text": "このIBN5100っていう"
    },
    "253": {
        "start": 886.02,
        "end": 887.22,
        "ja_text": "コンピューターだったんだ"
    },
    "254": {
        "start": 888.24,
        "end": 890.28,
        "ja_text": "だからこの修正プログラムで"
    },
    "255": {
        "start": 890.28,
        "end": 892.44,
        "ja_text": "2000年問題が起きないようにする"
    },
    "256": {
        "start": 892.64,
        "end": 895.64,
        "ja_text": "でも未来から来た私たち"
    },
    "257": {
        "start": 895.64,
        "end": 897.24,
        "ja_text": "がそんなことしていいの?"
    },
    "258": {
        "start": 897.38,
        "end": 900.12,
        "ja_text": "私たちがいた未来も変わっちゃうんじゃ"
    },
    "259": {
        "start": 901.86,
        "end": 904.0,
        "ja_text": "私たちはシュタインズゲートを目指すため"
    },
    "260": {
        "start": 904.96,
        "end": 906.86,
        "ja_text": "未来を変えるためここにいるんだ"
    },
    "261": {
        "start": 908.26,
        "end": 909.86,
        "ja_text": "未来を変える?"
    },
    "262": {
        "start": 910.6,
        "end": 913.42,
        "ja_text": "そうだ、あんな世界は存在しちゃいけないんだ"
    },
    "263": {
        "start": 913.46,
        "end": 914.8,
        "ja_text": "そのためには"
    },
    "264": {
        "start": 938.04,
        "end": 939.46,
        "ja_text": "ダメだよ"
    },
    "265": {
        "start": 941.4,
        "end": 943.74,
        "ja_text": "そんなことしちゃダメだ"
    },
    "266": {
        "start": 945.28,
        "end": 947.44,
        "ja_text": "声が聞こえる"
    },
    "267": {
        "start": 947.78,
        "end": 948.24,
        "ja_text": "ガガリン"
    },
    "268": {
        "start": 956.96,
        "end": 958.04,
        "ja_text": "お、鈴葉"
    },
    "269": {
        "start": 958.04,
        "end": 958.304,
        "ja_text": "どう?"
    },
    "270": {
        "start": 959.62,
        "end": 962.94,
        "ja_text": "警察の探し人のデータを一通り調べてみたけど"
    },
    "271": {
        "start": 964.096,
        "end": 965.68,
        "ja_text": "それらしい情報はないよ"
    },
    "272": {
        "start": 966.7,
        "end": 968.82,
        "ja_text": "一見平和に見えるこの世界でも"
    },
    "273": {
        "start": 970.08,
        "end": 973.2,
        "ja_text": "身元不明や行方不明の人って結構いるんだね"
    },
    "274": {
        "start": 974.38,
        "end": 975.82,
        "ja_text": "そういえば父さん"
    },
    "275": {
        "start": 976.2,
        "end": 978.22,
        "ja_text": "オカリンおじさんにも話したんだっけ"
    },
    "276": {
        "start": 978.82,
        "end": 979.18,
        "ja_text": "うん"
    },
    "277": {
        "start": 979.41,
        "end": 981.5,
        "ja_text": "いろいろ当たってみてくれるって"
    },
    "278": {
        "start": 982.624,
        "end": 983.14,
        "ja_text": "そうなんだ"
    },
    "279": {
        "start": 983.76,
        "end": 985.52,
        "ja_text": "今度お礼言わなきゃね"
    },
    "280": {
        "start": 986.04,
        "end": 988.38,
        "ja_text": "きっとオカリンも喜ぶと思う"
    },
    "281": {
        "start": 994.76,
        "end": 996.08,
        "ja_text": "何またイルス病"
    },
    "282": {
        "start": 996.5,
        "end": 997.62,
        "ja_text": "図書館にいたんだ"
    },
    "283": {
        "start": 998.4,
        "end": 998.94,
        "ja_text": "ごめん"
    },
    "284": {
        "start": 1000.352,
        "end": 1001.5,
        "ja_text": "それは私が悪かった"
    },
    "285": {
        "start": 1002.34,
        "end": 1003.98,
        "ja_text": "謝るごめんなさい"
    },
    "286": {
        "start": 1004.46,
        "end": 1006.06,
        "ja_text": "気にしなくていいのに"
    },
    "287": {
        "start": 1006.56,
        "end": 1007.46,
        "ja_text": "そうはいかないわ"
    },
    "288": {
        "start": 1007.92,
        "end": 1010.48,
        "ja_text": "間違ったことをごまかしたりするのは嫌いだもの"
    },
    "289": {
        "start": 1011.56,
        "end": 1012.9,
        "ja_text": "ところでなんで図書館に?"
    },
    "290": {
        "start": 1014.432,
        "end": 1017.504,
        "ja_text": "12年前からの新聞のバックナンバーを見たりな"
    },
    "291": {
        "start": 1018.2,
        "end": 1019.5,
        "ja_text": "例の身元不明の人?"
    },
    "292": {
        "start": 1019.92,
        "end": 1020.24,
        "ja_text": "そうだ"
    },
    "293": {
        "start": 1022.3,
        "end": 1024.08,
        "ja_text": "私が探してみましょうか"
    },
    "294": {
        "start": 1024.13,
        "end": 1024.58,
        "ja_text": "え?"
    },
    "295": {
        "start": 1025.344,
        "end": 1026.4,
        "ja_text": "そんなことできるのか?"
    },
    "296": {
        "start": 1026.62,
        "end": 1026.94,
        "ja_text": "ええ"
    },
    "297": {
        "start": 1027.38,
        "end": 1029.62,
        "ja_text": "アマデウスの本体はビクトリコンドリ"
    },
    "298": {
        "start": 1029.62,
        "end": 1031.66,
        "ja_text": "ア大学の研究棟のサーバーにあるのよ"
    },
    "299": {
        "start": 1032.78,
        "end": 1034.54,
        "ja_text": "研究用のコンピューターとネットワ"
    },
    "300": {
        "start": 1034.54,
        "end": 1036.66,
        "ja_text": "ークを私は自在に扱うことができる"
    },
    "301": {
        "start": 1037.44,
        "end": 1039.4,
        "ja_text": "オンライン上の情報を調べるくらい"
    },
    "302": {
        "start": 1040.06,
        "end": 1040.58,
        "ja_text": "わけない"
    },
    "303": {
        "start": 1041.46,
        "end": 1043.54,
        "ja_text": "でもそんなことやってしまっていいのか"
    },
    "304": {
        "start": 1046.82,
        "end": 1048.4,
        "ja_text": "ばれなければいいのよ"
    },
    "305": {
        "start": 1049.888,
        "end": 1052.46,
        "ja_text": "それに悪いことをしているわけじゃないんでしょ"
    },
    "306": {
        "start": 1052.86,
        "end": 1053.62,
        "ja_text": "無論だ"
    },
    "307": {
        "start": 1054.176,
        "end": 1056.22,
        "ja_text": "ならあとはあんたの判断に任せるわ"
    },
    "308": {
        "start": 1057.36,
        "end": 1057.68,
        "ja_text": "どうする"
    },
    "309": {
        "start": 1060.56,
        "end": 1062.22,
        "ja_text": "少し考えさせてくれ"
    },
    "310": {
        "start": 1067.76,
        "end": 1069.44,
        "ja_text": "にゃにゃ、そこにいるのはキ"
    },
    "311": {
        "start": 1069.44,
        "end": 1071.32,
        "ja_text": "ョ、じゃなかった、オカリン"
    },
    "312": {
        "start": 1072.62,
        "end": 1074.52,
        "ja_text": "なんだ、今日は珍しい組み合わせだな"
    },
    "313": {
        "start": 1074.98,
        "end": 1076.78,
        "ja_text": "ちょっと、ルカにゃのお父さん"
    },
    "314": {
        "start": 1076.78,
        "end": 1078.62,
        "ja_text": "に頼まれて買い出しだったのにゃ"
    },
    "315": {
        "start": 1078.64,
        "end": 1081.56,
        "ja_text": "お父さんのお客さんの一人が家に"
    },
    "316": {
        "start": 1081.56,
        "end": 1084.5,
        "ja_text": "住むことになりまして、その準備を"
    },
    "317": {
        "start": 1084.69,
        "end": 1085.46,
        "ja_text": "そうか"
    },
    "318": {
        "start": 1086.28,
        "end": 1087.68,
        "ja_text": "重そうだが手伝うか"
    },
    "319": {
        "start": 1087.68,
        "end": 1090.22,
        "ja_text": "あいえ大丈夫です"
    },
    "320": {
        "start": 1091.06,
        "end": 1094.3,
        "ja_text": "僕だってこのくらい滑りも毎日してますし"
    },
    "321": {
        "start": 1094.5,
        "end": 1097.2,
        "ja_text": "まああと少し今日オカリン"
    },
    "322": {
        "start": 1097.2,
        "end": 1099.2,
        "ja_text": "には頼みにくい話だったのにゃ"
    },
    "323": {
        "start": 1099.5,
        "end": 1101.98,
        "ja_text": "まあここはフェイリスにお任せにゃ"
    },
    "324": {
        "start": 1103.5,
        "end": 1104.3,
        "ja_text": "そうか"
    },
    "325": {
        "start": 1106.2,
        "end": 1108.44,
        "ja_text": "そういえば二人とも昔から地元か"
    },
    "326": {
        "start": 1109.04,
        "end": 1109.14,
        "ja_text": "にゃ"
    },
    "327": {
        "start": 1111.2,
        "end": 1112.84,
        "ja_text": "行方不明の女の子"
    },
    "328": {
        "start": 1112.84,
        "end": 1115.6,
        "ja_text": "おう、とりあえずクロッキーに聞いてみるにゃ"
    },
    "329": {
        "start": 1115.6,
        "end": 1116.38,
        "ja_text": "頼む"
    },
    "330": {
        "start": 1117.248,
        "end": 1119.38,
        "ja_text": "10年以上前の話ですよね"
    },
    "331": {
        "start": 1120.44,
        "end": 1121.92,
        "ja_text": "僕お父さんに聞いてみます"
    },
    "332": {
        "start": 1122.4,
        "end": 1123.3,
        "ja_text": "ああ、悪い"
    },
    "333": {
        "start": 1123.88,
        "end": 1125.26,
        "ja_text": "それじゃあそろそろ行くにゃ"
    },
    "334": {
        "start": 1125.26,
        "end": 1125.76,
        "ja_text": "はい"
    },
    "335": {
        "start": 1128.92,
        "end": 1129.5,
        "ja_text": "キョウマ"
    },
    "336": {
        "start": 1130.54,
        "end": 1132.48,
        "ja_text": "これからも困ったことがあったら"
    },
    "337": {
        "start": 1132.59,
        "end": 1135.54,
        "ja_text": "難しい顔してないでフェイリスたちに話してにゃ"
    },
    "338": {
        "start": 1149.312,
        "end": 1151.42,
        "ja_text": "そうか、手がかりはなしか"
    },
    "339": {
        "start": 1151.94,
        "end": 1152.78,
        "ja_text": "ごめんにゃ"
    },
    "340": {
        "start": 1153.54,
        "end": 1154.82,
        "ja_text": "いや、こちらこそすまない"
    },
    "341": {
        "start": 1155.38,
        "end": 1158.2,
        "ja_text": "あ、でも、お下げの幽霊の話は聞いたにゃ"
    },
    "342": {
        "start": 1158.848,
        "end": 1159.24,
        "ja_text": "幽霊?"
    },
    "343": {
        "start": 1160.06,
        "end": 1163.24,
        "ja_text": "なんか、数年ごとに噂になってる都市伝説にゃ"
    },
    "344": {
        "start": 1163.9,
        "end": 1165.84,
        "ja_text": "ラジカーのあたりで小さな女"
    },
    "345": {
        "start": 1165.84,
        "end": 1167.98,
        "ja_text": "の子を見なかったと尋ねてくる"
    },
    "346": {
        "start": 1168.0,
        "end": 1170.94,
        "ja_text": "お下げの女の子の幽霊が出るらしいにゃ"
    },
    "347": {
        "start": 1173.4,
        "end": 1174.44,
        "ja_text": "レスキネン教授"
    },
    "348": {
        "start": 1184.88,
        "end": 1186.56,
        "ja_text": "だからもういいって言ってるの"
    },
    "349": {
        "start": 1186.75,
        "end": 1187.62,
        "ja_text": "ありがとね"
    },
    "350": {
        "start": 1187.78,
        "end": 1190.16,
        "ja_text": "いや手がかりはないと言ったけど"
    },
    "351": {
        "start": 1190.25,
        "end": 1191.96,
        "ja_text": "諦めが早すぎじゃね"
    },
    "352": {
        "start": 1191.96,
        "end": 1193.4,
        "ja_text": "どうしたんだ"
    },
    "353": {
        "start": 1194.144,
        "end": 1194.92,
        "ja_text": "オカリン"
    },
    "354": {
        "start": 1195.86,
        "end": 1198.36,
        "ja_text": "これ以上父さんたちに迷惑はかけられない"
    },
    "355": {
        "start": 1199.26,
        "end": 1200.54,
        "ja_text": "もともとカガリの件は"
    },
    "356": {
        "start": 1200.54,
        "end": 1202.34,
        "ja_text": "あたしの責任なんだから"
    },
    "357": {
        "start": 1202.41,
        "end": 1203.74,
        "ja_text": "バカ言うなよ"
    },
    "358": {
        "start": 1203.86,
        "end": 1206.36,
        "ja_text": "子供の責任は親の責任だろ"
    },
    "359": {
        "start": 1206.36,
        "end": 1206.86,
        "ja_text": "女皇"
    },
    "360": {
        "start": 1208.3,
        "end": 1208.8,
        "ja_text": "父さん"
    },
    "361": {
        "start": 1210.82,
        "end": 1211.22,
        "ja_text": "どう"
    },
    "362": {
        "start": 1211.46,
        "end": 1214.48,
        "ja_text": "今のかなりパパっぽかった気がするんだけど"
    },
    "363": {
        "start": 1215.456,
        "end": 1216.6,
        "ja_text": "パパ大チキって"
    },
    "364": {
        "start": 1216.6,
        "end": 1218.28,
        "ja_text": "抱きついてもいいのだぜ"
    },
    "365": {
        "start": 1219.6,
        "end": 1220.6,
        "ja_text": "まあそれは置いといて"
    },
    "366": {
        "start": 1221.472,
        "end": 1223.02,
        "ja_text": "餅は餅やって言うっしょ"
    },
    "367": {
        "start": 1223.42,
        "end": 1224.64,
        "ja_text": "人探しはやっぱ"
    },
    "368": {
        "start": 1224.64,
        "end": 1227.64,
        "ja_text": "専門家に頼むのが一番だと思ったんだよね"
    },
    "369": {
        "start": 1228.512,
        "end": 1229.42,
        "ja_text": "私は反対"
    },
    "370": {
        "start": 1230.18,
        "end": 1232.16,
        "ja_text": "これ以上知らない人に知られるのは"
    },
    "371": {
        "start": 1234.06,
        "end": 1235.52,
        "ja_text": "心当たりはあるのか、ダル"
    },
    "372": {
        "start": 1236.42,
        "end": 1239.3,
        "ja_text": "ちっちっち、甘く見ないでほしいな"
    },
    "373": {
        "start": 1239.77,
        "end": 1242.3,
        "ja_text": "僕はオタだけど顔は広いのだぜ"
    },
    "374": {
        "start": 1243.04,
        "end": 1245.86,
        "ja_text": "とりあえず連絡はもう済ませてあるのさ"
    },
    "375": {
        "start": 1246.82,
        "end": 1247.18,
        "ja_text": "どう?"
    },
    "376": {
        "start": 1247.98,
        "end": 1249.22,
        "ja_text": "ちょうどドンピー"
    },
    "377": {
        "start": 1249.41,
        "end": 1251.96,
        "ja_text": "良ければすぐにでも来てくれるってさ"
    },
    "378": {
        "start": 1251.96,
        "end": 1252.8,
        "ja_text": "どうさ"
    },
    "379": {
        "start": 1253.1,
        "end": 1254.38,
        "ja_text": "ダルに任せよう"
    },
    "380": {
        "start": 1256.04,
        "end": 1258.56,
        "ja_text": "オッケー、近くまで来てるらしいんで"
    },
    "381": {
        "start": 1258.56,
        "end": 1259.76,
        "ja_text": "でこの後向かうって"
    },
    "382": {
        "start": 1259.76,
        "end": 1261.16,
        "ja_text": "また早いな"
    },
    "383": {
        "start": 1261.39,
        "end": 1262.6,
        "ja_text": "遅いよりはいいんだね"
    },
    "384": {
        "start": 1265.06,
        "end": 1266.0,
        "ja_text": "ルカコン"
    },
    "385": {
        "start": 1267.52,
        "end": 1267.86,
        "ja_text": "もしもし"
    },
    "386": {
        "start": 1268.672,
        "end": 1272.3,
        "ja_text": "あ岡部さんすみません今大丈夫ですか"
    },
    "387": {
        "start": 1272.3,
        "end": 1273.5,
        "ja_text": "どうした"
    },
    "388": {
        "start": 1274.76,
        "end": 1278.3,
        "ja_text": "あの僕岡部さんに相談したいことがあって"
    },
    "389": {
        "start": 1279.26,
        "end": 1281.2,
        "ja_text": "今から会っていただけないでしょうか"
    },
    "390": {
        "start": 1282.112,
        "end": 1282.62,
        "ja_text": "今から"
    },
    "391": {
        "start": 1283.04,
        "end": 1283.44,
        "ja_text": "はい"
    },
    "392": {
        "start": 1284.5,
        "end": 1286.82,
        "ja_text": "これからちょっと人が来ることになってて"
    },
    "393": {
        "start": 1287.648,
        "end": 1288.7,
        "ja_text": "夕方過ぎじゃダメか"
    },
    "394": {
        "start": 1289.32,
        "end": 1289.86,
        "ja_text": "すみません"
    },
    "395": {
        "start": 1290.6,
        "end": 1292.04,
        "ja_text": "この後は僕の方が"
    },
    "396": {
        "start": 1293.76,
        "end": 1295.08,
        "ja_text": "悪い後で連絡する"
    },
    "397": {
        "start": 1296.58,
        "end": 1297.62,
        "ja_text": "はい今開けます"
    },
    "398": {
        "start": 1321.88,
        "end": 1323.06,
        "ja_text": "連絡をもらった"
    },
    "399": {
        "start": 1324.46,
        "end": 1325.1,
        "ja_text": "キリュウ"
    },
    "400": {
        "start": 1325.94,
        "end": 1326.78,
        "ja_text": "モエカです"
    },
    "401": {
        "start": 1327.72,
        "end": 1328.48,
        "ja_text": "上がっても"
    },
    "402": {
        "start": 1346.82,
        "end": 1347.94,
        "ja_text": "to realize"
    },
    "403": {
        "start": 1347.94,
        "end": 1350.46,
        "ja_text": "there is peace"
    },
    "404": {
        "start": 1351.58,
        "end": 1354.02,
        "ja_text": "the truth will be lost"
    },
    "405": {
        "start": 1355.712,
        "end": 1358.86,
        "ja_text": "emptiness er"
    },
    "406": {
        "start": 1358.86,
        "end": 1360.8,
        "ja_text": "odes your heart"
    },
    "407": {
        "start": 1361.63,
        "end": 1363.04,
        "ja_text": "cause you're free"
    },
    "408": {
        "start": 1363.04,
        "end": 1366.72,
        "ja_text": "from pain and sorrow"
    },
    "409": {
        "start": 1367.38,
        "end": 1371.12,
        "ja_text": "future is just a fight"
    },
    "410": {
        "start": 1371.12,
        "end": 1373.46,
        "ja_text": "to show your ways"
    },
    "411": {
        "start": 1373.46,
        "end": 1376.84,
        "ja_text": "Wake up now, it's"
    },
    "412": {
        "start": 1376.84,
        "end": 1379.87,
        "ja_text": "time to renew souls"
    },
    "413": {
        "start": 1380.2,
        "end": 1380.74,
        "ja_text": "M"
    },
    "414": {
        "start": 1381.76,
        "end": 1385.06,
        "ja_text": "ove it up, turn"
    },
    "415": {
        "start": 1385.06,
        "end": 1386.44,
        "ja_text": "the universe"
    },
    "416": {
        "start": 1388.16,
        "end": 1391.04,
        "ja_text": "I am just a"
    },
    "417": {
        "start": 1391.04,
        "end": 1392.96,
        "ja_text": "part of a song"
    },
    "418": {
        "start": 1394.42,
        "end": 1397.64,
        "ja_text": "目には見えない歪んです"
    },
    "419": {
        "start": 1400.448,
        "end": 1405.4,
        "ja_text": "人はどこへと歩いてゆくの"
    },
    "420": {
        "start": 1408.16,
        "end": 1410.58,
        "ja_text": "The last train"
    },
    "421": {
        "start": 1428.62,
        "end": 1435.0,
        "ja_text": "ご視聴ありがとうございました"
    }
}