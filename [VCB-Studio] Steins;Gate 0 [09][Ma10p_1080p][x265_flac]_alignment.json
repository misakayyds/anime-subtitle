{
    "1": {
        "start": 14.28,
        "end": 14.94,
        "ja_text": "まゆりの生きている世界線に戻りなさい。"
    },
    "2": {
        "start": 15.02,
        "end": 16.78,
        "ja_text": "まゆりの生きている世界線に戻りなさい。"
    },
    "3": {
        "start": 32.93,
        "end": 33.32,
        "ja_text": "マユリ"
    },
    "4": {
        "start": 36.42,
        "end": 37.4,
        "ja_text": "マユリ"
    },
    "5": {
        "start": 37.4,
        "end": 38.86,
        "ja_text": "オカリン"
    },
    "6": {
        "start": 40.54,
        "end": 41.86,
        "ja_text": "気がついたのね"
    },
    "7": {
        "start": 42.52,
        "end": 43.58,
        "ja_text": "よかった王"
    },
    "8": {
        "start": 43.92,
        "end": 46.92,
        "ja_text": "いきなり倒れたときはどうしようかと思ったぜ"
    },
    "9": {
        "start": 47.62,
        "end": 48.5,
        "ja_text": "倒れた"
    },
    "10": {
        "start": 49.84,
        "end": 50.22,
        "ja_text": "俺が"
    },
    "11": {
        "start": 68.08,
        "end": 72.36,
        "ja_text": "この世界は非現実"
    },
    "12": {
        "start": 72.81,
        "end": 77.78,
        "ja_text": "ただ刷り込まれたビジョン"
    },
    "13": {
        "start": 80.24,
        "end": 84.42,
        "ja_text": "無限遠隔に価値観を今"
    },
    "14": {
        "start": 85.18,
        "end": 89.72,
        "ja_text": "上書きする変哲のない宇宙"
    },
    "15": {
        "start": 90.688,
        "end": 95.14,
        "ja_text": "傲慢な神は目に映らない"
    },
    "16": {
        "start": 95.82,
        "end": 100.4,
        "ja_text": "高速道で支配続けるならば"
    },
    "17": {
        "start": 100.4,
        "end": 104.72,
        "ja_text": "僕は僕だけは"
    },
    "18": {
        "start": 105.62,
        "end": 111.3,
        "ja_text": "奇跡的で致命的なマイノリティでいい"
    },
    "19": {
        "start": 112.22,
        "end": 113.88,
        "ja_text": "I can fly high"
    },
    "20": {
        "start": 113.88,
        "end": 116.44,
        "ja_text": "あの瞬間 あの場面が"
    },
    "21": {
        "start": 116.44,
        "end": 119.0,
        "ja_text": "君にとって特別なら"
    },
    "22": {
        "start": 119.15,
        "end": 124.48,
        "ja_text": "過去は離れてゆくものなんかじゃなくて"
    },
    "23": {
        "start": 124.48,
        "end": 127.1,
        "ja_text": "傷つくことの痛みより"
    },
    "24": {
        "start": 127.1,
        "end": 129.88,
        "ja_text": "大事な真相のすべての"
    },
    "25": {
        "start": 129.88,
        "end": 134.12,
        "ja_text": "光が今全部を生む"
    },
    "26": {
        "start": 134.94,
        "end": 137.2,
        "ja_text": "There is no God"
    },
    "27": {
        "start": 137.68,
        "end": 140.44,
        "ja_text": "Wonderful New World"
    },
    "28": {
        "start": 143.44,
        "end": 145.44,
        "ja_text": "ラボで俺と中瀬さんが"
    },
    "29": {
        "start": 146.76,
        "end": 148.44,
        "ja_text": "サンガニチで病院は開いて"
    },
    "30": {
        "start": 148.44,
        "end": 150.52,
        "ja_text": "ないし、本当に焦ったのだぜ"
    },
    "31": {
        "start": 151.72,
        "end": 152.96,
        "ja_text": "そうなのか…"
    },
    "32": {
        "start": 154.016,
        "end": 156.52,
        "ja_text": "元の世界線に戻ってきたのか…"
    },
    "33": {
        "start": 156.52,
        "end": 157.14,
        "ja_text": "はい!"
    },
    "34": {
        "start": 157.8,
        "end": 157.9,
        "ja_text": "ん?"
    },
    "35": {
        "start": 161.38,
        "end": 161.9,
        "ja_text": "マキセ・"
    },
    "36": {
        "start": 162.42,
        "end": 162.76,
        "ja_text": "クリス"
    },
    "37": {
        "start": 162.76,
        "end": 163.008,
        "ja_text": "え?"
    },
    "38": {
        "start": 164.16,
        "end": 164.46,
        "ja_text": "え?"
    },
    "39": {
        "start": 166.12,
        "end": 167.48,
        "ja_text": "マキセ・クリスを知ってるか?"
    },
    "40": {
        "start": 169.52,
        "end": 170.84,
        "ja_text": "うん、知ってるよ"
    },
    "41": {
        "start": 171.27,
        "end": 171.82,
        "ja_text": "な、あ…"
    },
    "42": {
        "start": 172.24,
        "end": 175.22,
        "ja_text": "オカリンの携帯さんの中にいる人だよね"
    },
    "43": {
        "start": 175.84,
        "end": 177.6,
        "ja_text": "アマデウスだっけ"
    },
    "44": {
        "start": 179.872,
        "end": 180.96,
        "ja_text": "驚かせるなよ"
    },
    "45": {
        "start": 182.304,
        "end": 183.54,
        "ja_text": "そういえばアマデウスは"
    },
    "46": {
        "start": 184.16,
        "end": 186.58,
        "ja_text": "乗っ取りは防いで今復旧中よ"
    },
    "47": {
        "start": 187.1,
        "end": 187.72,
        "ja_text": "だけど"
    },
    "48": {
        "start": 188.48,
        "end": 189.22,
        "ja_text": "どうかしたのか"
    },
    "49": {
        "start": 189.94,
        "end": 193.0,
        "ja_text": "マホさんのお部屋に泥棒さんが入ったんだって"
    },
    "50": {
        "start": 193.696,
        "end": 194.62,
        "ja_text": "それだけじゃないわ"
    },
    "51": {
        "start": 194.96,
        "end": 197.54,
        "ja_text": "和光のオフィスではガス爆発騒ぎがあって"
    },
    "52": {
        "start": 197.77,
        "end": 199.16,
        "ja_text": "今立ち入り禁止"
    },
    "53": {
        "start": 199.29,
        "end": 200.7,
        "ja_text": "タイミング的に"
    },
    "54": {
        "start": 201.44,
        "end": 203.64,
        "ja_text": "何者かが仕掛けたって可能性が高いか"
    },
    "55": {
        "start": 205.28,
        "end": 206.22,
        "ja_text": "犯人の心当たりは?"
    },
    "56": {
        "start": 206.98,
        "end": 207.58,
        "ja_text": "さっぱり"
    },
    "57": {
        "start": 208.22,
        "end": 209.86,
        "ja_text": "この前襲ってきた連中なのか"
    },
    "58": {
        "start": 211.16,
        "end": 212.94,
        "ja_text": "あ、気がついたんですね"
    },
    "59": {
        "start": 216.38,
        "end": 217.32,
        "ja_text": "熱は下がった?"
    },
    "60": {
        "start": 218.68,
        "end": 220.14,
        "ja_text": "うん、もう全然"
    },
    "61": {
        "start": 220.67,
        "end": 222.36,
        "ja_text": "オカリーさんももう元気そうですね"
    },
    "62": {
        "start": 222.83,
        "end": 223.04,
        "ja_text": "え、"
    },
    "63": {
        "start": 223.7,
        "end": 223.82,
        "ja_text": "ああ"
    },
    "64": {
        "start": 224.64,
        "end": 226.86,
        "ja_text": "先生は新型脳炎の可能性"
    },
    "65": {
        "start": 226.86,
        "end": 228.14,
        "ja_text": "がとか言ってるんですけど"
    },
    "66": {
        "start": 229.184,
        "end": 231.04,
        "ja_text": "もう心配ないと思うんだけどな"
    },
    "67": {
        "start": 231.76,
        "end": 233.02,
        "ja_text": "新型脳炎?"
    },
    "68": {
        "start": 233.632,
        "end": 234.98,
        "ja_text": "なんか流行ってるんだって"
    },
    "69": {
        "start": 235.648,
        "end": 237.18,
        "ja_text": "すごい熱が出るとかで"
    },
    "70": {
        "start": 237.53,
        "end": 240.66,
        "ja_text": "でもどうして同じタイミングで倒れたのかしらね"
    },
    "71": {
        "start": 241.54,
        "end": 242.96,
        "ja_text": "同時にショックを受けたとか"
    },
    "72": {
        "start": 243.07,
        "end": 245.48,
        "ja_text": "外的要因がないと考えにくいけど"
    },
    "73": {
        "start": 245.48,
        "end": 247.22,
        "ja_text": "やっぱりそう思いますよね"
    },
    "74": {
        "start": 247.808,
        "end": 248.8,
        "ja_text": "まだ言ってるの?"
    },
    "75": {
        "start": 248.9,
        "end": 249.82,
        "ja_text": "なになに?"
    },
    "76": {
        "start": 250.368,
        "end": 252.6,
        "ja_text": "楓ちゃんオカリンさんが私の運"
    },
    "77": {
        "start": 252.6,
        "end": 254.42,
        "ja_text": "命の人じゃないかって言うんだよ"
    },
    "78": {
        "start": 254.42,
        "end": 255.1,
        "ja_text": "は?"
    },
    "79": {
        "start": 256.032,
        "end": 258.54,
        "ja_text": "だって吹雪ちゃん気づいた時オ"
    },
    "80": {
        "start": 258.54,
        "end": 260.32,
        "ja_text": "カリンさんのこと気にしてたから"
    },
    "81": {
        "start": 260.96,
        "end": 263.64,
        "ja_text": "だからそれは夢の話だって言ったじゃん"
    },
    "82": {
        "start": 263.64,
        "end": 264.12,
        "ja_text": "夢?"
    },
    "83": {
        "start": 265.568,
        "end": 267.22,
        "ja_text": "ちょっとリアルな夢見ちゃって"
    },
    "84": {
        "start": 268.48,
        "end": 269.84,
        "ja_text": "そのマユシーが"
    },
    "85": {
        "start": 271.22,
        "end": 274.14,
        "ja_text": "夢だよあくまで夢の中でだけど"
    },
    "86": {
        "start": 275.1,
        "end": 276.6,
        "ja_text": "マユシーがいなくなってて"
    },
    "87": {
        "start": 277.28,
        "end": 279.46,
        "ja_text": "私はフェイリスさんのカフェにいるのね"
    },
    "88": {
        "start": 280.384,
        "end": 282.7,
        "ja_text": "するとそこにオカリンさんが来て"
    },
    "89": {
        "start": 284.15,
        "end": 286.01,
        "ja_text": "アルファ世界戦の記憶"
    },
    "90": {
        "start": 286.976,
        "end": 288.8,
        "ja_text": "まさかリーディングシュタイナーを"
    },
    "91": {
        "start": 289.66,
        "end": 293.02,
        "ja_text": "うーんまあ異常も見られないよう"
    },
    "92": {
        "start": 293.02,
        "end": 294.98,
        "ja_text": "ですし経過観察でいいでしょう"
    },
    "93": {
        "start": 295.56,
        "end": 297.44,
        "ja_text": "来週もう一度来てください"
    },
    "94": {
        "start": 298.36,
        "end": 298.76,
        "ja_text": "はい"
    },
    "95": {
        "start": 300.7,
        "end": 303.04,
        "ja_text": "退院できてよかったねオカリン"
    },
    "96": {
        "start": 303.56,
        "end": 305.98,
        "ja_text": "フブキちゃんはもう少しかかるみたいだけど"
    },
    "97": {
        "start": 307.32,
        "end": 309.72,
        "ja_text": "大丈夫元気そうだし心配ないよ"
    },
    "98": {
        "start": 309.72,
        "end": 311.88,
        "ja_text": "そうかなそうだよね"
    },
    "99": {
        "start": 311.88,
        "end": 315.64,
        "ja_text": "オカベさんなぜさっきクリスの名前を"
    },
    "100": {
        "start": 317.52,
        "end": 318.48,
        "ja_text": "いやちょっとな"
    },
    "101": {
        "start": 321.26,
        "end": 322.46,
        "ja_text": "夢を見ていたんだ"
    },
    "102": {
        "start": 323.4,
        "end": 323.76,
        "ja_text": "夢"
    },
    "103": {
        "start": 326.26,
        "end": 327.74,
        "ja_text": "そういえば橋田さんは"
    },
    "104": {
        "start": 328.28,
        "end": 330.44,
        "ja_text": "あだるくんはねちょっと用"
    },
    "105": {
        "start": 330.44,
        "end": 332.192,
        "ja_text": "事があるから先に行くって"
    },
    "106": {
        "start": 333.52,
        "end": 333.632,
        "ja_text": "それで"
    },
    "107": {
        "start": 336.9,
        "end": 338.96,
        "ja_text": "うんオカリンはどこにも異常"
    },
    "108": {
        "start": 338.96,
        "end": 340.672,
        "ja_text": "なかったから退院になったって"
    },
    "109": {
        "start": 340.97,
        "end": 343.22,
        "ja_text": "オカリンおじさんたちが襲撃されて"
    },
    "110": {
        "start": 343.84,
        "end": 345.06,
        "ja_text": "2人が同時に倒れて"
    },
    "111": {
        "start": 345.824,
        "end": 347.68,
        "ja_text": "意識が戻った時の様子は"
    },
    "112": {
        "start": 347.82,
        "end": 350.32,
        "ja_text": "特に変わった様子はなかったけど"
    },
    "113": {
        "start": 351.44,
        "end": 352.5,
        "ja_text": "名前言ってた"
    },
    "114": {
        "start": 352.79,
        "end": 353.88,
        "ja_text": "マキセ氏の"
    },
    "115": {
        "start": 354.64,
        "end": 355.06,
        "ja_text": "マキセ"
    },
    "116": {
        "start": 358.14,
        "end": 358.88,
        "ja_text": "じゃあね"
    },
    "117": {
        "start": 359.58,
        "end": 359.968,
        "ja_text": "うん"
    },
    "118": {
        "start": 360.7,
        "end": 361.88,
        "ja_text": "後で連絡するね"
    },
    "119": {
        "start": 364.08,
        "end": 365.22,
        "ja_text": "はいコーヒー"
    },
    "120": {
        "start": 365.98,
        "end": 366.38,
        "ja_text": "ありがとう"
    },
    "121": {
        "start": 367.66,
        "end": 368.46,
        "ja_text": "考えてみたら"
    },
    "122": {
        "start": 369.06,
        "end": 370.64,
        "ja_text": "ホテルに泥棒は入るわ"
    },
    "123": {
        "start": 370.64,
        "end": 371.98,
        "ja_text": "ぼや騒ぎはあるわで"
    },
    "124": {
        "start": 372.68,
        "end": 374.56,
        "ja_text": "ゆうべから何も口にしてないわね"
    },
    "125": {
        "start": 375.54,
        "end": 377.74,
        "ja_text": "唐揚げとバナナくらいしかないけど"
    },
    "126": {
        "start": 378.34,
        "end": 380.34,
        "ja_text": "あ、お弁当買ってこようか?"
    },
    "127": {
        "start": 380.84,
        "end": 381.2,
        "ja_text": "大丈夫"
    },
    "128": {
        "start": 381.82,
        "end": 384.16,
        "ja_text": "ホテル戻ってから食べるから"
    },
    "129": {
        "start": 385.216,
        "end": 385.8,
        "ja_text": "戻るの?"
    },
    "130": {
        "start": 387.66,
        "end": 389.44,
        "ja_text": "教授にも同じこと言われた"
    },
    "131": {
        "start": 389.66,
        "end": 391.78,
        "ja_text": "ホテル変えた方がいいんじゃないかって"
    },
    "132": {
        "start": 392.672,
        "end": 393.98,
        "ja_text": "その方が安全だろうな"
    },
    "133": {
        "start": 394.84,
        "end": 396.9,
        "ja_text": "でも、あてがあるわけじゃないし"
    },
    "134": {
        "start": 397.824,
        "end": 398.18,
        "ja_text": "ここは?"
    },
    "135": {
        "start": 399.5,
        "end": 401.06,
        "ja_text": "さすがにそれは悪いわ"
    },
    "136": {
        "start": 402.336,
        "end": 404.34,
        "ja_text": "それにここも襲撃を受けているしな"
    },
    "137": {
        "start": 405.28,
        "end": 405.82,
        "ja_text": "安全とは"
    },
    "138": {
        "start": 415.34,
        "end": 416.32,
        "ja_text": "収穫なしか"
    },
    "139": {
        "start": 416.86,
        "end": 417.248,
        "ja_text": "そう"
    },
    "140": {
        "start": 420.98,
        "end": 422.48,
        "ja_text": "どこから現れた"
    },
    "141": {
        "start": 423.94,
        "end": 425.74,
        "ja_text": "オカリンお客さん"
    },
    "142": {
        "start": 428.16,
        "end": 429.24,
        "ja_text": "いつの間に"
    },
    "143": {
        "start": 437.38,
        "end": 438.24,
        "ja_text": "ずっといたのか"
    },
    "144": {
        "start": 439.06,
        "end": 439.46,
        "ja_text": "いた"
    },
    "145": {
        "start": 452.42,
        "end": 455.18,
        "ja_text": "どうしたの黙って迎え合って"
    },
    "146": {
        "start": 456.02,
        "end": 456.42,
        "ja_text": "いや"
    },
    "147": {
        "start": 456.42,
        "end": 456.98,
        "ja_text": "あ、いや…"
    },
    "148": {
        "start": 464.544,
        "end": 465.38,
        "ja_text": "コーヒー!"
    },
    "149": {
        "start": 465.7,
        "end": 466.28,
        "ja_text": "あれ?"
    },
    "150": {
        "start": 467.08,
        "end": 469.12,
        "ja_text": "お客さん もう帰っちゃったの?"
    },
    "151": {
        "start": 469.92,
        "end": 472.22,
        "ja_text": "せっかく入れたのにな コーヒー…"
    },
    "152": {
        "start": 473.376,
        "end": 474.32,
        "ja_text": "戻ってきたんだ"
    },
    "153": {
        "start": 476.72,
        "end": 477.04,
        "ja_text": "俺は"
    },
    "154": {
        "start": 478.06,
        "end": 479.04,
        "ja_text": "この世界線を…"
    },
    "155": {
        "start": 480.2,
        "end": 482.46,
        "ja_text": "マユリが殺されない 世界線を守る"
    },
    "156": {
        "start": 483.55,
        "end": 485.42,
        "ja_text": "タイムマシンを使わず 守るんだ"
    },
    "157": {
        "start": 486.944,
        "end": 488.76,
        "ja_text": "それがあいつの願いでもあるはずだ"
    },
    "158": {
        "start": 490.688,
        "end": 491.34,
        "ja_text": "それしかない"
    },
    "159": {
        "start": 494.34,
        "end": 494.98,
        "ja_text": "日矢嬢さん"
    },
    "160": {
        "start": 496.14,
        "end": 499.18,
        "ja_text": "ホテルについては一度預けてくれないか?"
    },
    "161": {
        "start": 500.512,
        "end": 501.22,
        "ja_text": "心当たりがある"
    },
    "162": {
        "start": 502.9,
        "end": 504.82,
        "ja_text": "それでみんなで家に来たのかにゃ?"
    },
    "163": {
        "start": 506.46,
        "end": 508.34,
        "ja_text": "ああ、ここに滞在させてもらうのが"
    },
    "164": {
        "start": 508.34,
        "end": 510.24,
        "ja_text": "最善なんじゃないかって話になってな"
    },
    "165": {
        "start": 510.84,
        "end": 511.66,
        "ja_text": "急すぎるわ、"
    },
    "166": {
        "start": 512.58,
        "end": 514.04,
        "ja_text": "無理言ってるのは分かってるから"
    },
    "167": {
        "start": 514.04,
        "end": 516.42,
        "ja_text": "フェリスは全く問題なしにゃん"
    },
    "168": {
        "start": 516.992,
        "end": 517.62,
        "ja_text": "だよね"
    },
    "169": {
        "start": 518.76,
        "end": 520.7,
        "ja_text": "だから言ったでしょフェリスちゃん"
    },
    "170": {
        "start": 520.7,
        "end": 522.7,
        "ja_text": "は絶対いいって言ってくれるって"
    },
    "171": {
        "start": 522.88,
        "end": 524.88,
        "ja_text": "奥の客間を使うといいにゃん"
    },
    "172": {
        "start": 524.88,
        "end": 526.72,
        "ja_text": "数日と言わずマホニャンが"
    },
    "173": {
        "start": 526.72,
        "end": 528.98,
        "ja_text": "日本に滞在している間ずっと"
    },
    "174": {
        "start": 530.08,
        "end": 530.96,
        "ja_text": "マホニャン"
    },
    "175": {
        "start": 530.96,
        "end": 533.68,
        "ja_text": "うちにはクロキもいるからとっても安全にゃん"
    },
    "176": {
        "start": 533.68,
        "end": 534.28,
        "ja_text": "クロキ"
    },
    "177": {
        "start": 534.28,
        "end": 536.74,
        "ja_text": "そうそうこっちにゃん一緒に来るにゃん"
    },
    "178": {
        "start": 538.112,
        "end": 539.12,
        "ja_text": "これで安全だね"
    },
    "179": {
        "start": 540.62,
        "end": 542.84,
        "ja_text": "それでカガリはルカコのところにいるんだな"
    },
    "180": {
        "start": 542.94,
        "end": 545.78,
        "ja_text": "うんさっき聞いたから間違いないよ"
    },
    "181": {
        "start": 546.3,
        "end": 547.68,
        "ja_text": "あまり外に出ないように"
    },
    "182": {
        "start": 547.68,
        "end": 549.632,
        "ja_text": "してるから心配しないでって"
    },
    "183": {
        "start": 552.3,
        "end": 554.2,
        "ja_text": "とりあえず撃てる手は撃った"
    },
    "184": {
        "start": 555.6,
        "end": 558.98,
        "ja_text": "あとはラボを襲った犯人とその目的が分かれば"
    },
    "185": {
        "start": 561.376,
        "end": 561.96,
        "ja_text": "鈴葉"
    },
    "186": {
        "start": 579.5,
        "end": 579.7,
        "ja_text": "鈴葉"
    },
    "187": {
        "start": 581.22,
        "end": 582.06,
        "ja_text": "ここだよ"
    },
    "188": {
        "start": 584.16,
        "end": 586.64,
        "ja_text": "悪かったね こんなところに呼び出しちゃって"
    },
    "189": {
        "start": 587.84,
        "end": 588.56,
        "ja_text": "話とはなんだ"
    },
    "190": {
        "start": 589.76,
        "end": 593.14,
        "ja_text": "私はなんていうか 話の駆け引きとか苦手でさ"
    },
    "191": {
        "start": 594.56,
        "end": 596.88,
        "ja_text": "悪いけど単刀直入に聞かせてもらう"
    },
    "192": {
        "start": 597.4,
        "end": 597.76,
        "ja_text": "なんだ"
    },
    "193": {
        "start": 598.88,
        "end": 600.64,
        "ja_text": "世界線は変わってしまったの"
    },
    "194": {
        "start": 606.5,
        "end": 607.84,
        "ja_text": "どうしてそう思う"
    },
    "195": {
        "start": 608.44,
        "end": 611.26,
        "ja_text": "今の状況と以前オカリンおじさんから聞"
    },
    "196": {
        "start": 611.26,
        "end": 613.2,
        "ja_text": "いたリーディングシュタイナーの話から"
    },
    "197": {
        "start": 614.0,
        "end": 615.14,
        "ja_text": "聞いてどうする"
    },
    "198": {
        "start": 618.96,
        "end": 622.02,
        "ja_text": "私にとってそれはとても大きなことなの"
    },
    "199": {
        "start": 623.66,
        "end": 624.24,
        "ja_text": "セザ"
    },
    "200": {
        "start": 626.12,
        "end": 628.44,
        "ja_text": "答えてこれは命令だ"
    },
    "201": {
        "start": 628.75,
        "end": 629.96,
        "ja_text": "オカベリンタロウ"
    },
    "202": {
        "start": 637.5,
        "end": 638.34,
        "ja_text": "もう一度聞く"
    },
    "203": {
        "start": 639.32,
        "end": 640.82,
        "ja_text": "世界線は変動したのか"
    },
    "204": {
        "start": 641.88,
        "end": 644.14,
        "ja_text": "ここはもう以前とは違う世界線なの"
    },
    "205": {
        "start": 645.44,
        "end": 646.0,
        "ja_text": "大丈夫だ"
    },
    "206": {
        "start": 646.9,
        "end": 648.92,
        "ja_text": "俺たちは以前のままの世界線にいる"
    },
    "207": {
        "start": 649.696,
        "end": 650.26,
        "ja_text": "本当に"
    },
    "208": {
        "start": 650.26,
        "end": 650.432,
        "ja_text": "ああ"
    },
    "209": {
        "start": 651.86,
        "end": 654.06,
        "ja_text": "一度別の世界線に移動したのは事実だが"
    },
    "210": {
        "start": 654.86,
        "end": 656.2,
        "ja_text": "再び戻ったはずだ"
    },
    "211": {
        "start": 656.48,
        "end": 658.44,
        "ja_text": "やっぱり変動はあったんだ"
    },
    "212": {
        "start": 659.04,
        "end": 661.0,
        "ja_text": "原因は俺にはわからない"
    },
    "213": {
        "start": 661.92,
        "end": 662.64,
        "ja_text": "地震、"
    },
    "214": {
        "start": 663.4,
        "end": 663.98,
        "ja_text": "ロシアの"
    },
    "215": {
        "start": 663.98,
        "end": 666.88,
        "ja_text": "あれは核実験なんかじゃない"
    },
    "216": {
        "start": 667.45,
        "end": 670.46,
        "ja_text": "ロシアとアメリカのタイムマシン開発競争"
    },
    "217": {
        "start": 671.76,
        "end": 675.84,
        "ja_text": "そして最終的に訪れる第三次世界大戦の始まり"
    },
    "218": {
        "start": 677.312,
        "end": 679.0,
        "ja_text": "ロシアとアメリカ"
    },
    "219": {
        "start": 679.92,
        "end": 683.16,
        "ja_text": "あの発音通貨言い方はフォネティックコードだ"
    },
    "220": {
        "start": 683.38,
        "end": 684.98,
        "ja_text": "フォネティックコード"
    },
    "221": {
        "start": 685.66,
        "end": 686.84,
        "ja_text": "軍隊用語だよ"
    },
    "222": {
        "start": 687.648,
        "end": 689.4,
        "ja_text": "それも西側のな"
    },
    "223": {
        "start": 690.2,
        "end": 691.26,
        "ja_text": "そういうことか"
    },
    "224": {
        "start": 692.1,
        "end": 692.92,
        "ja_text": "それであの時"
    },
    "225": {
        "start": 697.6,
        "end": 698.5,
        "ja_text": "私はバカだ"
    },
    "226": {
        "start": 699.296,
        "end": 700.56,
        "ja_text": "悩んでいる場合じゃなかった"
    },
    "227": {
        "start": 700.98,
        "end": 702.5,
        "ja_text": "もう言うよなんてないんだ"
    },
    "228": {
        "start": 703.136,
        "end": 703.92,
        "ja_text": "どうするつもりだ"
    },
    "229": {
        "start": 704.64,
        "end": 707.4,
        "ja_text": "私と一緒に7月28日へ行くんだ"
    },
    "230": {
        "start": 708.416,
        "end": 709.02,
        "ja_text": "拒否したら"
    },
    "231": {
        "start": 709.888,
        "end": 710.92,
        "ja_text": "拒否なんかさせない"
    },
    "232": {
        "start": 712.38,
        "end": 714.72,
        "ja_text": "もうタイムマシンの実験は始まっているんだ"
    },
    "233": {
        "start": 715.44,
        "end": 717.16,
        "ja_text": "そのせいで世界線が変動して"
    },
    "234": {
        "start": 717.35,
        "end": 719.6,
        "ja_text": "シュタインズゲートへの道が閉ざされたら"
    },
    "235": {
        "start": 721.18,
        "end": 722.68,
        "ja_text": "もう閉ざされてるとしたら"
    },
    "236": {
        "start": 723.58,
        "end": 724.46,
        "ja_text": "どちらかを"
    },
    "237": {
        "start": 725.54,
        "end": 728.28,
        "ja_text": "どちらかの世界線を選ぶしかないのだとしたら"
    },
    "238": {
        "start": 729.38,
        "end": 730.68,
        "ja_text": "お前はこの世界線を"
    },
    "239": {
        "start": 730.68,
        "end": 732.48,
        "ja_text": "なかったことにしていいのか"
    },
    "240": {
        "start": 732.48,
        "end": 733.36,
        "ja_text": "うるさい"
    },
    "241": {
        "start": 748.544,
        "end": 749.2,
        "ja_text": "スズハ"
    },
    "242": {
        "start": 750.38,
        "end": 751.5,
        "ja_text": "次は当てる"
    },
    "243": {
        "start": 756.2,
        "end": 756.56,
        "ja_text": "お願い"
    },
    "244": {
        "start": 765.504,
        "end": 766.7,
        "ja_text": "2010年7月"
    },
    "245": {
        "start": 767.68,
        "end": 770.12,
        "ja_text": "俺は電話レンジかっこ借りを使って"
    },
    "246": {
        "start": 770.28,
        "end": 772.36,
        "ja_text": "メールを過去に送れることに気づいた"
    },
    "247": {
        "start": 773.536,
        "end": 774.14,
        "ja_text": "しかしそれは"
    },
    "248": {
        "start": 774.14,
        "end": 776.62,
        "ja_text": "俺は世界線を変えることに他ならなかった"
    },
    "249": {
        "start": 777.34,
        "end": 779.14,
        "ja_text": "変わった世界線を戻すために"
    },
    "250": {
        "start": 779.14,
        "end": 781.42,
        "ja_text": "俺は数多くの思いを踏みにじった"
    },
    "251": {
        "start": 783.22,
        "end": 785.12,
        "ja_text": "一度起きたことをなかったことにしたんだ"
    },
    "252": {
        "start": 786.52,
        "end": 788.18,
        "ja_text": "数多くの思いと犠牲のもとに"
    },
    "253": {
        "start": 788.43,
        "end": 790.74,
        "ja_text": "俺はやっとこの世界線にたどり着いた"
    },
    "254": {
        "start": 794.14,
        "end": 795.78,
        "ja_text": "今、あの夏に戻ったとして"
    },
    "255": {
        "start": 796.48,
        "end": 798.28,
        "ja_text": "あるのはあの悪夢の繰り返しだ"
    },
    "256": {
        "start": 798.72,
        "end": 801.08,
        "ja_text": "だからって今の世界線のままでいいの?"
    },
    "257": {
        "start": 801.47,
        "end": 804.66,
        "ja_text": "第3次世界大戦が起きてたくさんの人が死ぬ"
    },
    "258": {
        "start": 805.24,
        "end": 806.4,
        "ja_text": "何も回避できない"
    },
    "259": {
        "start": 806.4,
        "end": 808.28,
        "ja_text": "それがこの世界線なんだ"
    },
    "260": {
        "start": 808.56,
        "end": 811.04,
        "ja_text": "今より状況が悪くなったらどうする"
    },
    "261": {
        "start": 811.94,
        "end": 812.3,
        "ja_text": "それは"
    },
    "262": {
        "start": 813.152,
        "end": 814.56,
        "ja_text": "世界線移動を繰り返した末"
    },
    "263": {
        "start": 814.8,
        "end": 817.24,
        "ja_text": "さらに絶望的な未来しか待ってい"
    },
    "264": {
        "start": 817.24,
        "end": 819.32,
        "ja_text": "ない世界線にたどり着いたらどうする"
    },
    "265": {
        "start": 821.536,
        "end": 823.18,
        "ja_text": "世界線を変えることはできても"
    },
    "266": {
        "start": 824.42,
        "end": 826.16,
        "ja_text": "未来を操ることはできないんだ"
    },
    "267": {
        "start": 828.768,
        "end": 829.14,
        "ja_text": "鈴葉"
    },
    "268": {
        "start": 831.08,
        "end": 831.88,
        "ja_text": "父さん"
    },
    "269": {
        "start": 833.088,
        "end": 834.84,
        "ja_text": "こんなことだろうと思ったけど"
    },
    "270": {
        "start": 836.32,
        "end": 837.24,
        "ja_text": "その銃は何"
    },
    "271": {
        "start": 838.33,
        "end": 839.98,
        "ja_text": "父さんだって分かるでしょ"
    },
    "272": {
        "start": 840.52,
        "end": 841.86,
        "ja_text": "もう時間がないんだ"
    },
    "273": {
        "start": 842.64,
        "end": 844.64,
        "ja_text": "このままじゃ第三次世界大戦が"
    },
    "274": {
        "start": 844.94,
        "end": 847.4,
        "ja_text": "でも無理やりオカリン連れてったからって"
    },
    "275": {
        "start": 847.73,
        "end": 848.88,
        "ja_text": "それでうまくいくわけ"
    },
    "276": {
        "start": 850.24,
        "end": 850.64,
        "ja_text": "それは"
    },
    "277": {
        "start": 851.72,
        "end": 854.98,
        "ja_text": "タイムマシンや世界戦のことを勉強し始めて"
    },
    "278": {
        "start": 854.98,
        "end": 856.68,
        "ja_text": "分かってきたんだよね"
    },
    "279": {
        "start": 857.7,
        "end": 860.256,
        "ja_text": "インガ率や世界線をコントロールするって"
    },
    "280": {
        "start": 860.288,
        "end": 861.856,
        "ja_text": "そう簡単じゃないって"
    },
    "281": {
        "start": 861.888,
        "end": 863.7,
        "ja_text": "じゃあどうしろって"
    },
    "282": {
        "start": 864.608,
        "end": 866.84,
        "ja_text": "それを僕らは研究してるわけっしょ"
    },
    "283": {
        "start": 868.26,
        "end": 869.06,
        "ja_text": "父さん"
    },
    "284": {
        "start": 869.25,
        "end": 871.5,
        "ja_text": "たまには父さんの言うことを"
    },
    "285": {
        "start": 871.5,
        "end": 873.62,
        "ja_text": "素直に聞いてほしいのだぜ"
    },
    "286": {
        "start": 875.72,
        "end": 876.8,
        "ja_text": "任せておけって"
    },
    "287": {
        "start": 877.36,
        "end": 879.16,
        "ja_text": "絶対に何とかしてみせる"
    },
    "288": {
        "start": 879.4,
        "end": 882.26,
        "ja_text": "何しろ僕はスーパーハッカーなのだぜ"
    },
    "289": {
        "start": 889.29,
        "end": 891.9,
        "ja_text": "私どうしていいか分かんない"
    },
    "290": {
        "start": 892.15,
        "end": 893.86,
        "ja_text": "分かんなくなっちゃった"
    },
    "291": {
        "start": 893.86,
        "end": 895.44,
        "ja_text": "うん"
    },
    "292": {
        "start": 895.44,
        "end": 897.24,
        "ja_text": "助けて"
    },
    "293": {
        "start": 897.24,
        "end": 898.5,
        "ja_text": "父さん"
    },
    "294": {
        "start": 898.5,
        "end": 899.46,
        "ja_text": "助けて"
    },
    "295": {
        "start": 902.46,
        "end": 902.66,
        "ja_text": "ねえ"
    },
    "296": {
        "start": 903.38,
        "end": 904.22,
        "ja_text": "父さん"
    },
    "297": {
        "start": 904.22,
        "end": 906.26,
        "ja_text": "助けて"
    },
    "298": {
        "start": 906.26,
        "end": 908.54,
        "ja_text": "父さん"
    },
    "299": {
        "start": 916.16,
        "end": 917.8,
        "ja_text": "第3次世界大戦"
    },
    "300": {
        "start": 921.06,
        "end": 922.52,
        "ja_text": "今ある情報を使って"
    },
    "301": {
        "start": 923.33,
        "end": 925.0,
        "ja_text": "タイムマシンを使わずに"
    },
    "302": {
        "start": 925.8,
        "end": 927.6,
        "ja_text": "未来を変えることはできないのか"
    },
    "303": {
        "start": 928.84,
        "end": 929.42,
        "ja_text": "難題ね"
    },
    "304": {
        "start": 935.6,
        "end": 938.42,
        "ja_text": "でも全てを不可能だと片付けてしまうのは"
    },
    "305": {
        "start": 938.88,
        "end": 939.78,
        "ja_text": "科学者失格ね"
    },
    "306": {
        "start": 942.912,
        "end": 945.26,
        "ja_text": "そう言うよな、お前なら"
    },
    "307": {
        "start": 953.34,
        "end": 954.74,
        "ja_text": "おう、なんだ、"
    },
    "308": {
        "start": 955.56,
        "end": 956.8,
        "ja_text": "家賃待ってくださいなら"
    },
    "309": {
        "start": 956.8,
        "end": 958.26,
        "ja_text": "この前の話の続きを"
    },
    "310": {
        "start": 964.08,
        "end": 964.94,
        "ja_text": "おめえ、"
    },
    "311": {
        "start": 967.1,
        "end": 967.54,
        "ja_text": "マジか"
    },
    "312": {
        "start": 968.18,
        "end": 968.66,
        "ja_text": "はい"
    },
    "313": {
        "start": 974.02,
        "end": 974.4,
        "ja_text": "さあな"
    },
    "314": {
        "start": 975.28,
        "end": 976.94,
        "ja_text": "あれだけじゃ何も分からねえよ"
    },
    "315": {
        "start": 977.536,
        "end": 979.4,
        "ja_text": "そのフォネティックコードを使って"
    },
    "316": {
        "start": 979.4,
        "end": 980.98,
        "ja_text": "いる組織というだけでもいいんです"
    },
    "317": {
        "start": 981.28,
        "end": 984.14,
        "ja_text": "そりゃ西側ってだけで5万とある"
    },
    "318": {
        "start": 985.28,
        "end": 985.64,
        "ja_text": "ただな"
    },
    "319": {
        "start": 986.1,
        "end": 986.46,
        "ja_text": "ただ"
    },
    "320": {
        "start": 987.44,
        "end": 989.7,
        "ja_text": "公に名前が出ているようなところが"
    },
    "321": {
        "start": 990.14,
        "end": 992.64,
        "ja_text": "あんな連中を送り込んでくるとは考えにくい"
    },
    "322": {
        "start": 993.26,
        "end": 996.22,
        "ja_text": "やるとしたら表に名前が出てないようなところか"
    },
    "323": {
        "start": 996.76,
        "end": 999.0,
        "ja_text": "もしくは表面上そんなやばいことは"
    },
    "324": {
        "start": 999.0,
        "end": 1000.84,
        "ja_text": "やってないことになっている組織だ"
    },
    "325": {
        "start": 1001.38,
        "end": 1001.74,
        "ja_text": "例えば"
    },
    "326": {
        "start": 1002.62,
        "end": 1004.22,
        "ja_text": "そこまで言わせるのかよ"
    },
    "327": {
        "start": 1006.86,
        "end": 1007.54,
        "ja_text": "まあいい"
    },
    "328": {
        "start": 1007.75,
        "end": 1010.28,
        "ja_text": "おめえが知っといて俺に損はねえしな"
    },
    "329": {
        "start": 1011.46,
        "end": 1011.8,
        "ja_text": "正直"
    },
    "330": {
        "start": 1011.98,
        "end": 1015.12,
        "ja_text": "おめえのこの前の話が全部本当だと"
    },
    "331": {
        "start": 1015.12,
        "end": 1017.2,
        "ja_text": "仮定した上で考えると"
    },
    "332": {
        "start": 1019.78,
        "end": 1020.14,
        "ja_text": "ダーパ"
    },
    "333": {
        "start": 1021.0,
        "end": 1023.24,
        "ja_text": "国防高度研究開発局"
    },
    "334": {
        "start": 1024.04,
        "end": 1025.78,
        "ja_text": "国防省内に作られた"
    },
    "335": {
        "start": 1025.84,
        "end": 1028.16,
        "ja_text": "軍事研究統括機関の一つ"
    },
    "336": {
        "start": 1029.856,
        "end": 1030.44,
        "ja_text": "ストラト4"
    },
    "337": {
        "start": 1030.44,
        "end": 1034.18,
        "ja_text": "そう、アメリカの民間シンクタンク、影の"
    },
    "338": {
        "start": 1034.18,
        "end": 1037.18,
        "ja_text": "CIAとも呼ばれ、後の大規模テロを予言"
    },
    "339": {
        "start": 1038.52,
        "end": 1040.7,
        "ja_text": "ロシアのタイムマシン開発の元は、"
    },
    "340": {
        "start": 1042.144,
        "end": 1043.52,
        "ja_text": "中鉢博士の論文"
    },
    "341": {
        "start": 1044.14,
        "end": 1045.94,
        "ja_text": "まさかパパ、盗むの?"
    },
    "342": {
        "start": 1047.42,
        "end": 1049.04,
        "ja_text": "この情報を掴んだアメリカは、"
    },
    "343": {
        "start": 1050.3,
        "end": 1051.14,
        "ja_text": "データを求めて"
    },
    "344": {
        "start": 1051.7,
        "end": 1053.12,
        "ja_text": "マキセ・クリスにたどり着いた"
    },
    "345": {
        "start": 1055.36,
        "end": 1057.88,
        "ja_text": "でもビクトルコンドリア大学の研究施設は"
    },
    "346": {
        "start": 1058.62,
        "end": 1059.76,
        "ja_text": "その気になればいくらでも"
    },
    "347": {
        "start": 1059.76,
        "end": 1060.82,
        "ja_text": "調べられるはずじゃない"
    },
    "348": {
        "start": 1061.66,
        "end": 1063.48,
        "ja_text": "わざわざここまで来た理由は"
    },
    "349": {
        "start": 1064.26,
        "end": 1067.18,
        "ja_text": "ラボを襲撃したときはカガリが狙いだった"
    },
    "350": {
        "start": 1067.86,
        "end": 1069.52,
        "ja_text": "カガリが未来から来ているから"
    },
    "351": {
        "start": 1071.08,
        "end": 1072.96,
        "ja_text": "彼女が乗ってきたタイムマシンを探している"
    },
    "352": {
        "start": 1073.76,
        "end": 1075.0,
        "ja_text": "仮にそうだとしてもタイ"
    },
    "353": {
        "start": 1075.0,
        "end": 1076.2,
        "ja_text": "ムマシンは見つからないわ"
    },
    "354": {
        "start": 1076.29,
        "end": 1077.02,
        "ja_text": "なぜだ"
    },
    "355": {
        "start": 1077.72,
        "end": 1079.7,
        "ja_text": "タイムマシン開発が未来のタ"
    },
    "356": {
        "start": 1079.7,
        "end": 1081.28,
        "ja_text": "イムマシンを元に行われれば"
    },
    "357": {
        "start": 1081.43,
        "end": 1083.62,
        "ja_text": "強力なタイムパラドックスが発生する"
    },
    "358": {
        "start": 1084.22,
        "end": 1085.06,
        "ja_text": "実現はしない"
    },
    "359": {
        "start": 1085.8,
        "end": 1086.54,
        "ja_text": "となると"
    },
    "360": {
        "start": 1086.6,
        "end": 1089.12,
        "ja_text": "マホさんのお部屋に泥棒さんが"
    },
    "361": {
        "start": 1090.12,
        "end": 1091.14,
        "ja_text": "それだけじゃないわ"
    },
    "362": {
        "start": 1091.52,
        "end": 1092.64,
        "ja_text": "和光のオフィスでは"
    },
    "363": {
        "start": 1093.22,
        "end": 1094.6,
        "ja_text": "ガス爆発騒ぎがあって"
    },
    "364": {
        "start": 1097.78,
        "end": 1098.86,
        "ja_text": "そういうことか"
    },
    "365": {
        "start": 1100.9,
        "end": 1101.28,
        "ja_text": "僕さ"
    },
    "366": {
        "start": 1102.32,
        "end": 1103.84,
        "ja_text": "いつか必ずオカリンは"
    },
    "367": {
        "start": 1103.86,
        "end": 1105.8,
        "ja_text": "僕らの先頭に立って"
    },
    "368": {
        "start": 1105.8,
        "end": 1108.62,
        "ja_text": "指揮を取ってくれるって信じてるんだよね"
    },
    "369": {
        "start": 1109.84,
        "end": 1110.9,
        "ja_text": "今何時"
    },
    "370": {
        "start": 1111.98,
        "end": 1113.44,
        "ja_text": "もうすぐ日付が変わる"
    },
    "371": {
        "start": 1115.136,
        "end": 1115.92,
        "ja_text": "乗ってくれるかな"
    },
    "372": {
        "start": 1117.55,
        "end": 1118.94,
        "ja_text": "オカリンおじさん"
    },
    "373": {
        "start": 1119.85,
        "end": 1120.9,
        "ja_text": "タイムマシンに"
    },
    "374": {
        "start": 1122.976,
        "end": 1124.66,
        "ja_text": "その時が来たらきっとね"
    },
    "375": {
        "start": 1126.3,
        "end": 1129.04,
        "ja_text": "同時に法王院凶魔も復活するわけ"
    },
    "376": {
        "start": 1129.66,
        "end": 1131.64,
        "ja_text": "不死鳥の名は伊達じゃない的な"
    },
    "377": {
        "start": 1131.84,
        "end": 1133.68,
        "ja_text": "中二病を打つ的な"
    },
    "378": {
        "start": 1134.432,
        "end": 1136.78,
        "ja_text": "だって未来ガジェット研究所"
    },
    "379": {
        "start": 1136.78,
        "end": 1138.6,
        "ja_text": "はオカリンがいてこそだから"
    },
    "380": {
        "start": 1139.88,
        "end": 1141.94,
        "ja_text": "父さん、すごく恥ずかしい"
    },
    "381": {
        "start": 1141.94,
        "end": 1143.52,
        "ja_text": "こと言ってるの、自覚してる?"
    },
    "382": {
        "start": 1143.9,
        "end": 1145.9,
        "ja_text": "うは、ですよね。"
    },
    "383": {
        "start": 1147.0,
        "end": 1149.46,
        "ja_text": "オカリンには口が裂けても言えないな。"
    },
    "384": {
        "start": 1152.12,
        "end": 1153.56,
        "ja_text": "私、手紙を書くよ。"
    },
    "385": {
        "start": 1154.4,
        "end": 1156.26,
        "ja_text": "オカリンおじさんにごめんなさいって言"
    },
    "386": {
        "start": 1156.26,
        "end": 1158.72,
        "ja_text": "うのと、もうちょっと足掻いてみるって。"
    },
    "387": {
        "start": 1160.2,
        "end": 1161.06,
        "ja_text": "いいと思われ。"
    },
    "388": {
        "start": 1161.56,
        "end": 1163.68,
        "ja_text": "ついでにパパにも手紙プレイズ。"
    },
    "389": {
        "start": 1164.32,
        "end": 1165.68,
        "ja_text": "できれば写真付きで。"
    },
    "390": {
        "start": 1166.6,
        "end": 1167.72,
        "ja_text": "気が向いたらね。"
    },
    "391": {
        "start": 1168.48,
        "end": 1171.0,
        "ja_text": "なにその絶望感しかないレス"
    },
    "392": {
        "start": 1171.0,
        "end": 1175.1,
        "ja_text": "だってそんなことしている時間はもうないもん"
    },
    "393": {
        "start": 1175.8,
        "end": 1178.3,
        "ja_text": "ロシアがタイムマシンの実験を始めたから"
    },
    "394": {
        "start": 1179.104,
        "end": 1181.52,
        "ja_text": "それもあるけどもう燃料がね"
    },
    "395": {
        "start": 1182.36,
        "end": 1184.82,
        "ja_text": "カガリ探すので何度もタイ"
    },
    "396": {
        "start": 1184.82,
        "end": 1186.06,
        "ja_text": "ムマシン使っちゃったから"
    },
    "397": {
        "start": 1187.66,
        "end": 1189.38,
        "ja_text": "他の電池で代用できないの"
    },
    "398": {
        "start": 1190.08,
        "end": 1190.36,
        "ja_text": "無理"
    },
    "399": {
        "start": 1191.06,
        "end": 1193.34,
        "ja_text": "前にルミ姉さんにトラックとかに積ま"
    },
    "400": {
        "start": 1193.34,
        "end": 1195.04,
        "ja_text": "れている電池持ってきてもらったけど"
    },
    "401": {
        "start": 1195.6,
        "end": 1196.56,
        "ja_text": "一瞬で切れちゃった"
    },
    "402": {
        "start": 1197.76,
        "end": 1199.38,
        "ja_text": "あと何回ぐらい飛べるん?"
    },
    "403": {
        "start": 1200.26,
        "end": 1202.42,
        "ja_text": "半年の間を1回か2回"
    },
    "404": {
        "start": 1203.712,
        "end": 1204.4,
        "ja_text": "それで終わり"
    },
    "405": {
        "start": 1205.664,
        "end": 1207.46,
        "ja_text": "もし途中で電池が切れたら?"
    },
    "406": {
        "start": 1208.16,
        "end": 1208.62,
        "ja_text": "さあ、"
    },
    "407": {
        "start": 1209.44,
        "end": 1210.44,
        "ja_text": "制御を失って"
    },
    "408": {
        "start": 1210.62,
        "end": 1212.52,
        "ja_text": "イベントホライゾンの向こうから"
    },
    "409": {
        "start": 1212.52,
        "end": 1214.36,
        "ja_text": "永久に戻って来られないとか?"
    },
    "410": {
        "start": 1215.456,
        "end": 1217.18,
        "ja_text": "縁起でもないこと言ったらダメだよ"
    },
    "411": {
        "start": 1220.56,
        "end": 1221.46,
        "ja_text": "ごめん"
    },
    "412": {
        "start": 1223.32,
        "end": 1223.68,
        "ja_text": "うん"
    },
    "413": {
        "start": 1234.9,
        "end": 1235.136,
        "ja_text": "でも、"
    },
    "414": {
        "start": 1235.68,
        "end": 1237.46,
        "ja_text": "そこってどんな場所なのかな"
    },
    "415": {
        "start": 1240.64,
        "end": 1244.06,
        "ja_text": "今みたいに静かな時間が永遠に続くのかな"
    },
    "416": {
        "start": 1245.84,
        "end": 1248.12,
        "ja_text": "だったら、それもいいな"
    },
    "417": {
        "start": 1254.3,
        "end": 1254.84,
        "ja_text": "冷や状さ"
    },
    "418": {
        "start": 1258.52,
        "end": 1259.46,
        "ja_text": "どうしたの"
    },
    "419": {
        "start": 1261.632,
        "end": 1262.5,
        "ja_text": "どういうことだ"
    },
    "420": {
        "start": 1263.18,
        "end": 1263.98,
        "ja_text": "この山上は"
    },
    "421": {
        "start": 1264.7,
        "end": 1266.0,
        "ja_text": "山上な"
    },
    "422": {
        "start": 1266.528,
        "end": 1268.74,
        "ja_text": "かなか居心地のいい空間だと思うけど"
    },
    "423": {
        "start": 1269.74,
        "end": 1271.38,
        "ja_text": "まだたった一日だろう"
    },
    "424": {
        "start": 1272.06,
        "end": 1273.48,
        "ja_text": "出歩くのが危険なんだから"
    },
    "425": {
        "start": 1274.24,
        "end": 1275.76,
        "ja_text": "ここで研究するしかないでしょ"
    },
    "426": {
        "start": 1276.11,
        "end": 1276.84,
        "ja_text": "それより何"
    },
    "427": {
        "start": 1277.62,
        "end": 1278.0,
        "ja_text": "いや"
    },
    "428": {
        "start": 1281.1,
        "end": 1283.7,
        "ja_text": "タイムマシン理論の研究をクリスが"
    },
    "429": {
        "start": 1284.86,
        "end": 1288.2,
        "ja_text": "ああ 連中の狙いはおそらくその研究の痕跡"
    },
    "430": {
        "start": 1288.58,
        "end": 1292.04,
        "ja_text": "もしくはアマデウスの中にあるクリスの理論"
    },
    "431": {
        "start": 1293.86,
        "end": 1294.76,
        "ja_text": "心当たりはないか"
    },
    "432": {
        "start": 1295.96,
        "end": 1297.5,
        "ja_text": "例えばクリスの論文のメモ"
    },
    "433": {
        "start": 1297.5,
        "end": 1298.9,
        "ja_text": "やスタンドアローンのデータ"
    },
    "434": {
        "start": 1299.56,
        "end": 1301.28,
        "ja_text": "それがあるとしたら襲撃"
    },
    "435": {
        "start": 1301.28,
        "end": 1302.72,
        "ja_text": "してきた理由も説明できる"
    },
    "436": {
        "start": 1304.68,
        "end": 1304.96,
        "ja_text": "それは"
    },
    "437": {
        "start": 1307.392,
        "end": 1307.76,
        "ja_text": "ないわ"
    },
    "438": {
        "start": 1309.96,
        "end": 1310.48,
        "ja_text": "そうか"
    },
    "439": {
        "start": 1323.92,
        "end": 1330.52,
        "ja_text": "ご視聴ありがとうございました"
    },
    "440": {
        "start": 1343.7,
        "end": 1345.46,
        "ja_text": "I just pray for the"
    },
    "441": {
        "start": 1345.46,
        "end": 1348.02,
        "ja_text": "world to realize"
    },
    "442": {
        "start": 1348.8,
        "end": 1351.74,
        "ja_text": "There is peace, the"
    },
    "443": {
        "start": 1351.744,
        "end": 1354.4,
        "ja_text": "truth within us"
    },
    "444": {
        "start": 1355.24,
        "end": 1359.12,
        "ja_text": "Emptiness rules"
    },
    "445": {
        "start": 1359.12,
        "end": 1360.8,
        "ja_text": "your heart"
    },
    "446": {
        "start": 1361.6,
        "end": 1363.08,
        "ja_text": "Cause you're free"
    },
    "447": {
        "start": 1363.08,
        "end": 1366.74,
        "ja_text": "from pain and sorrow"
    },
    "448": {
        "start": 1366.98,
        "end": 1371.12,
        "ja_text": "Future is just a fight"
    },
    "449": {
        "start": 1371.12,
        "end": 1373.52,
        "ja_text": "to show your ways"
    },
    "450": {
        "start": 1373.92,
        "end": 1377.0,
        "ja_text": "Wake up now and start"
    },
    "451": {
        "start": 1377.0,
        "end": 1379.38,
        "ja_text": "to lead new souls"
    },
    "452": {
        "start": 1380.24,
        "end": 1380.8,
        "ja_text": "M"
    },
    "453": {
        "start": 1381.824,
        "end": 1385.0,
        "ja_text": "ove it up, open"
    },
    "454": {
        "start": 1385.0,
        "end": 1386.46,
        "ja_text": "the universe"
    },
    "455": {
        "start": 1388.22,
        "end": 1391.08,
        "ja_text": "I am just a"
    },
    "456": {
        "start": 1391.08,
        "end": 1393.02,
        "ja_text": "part of a song"
    },
    "457": {
        "start": 1394.44,
        "end": 1398.98,
        "ja_text": "目には見えない歪んでる空"
    },
    "458": {
        "start": 1400.416,
        "end": 1405.408,
        "ja_text": "人はどこへと歩いてゆくの"
    },
    "459": {
        "start": 1408.36,
        "end": 1410.5,
        "ja_text": "The Last Day"
    }
}