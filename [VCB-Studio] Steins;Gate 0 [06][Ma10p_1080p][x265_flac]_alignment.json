{
    "1": {
        "start": 0.672,
        "end": 4.78,
        "ja_text": "あなたは何か必要なものがあ"
    },
    "2": {
        "start": 4.78,
        "end": 5.82,
        "ja_text": "ったら、私に連絡してください。"
    },
    "3": {
        "start": 6.28,
        "end": 6.68,
        "ja_text": "はい。"
    },
    "4": {
        "start": 11.96,
        "end": 13.36,
        "ja_text": "マユリちゃん、大丈夫ですか?"
    },
    "5": {
        "start": 16.46,
        "end": 18.56,
        "ja_text": "マユシーがいなくても役に立たない。"
    },
    "6": {
        "start": 21.1,
        "end": 23.58,
        "ja_text": "あなたは遠回りに行くことができますか?"
    },
    "7": {
        "start": 30.54,
        "end": 31.98,
        "ja_text": "記憶がないだって?"
    },
    "8": {
        "start": 32.84,
        "end": 33.2,
        "ja_text": "はい"
    },
    "9": {
        "start": 34.048,
        "end": 36.8,
        "ja_text": "それじゃあ今までどこで何してたのかも"
    },
    "10": {
        "start": 38.62,
        "end": 38.98,
        "ja_text": "そんな"
    },
    "11": {
        "start": 40.288,
        "end": 40.64,
        "ja_text": "鈴葉"
    },
    "12": {
        "start": 40.87,
        "end": 43.98,
        "ja_text": "お前はなんで彼女がシーナかがりだと思った"
    },
    "13": {
        "start": 44.72,
        "end": 45.64,
        "ja_text": "前に言っただろ"
    },
    "14": {
        "start": 45.68,
        "end": 47.12,
        "ja_text": "そのウーパだよ"
    },
    "15": {
        "start": 47.712,
        "end": 49.54,
        "ja_text": "それはかがりがママにもらったんだ"
    },
    "16": {
        "start": 50.0,
        "end": 52.74,
        "ja_text": "お守りだってずっと大切にしてた"
    },
    "17": {
        "start": 54.16,
        "end": 55.4,
        "ja_text": "カナさんはそれをどこで"
    },
    "18": {
        "start": 56.02,
        "end": 56.94,
        "ja_text": "分かりません"
    },
    "19": {
        "start": 57.07,
        "end": 59.8,
        "ja_text": "記憶をなくして倒れていた私が"
    },
    "20": {
        "start": 59.96,
        "end": 62.8,
        "ja_text": "ただ一つ持っていたのがこれだったそうです"
    },
    "21": {
        "start": 63.776,
        "end": 64.5,
        "ja_text": "倒れていた?"
    },
    "22": {
        "start": 65.22,
        "end": 67.76,
        "ja_text": "千葉県の県境で倒れていたところを"
    },
    "23": {
        "start": 68.28,
        "end": 70.66,
        "ja_text": "通りがかった住職さんが見つけてくれて"
    },
    "24": {
        "start": 71.36,
        "end": 73.28,
        "ja_text": "それがどうしてルカ子の家へ?"
    },
    "25": {
        "start": 73.952,
        "end": 75.36,
        "ja_text": "修行の場である寺には"
    },
    "26": {
        "start": 75.39,
        "end": 77.92,
        "ja_text": "女性を長く置いてはおけぬと"
    },
    "27": {
        "start": 79.1,
        "end": 80.22,
        "ja_text": "ルカ兄さんの家?"
    },
    "28": {
        "start": 80.928,
        "end": 82.4,
        "ja_text": "そんな近くにいたなんて"
    },
    "29": {
        "start": 83.72,
        "end": 85.88,
        "ja_text": "あの、私はシーナカガリ"
    },
    "30": {
        "start": 85.88,
        "end": 87.18,
        "ja_text": "という名前なんでしょうか"
    },
    "31": {
        "start": 87.43,
        "end": 90.06,
        "ja_text": "お二人は私のことご存知なんですか"
    },
    "32": {
        "start": 91.392,
        "end": 91.88,
        "ja_text": "私は"
    },
    "33": {
        "start": 91.88,
        "end": 93.06,
        "ja_text": "待って、落ち着いて"
    },
    "34": {
        "start": 93.06,
        "end": 94.86,
        "ja_text": "すみません"
    },
    "35": {
        "start": 95.3,
        "end": 95.94,
        "ja_text": "カナさん、"
    },
    "36": {
        "start": 96.72,
        "end": 98.66,
        "ja_text": "君はシーナカガリという名前を聞いて"
    },
    "37": {
        "start": 99.38,
        "end": 100.42,
        "ja_text": "何か思い出すことは"
    },
    "38": {
        "start": 101.88,
        "end": 102.88,
        "ja_text": "よく分かりません"
    },
    "39": {
        "start": 105.2,
        "end": 108.24,
        "ja_text": "ただ、なんだかとても懐かしい感じがします"
    },
    "40": {
        "start": 109.216,
        "end": 109.6,
        "ja_text": "それに、"
    },
    "41": {
        "start": 110.18,
        "end": 110.88,
        "ja_text": "さっきの人"
    },
    "42": {
        "start": 111.2,
        "end": 112.52,
        "ja_text": "マユリのことか?"
    },
    "43": {
        "start": 114.94,
        "end": 117.1,
        "ja_text": "マユリさんというのですね"
    },
    "44": {
        "start": 119.79,
        "end": 120.52,
        "ja_text": "カガリ"
    },
    "45": {
        "start": 121.94,
        "end": 122.44,
        "ja_text": "シーナ"
    },
    "46": {
        "start": 123.22,
        "end": 123.76,
        "ja_text": "カガリ"
    },
    "47": {
        "start": 126.24,
        "end": 127.34,
        "ja_text": "シーナカガリ"
    },
    "48": {
        "start": 128.416,
        "end": 129.86,
        "ja_text": "2036年の"
    },
    "49": {
        "start": 130.88,
        "end": 131.4,
        "ja_text": "マユリの"
    },
    "50": {
        "start": 132.2,
        "end": 132.68,
        "ja_text": "娘"
    },
    "51": {
        "start": 149.96,
        "end": 154.32,
        "ja_text": "この世界は非現実"
    },
    "52": {
        "start": 154.64,
        "end": 159.74,
        "ja_text": "ただ擦り込まれたビジョン"
    },
    "53": {
        "start": 162.2,
        "end": 166.38,
        "ja_text": "無限遠隔に価値観を今"
    },
    "54": {
        "start": 166.38,
        "end": 171.76,
        "ja_text": "今 上書きする 変哲のない宇宙"
    },
    "55": {
        "start": 172.78,
        "end": 177.16,
        "ja_text": "傲慢な神は 目に映らない"
    },
    "56": {
        "start": 178.0,
        "end": 182.36,
        "ja_text": "高速度で 支配続けるならば"
    },
    "57": {
        "start": 182.36,
        "end": 186.68,
        "ja_text": "僕は 僕だけは"
    },
    "58": {
        "start": 187.7,
        "end": 193.28,
        "ja_text": "奇跡的で致命的な マイノリティでいい"
    },
    "59": {
        "start": 194.16,
        "end": 196.32,
        "ja_text": "I can fly high あの"
    },
    "60": {
        "start": 196.32,
        "end": 200.96,
        "ja_text": "瞬間 あの場面が 君にとって特別なら"
    },
    "61": {
        "start": 201.15,
        "end": 206.48,
        "ja_text": "過去へ離れてゆくものなんかじゃなくて"
    },
    "62": {
        "start": 206.48,
        "end": 210.28,
        "ja_text": "傷つくことの痛みより 大事なシ"
    },
    "63": {
        "start": 210.28,
        "end": 216.12,
        "ja_text": "ーン その全ての光が今 ゼロを生む"
    },
    "64": {
        "start": 216.9,
        "end": 219.26,
        "ja_text": "There is no God,"
    },
    "65": {
        "start": 219.3,
        "end": 222.26,
        "ja_text": "wonderful new world"
    },
    "66": {
        "start": 224.864,
        "end": 227.0,
        "ja_text": "それじゃあカナス…あ、じゃなくて"
    },
    "67": {
        "start": 227.42,
        "end": 229.34,
        "ja_text": "カガリさんは鈴葉さんのお"
    },
    "68": {
        "start": 229.34,
        "end": 230.48,
        "ja_text": "知り合いの方なんですか?"
    },
    "69": {
        "start": 230.72,
        "end": 233.16,
        "ja_text": "ま、まあそういうことになる"
    },
    "70": {
        "start": 233.8,
        "end": 236.7,
        "ja_text": "だったらカガリさんがどこに住んでいたかも"
    },
    "71": {
        "start": 237.02,
        "end": 238.92,
        "ja_text": "ご家族の方もご存知なんでしょうか?"
    },
    "72": {
        "start": 239.12,
        "end": 241.46,
        "ja_text": "あ、いや、それは…"
    },
    "73": {
        "start": 241.46,
        "end": 244.24,
        "ja_text": "あ、あが、彼女の家は子供"
    },
    "74": {
        "start": 244.24,
        "end": 245.28,
        "ja_text": "の頃に引っ越してしまって"
    },
    "75": {
        "start": 246.06,
        "end": 247.8,
        "ja_text": "その後のことは鈴葉も知らないそうだ"
    },
    "76": {
        "start": 248.7,
        "end": 249.34,
        "ja_text": "そうですか"
    },
    "77": {
        "start": 250.22,
        "end": 252.94,
        "ja_text": "あ、でも名前だけでもわかってよかったです"
    },
    "78": {
        "start": 253.984,
        "end": 254.8,
        "ja_text": "ねえねえ、"
    },
    "79": {
        "start": 255.52,
        "end": 258.08,
        "ja_text": "かがりさんはシーナかがりって言うんだよね"
    },
    "80": {
        "start": 258.9,
        "end": 259.0,
        "ja_text": "はい"
    },
    "81": {
        "start": 260.2,
        "end": 262.2,
        "ja_text": "だったらマユシーと一緒だね"
    },
    "82": {
        "start": 262.8,
        "end": 265.24,
        "ja_text": "マユシーもシーナマユリって言うんだ"
    },
    "83": {
        "start": 265.984,
        "end": 268.06,
        "ja_text": "シーナマユリさん"
    },
    "84": {
        "start": 269.04,
        "end": 271.46,
        "ja_text": "ルカ君から聞いたけど、か"
    },
    "85": {
        "start": 271.46,
        "end": 274.02,
        "ja_text": "がりさんは記憶喪失なの?"
    },
    "86": {
        "start": 274.38,
        "end": 274.76,
        "ja_text": "ええ"
    },
    "87": {
        "start": 275.616,
        "end": 277.7,
        "ja_text": "それって自分が誰なのかも"
    },
    "88": {
        "start": 277.7,
        "end": 279.14,
        "ja_text": "わからないってことだよね"
    },
    "89": {
        "start": 281.62,
        "end": 283.58,
        "ja_text": "そっかき"
    },
    "90": {
        "start": 284.288,
        "end": 284.46,
        "ja_text": "っと"
    },
    "91": {
        "start": 285.38,
        "end": 286.72,
        "ja_text": "辛いこといっぱいだよね"
    },
    "92": {
        "start": 287.1,
        "end": 289.46,
        "ja_text": "だって自分が大好きな人の"
    },
    "93": {
        "start": 289.46,
        "end": 290.72,
        "ja_text": "ことも忘れちゃうんでしょ"
    },
    "94": {
        "start": 291.872,
        "end": 296.12,
        "ja_text": "それってすごく悲しいことだってまゆしは思うな"
    },
    "95": {
        "start": 297.248,
        "end": 297.74,
        "ja_text": "だからね"
    },
    "96": {
        "start": 298.54,
        "end": 301.04,
        "ja_text": "えっとうまく言えないけど"
    },
    "97": {
        "start": 302.0,
        "end": 304.92,
        "ja_text": "まゆしもお手伝いするから頑張ろうね"
    },
    "98": {
        "start": 309.14,
        "end": 310.62,
        "ja_text": "あ、どうしちゃったのかな?"
    },
    "99": {
        "start": 310.8,
        "end": 313.34,
        "ja_text": "もしかして何か変なこと言っちゃったかな?"
    },
    "100": {
        "start": 313.58,
        "end": 316.02,
        "ja_text": "い、いえ、マユリさんの"
    },
    "101": {
        "start": 316.02,
        "end": 318.6,
        "ja_text": "言葉がなんだか嬉しくて…"
    },
    "102": {
        "start": 319.66,
        "end": 321.18,
        "ja_text": "マユシーだけじゃないよ"
    },
    "103": {
        "start": 325.0,
        "end": 327.8,
        "ja_text": "ぼ、僕もできることがあれば何でもします"
    },
    "104": {
        "start": 331.54,
        "end": 331.94,
        "ja_text": "ありがとうございます"
    },
    "105": {
        "start": 333.48,
        "end": 333.84,
        "ja_text": "ありがとうございます"
    },
    "106": {
        "start": 336.62,
        "end": 338.82,
        "ja_text": "シーナカガリが見つかった"
    },
    "107": {
        "start": 340.2,
        "end": 340.56,
        "ja_text": "どこで"
    },
    "108": {
        "start": 341.39,
        "end": 343.32,
        "ja_text": "知り合いの神社にお世話になっていた"
    },
    "109": {
        "start": 344.78,
        "end": 346.72,
        "ja_text": "千葉の県境で倒れていたらしい"
    },
    "110": {
        "start": 348.0,
        "end": 348.34,
        "ja_text": "どうして"
    },
    "111": {
        "start": 349.06,
        "end": 350.02,
        "ja_text": "わからない"
    },
    "112": {
        "start": 350.78,
        "end": 352.16,
        "ja_text": "記憶をなくしているそうだ"
    },
    "113": {
        "start": 352.86,
        "end": 353.22,
        "ja_text": "そう"
    },
    "114": {
        "start": 353.9,
        "end": 356.52,
        "ja_text": "彼女を探していた連中については何か"
    },
    "115": {
        "start": 357.28,
        "end": 358.0,
        "ja_text": "まだ何も"
    },
    "116": {
        "start": 359.104,
        "end": 360.04,
        "ja_text": "すまないな"
    },
    "117": {
        "start": 360.51,
        "end": 362.04,
        "ja_text": "年の瀬の忙しい時期に"
    },
    "118": {
        "start": 363.104,
        "end": 363.7,
        "ja_text": "仕事だから"
    },
    "119": {
        "start": 364.96,
        "end": 365.36,
        "ja_text": "どうする?"
    },
    "120": {
        "start": 366.112,
        "end": 366.52,
        "ja_text": "続ける?"
    },
    "121": {
        "start": 366.66,
        "end": 369.16,
        "ja_text": "引き続き追ってもらえると助かる"
    },
    "122": {
        "start": 369.62,
        "end": 370.44,
        "ja_text": "分かった"
    },
    "123": {
        "start": 373.44,
        "end": 373.86,
        "ja_text": "そう"
    },
    "124": {
        "start": 375.02,
        "end": 376.34,
        "ja_text": "見つかったの"
    },
    "125": {
        "start": 393.312,
        "end": 393.9,
        "ja_text": "マホー"
    },
    "126": {
        "start": 396.096,
        "end": 397.9,
        "ja_text": "ちょっと何するんですか教授"
    },
    "127": {
        "start": 398.96,
        "end": 401.06,
        "ja_text": "もしかして彼から連絡"
    },
    "128": {
        "start": 401.06,
        "end": 403.22,
        "ja_text": "そんなんじゃありません"
    },
    "129": {
        "start": 403.56,
        "end": 406.18,
        "ja_text": "まったくレスキネン教授といいすぐその話"
    },
    "130": {
        "start": 406.74,
        "end": 409.06,
        "ja_text": "恋愛なんて何の役にも立たないのに"
    },
    "131": {
        "start": 410.28,
        "end": 412.6,
        "ja_text": "あらそんなことないわよ"
    },
    "132": {
        "start": 415.8,
        "end": 420.16,
        "ja_text": "何より恋愛感情も私の大事な研究対象よ"
    },
    "133": {
        "start": 421.632,
        "end": 425.02,
        "ja_text": "だからって人を研究対象扱いしないでください"
    },
    "134": {
        "start": 425.82,
        "end": 428.16,
        "ja_text": "私に限ってそんなものにうつつを"
    },
    "135": {
        "start": 428.16,
        "end": 429.7,
        "ja_text": "抜かすことなんてありませんから"
    },
    "136": {
        "start": 430.24,
        "end": 431.2,
        "ja_text": "あら残念"
    },
    "137": {
        "start": 433.76,
        "end": 434.58,
        "ja_text": "そうだ教授"
    },
    "138": {
        "start": 440.64,
        "end": 442.62,
        "ja_text": "あのすみませんいろいろ"
    },
    "139": {
        "start": 443.232,
        "end": 444.38,
        "ja_text": "そんなことないよ"
    },
    "140": {
        "start": 445.34,
        "end": 448.56,
        "ja_text": "マユシーも協力するから何かあったら言ってね"
    },
    "141": {
        "start": 449.62,
        "end": 449.824,
        "ja_text": "ありがとうございます"
    },
    "142": {
        "start": 452.62,
        "end": 454.46,
        "ja_text": "ルカコちょっといいか"
    },
    "143": {
        "start": 456.68,
        "end": 458.94,
        "ja_text": "カガリさんを外に出さないように"
    },
    "144": {
        "start": 460.256,
        "end": 460.8,
        "ja_text": "でもそれは"
    },
    "145": {
        "start": 461.18,
        "end": 463.68,
        "ja_text": "出るときは誰かについていてもらってくれ"
    },
    "146": {
        "start": 464.74,
        "end": 465.28,
        "ja_text": "理由は"
    },
    "147": {
        "start": 466.46,
        "end": 467.0,
        "ja_text": "まだ言えない"
    },
    "148": {
        "start": 468.192,
        "end": 470.2,
        "ja_text": "岡部さんがそう言うなら"
    },
    "149": {
        "start": 471.24,
        "end": 471.72,
        "ja_text": "すまない"
    },
    "150": {
        "start": 473.74,
        "end": 476.36,
        "ja_text": "カガリを探しているという連中が何者なのか"
    },
    "151": {
        "start": 477.216,
        "end": 478.06,
        "ja_text": "それが分かるまでは"
    },
    "152": {
        "start": 478.9,
        "end": 481.3,
        "ja_text": "一応用心しておいた方がいいだろうからな"
    },
    "153": {
        "start": 483.936,
        "end": 484.72,
        "ja_text": "なんにせよ"
    },
    "154": {
        "start": 484.92,
        "end": 487.6,
        "ja_text": "カガリたんが見つかってよかったじゃん"
    },
    "155": {
        "start": 487.71,
        "end": 489.36,
        "ja_text": "鈴葉も一安心だろ"
    },
    "156": {
        "start": 489.92,
        "end": 490.28,
        "ja_text": "うん"
    },
    "157": {
        "start": 490.94,
        "end": 491.3,
        "ja_text": "まあ"
    },
    "158": {
        "start": 493.984,
        "end": 496.62,
        "ja_text": "の割には浮かない顔してるけど"
    },
    "159": {
        "start": 496.89,
        "end": 500.56,
        "ja_text": "あいつ今までどこでどうしてたんだろう"
    },
    "160": {
        "start": 501.46,
        "end": 502.82,
        "ja_text": "記憶喪失ね"
    },
    "161": {
        "start": 503.808,
        "end": 505.9,
        "ja_text": "確かに気にはなるけどさ"
    },
    "162": {
        "start": 506.944,
        "end": 508.46,
        "ja_text": "だからって鈴葉がどうこう"
    },
    "163": {
        "start": 508.46,
        "end": 509.9,
        "ja_text": "できるもんでもないっしょ"
    },
    "164": {
        "start": 510.86,
        "end": 512.14,
        "ja_text": "ああいうのってひょんな"
    },
    "165": {
        "start": 512.14,
        "end": 513.88,
        "ja_text": "ことから思い出すとも言うし"
    },
    "166": {
        "start": 514.01,
        "end": 515.82,
        "ja_text": "様子見るしかないんじゃね"
    },
    "167": {
        "start": 516.736,
        "end": 518.18,
        "ja_text": "それはそうなんだけど"
    },
    "168": {
        "start": 519.392,
        "end": 522.4,
        "ja_text": "それとも思いっきり脅かしてみるとか"
    },
    "169": {
        "start": 522.4,
        "end": 523.98,
        "ja_text": "こんな感じで"
    },
    "170": {
        "start": 537.78,
        "end": 540.4,
        "ja_text": "そんなことしちゃだめだ"
    },
    "171": {
        "start": 542.112,
        "end": 544.08,
        "ja_text": "声が聞こえる"
    },
    "172": {
        "start": 544.23,
        "end": 544.96,
        "ja_text": "ガガリ"
    },
    "173": {
        "start": 556.8,
        "end": 557.62,
        "ja_text": "スズハ?"
    },
    "174": {
        "start": 566.14,
        "end": 566.84,
        "ja_text": "なあオカリン"
    },
    "175": {
        "start": 567.74,
        "end": 570.78,
        "ja_text": "僕たち今から初詣に行く予定だったよね"
    },
    "176": {
        "start": 570.78,
        "end": 571.46,
        "ja_text": "ああ"
    },
    "177": {
        "start": 573.42,
        "end": 573.94,
        "ja_text": "でもさ"
    },
    "178": {
        "start": 574.08,
        "end": 576.6,
        "ja_text": "ならこの状況おかしくね"
    },
    "179": {
        "start": 576.6,
        "end": 577.46,
        "ja_text": "おい"
    },
    "180": {
        "start": 577.46,
        "end": 577.72,
        "ja_text": "おい!"
    },
    "181": {
        "start": 578.9,
        "end": 580.08,
        "ja_text": "言いたいことがあるなら"
    },
    "182": {
        "start": 580.08,
        "end": 581.94,
        "ja_text": "大きな声で言ったらどうだ?"
    },
    "183": {
        "start": 582.496,
        "end": 584.32,
        "ja_text": "えぇ… なんでもございません"
    },
    "184": {
        "start": 586.24,
        "end": 588.82,
        "ja_text": "と、ところで ラボに入りたいのですが…"
    },
    "185": {
        "start": 589.46,
        "end": 589.8,
        "ja_text": "だめだ!"
    },
    "186": {
        "start": 590.2,
        "end": 591.24,
        "ja_text": "な、なんでだ?"
    },
    "187": {
        "start": 591.4,
        "end": 592.6,
        "ja_text": "お、応募だ!"
    },
    "188": {
        "start": 593.42,
        "end": 595.4,
        "ja_text": "みんなで初詣に出かける約"
    },
    "189": {
        "start": 595.4,
        "end": 597.34,
        "ja_text": "束で 集まってるのですが…"
    },
    "190": {
        "start": 597.84,
        "end": 598.92,
        "ja_text": "お待たせしました!"
    },
    "191": {
        "start": 599.68,
        "end": 600.04,
        "ja_text": "お?"
    },
    "192": {
        "start": 602.76,
        "end": 603.62,
        "ja_text": "えへへへ"
    },
    "193": {
        "start": 607.78,
        "end": 608.46,
        "ja_text": "なえ!"
    },
    "194": {
        "start": 609.28,
        "end": 613.02,
        "ja_text": "かわいそう!さすがはお父さんの子だ!"
    },
    "195": {
        "start": 615.36,
        "end": 616.8,
        "ja_text": "痛いよ、お父さん"
    },
    "196": {
        "start": 617.536,
        "end": 618.8,
        "ja_text": "本当になくてよかった"
    },
    "197": {
        "start": 619.38,
        "end": 622.32,
        "ja_text": "お父さん、私ね、まゆりお姉ちゃん"
    },
    "198": {
        "start": 622.32,
        "end": 624.52,
        "ja_text": "の巫女さん、すごく楽しみなんだ"
    },
    "199": {
        "start": 625.32,
        "end": 625.8,
        "ja_text": "そっか!"
    },
    "200": {
        "start": 626.5,
        "end": 627.46,
        "ja_text": "お姉ちゃんたちの言う"
    },
    "201": {
        "start": 627.46,
        "end": 628.68,
        "ja_text": "こと、ちゃんと聞くんだぞ!"
    },
    "202": {
        "start": 628.9,
        "end": 629.28,
        "ja_text": "うん!"
    },
    "203": {
        "start": 630.34,
        "end": 631.22,
        "ja_text": "来られないんですか?"
    },
    "204": {
        "start": 632.192,
        "end": 633.62,
        "ja_text": "ちょっと野暮用があってな"
    },
    "205": {
        "start": 634.7,
        "end": 636.84,
        "ja_text": "じゃなきゃこんなに可愛い娘を"
    },
    "206": {
        "start": 636.91,
        "end": 639.08,
        "ja_text": "おめえらに任せたりなんてするか"
    },
    "207": {
        "start": 639.76,
        "end": 643.28,
        "ja_text": "言っとくが万が一ないに何かあったら"
    },
    "208": {
        "start": 644.064,
        "end": 645.32,
        "ja_text": "さあいえさあ"
    },
    "209": {
        "start": 645.32,
        "end": 647.58,
        "ja_text": "いってらっしゃいお父さん"
    },
    "210": {
        "start": 648.94,
        "end": 650.7,
        "ja_text": "じゃあそろそろ行きますか"
    },
    "211": {
        "start": 650.7,
        "end": 651.38,
        "ja_text": "ああ"
    },
    "212": {
        "start": 652.32,
        "end": 653.4,
        "ja_text": "その前に"
    },
    "213": {
        "start": 654.06,
        "end": 655.78,
        "ja_text": "大事なこと忘れてますよ"
    },
    "214": {
        "start": 656.44,
        "end": 657.42,
        "ja_text": "あけまして"
    },
    "215": {
        "start": 658.54,
        "end": 659.68,
        "ja_text": "おめでとうございます"
    },
    "216": {
        "start": 661.76,
        "end": 663.74,
        "ja_text": "マユシーの巫女コズ楽しみ"
    },
    "217": {
        "start": 665.08,
        "end": 667.58,
        "ja_text": "今日はコスプレじゃなくて清掃だって"
    },
    "218": {
        "start": 667.58,
        "end": 668.82,
        "ja_text": "あそっか"
    },
    "219": {
        "start": 669.824,
        "end": 673.2,
        "ja_text": "鈴葉さんもアルバイトでしたっけ楽しみですね"
    },
    "220": {
        "start": 674.048,
        "end": 678.04,
        "ja_text": "妹属性の巫女さんどうせならナース属性も追"
    },
    "221": {
        "start": 678.04,
        "end": 681.3,
        "ja_text": "加してくれれば萌えの数え役マンなんですが"
    },
    "222": {
        "start": 681.3,
        "end": 684.02,
        "ja_text": "橋田さんは相変わらず変態さんですね"
    },
    "223": {
        "start": 685.54,
        "end": 686.62,
        "ja_text": "その悪かったな"
    },
    "224": {
        "start": 687.64,
        "end": 689.0,
        "ja_text": "言い出しっぺのまゆりがいなくて"
    },
    "225": {
        "start": 689.94,
        "end": 692.3,
        "ja_text": "急に巫女のバイトに借り出されることになってな"
    },
    "226": {
        "start": 693.08,
        "end": 694.28,
        "ja_text": "別に構わないわよ"
    },
    "227": {
        "start": 694.78,
        "end": 696.64,
        "ja_text": "ちょうど話したいこともあったし"
    },
    "228": {
        "start": 698.72,
        "end": 701.2,
        "ja_text": "そういえば冷谷城さんはアメリ"
    },
    "229": {
        "start": 701.2,
        "end": 703.14,
        "ja_text": "カの大学に通ってるんですよね"
    },
    "230": {
        "start": 703.14,
        "end": 703.66,
        "ja_text": "え?"
    },
    "231": {
        "start": 703.8,
        "end": 704.14,
        "ja_text": "うん"
    },
    "232": {
        "start": 704.96,
        "end": 706.36,
        "ja_text": "すごい研究してるんでしょ"
    },
    "233": {
        "start": 706.74,
        "end": 707.42,
        "ja_text": "なんだっけ"
    },
    "234": {
        "start": 707.42,
        "end": 708.54,
        "ja_text": "あいあい?"
    },
    "235": {
        "start": 708.74,
        "end": 709.6,
        "ja_text": "おさるさん?"
    },
    "236": {
        "start": 710.24,
        "end": 711.7,
        "ja_text": "AIだよふぶきちゃん"
    },
    "237": {
        "start": 711.7,
        "end": 713.14,
        "ja_text": "そうそうそれ"
    },
    "238": {
        "start": 713.14,
        "end": 717.62,
        "ja_text": "それAIって人工知能の研究ってことですよね"
    },
    "239": {
        "start": 717.95,
        "end": 720.62,
        "ja_text": "私今すごく興味があって"
    },
    "240": {
        "start": 724.02,
        "end": 727.6,
        "ja_text": "オカリンどないしたん"
    },
    "241": {
        "start": 729.4,
        "end": 731.94,
        "ja_text": "なんでもない行こう"
    },
    "242": {
        "start": 735.82,
        "end": 738.4,
        "ja_text": "オカリンこっちにゃー"
    },
    "243": {
        "start": 739.14,
        "end": 741.44,
        "ja_text": "明けましておめでとうございます"
    },
    "244": {
        "start": 745.12,
        "end": 746.66,
        "ja_text": "おめでとうにゃ"
    },
    "245": {
        "start": 748.44,
        "end": 752.38,
        "ja_text": "まさにみこみこパラダイスここは天国か"
    },
    "246": {
        "start": 755.808,
        "end": 756.9,
        "ja_text": "鈴葉さん素敵"
    },
    "247": {
        "start": 757.7,
        "end": 758.14,
        "ja_text": "ありがとう"
    },
    "248": {
        "start": 759.7,
        "end": 761.79,
        "ja_text": "とっても似合ってますよね"
    },
    "249": {
        "start": 764.9,
        "end": 769.3,
        "ja_text": "スズハ、それでお注射の時間だよ、"
    },
    "250": {
        "start": 769.42,
        "end": 771.7,
        "ja_text": "お兄ちゃんって言ってみておくれ。"
    },
    "251": {
        "start": 774.12,
        "end": 775.96,
        "ja_text": "またそんなことばかり。"
    },
    "252": {
        "start": 776.02,
        "end": 778.24,
        "ja_text": "だから母さんと進展したいんだ。"
    },
    "253": {
        "start": 781.86,
        "end": 784.6,
        "ja_text": "二人とも仲いいですよね。"
    },
    "254": {
        "start": 794.55,
        "end": 796.08,
        "ja_text": "それよりおみきどう?"
    },
    "255": {
        "start": 796.8,
        "end": 797.8,
        "ja_text": "おみくじもあるよ"
    },
    "256": {
        "start": 800.48,
        "end": 802.04,
        "ja_text": "信じられない"
    },
    "257": {
        "start": 803.12,
        "end": 804.84,
        "ja_text": "あの僕が何か"
    },
    "258": {
        "start": 805.05,
        "end": 807.74,
        "ja_text": "ルカ君は相変わらず美人さんね"
    },
    "259": {
        "start": 809.06,
        "end": 810.02,
        "ja_text": "そんなこと"
    },
    "260": {
        "start": 810.58,
        "end": 812.0,
        "ja_text": "やっぱり信じられない"
    },
    "261": {
        "start": 812.25,
        "end": 813.66,
        "ja_text": "男の子だなんて"
    },
    "262": {
        "start": 813.66,
        "end": 817.44,
        "ja_text": "だが事実よなんなら確かめてみます"
    },
    "263": {
        "start": 817.44,
        "end": 818.08,
        "ja_text": "なっ"
    },
    "264": {
        "start": 818.66,
        "end": 819.6,
        "ja_text": "どどうやって"
    },
    "265": {
        "start": 829.76,
        "end": 830.62,
        "ja_text": "どうかな"
    },
    "266": {
        "start": 831.3,
        "end": 833.24,
        "ja_text": "ああよく似合ってる"
    },
    "267": {
        "start": 833.72,
        "end": 835.62,
        "ja_text": "ほんとよかった"
    },
    "268": {
        "start": 836.43,
        "end": 838.72,
        "ja_text": "まゆりさんてば何度言っても"
    },
    "269": {
        "start": 838.72,
        "end": 840.46,
        "ja_text": "納得してくれなかったんですよ"
    },
    "270": {
        "start": 840.47,
        "end": 842.42,
        "ja_text": "オカリンどういうかなって"
    },
    "271": {
        "start": 842.42,
        "end": 845.4,
        "ja_text": "うわっ!そ、それは言っちゃダメだよー"
    },
    "272": {
        "start": 845.4,
        "end": 847.54,
        "ja_text": "えへへ、ごめんなさい"
    },
    "273": {
        "start": 847.68,
        "end": 850.32,
        "ja_text": "もう、それにカガリさんだ"
    },
    "274": {
        "start": 850.32,
        "end": 852.1,
        "ja_text": "ってずっと気にしてたのです"
    },
    "275": {
        "start": 852.1,
        "end": 854.88,
        "ja_text": "え、だって、私なんて…"
    },
    "276": {
        "start": 855.14,
        "end": 858.2,
        "ja_text": "そんなことないよ、すっごく素敵だもん"
    },
    "277": {
        "start": 859.4,
        "end": 860.68,
        "ja_text": "ね、オカリン"
    },
    "278": {
        "start": 860.68,
        "end": 862.22,
        "ja_text": "お、ああ、"
    },
    "279": {
        "start": 863.72,
        "end": 864.56,
        "ja_text": "いいんじゃないかな"
    },
    "280": {
        "start": 881.536,
        "end": 884.8,
        "ja_text": "驚いたわ彼女クリスそっくり"
    },
    "281": {
        "start": 884.8,
        "end": 885.82,
        "ja_text": "そうか"
    },
    "282": {
        "start": 886.67,
        "end": 888.22,
        "ja_text": "似ているわよすごく"
    },
    "283": {
        "start": 889.344,
        "end": 891.2,
        "ja_text": "俺はそうは思わない"
    },
    "284": {
        "start": 894.24,
        "end": 896.32,
        "ja_text": "私の言いたいこと分かってる?"
    },
    "285": {
        "start": 897.34,
        "end": 898.36,
        "ja_text": "アマデウスのことか"
    },
    "286": {
        "start": 899.52,
        "end": 900.76,
        "ja_text": "いつまでもこのままにして"
    },
    "287": {
        "start": 900.76,
        "end": 902.22,
        "ja_text": "おいても解決はしないわ"
    },
    "288": {
        "start": 903.36,
        "end": 903.74,
        "ja_text": "せめて"
    },
    "289": {
        "start": 904.26,
        "end": 906.42,
        "ja_text": "お正月明けには決断してほしいの"
    },
    "290": {
        "start": 919.68,
        "end": 921.78,
        "ja_text": "ああ 間に合わなかったわね"
    },
    "291": {
        "start": 922.34,
        "end": 924.21,
        "ja_text": "ん ウィンターアロー"
    },
    "292": {
        "start": 929.02,
        "end": 932.26,
        "ja_text": "教授 ヘッピーニューイエーイウィンター"
    },
    "293": {
        "start": 932.26,
        "end": 935.94,
        "ja_text": "アロー せっかくだから二人とも誘ったんだ"
    },
    "294": {
        "start": 935.94,
        "end": 936.26,
        "ja_text": "だけど"
    },
    "295": {
        "start": 938.78,
        "end": 942.0,
        "ja_text": "シャーマン"
    },
    "296": {
        "start": 942.0,
        "end": 943.64,
        "ja_text": "ああもしかして"
    },
    "297": {
        "start": 943.64,
        "end": 944.36,
        "ja_text": "巫女さんですか"
    },
    "298": {
        "start": 945.216,
        "end": 946.64,
        "ja_text": "それなら今日はもう終わりましたよ"
    },
    "299": {
        "start": 947.24,
        "end": 949.49,
        "ja_text": "自分らも片付け終わったら帰るところです"
    },
    "300": {
        "start": 949.54,
        "end": 951.58,
        "ja_text": "オリカ"
    },
    "301": {
        "start": 952.18,
        "end": 953.8,
        "ja_text": "だから早く行こうって"
    },
    "302": {
        "start": 953.8,
        "end": 954.22,
        "ja_text": "言ったんだ"
    },
    "303": {
        "start": 954.22,
        "end": 957.18,
        "ja_text": "あなただって色々買い物してたじゃない"
    },
    "304": {
        "start": 957.6,
        "end": 959.86,
        "ja_text": "ほらさっさとお参りに行くわよ"
    },
    "305": {
        "start": 960.6,
        "end": 961.18,
        "ja_text": "シンガー"
    },
    "306": {
        "start": 961.2,
        "end": 962.66,
        "ja_text": "まずこっちで手を洗って"
    },
    "307": {
        "start": 962.66,
        "end": 963.26,
        "ja_text": "おかりー"
    },
    "308": {
        "start": 964.54,
        "end": 966.5,
        "ja_text": "ルカ君のお母さんにおせ"
    },
    "309": {
        "start": 966.5,
        "end": 967.76,
        "ja_text": "ちたくさんもらっちゃった"
    },
    "310": {
        "start": 968.0,
        "end": 969.48,
        "ja_text": "お待たせしました"
    },
    "311": {
        "start": 971.072,
        "end": 972.92,
        "ja_text": "凛太郎じゃあまたね"
    },
    "312": {
        "start": 973.2,
        "end": 975.24,
        "ja_text": "もう帰るんですか"
    },
    "313": {
        "start": 976.5,
        "end": 978.624,
        "ja_text": "巫女さんがいないなら意味がないんですって"
    },
    "314": {
        "start": 978.688,
        "end": 980.4,
        "ja_text": "それじゃあねバイ"
    },
    "315": {
        "start": 981.3,
        "end": 984.1,
        "ja_text": "すみません遅くなりました"
    },
    "316": {
        "start": 984.896,
        "end": 985.64,
        "ja_text": "なりました"
    },
    "317": {
        "start": 990.08,
        "end": 992.4,
        "ja_text": "さてと俺たちも帰るか"
    },
    "318": {
        "start": 992.4,
        "end": 995.98,
        "ja_text": "ああごめんなさい私も今日はここで"
    },
    "319": {
        "start": 995.98,
        "end": 998.78,
        "ja_text": "えゆきさんラボに来ないの"
    },
    "320": {
        "start": 999.56,
        "end": 1001.78,
        "ja_text": "急にバイトに欠員が出ちゃって"
    },
    "321": {
        "start": 1002.7,
        "end": 1003.18,
        "ja_text": "ごめんね"
    },
    "322": {
        "start": 1003.96,
        "end": 1005.58,
        "ja_text": "そっか残念"
    },
    "323": {
        "start": 1006.88,
        "end": 1009.64,
        "ja_text": "また今度ゆっくり遊びに行きますね"
    },
    "324": {
        "start": 1012.04,
        "end": 1013.2,
        "ja_text": "それじゃあ帰るとするか"
    },
    "325": {
        "start": 1014.22,
        "end": 1016.74,
        "ja_text": "うんラボでお正月パーティーだよ"
    },
    "326": {
        "start": 1020.0,
        "end": 1021.26,
        "ja_text": "それでは改めまして"
    },
    "327": {
        "start": 1021.94,
        "end": 1023.61,
        "ja_text": "明けましておめでとうございます"
    },
    "328": {
        "start": 1024.46,
        "end": 1026.6,
        "ja_text": "明けましておめでとうございます"
    },
    "329": {
        "start": 1027.776,
        "end": 1028.1,
        "ja_text": "キャンプ"
    },
    "330": {
        "start": 1030.48,
        "end": 1032.4,
        "ja_text": "このお雑煮絶品"
    },
    "331": {
        "start": 1032.61,
        "end": 1035.74,
        "ja_text": "実はメイクインのお正月メニューなんだニャン"
    },
    "332": {
        "start": 1035.78,
        "end": 1038.34,
        "ja_text": "そういうことはフェリスタンの味ですね"
    },
    "333": {
        "start": 1038.34,
        "end": 1041.16,
        "ja_text": "橋田さん本当に変態さんですね"
    },
    "334": {
        "start": 1042.12,
        "end": 1044.86,
        "ja_text": "この豆おいしいね栄養価も高そう"
    },
    "335": {
        "start": 1045.632,
        "end": 1047.1,
        "ja_text": "はいなえちゃんもどうぞ"
    },
    "336": {
        "start": 1047.1,
        "end": 1049.5,
        "ja_text": "こっちのきんとんもおいしいよ"
    },
    "337": {
        "start": 1049.5,
        "end": 1052.26,
        "ja_text": "そそんなに食べられないよ"
    },
    "338": {
        "start": 1054.944,
        "end": 1056.92,
        "ja_text": "食べなきゃ大きくなれないよ"
    },
    "339": {
        "start": 1060.88,
        "end": 1063.12,
        "ja_text": "それお茶ってもうないのかにゃん"
    },
    "340": {
        "start": 1064.32,
        "end": 1065.98,
        "ja_text": "それじゃあ私たち買ってきます"
    },
    "341": {
        "start": 1071.104,
        "end": 1072.1,
        "ja_text": "どうもです"
    },
    "342": {
        "start": 1072.16,
        "end": 1073.56,
        "ja_text": "おやさんの人だ"
    },
    "343": {
        "start": 1074.336,
        "end": 1075.46,
        "ja_text": "初詣は終わったのか?"
    },
    "344": {
        "start": 1076.02,
        "end": 1076.78,
        "ja_text": "他の連中は?"
    },
    "345": {
        "start": 1077.536,
        "end": 1079.04,
        "ja_text": "今みんなでパーティー中です"
    },
    "346": {
        "start": 1079.648,
        "end": 1080.84,
        "ja_text": "私たちは買い出しで"
    },
    "347": {
        "start": 1081.728,
        "end": 1084.8,
        "ja_text": "そうか、じゃあ後から苗を迎えに行くから"
    },
    "348": {
        "start": 1085.26,
        "end": 1087.1,
        "ja_text": "終わったら連絡よこすようにオ"
    },
    "349": {
        "start": 1087.104,
        "end": 1088.32,
        "ja_text": "オカメのやつに言っといてくれ"
    },
    "350": {
        "start": 1089.12,
        "end": 1089.62,
        "ja_text": "わかりました"
    },
    "351": {
        "start": 1109.9,
        "end": 1112.76,
        "ja_text": "あ、先輩、一体今どこに"
    },
    "352": {
        "start": 1113.36,
        "end": 1114.14,
        "ja_text": "あら、"
    },
    "353": {
        "start": 1114.94,
        "end": 1116.1,
        "ja_text": "もしかしてその場所"
    },
    "354": {
        "start": 1116.17,
        "end": 1117.76,
        "ja_text": "ねえ、それ何?"
    },
    "355": {
        "start": 1117.76,
        "end": 1117.96,
        "ja_text": "なに?"
    },
    "356": {
        "start": 1120.8,
        "end": 1122.64,
        "ja_text": "マホニャのお友達かニャン?"
    },
    "357": {
        "start": 1123.08,
        "end": 1125.36,
        "ja_text": "ああ、えっと、私は"
    },
    "358": {
        "start": 1127.08,
        "end": 1128.84,
        "ja_text": "外国の人かニャン"
    },
    "359": {
        "start": 1129.5,
        "end": 1130.34,
        "ja_text": "人ではありません"
    },
    "360": {
        "start": 1130.61,
        "end": 1134.24,
        "ja_text": "人工知能、マホ先輩によって作られたAIです"
    },
    "361": {
        "start": 1134.72,
        "end": 1135.16,
        "ja_text": "AI?"
    },
    "362": {
        "start": 1136.14,
        "end": 1137.76,
        "ja_text": "お猿さんじゃないよ"
    },
    "363": {
        "start": 1137.76,
        "end": 1138.98,
        "ja_text": "マジで?"
    },
    "364": {
        "start": 1139.3,
        "end": 1140.58,
        "ja_text": "本当にAIなん?"
    },
    "365": {
        "start": 1145.72,
        "end": 1147.2,
        "ja_text": "なるほど、皆さんが岡部さん"
    },
    "366": {
        "start": 1147.2,
        "end": 1148.44,
        "ja_text": "のラボのメンバーなんですね"
    },
    "367": {
        "start": 1149.46,
        "end": 1151.04,
        "ja_text": "では、改めてご挨拶を"
    },
    "368": {
        "start": 1152.0,
        "end": 1152.9,
        "ja_text": "私はアマデウス、"
    },
    "369": {
        "start": 1153.64,
        "end": 1155.3,
        "ja_text": "マキセ・クリスという人物の記"
    },
    "370": {
        "start": 1155.3,
        "end": 1157.5,
        "ja_text": "憶をもとに作られた人工知能です"
    },
    "371": {
        "start": 1159.58,
        "end": 1161.52,
        "ja_text": "マキセ・クリスさん?"
    },
    "372": {
        "start": 1163.24,
        "end": 1164.7,
        "ja_text": "どうやら皆さん、オリジナ"
    },
    "373": {
        "start": 1164.7,
        "end": 1166.31,
        "ja_text": "ルの私をご存知みたいですね"
    },
    "374": {
        "start": 1167.17,
        "end": 1170.16,
        "ja_text": "ご存知っつーか、サイエンシー"
    },
    "375": {
        "start": 1170.16,
        "end": 1171.86,
        "ja_text": "の記事で見たことあるっつーか"
    },
    "376": {
        "start": 1172.38,
        "end": 1173.3,
        "ja_text": "失礼しました"
    },
    "377": {
        "start": 1174.2,
        "end": 1175.8,
        "ja_text": "でも、あの雑誌を読まれた"
    },
    "378": {
        "start": 1175.8,
        "end": 1177.5,
        "ja_text": "ということは科学に関心が?"
    },
    "379": {
        "start": 1178.0,
        "end": 1180.5,
        "ja_text": "うーん、まあ、僕はネットや"
    },
    "380": {
        "start": 1180.5,
        "end": 1182.4,
        "ja_text": "システム専門の方なんだけど"
    },
    "381": {
        "start": 1182.41,
        "end": 1186.46,
        "ja_text": "ねえねえAIさん、これってゲームじゃないの?"
    },
    "382": {
        "start": 1186.54,
        "end": 1187.28,
        "ja_text": "ラブロス?"
    },
    "383": {
        "start": 1188.24,
        "end": 1189.46,
        "ja_text": "ゲームじゃないわよ"
    },
    "384": {
        "start": 1190.2,
        "end": 1191.6,
        "ja_text": "私はこの場で話を"
    },
    "385": {
        "start": 1191.6,
        "end": 1192.24,
        "ja_text": "ごめんなさい。"
    },
    "386": {
        "start": 1192.34,
        "end": 1194.56,
        "ja_text": "あなたにあれだけ言ってお"
    },
    "387": {
        "start": 1194.56,
        "end": 1196.38,
        "ja_text": "きながら、こんな場所で…"
    },
    "388": {
        "start": 1197.16,
        "end": 1198.22,
        "ja_text": "謝罪するわ。"
    },
    "389": {
        "start": 1207.98,
        "end": 1209.62,
        "ja_text": "いや、これでいいのかもしれない。"
    },
    "390": {
        "start": 1211.7,
        "end": 1212.18,
        "ja_text": "辛いけど、"
    },
    "391": {
        "start": 1213.32,
        "end": 1214.92,
        "ja_text": "前に進まなきゃいけないんだよな。"
    },
    "392": {
        "start": 1216.26,
        "end": 1219.3,
        "ja_text": "カガニがどこかクリスに似ていようと"
    },
    "393": {
        "start": 1219.64,
        "end": 1220.8,
        "ja_text": "彼女はクリスじゃない"
    },
    "394": {
        "start": 1221.82,
        "end": 1224.06,
        "ja_text": "アマデウスもそのもとが彼"
    },
    "395": {
        "start": 1224.06,
        "end": 1225.26,
        "ja_text": "女そのものだったとしても"
    },
    "396": {
        "start": 1226.048,
        "end": 1227.42,
        "ja_text": "それはもう別の存在なんだ"
    },
    "397": {
        "start": 1228.68,
        "end": 1229.82,
        "ja_text": "引きずってはいけない"
    },
    "398": {
        "start": 1230.36,
        "end": 1232.96,
        "ja_text": "君が言いたかったのはそういうことだろう"
    },
    "399": {
        "start": 1237.74,
        "end": 1238.06,
        "ja_text": "そうだ"
    },
    "400": {
        "start": 1238.26,
        "end": 1238.66,
        "ja_text": "あ"
    },
    "401": {
        "start": 1239.552,
        "end": 1240.5,
        "ja_text": "いつが守ってくれた"
    },
    "402": {
        "start": 1241.36,
        "end": 1243.1,
        "ja_text": "マイルやみんなとのこの生活を"
    },
    "403": {
        "start": 1244.04,
        "end": 1246.94,
        "ja_text": "俺は振り返らずに守らなければならないんだ"
    },
    "404": {
        "start": 1248.192,
        "end": 1250.86,
        "ja_text": "鈴葉はまだ納得はできないかもしれない"
    },
    "405": {
        "start": 1251.72,
        "end": 1254.6,
        "ja_text": "かがりのことだって何も分かってはいない"
    },
    "406": {
        "start": 1255.36,
        "end": 1255.74,
        "ja_text": "でもい"
    },
    "407": {
        "start": 1256.32,
        "end": 1257.1,
        "ja_text": "ずれきっと"
    },
    "408": {
        "start": 1258.176,
        "end": 1258.84,
        "ja_text": "ところでその"
    },
    "409": {
        "start": 1259.88,
        "end": 1261.02,
        "ja_text": "そこに岡部さんが"
    },
    "410": {
        "start": 1262.16,
        "end": 1262.46,
        "ja_text": "あら"
    },
    "411": {
        "start": 1263.38,
        "end": 1264.22,
        "ja_text": "どうしたの"
    },
    "412": {
        "start": 1264.29,
        "end": 1265.6,
        "ja_text": "急に切れたんだ"
    },
    "413": {
        "start": 1267.1,
        "end": 1267.32,
        "ja_text": "貸して"
    },
    "414": {
        "start": 1270.84,
        "end": 1273.06,
        "ja_text": "あれ別にスマホはなんとも"
    },
    "415": {
        "start": 1274.06,
        "end": 1275.42,
        "ja_text": "でもどうしたのかしら"
    },
    "416": {
        "start": 1275.85,
        "end": 1278.24,
        "ja_text": "アマデウスのサーバーにつながらない"
    },
    "417": {
        "start": 1281.04,
        "end": 1283.94,
        "ja_text": "あれマユシーの懐中止まっちゃってる"
    },
    "418": {
        "start": 1284.94,
        "end": 1288.84,
        "ja_text": "おかしいなさっきネジ巻いたばかりなのに"
    },
    "419": {
        "start": 1291.66,
        "end": 1293.52,
        "ja_text": "サーバーのデータ更新とか"
    },
    "420": {
        "start": 1294.72,
        "end": 1296.04,
        "ja_text": "そんな話聞いてないわ"
    },
    "421": {
        "start": 1298.016,
        "end": 1298.76,
        "ja_text": "岡部凛太郎"
    },
    "422": {
        "start": 1298.9,
        "end": 1299.6,
        "ja_text": "な、"
    },
    "423": {
        "start": 1308.8,
        "end": 1310.06,
        "ja_text": "なにこれ"
    },
    "424": {
        "start": 1311.28,
        "end": 1312.12,
        "ja_text": "サプライズ"
    },
    "425": {
        "start": 1312.12,
        "end": 1312.7,
        "ja_text": "動くな"
    },
    "426": {
        "start": 1313.54,
        "end": 1314.1,
        "ja_text": "なんだ"
    },
    "427": {
        "start": 1316.8,
        "end": 1317.28,
        "ja_text": "岡部"
    },
    "428": {
        "start": 1318.82,
        "end": 1319.94,
        "ja_text": "なんだよ"
    },
    "429": {
        "start": 1321.46,
        "end": 1322.02,
        "ja_text": "これ"
    },
    "430": {
        "start": 1388.3,
        "end": 1391.04,
        "ja_text": "I am just a"
    },
    "431": {
        "start": 1391.04,
        "end": 1392.96,
        "ja_text": "part of a sun"
    },
    "432": {
        "start": 1394.42,
        "end": 1397.64,
        "ja_text": "目には見えない歪んです"
    },
    "433": {
        "start": 1400.448,
        "end": 1405.42,
        "ja_text": "人はどこへと歩いてゆくの"
    },
    "434": {
        "start": 1408.0,
        "end": 1410.5,
        "ja_text": "The last day"
    },
    "435": {
        "start": 1434.68,
        "end": 1436.08,
        "ja_text": "ありがとうございました"
    }
}