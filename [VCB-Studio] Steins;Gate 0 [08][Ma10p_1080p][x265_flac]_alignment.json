{
    "1": {
        "start": 6.08,
        "end": 8.42,
        "ja_text": "しかも、彼らは20世紀のことを、"
    },
    "2": {
        "start": 8.42,
        "end": 8.64,
        "ja_text": "元天にいうことから使用されたこと"
    },
    "3": {
        "start": 8.64,
        "end": 8.88,
        "ja_text": "を認識することになったようです。"
    },
    "4": {
        "start": 22.9,
        "end": 26.26,
        "ja_text": "ったと感じて、そこにはペティがいて、アニマは"
    },
    "5": {
        "start": 26.26,
        "end": 29.54,
        "ja_text": "ヒーローなどの人々がいるようになりました。"
    },
    "6": {
        "start": 30.66,
        "end": 32.72,
        "ja_text": "と言うか、珍しいわね。"
    },
    "7": {
        "start": 33.22,
        "end": 35.02,
        "ja_text": "あんたがここに顔出すなんて。"
    },
    "8": {
        "start": 38.02,
        "end": 39.84,
        "ja_text": "ち、新年早々なにを!"
    },
    "9": {
        "start": 66.02,
        "end": 70.36,
        "ja_text": "この世界は非現実"
    },
    "10": {
        "start": 70.81,
        "end": 75.78,
        "ja_text": "ただ刷り込まれたビジョン"
    },
    "11": {
        "start": 78.24,
        "end": 82.4,
        "ja_text": "無限遠隔に価値観を今"
    },
    "12": {
        "start": 82.7,
        "end": 87.8,
        "ja_text": "上書きする変哲のない宇宙"
    },
    "13": {
        "start": 88.24,
        "end": 93.14,
        "ja_text": "傲慢な神は目に映らない"
    },
    "14": {
        "start": 93.76,
        "end": 98.4,
        "ja_text": "高速度で支配続けるならば"
    },
    "15": {
        "start": 98.4,
        "end": 102.72,
        "ja_text": "僕は 僕だけは"
    },
    "16": {
        "start": 103.56,
        "end": 109.3,
        "ja_text": "奇跡的で致命的なマイノリティでいい"
    },
    "17": {
        "start": 110.18,
        "end": 111.88,
        "ja_text": "I can fly high"
    },
    "18": {
        "start": 111.88,
        "end": 114.42,
        "ja_text": "あの瞬間 あの場面が"
    },
    "19": {
        "start": 114.42,
        "end": 116.98,
        "ja_text": "君にとって特別なら"
    },
    "20": {
        "start": 116.98,
        "end": 122.48,
        "ja_text": "だから過去は離れてゆくものなんかじゃなくて"
    },
    "21": {
        "start": 122.48,
        "end": 127.14,
        "ja_text": "傷つくことの痛みより大事な真相の"
    },
    "22": {
        "start": 127.14,
        "end": 132.92,
        "ja_text": "全ての光が今全部を生む"
    },
    "23": {
        "start": 132.92,
        "end": 135.28,
        "ja_text": "There is no God,"
    },
    "24": {
        "start": 135.7,
        "end": 138.3,
        "ja_text": "wonderful new world"
    },
    "25": {
        "start": 141.46,
        "end": 142.7,
        "ja_text": "すまない"
    },
    "26": {
        "start": 143.24,
        "end": 144.3,
        "ja_text": "気にしないで"
    },
    "27": {
        "start": 144.62,
        "end": 146.06,
        "ja_text": "私も時々ある"
    },
    "28": {
        "start": 147.4,
        "end": 148.2,
        "ja_text": "思い出したんでしょう"
    },
    "29": {
        "start": 150.29,
        "end": 151.0,
        "ja_text": "まゆりのこと"
    },
    "30": {
        "start": 153.16,
        "end": 155.22,
        "ja_text": "特にラボにいるといつも思う"
    },
    "31": {
        "start": 156.16,
        "end": 156.86,
        "ja_text": "足音がして"
    },
    "32": {
        "start": 157.792,
        "end": 158.46,
        "ja_text": "扉が開いて"
    },
    "33": {
        "start": 159.34,
        "end": 161.312,
        "ja_text": "あの声が飛び込んでくるんじゃないかって"
    },
    "34": {
        "start": 163.96,
        "end": 164.16,
        "ja_text": "岡部"
    },
    "35": {
        "start": 171.82,
        "end": 172.04,
        "ja_text": "岡部"
    },
    "36": {
        "start": 192.78,
        "end": 193.44,
        "ja_text": "大壁"
    },
    "37": {
        "start": 193.472,
        "end": 197.02,
        "ja_text": "すまなかった"
    },
    "38": {
        "start": 197.42,
        "end": 198.58,
        "ja_text": "ううんごめん"
    },
    "39": {
        "start": 199.29,
        "end": 200.82,
        "ja_text": "私こそ余計なこと言った"
    },
    "40": {
        "start": 201.94,
        "end": 204.2,
        "ja_text": "考えてみればあんたがここに来るなんて"
    },
    "41": {
        "start": 204.74,
        "end": 206.28,
        "ja_text": "まゆり絡み以外ないものね"
    },
    "42": {
        "start": 208.832,
        "end": 209.3,
        "ja_text": "そうか"
    },
    "43": {
        "start": 210.22,
        "end": 212.88,
        "ja_text": "あれ以来ほとんど顔見せたことないじゃない"
    },
    "44": {
        "start": 213.8,
        "end": 214.4,
        "ja_text": "橋田もだけど"
    },
    "45": {
        "start": 215.0,
        "end": 216.544,
        "ja_text": "あんたよりはまだね"
    },
    "46": {
        "start": 218.98,
        "end": 221.86,
        "ja_text": "ここは本当にアルファ世界線なのか"
    },
    "47": {
        "start": 226.54,
        "end": 227.66,
        "ja_text": "電話レンジは"
    },
    "48": {
        "start": 227.75,
        "end": 230.9,
        "ja_text": "あんたが破棄させたんでしょ忘れたの"
    },
    "49": {
        "start": 237.856,
        "end": 238.06,
        "ja_text": "岡部?"
    },
    "50": {
        "start": 238.912,
        "end": 241.56,
        "ja_text": "少し、外の風にあたってくる。"
    },
    "51": {
        "start": 243.3,
        "end": 244.44,
        "ja_text": "そう、しっかりね。"
    },
    "52": {
        "start": 254.22,
        "end": 258.3,
        "ja_text": "昨日までと何も変わらない、人、街の空気。"
    },
    "53": {
        "start": 261.12,
        "end": 265.14,
        "ja_text": "だが、ここはアルファ世界線だ、現実の。"
    },
    "54": {
        "start": 266.24,
        "end": 268.18,
        "ja_text": "あの、どんなに避けようとしても"
    },
    "55": {
        "start": 268.18,
        "end": 270.06,
        "ja_text": "マイリの死へと収束してしまった"
    },
    "56": {
        "start": 271.008,
        "end": 271.62,
        "ja_text": "世界戦"
    },
    "57": {
        "start": 280.68,
        "end": 284.46,
        "ja_text": "今病院に運ばれて心臓発作じゃないかって"
    },
    "58": {
        "start": 285.3,
        "end": 288.64,
        "ja_text": "たとえセルニアその手から逃れたとしても"
    },
    "59": {
        "start": 289.42,
        "end": 290.88,
        "ja_text": "この世界戦にいる限り"
    },
    "60": {
        "start": 291.4,
        "end": 293.12,
        "ja_text": "マイリは世界に殺される"
    },
    "61": {
        "start": 295.06,
        "end": 296.5,
        "ja_text": "だから、だから俺は…"
    },
    "62": {
        "start": 299.4,
        "end": 301.48,
        "ja_text": "なのに、なぜ俺はここにいる?"
    },
    "63": {
        "start": 302.4,
        "end": 304.4,
        "ja_text": "なぜリーディングシュタイナーが発動した?"
    },
    "64": {
        "start": 305.44,
        "end": 307.14,
        "ja_text": "ディメールも、タイムリープ"
    },
    "65": {
        "start": 307.14,
        "end": 308.82,
        "ja_text": "マシーンも使ってないのに…"
    },
    "66": {
        "start": 312.88,
        "end": 313.7,
        "ja_text": "オカリン?"
    },
    "67": {
        "start": 315.36,
        "end": 315.68,
        "ja_text": "誰?"
    },
    "68": {
        "start": 319.48,
        "end": 321.64,
        "ja_text": "秋葉に来るなんて珍しいじゃん"
    },
    "69": {
        "start": 323.12,
        "end": 324.46,
        "ja_text": "おかえりにゃさーい"
    },
    "70": {
        "start": 325.8,
        "end": 326.62,
        "ja_text": "ご主人様"
    },
    "71": {
        "start": 328.06,
        "end": 328.74,
        "ja_text": "ただいまー"
    },
    "72": {
        "start": 329.7,
        "end": 332.0,
        "ja_text": "今日はオカリンも連れてきたでござるよ"
    },
    "73": {
        "start": 334.016,
        "end": 334.54,
        "ja_text": "岡部さん"
    },
    "74": {
        "start": 334.67,
        "end": 335.46,
        "ja_text": "ルカ子"
    },
    "75": {
        "start": 335.53,
        "end": 336.352,
        "ja_text": "キョウマー"
    },
    "76": {
        "start": 337.66,
        "end": 339.06,
        "ja_text": "会いたかったにゃ"
    },
    "77": {
        "start": 340.032,
        "end": 341.58,
        "ja_text": "そんなに久しぶりだったか"
    },
    "78": {
        "start": 342.26,
        "end": 343.42,
        "ja_text": "いえ、全然"
    },
    "79": {
        "start": 344.32,
        "end": 346.92,
        "ja_text": "僕もしばらく足が遠のいていたしね"
    },
    "80": {
        "start": 347.7,
        "end": 348.1,
        "ja_text": "あの"
    },
    "81": {
        "start": 348.1,
        "end": 352.34,
        "ja_text": "あのー、はじめまして、ふぶきと言います"
    },
    "82": {
        "start": 353.12,
        "end": 354.72,
        "ja_text": "まゆりちゃんとはコスプレ仲"
    },
    "83": {
        "start": 354.72,
        "end": 356.56,
        "ja_text": "間でずいぶん世話になっていて"
    },
    "84": {
        "start": 357.82,
        "end": 359.86,
        "ja_text": "ふぶにゃんにはまゆしーがいなくなって"
    },
    "85": {
        "start": 359.86,
        "end": 361.9,
        "ja_text": "から店を手伝ってもらってるんだにゃ"
    },
    "86": {
        "start": 363.04,
        "end": 365.82,
        "ja_text": "つらかったけど、そっちの方がまゆ"
    },
    "87": {
        "start": 365.82,
        "end": 367.712,
        "ja_text": "りちゃんも喜んでくれるかなーって"
    },
    "88": {
        "start": 369.28,
        "end": 370.88,
        "ja_text": "夏コミマの時の写真です"
    },
    "89": {
        "start": 371.648,
        "end": 373.34,
        "ja_text": "すごく可愛くできたからって、"
    },
    "90": {
        "start": 373.86,
        "end": 375.88,
        "ja_text": "みんなで一緒に記念写真も撮って"
    },
    "91": {
        "start": 376.86,
        "end": 378.7,
        "ja_text": "全然元気だったんですよ"
    },
    "92": {
        "start": 379.46,
        "end": 381.34,
        "ja_text": "具合悪そうなところもなくて"
    },
    "93": {
        "start": 382.24,
        "end": 383.94,
        "ja_text": "いつものまゆりちゃんね"
    },
    "94": {
        "start": 386.62,
        "end": 389.2,
        "ja_text": "ふぶにゃん前にも言ったにゃん"
    },
    "95": {
        "start": 389.33,
        "end": 392.24,
        "ja_text": "泣けばそれだけまゆしーが心配しちゃうにゃん"
    },
    "96": {
        "start": 392.864,
        "end": 394.72,
        "ja_text": "にゃんふぶにゃん"
    },
    "97": {
        "start": 396.32,
        "end": 396.66,
        "ja_text": "もし"
    },
    "98": {
        "start": 399.84,
        "end": 400.94,
        "ja_text": "もしまゆりが"
    },
    "99": {
        "start": 402.24,
        "end": 403.32,
        "ja_text": "生きていられる世界"
    },
    "100": {
        "start": 403.48,
        "end": 403.72,
        "ja_text": "そんな世界…"
    },
    "101": {
        "start": 404.512,
        "end": 408.0,
        "ja_text": "そんな世界が…あったとしたら…"
    },
    "102": {
        "start": 409.88,
        "end": 410.68,
        "ja_text": "あ、誰?"
    },
    "103": {
        "start": 411.0,
        "end": 414.1,
        "ja_text": "オカリン、ちょっと…おい…"
    },
    "104": {
        "start": 415.8,
        "end": 417.24,
        "ja_text": "オカフェさん…"
    },
    "105": {
        "start": 420.6,
        "end": 421.9,
        "ja_text": "な、なんだよ…"
    },
    "106": {
        "start": 423.12,
        "end": 425.74,
        "ja_text": "言っていいことと悪いことがあるんじゃないか?"
    },
    "107": {
        "start": 427.296,
        "end": 429.38,
        "ja_text": "マユシが生きてる世界だなんて…"
    },
    "108": {
        "start": 430.1,
        "end": 432.82,
        "ja_text": "あの時それを選ばなかったのはオカリンだろ?"
    },
    "109": {
        "start": 434.11,
        "end": 436.44,
        "ja_text": "エシュロンのデータをクラッキング"
    },
    "110": {
        "start": 436.44,
        "end": 438.8,
        "ja_text": "するのをやめたのはオカリンだろ"
    },
    "111": {
        "start": 440.54,
        "end": 442.7,
        "ja_text": "俺は幼かったのか"
    },
    "112": {
        "start": 445.7,
        "end": 448.5,
        "ja_text": "自分でもずっと言い続けてたじゃんか"
    },
    "113": {
        "start": 449.8,
        "end": 451.32,
        "ja_text": "俺がマユシンを殺した"
    },
    "114": {
        "start": 452.2,
        "end": 454.22,
        "ja_text": "俺がそれを選択したんだって"
    },
    "115": {
        "start": 456.18,
        "end": 457.76,
        "ja_text": "なんで電話レンジもタイム"
    },
    "116": {
        "start": 457.76,
        "end": 459.4,
        "ja_text": "リーブマシンも破棄したん"
    },
    "117": {
        "start": 460.16,
        "end": 461.9,
        "ja_text": "今更後悔するくらいだった"
    },
    "118": {
        "start": 461.9,
        "end": 463.34,
        "ja_text": "ら残しておけばよかった"
    },
    "119": {
        "start": 465.02,
        "end": 466.64,
        "ja_text": "マキセ氏だってあんなに"
    },
    "120": {
        "start": 467.05,
        "end": 467.82,
        "ja_text": "クリスが"
    },
    "121": {
        "start": 468.18,
        "end": 469.3,
        "ja_text": "チャンスはある"
    },
    "122": {
        "start": 469.88,
        "end": 471.04,
        "ja_text": "まだやり直せる"
    },
    "123": {
        "start": 471.04,
        "end": 473.216,
        "ja_text": "まだできることはあるはずって"
    },
    "124": {
        "start": 478.336,
        "end": 479.32,
        "ja_text": "はいマキセです"
    },
    "125": {
        "start": 480.74,
        "end": 481.24,
        "ja_text": "橋田か"
    },
    "126": {
        "start": 481.42,
        "end": 482.32,
        "ja_text": "久しぶり"
    },
    "127": {
        "start": 482.66,
        "end": 483.54,
        "ja_text": "明けましておめでとう"
    },
    "128": {
        "start": 483.67,
        "end": 485.12,
        "ja_text": "明けおめのことよろ"
    },
    "129": {
        "start": 485.888,
        "end": 486.5,
        "ja_text": "珍しいわね"
    },
    "130": {
        "start": 487.14,
        "end": 489.04,
        "ja_text": "橋田が私に電話してくるなんて"
    },
    "131": {
        "start": 489.87,
        "end": 491.61,
        "ja_text": "オカリンに会った?"
    },
    "132": {
        "start": 492.4,
        "end": 492.76,
        "ja_text": "そう"
    },
    "133": {
        "start": 494.08,
        "end": 496.08,
        "ja_text": "やっぱ、ラボにも来たんだよね"
    },
    "134": {
        "start": 497.68,
        "end": 499.42,
        "ja_text": "ええ、あいつ何か言ってた?"
    },
    "135": {
        "start": 500.84,
        "end": 502.52,
        "ja_text": "うん、マユシのことまだ"
    },
    "136": {
        "start": 504.256,
        "end": 506.944,
        "ja_text": "もし生きてたら、そんな世界があったらって"
    },
    "137": {
        "start": 509.15,
        "end": 509.9,
        "ja_text": "オカビは?"
    },
    "138": {
        "start": 511.52,
        "end": 514.04,
        "ja_text": "僕さ、オカリンになんで今さら"
    },
    "139": {
        "start": 514.04,
        "end": 515.78,
        "ja_text": "そんなことって怒っちゃったけどさ"
    },
    "140": {
        "start": 516.86,
        "end": 517.52,
        "ja_text": "ひょっとして"
    },
    "141": {
        "start": 517.52,
        "end": 517.74,
        "ja_text": "てい"
    },
    "142": {
        "start": 548.64,
        "end": 550.32,
        "ja_text": "クリスな"
    },
    "143": {
        "start": 550.944,
        "end": 552.02,
        "ja_text": "ぜここが"
    },
    "144": {
        "start": 552.02,
        "end": 554.48,
        "ja_text": "わかるわよあんたのことだもの"
    },
    "145": {
        "start": 555.84,
        "end": 556.28,
        "ja_text": "そうか"
    },
    "146": {
        "start": 557.088,
        "end": 557.42,
        "ja_text": "嘘よ"
    },
    "147": {
        "start": 562.4,
        "end": 562.98,
        "ja_text": "GPS"
    },
    "148": {
        "start": 563.68,
        "end": 564.82,
        "ja_text": "そんなものが"
    },
    "149": {
        "start": 565.46,
        "end": 566.56,
        "ja_text": "やっぱり知らないのね"
    },
    "150": {
        "start": 568.88,
        "end": 569.4,
        "ja_text": "岡部あ"
    },
    "151": {
        "start": 570.048,
        "end": 570.28,
        "ja_text": "なた"
    },
    "152": {
        "start": 571.82,
        "end": 573.24,
        "ja_text": "別の世界線から来たわね"
    },
    "153": {
        "start": 584.52,
        "end": 586.28,
        "ja_text": "あんたが今座ってる場所は"
    },
    "154": {
        "start": 586.94,
        "end": 588.72,
        "ja_text": "マユリがいつも座ってた場所だった"
    },
    "155": {
        "start": 589.9,
        "end": 591.26,
        "ja_text": "あの子を諦めたあいつは"
    },
    "156": {
        "start": 591.86,
        "end": 594.02,
        "ja_text": "そこには絶対に座ろうとはしなかった"
    },
    "157": {
        "start": 595.68,
        "end": 598.04,
        "ja_text": "罪の意識だったのかしらね"
    },
    "158": {
        "start": 600.46,
        "end": 603.38,
        "ja_text": "あとあんたGPSのことも知らなかったでしょ"
    },
    "159": {
        "start": 604.34,
        "end": 605.88,
        "ja_text": "そうだななぜだ"
    },
    "160": {
        "start": 607.296,
        "end": 607.82,
        "ja_text": "教えない"
    },
    "161": {
        "start": 615.64,
        "end": 616.04,
        "ja_text": "それは"
    },
    "162": {
        "start": 616.44,
        "end": 617.56,
        "ja_text": "作り直したの"
    },
    "163": {
        "start": 618.26,
        "end": 620.26,
        "ja_text": "言うならば電話レンジ買い"
    },
    "164": {
        "start": 620.36,
        "end": 623.264,
        "ja_text": "いや電話レンジかっこ借り買いか"
    },
    "165": {
        "start": 623.96,
        "end": 624.8,
        "ja_text": "作り直した"
    },
    "166": {
        "start": 625.46,
        "end": 626.26,
        "ja_text": "どうして"
    },
    "167": {
        "start": 627.42,
        "end": 628.66,
        "ja_text": "過去にメールを送るため"
    },
    "168": {
        "start": 629.46,
        "end": 630.02,
        "ja_text": "いえ"
    },
    "169": {
        "start": 631.392,
        "end": 632.68,
        "ja_text": "世界線を変えるためよ"
    },
    "170": {
        "start": 634.176,
        "end": 636.0,
        "ja_text": "岡部あなたはこれを使って"
    },
    "171": {
        "start": 636.0,
        "end": 637.96,
        "ja_text": "元の世界線に戻りなさい"
    },
    "172": {
        "start": 639.264,
        "end": 639.86,
        "ja_text": "どういう"
    },
    "173": {
        "start": 640.03,
        "end": 640.38,
        "ja_text": "あ"
    },
    "174": {
        "start": 641.28,
        "end": 642.54,
        "ja_text": "なたはマユリの生きていた"
    },
    "175": {
        "start": 643.6,
        "end": 645.56,
        "ja_text": "というよりマユリを生かすことので"
    },
    "176": {
        "start": 645.56,
        "end": 647.44,
        "ja_text": "きた世界線から来た岡部なんでしょう"
    },
    "177": {
        "start": 650.02,
        "end": 651.88,
        "ja_text": "全てお見通しか"
    },
    "178": {
        "start": 652.64,
        "end": 654.92,
        "ja_text": "わかるわよどんだけ見てきたと"
    },
    "179": {
        "start": 655.86,
        "end": 657.06,
        "ja_text": "そういう意味じゃなく"
    },
    "180": {
        "start": 658.2,
        "end": 659.38,
        "ja_text": "違わないんだけど"
    },
    "181": {
        "start": 660.224,
        "end": 664.0,
        "ja_text": "とにかくあなたは違う世界線から来た岡部凛太郎"
    },
    "182": {
        "start": 664.96,
        "end": 665.96,
        "ja_text": "なら話は早い"
    },
    "183": {
        "start": 667.296,
        "end": 667.82,
        "ja_text": "戻りなさい"
    },
    "184": {
        "start": 671.84,
        "end": 673.06,
        "ja_text": "世界線を変えて"
    },
    "185": {
        "start": 673.75,
        "end": 675.84,
        "ja_text": "まゆりは確かに生きることができた"
    },
    "186": {
        "start": 677.82,
        "end": 680.5,
        "ja_text": "でもそんな世界線もこうして簡単に"
    },
    "187": {
        "start": 681.72,
        "end": 684.24,
        "ja_text": "俺が何をするでもなく変わってしまった"
    },
    "188": {
        "start": 685.568,
        "end": 688.66,
        "ja_text": "本当に今回は俺は何もしていないんだ"
    },
    "189": {
        "start": 688.66,
        "end": 690.38,
        "ja_text": "だそれなのに"
    },
    "190": {
        "start": 691.3,
        "end": 692.66,
        "ja_text": "なんでこんなこと になるんだ"
    },
    "191": {
        "start": 694.18,
        "end": 695.3,
        "ja_text": "俺はお前を"
    },
    "192": {
        "start": 696.74,
        "end": 698.06,
        "ja_text": "俺なんかを好いてくれた お"
    },
    "193": {
        "start": 698.06,
        "end": 700.04,
        "ja_text": "前をなかったことにしてまで"
    },
    "194": {
        "start": 701.52,
        "end": 701.97,
        "ja_text": "なのにな"
    },
    "195": {
        "start": 702.816,
        "end": 706.62,
        "ja_text": "のにお前をもう一度殺 せと言うのか"
    },
    "196": {
        "start": 708.52,
        "end": 710.96,
        "ja_text": "俺にはもうそんなこと"
    },
    "197": {
        "start": 720.928,
        "end": 721.4,
        "ja_text": "はじだ"
    },
    "198": {
        "start": 723.41,
        "end": 724.5,
        "ja_text": "オカリンは"
    },
    "199": {
        "start": 725.18,
        "end": 725.82,
        "ja_text": "出てくるって"
    },
    "200": {
        "start": 726.74,
        "end": 727.6,
        "ja_text": "結局は"
    },
    "201": {
        "start": 728.12,
        "end": 729.36,
        "ja_text": "オカベがマユリのこと"
    },
    "202": {
        "start": 729.9,
        "end": 731.26,
        "ja_text": "忘れられるわけないもんね"
    },
    "203": {
        "start": 734.62,
        "end": 735.4,
        "ja_text": "マキセ氏は"
    },
    "204": {
        "start": 736.8,
        "end": 738.1,
        "ja_text": "いや何でもないよ"
    },
    "205": {
        "start": 759.68,
        "end": 765.12,
        "ja_text": "ご視聴ありがとうございました"
    },
    "206": {
        "start": 782.8,
        "end": 783.8,
        "ja_text": "結論は出た"
    },
    "207": {
        "start": 786.18,
        "end": 787.66,
        "ja_text": "出るわけないわよね"
    },
    "208": {
        "start": 789.36,
        "end": 790.64,
        "ja_text": "もう電車動いてるわよね"
    },
    "209": {
        "start": 791.78,
        "end": 794.06,
        "ja_text": "1時間後秋葉原の駅で集合"
    },
    "210": {
        "start": 794.82,
        "end": 795.54,
        "ja_text": "なぜ"
    },
    "211": {
        "start": 796.04,
        "end": 797.58,
        "ja_text": "連れて行きたいところがあるの"
    },
    "212": {
        "start": 802.944,
        "end": 804.46,
        "ja_text": "白衣じゃないと目立たないわね"
    },
    "213": {
        "start": 805.58,
        "end": 807.2,
        "ja_text": "どこへ行くんだ"
    },
    "214": {
        "start": 807.74,
        "end": 809.04,
        "ja_text": "ついてくればわかるわ"
    },
    "215": {
        "start": 817.632,
        "end": 818.14,
        "ja_text": "なに?"
    },
    "216": {
        "start": 819.14,
        "end": 820.66,
        "ja_text": "いや、こうして電車に乗"
    },
    "217": {
        "start": 820.66,
        "end": 822.3,
        "ja_text": "るようなことなかったなと"
    },
    "218": {
        "start": 822.7,
        "end": 824.0,
        "ja_text": "あんまりジロジロ見んな。"
    },
    "219": {
        "start": 824.5,
        "end": 825.56,
        "ja_text": "駅員に突き出すぞ"
    },
    "220": {
        "start": 826.24,
        "end": 826.86,
        "ja_text": "冤罪だ"
    },
    "221": {
        "start": 827.26,
        "end": 829.26,
        "ja_text": "四川だけでセクハラが成立"
    },
    "222": {
        "start": 829.26,
        "end": 830.86,
        "ja_text": "した事案はいくらでもある"
    },
    "223": {
        "start": 832.448,
        "end": 835.24,
        "ja_text": "やはりアマデウスとは違うか"
    },
    "224": {
        "start": 835.84,
        "end": 836.72,
        "ja_text": "アマデウス?"
    },
    "225": {
        "start": 837.58,
        "end": 838.98,
        "ja_text": "いや、人工知能の"
    },
    "226": {
        "start": 839.27,
        "end": 840.8,
        "ja_text": "なんであんたが知ってんのよ"
    },
    "227": {
        "start": 841.408,
        "end": 842.36,
        "ja_text": "私話したっけ?"
    },
    "228": {
        "start": 842.848,
        "end": 845.18,
        "ja_text": "冷谷城さんとレスキネン教授とな"
    },
    "229": {
        "start": 845.18,
        "end": 845.56,
        "ja_text": "は?"
    },
    "230": {
        "start": 846.14,
        "end": 847.2,
        "ja_text": "マホ先輩と?"
    },
    "231": {
        "start": 847.32,
        "end": 849.6,
        "ja_text": "そっちの世界線ではどんなことになってんのよ"
    },
    "232": {
        "start": 849.6,
        "end": 850.72,
        "ja_text": "なんで怒ってるんだ"
    },
    "233": {
        "start": 850.72,
        "end": 851.84,
        "ja_text": "怒ってないし"
    },
    "234": {
        "start": 858.08,
        "end": 860.48,
        "ja_text": "そしてその直前アクセスができなくなった"
    },
    "235": {
        "start": 860.94,
        "end": 861.26,
        "ja_text": "うん"
    },
    "236": {
        "start": 861.82,
        "end": 863.16,
        "ja_text": "アマデウスに何か?"
    },
    "237": {
        "start": 863.48,
        "end": 864.24,
        "ja_text": "わからない"
    },
    "238": {
        "start": 865.12,
        "end": 866.6,
        "ja_text": "でも常識的に考えて"
    },
    "239": {
        "start": 866.78,
        "end": 869.46,
        "ja_text": "人工知能と世界線変動が関"
    },
    "240": {
        "start": 869.46,
        "end": 870.78,
        "ja_text": "係してるとは思えないけど"
    },
    "241": {
        "start": 871.68,
        "end": 872.448,
        "ja_text": "偶然か"
    },
    "242": {
        "start": 873.09,
        "end": 875.84,
        "ja_text": "アマデウスには私の記憶も保管されている"
    },
    "243": {
        "start": 876.928,
        "end": 879.66,
        "ja_text": "その中にタイムマシンの理論があることも"
    },
    "244": {
        "start": 880.01,
        "end": 880.62,
        "ja_text": "あるのか"
    },
    "245": {
        "start": 880.9,
        "end": 883.72,
        "ja_text": "私は理論的には否定してたけど"
    },
    "246": {
        "start": 884.55,
        "end": 886.44,
        "ja_text": "タイムマシンは可能ではない"
    },
    "247": {
        "start": 887.264,
        "end": 889.36,
        "ja_text": "けれど不可能とまでは言い切"
    },
    "248": {
        "start": 889.36,
        "end": 891.0,
        "ja_text": "れないといったところでしょうか"
    },
    "249": {
        "start": 891.78,
        "end": 892.42,
        "ja_text": "クリスの"
    },
    "250": {
        "start": 892.96,
        "end": 894.92,
        "ja_text": "アマデウスの答えは違っていた"
    },
    "251": {
        "start": 895.34,
        "end": 898.0,
        "ja_text": "パパに見てもらおうと思って私なりに"
    },
    "252": {
        "start": 899.712,
        "end": 901.36,
        "ja_text": "盗むの私の論文"
    },
    "253": {
        "start": 902.62,
        "end": 902.84,
        "ja_text": "岡部"
    },
    "254": {
        "start": 905.312,
        "end": 905.78,
        "ja_text": "大丈夫だ"
    },
    "255": {
        "start": 907.872,
        "end": 909.5,
        "ja_text": "それにしてもマホ先輩と知"
    },
    "256": {
        "start": 909.5,
        "end": 910.56,
        "ja_text": "り合いになってるなんてね"
    },
    "257": {
        "start": 911.328,
        "end": 912.74,
        "ja_text": "セミナーでたまたまな"
    },
    "258": {
        "start": 913.44,
        "end": 915.6,
        "ja_text": "先輩結構ガサツで融通効"
    },
    "259": {
        "start": 915.6,
        "end": 916.58,
        "ja_text": "かないところがあるでしょ"
    },
    "260": {
        "start": 917.42,
        "end": 918.32,
        "ja_text": "不器用だし"
    },
    "261": {
        "start": 919.648,
        "end": 921.14,
        "ja_text": "そこは変わってないんだな"
    },
    "262": {
        "start": 922.12,
        "end": 924.5,
        "ja_text": "じゃあお前も生意気な後輩だったのか"
    },
    "263": {
        "start": 925.16,
        "end": 925.98,
        "ja_text": "失礼ね"
    },
    "264": {
        "start": 926.688,
        "end": 927.9,
        "ja_text": "従順な後輩してました"
    },
    "265": {
        "start": 928.84,
        "end": 930.34,
        "ja_text": "いつも飲み物買いに行ってたし"
    },
    "266": {
        "start": 931.18,
        "end": 931.84,
        "ja_text": "三品茶とか"
    },
    "267": {
        "start": 960.38,
        "end": 961.92,
        "ja_text": "みんな来てくれているのね"
    },
    "268": {
        "start": 964.76,
        "end": 966.38,
        "ja_text": "まゆりが死んでからのあん"
    },
    "269": {
        "start": 966.38,
        "end": 968.08,
        "ja_text": "たはそれはひどいものだった"
    },
    "270": {
        "start": 969.22,
        "end": 970.9,
        "ja_text": "ラボにも大学にも行かず"
    },
    "271": {
        "start": 971.84,
        "end": 974.08,
        "ja_text": "毎日ここで日が暮れるまで過ごしていた"
    },
    "272": {
        "start": 975.34,
        "end": 975.76,
        "ja_text": "まるで"
    },
    "273": {
        "start": 977.34,
        "end": 978.1,
        "ja_text": "誰かに"
    },
    "274": {
        "start": 978.76,
        "end": 980.82,
        "ja_text": "天国へ連れて行ってほしいかのように"
    },
    "275": {
        "start": 985.98,
        "end": 987.6,
        "ja_text": "私にはどうすることもできなかった"
    },
    "276": {
        "start": 988.24,
        "end": 991.62,
        "ja_text": "だってそれは私を生かすためだったから"
    },
    "277": {
        "start": 993.5,
        "end": 993.8,
        "ja_text": "クリス"
    },
    "278": {
        "start": 995.04,
        "end": 996.14,
        "ja_text": "でもそれも終わり"
    },
    "279": {
        "start": 998.22,
        "end": 999.88,
        "ja_text": "終わりにしなきゃいけないの"
    },
    "280": {
        "start": 1000.66,
        "end": 1002.76,
        "ja_text": "このままじゃオカベが押しつぶされてしまう"
    },
    "281": {
        "start": 1004.8,
        "end": 1005.62,
        "ja_text": "同じだ"
    },
    "282": {
        "start": 1006.88,
        "end": 1008.8,
        "ja_text": "たとえベータ世界戦へ行っても"
    },
    "283": {
        "start": 1010.368,
        "end": 1011.4,
        "ja_text": "それは変わらないんだ"
    },
    "284": {
        "start": 1012.32,
        "end": 1014.48,
        "ja_text": "お前を見殺しに俺は"
    },
    "285": {
        "start": 1014.48,
        "end": 1016.5,
        "ja_text": "しっかりしなさい岡部凛太郎"
    },
    "286": {
        "start": 1020.64,
        "end": 1022.2,
        "ja_text": "なんて顔してんのよ"
    },
    "287": {
        "start": 1023.8,
        "end": 1026.14,
        "ja_text": "私の知ってる法王院凶魔さんなら"
    },
    "288": {
        "start": 1026.18,
        "end": 1028.86,
        "ja_text": "もっと自信に満ちた顔しなくちゃ"
    },
    "289": {
        "start": 1028.86,
        "end": 1031.7,
        "ja_text": "そんなのは設定だ嘘だ"
    },
    "290": {
        "start": 1032.84,
        "end": 1035.74,
        "ja_text": "あの時のまゆりを元気づけようとして作り上げた"
    },
    "291": {
        "start": 1036.73,
        "end": 1039.14,
        "ja_text": "あんたはまゆりに笑っていてほしかった"
    },
    "292": {
        "start": 1040.576,
        "end": 1041.42,
        "ja_text": "それだけなのよ"
    },
    "293": {
        "start": 1042.432,
        "end": 1043.94,
        "ja_text": "そしてそれは私も同じ"
    },
    "294": {
        "start": 1044.84,
        "end": 1047.22,
        "ja_text": "あんたの選択は間違っていない"
    },
    "295": {
        "start": 1048.02,
        "end": 1050.46,
        "ja_text": "あいつが間違えてしまっただけなのよ"
    },
    "296": {
        "start": 1051.16,
        "end": 1051.98,
        "ja_text": "この世界線は"
    },
    "297": {
        "start": 1053.42,
        "end": 1055.5,
        "ja_text": "だから戻りなさい岡部凛太郎"
    },
    "298": {
        "start": 1055.5,
        "end": 1058.6,
        "ja_text": "あなたが今ここにいるのは夢でしかない"
    },
    "299": {
        "start": 1060.06,
        "end": 1061.2,
        "ja_text": "現実に帰るの"
    },
    "300": {
        "start": 1061.2,
        "end": 1062.6,
        "ja_text": "夢"
    },
    "301": {
        "start": 1062.6,
        "end": 1062.976,
        "ja_text": "そう"
    },
    "302": {
        "start": 1113.312,
        "end": 1113.82,
        "ja_text": "戻りましょう"
    },
    "303": {
        "start": 1114.752,
        "end": 1115.02,
        "ja_text": "ラヴァイ"
    },
    "304": {
        "start": 1120.28,
        "end": 1122.98,
        "ja_text": "夢から覚める前に一つだけ約束して"
    },
    "305": {
        "start": 1123.58,
        "end": 1123.94,
        "ja_text": "なんだ"
    },
    "306": {
        "start": 1125.088,
        "end": 1126.86,
        "ja_text": "戻ったら私のことは忘れなさい"
    },
    "307": {
        "start": 1128.192,
        "end": 1130.1,
        "ja_text": "できるわけないだろ"
    },
    "308": {
        "start": 1131.04,
        "end": 1132.02,
        "ja_text": "できなくてもしなさい"
    },
    "309": {
        "start": 1132.992,
        "end": 1134.36,
        "ja_text": "それが私の望みなんだから"
    },
    "310": {
        "start": 1136.14,
        "end": 1137.1,
        "ja_text": "感情の問題じゃない"
    },
    "311": {
        "start": 1137.89,
        "end": 1138.52,
        "ja_text": "アマデウス"
    },
    "312": {
        "start": 1140.38,
        "end": 1143.1,
        "ja_text": "今回のあなたの世界線変動の原因はわからない"
    },
    "313": {
        "start": 1143.88,
        "end": 1146.5,
        "ja_text": "けれどタイムマシンが絡んでることは明白"
    },
    "314": {
        "start": 1147.52,
        "end": 1148.56,
        "ja_text": "でも電話レンジは"
    },
    "315": {
        "start": 1148.61,
        "end": 1151.2,
        "ja_text": "あっちの私については断言できないけれど"
    },
    "316": {
        "start": 1151.58,
        "end": 1152.9,
        "ja_text": "こっちの世界線では"
    },
    "317": {
        "start": 1153.664,
        "end": 1155.34,
        "ja_text": "私はあなたと出会ってタイムマ"
    },
    "318": {
        "start": 1155.34,
        "end": 1157.02,
        "ja_text": "シン理論を完成させてしまった"
    },
    "319": {
        "start": 1158.1,
        "end": 1159.9,
        "ja_text": "同じことにならない保証はない"
    },
    "320": {
        "start": 1161.0,
        "end": 1164.34,
        "ja_text": "少なくとも深く関わりを持つのは危険だと思う"
    },
    "321": {
        "start": 1169.86,
        "end": 1172.98,
        "ja_text": "指切りゲンマン 嘘ついたら"
    },
    "322": {
        "start": 1172.98,
        "end": 1178.06,
        "ja_text": "カイパに電極ぶっ刺す 指切った"
    },
    "323": {
        "start": 1180.66,
        "end": 1181.58,
        "ja_text": "語呂悪いな"
    },
    "324": {
        "start": 1181.58,
        "end": 1182.42,
        "ja_text": "ほっとけ"
    },
    "325": {
        "start": 1198.496,
        "end": 1198.62,
        "ja_text": "ねえ"
    },
    "326": {
        "start": 1200.128,
        "end": 1200.56,
        "ja_text": "覚えてる?"
    },
    "327": {
        "start": 1201.34,
        "end": 1202.52,
        "ja_text": "初めて会った時のこと"
    },
    "328": {
        "start": 1203.62,
        "end": 1205.6,
        "ja_text": "いきなり人の服まくり上げて"
    },
    "329": {
        "start": 1205.6,
        "end": 1207.22,
        "ja_text": "なんなんだこの変態は"
    },
    "330": {
        "start": 1207.22,
        "end": 1208.28,
        "ja_text": "と思ったわよ"
    },
    "331": {
        "start": 1211.24,
        "end": 1211.9,
        "ja_text": "そうか"
    },
    "332": {
        "start": 1212.52,
        "end": 1213.66,
        "ja_text": "こいつからしたら"
    },
    "333": {
        "start": 1214.46,
        "end": 1216.1,
        "ja_text": "あの時が初対面になるのか"
    },
    "334": {
        "start": 1217.248,
        "end": 1217.52,
        "ja_text": "俺は"
    },
    "335": {
        "start": 1220.52,
        "end": 1220.96,
        "ja_text": "待てよ"
    },
    "336": {
        "start": 1229.3,
        "end": 1229.88,
        "ja_text": "準備できたわ"
    },
    "337": {
        "start": 1230.88,
        "end": 1232.36,
        "ja_text": "これであとはそのメールを送れば"
    },
    "338": {
        "start": 1232.49,
        "end": 1234.8,
        "ja_text": "あなたは元の世界線に戻れる"
    },
    "339": {
        "start": 1242.944,
        "end": 1243.36,
        "ja_text": "岡部"
    },
    "340": {
        "start": 1252.58,
        "end": 1254.0,
        "ja_text": "元の世界線に戻れる。"
    },
    "341": {
        "start": 1255.168,
        "end": 1256.3,
        "ja_text": "マユリが死んでいない、"
    },
    "342": {
        "start": 1257.24,
        "end": 1258.46,
        "ja_text": "失わずに済む世界。"
    },
    "343": {
        "start": 1259.42,
        "end": 1259.74,
        "ja_text": "だが、"
    },
    "344": {
        "start": 1260.66,
        "end": 1261.88,
        "ja_text": "そこにこいつはいない。"
    },
    "345": {
        "start": 1262.34,
        "end": 1263.5,
        "ja_text": "クリスはいない。"
    },
    "346": {
        "start": 1264.28,
        "end": 1265.6,
        "ja_text": "俺が殺してしまった。"
    },
    "347": {
        "start": 1266.88,
        "end": 1267.26,
        "ja_text": "一番"
    },
    "348": {
        "start": 1268.48,
        "end": 1269.44,
        "ja_text": "大切なこと。"
    },
    "349": {
        "start": 1278.656,
        "end": 1280.1,
        "ja_text": "岡部"
    },
    "350": {
        "start": 1311.776,
        "end": 1315.584,
        "ja_text": "いつだって誰かを想う"
    },
    "351": {
        "start": 1317.824,
        "end": 1319.9,
        "ja_text": "優しい嘘だって"
    },
    "352": {
        "start": 1319.9,
        "end": 1324.12,
        "ja_text": "みんなちゃんと知ってる"
    },
    "353": {
        "start": 1324.12,
        "end": 1327.98,
        "ja_text": "ずっと一緒にいたいよ"
    },
    "354": {
        "start": 1329.04,
        "end": 1332.26,
        "ja_text": "本当の気持ち"
    },
    "355": {
        "start": 1334.144,
        "end": 1336.74,
        "ja_text": "これは愛なのかな"
    },
    "356": {
        "start": 1337.44,
        "end": 1342.52,
        "ja_text": "奇跡と運命の出会いから"
    },
    "357": {
        "start": 1343.0,
        "end": 1348.88,
        "ja_text": "僕らはまた あの場所へと"
    },
    "358": {
        "start": 1348.88,
        "end": 1355.26,
        "ja_text": "きらめく星 夜空に 手を伸ばせば"
    },
    "359": {
        "start": 1355.808,
        "end": 1357.64,
        "ja_text": "蘇るね"
    },
    "360": {
        "start": 1357.64,
        "end": 1363.98,
        "ja_text": "想いも ぬくもりの気も 溢れ出すよ"
    },
    "361": {
        "start": 1363.98,
        "end": 1365.5,
        "ja_text": "あの時"
    },
    "362": {
        "start": 1366.08,
        "end": 1367.86,
        "ja_text": "あの場面で"
    },
    "363": {
        "start": 1368.608,
        "end": 1370.4,
        "ja_text": "君の言葉"
    },
    "364": {
        "start": 1372.512,
        "end": 1378.22,
        "ja_text": "泣いて笑った 記憶のすべてが"
    },
    "365": {
        "start": 1378.92,
        "end": 1381.08,
        "ja_text": "書き換わるとしても"
    },
    "366": {
        "start": 1381.08,
        "end": 1388.32,
        "ja_text": "デジャヴみたいに 心の奥で揺れて"
    }
}