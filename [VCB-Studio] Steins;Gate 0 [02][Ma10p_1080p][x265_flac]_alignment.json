{
    "1": {
        "start": 1.376,
        "end": 3.64,
        "ja_text": "それが、これからデモンストレーショ"
    },
    "2": {
        "start": 3.64,
        "end": 5.72,
        "ja_text": "ンするシステム、アマデウスです。"
    },
    "3": {
        "start": 7.168,
        "end": 8.86,
        "ja_text": "研究員であったマキセ・クリスの"
    },
    "4": {
        "start": 8.86,
        "end": 10.7,
        "ja_text": "理論をもとに完成したシステム。"
    },
    "5": {
        "start": 11.72,
        "end": 12.24,
        "ja_text": "ご覧ください。"
    },
    "6": {
        "start": 20.98,
        "end": 21.8,
        "ja_text": "失礼しました。"
    },
    "7": {
        "start": 22.3,
        "end": 24.86,
        "ja_text": "起動まで少し時間がかかってしまうようです。"
    },
    "8": {
        "start": 25.48,
        "end": 26.32,
        "ja_text": "少々お待ちください。"
    },
    "9": {
        "start": 26.88,
        "end": 28.06,
        "ja_text": "なんだ、失敗か?"
    },
    "10": {
        "start": 28.78,
        "end": 30.76,
        "ja_text": "そもそも、人の記憶を外部ストレ"
    },
    "11": {
        "start": 30.76,
        "end": 32.38,
        "ja_text": "ージに保存するとか可能なのか?"
    },
    "12": {
        "start": 32.78,
        "end": 34.74,
        "ja_text": "記憶をどうサンプリングするのか?"
    },
    "13": {
        "start": 35.872,
        "end": 38.1,
        "ja_text": "そもそもこれは医学的に無謀でしょう!"
    },
    "14": {
        "start": 38.53,
        "end": 40.36,
        "ja_text": "デジタルデータを脳に書き戻"
    },
    "15": {
        "start": 40.36,
        "end": 42.12,
        "ja_text": "すなんて、絶対に不可能だ!"
    },
    "16": {
        "start": 42.28,
        "end": 43.74,
        "ja_text": "正気の沙汰ではない!"
    },
    "17": {
        "start": 44.192,
        "end": 46.52,
        "ja_text": "サイエンス誌に掲載された論文も読み"
    },
    "18": {
        "start": 46.52,
        "end": 48.44,
        "ja_text": "ましたが、にわかには信じられない!"
    },
    "19": {
        "start": 48.64,
        "end": 51.76,
        "ja_text": "ましてや、筆頭論者が若干17"
    },
    "20": {
        "start": 51.76,
        "end": 53.86,
        "ja_text": "歳の女性だったとあっては!"
    },
    "21": {
        "start": 55.38,
        "end": 56.38,
        "ja_text": "あなたね"
    },
    "22": {
        "start": 56.56,
        "end": 57.54,
        "ja_text": "逃げ張り"
    },
    "23": {
        "start": 63.808,
        "end": 66.12,
        "ja_text": "やってみもしないで何が分かるって言うんだ"
    },
    "24": {
        "start": 66.42,
        "end": 68.9,
        "ja_text": "最初は無理だと不可能だと思わ"
    },
    "25": {
        "start": 68.9,
        "end": 70.62,
        "ja_text": "れていた技術なんていくらでもある"
    },
    "26": {
        "start": 71.328,
        "end": 72.88,
        "ja_text": "それを克服した研究者がいた"
    },
    "27": {
        "start": 72.88,
        "end": 74.42,
        "ja_text": "からこそ今があるんだろう"
    },
    "28": {
        "start": 74.64,
        "end": 77.14,
        "ja_text": "ただ批判するだけじゃ何も生まれない"
    },
    "29": {
        "start": 86.784,
        "end": 87.5,
        "ja_text": "素晴らしい"
    },
    "30": {
        "start": 90.46,
        "end": 92.76,
        "ja_text": "彼のような挑戦者がいつでも"
    },
    "31": {
        "start": 92.76,
        "end": 94.38,
        "ja_text": "科学を進歩させてきたのです"
    },
    "32": {
        "start": 95.04,
        "end": 97.52,
        "ja_text": "彼ならきっと第三のアインシュ"
    },
    "33": {
        "start": 97.52,
        "end": 98.78,
        "ja_text": "タインになれるかもしれません"
    },
    "34": {
        "start": 99.7,
        "end": 103.1,
        "ja_text": "しかし同時に科学者は冷静でなければなりません"
    },
    "35": {
        "start": 103.52,
        "end": 107.06,
        "ja_text": "大声を出すのは実験が成功した時だけでいい"
    },
    "36": {
        "start": 111.09,
        "end": 112.22,
        "ja_text": "お待たせしました"
    },
    "37": {
        "start": 113.18,
        "end": 115.32,
        "ja_text": "これより私に代わって、より"
    },
    "38": {
        "start": 115.32,
        "end": 117.38,
        "ja_text": "優秀な通訳が画面に登場します"
    },
    "39": {
        "start": 122.38,
        "end": 123.96,
        "ja_text": "皆さん、初めてお目にかかります"
    },
    "40": {
        "start": 125.08,
        "end": 126.18,
        "ja_text": "私はヒアジョー・マホ"
    },
    "41": {
        "start": 127.7,
        "end": 130.46,
        "ja_text": "正確に言うなら、78時間22"
    },
    "42": {
        "start": 130.46,
        "end": 132.68,
        "ja_text": "分前の彼女から派生した存在"
    },
    "43": {
        "start": 133.376,
        "end": 134.18,
        "ja_text": "ということになります"
    },
    "44": {
        "start": 136.224,
        "end": 138.42,
        "ja_text": "私は、およそ4日前のヒア"
    },
    "45": {
        "start": 138.42,
        "end": 139.76,
        "ja_text": "ジョー・マホの記憶を持ち"
    },
    "46": {
        "start": 139.98,
        "end": 142.04,
        "ja_text": "そのデータを元に動いているのです"
    },
    "47": {
        "start": 142.92,
        "end": 145.26,
        "ja_text": "今鼻で笑ったそこの5列目の"
    },
    "48": {
        "start": 145.61,
        "end": 147.48,
        "ja_text": "ええ赤いチェックのあなた"
    },
    "49": {
        "start": 148.576,
        "end": 150.0,
        "ja_text": "今こう思っていませんか"
    },
    "50": {
        "start": 150.78,
        "end": 153.04,
        "ja_text": "あらかじめ予測をプログラムしておけば"
    },
    "51": {
        "start": 153.68,
        "end": 155.52,
        "ja_text": "この程度の反応は可能だと"
    },
    "52": {
        "start": 156.768,
        "end": 157.06,
        "ja_text": "あるいは"
    },
    "53": {
        "start": 158.12,
        "end": 158.98,
        "ja_text": "そこの私が"
    },
    "54": {
        "start": 159.11,
        "end": 161.78,
        "ja_text": "パソコンで私を操作しているのではと"
    },
    "55": {
        "start": 163.008,
        "end": 165.28,
        "ja_text": "また多くの人はこう思うでしょう"
    },
    "56": {
        "start": 165.63,
        "end": 165.98,
        "ja_text": "人"
    },
    "57": {
        "start": 166.752,
        "end": 169.56,
        "ja_text": "の記憶をデータとして保存なんてできるのかと"
    },
    "58": {
        "start": 170.496,
        "end": 171.5,
        "ja_text": "ですがそれならば"
    },
    "59": {
        "start": 173.68,
        "end": 176.16,
        "ja_text": "一体私は何でしょうか"
    },
    "60": {
        "start": 192.96,
        "end": 197.34,
        "ja_text": "この世界は非現実"
    },
    "61": {
        "start": 197.61,
        "end": 202.78,
        "ja_text": "ただすり込まれたビジョン"
    },
    "62": {
        "start": 205.2,
        "end": 210.8,
        "ja_text": "無限遠征 価値観を今 上"
    },
    "63": {
        "start": 210.8,
        "end": 214.8,
        "ja_text": "書きする 変哲のない宇宙"
    },
    "64": {
        "start": 215.2,
        "end": 220.26,
        "ja_text": "傲慢な神は 目に映らない"
    },
    "65": {
        "start": 220.46,
        "end": 225.4,
        "ja_text": "高速度で支配続けるならば"
    },
    "66": {
        "start": 225.4,
        "end": 232.36,
        "ja_text": "僕は 僕だけは 奇跡的で"
    },
    "67": {
        "start": 232.36,
        "end": 236.32,
        "ja_text": "致命的なマイノリティでいい"
    },
    "68": {
        "start": 237.24,
        "end": 239.4,
        "ja_text": "I can fly high あの"
    },
    "69": {
        "start": 239.4,
        "end": 243.98,
        "ja_text": "瞬間 あの場面が 君にとって特別なら"
    },
    "70": {
        "start": 244.19,
        "end": 249.5,
        "ja_text": "過去は離れてゆくものなんかじゃなくて"
    },
    "71": {
        "start": 249.5,
        "end": 254.86,
        "ja_text": "傷つくことの痛みより 大事な真相のすべての"
    },
    "72": {
        "start": 254.86,
        "end": 257.9,
        "ja_text": "光が今 照るわ"
    },
    "73": {
        "start": 259.82,
        "end": 262.32,
        "ja_text": "There is no God,"
    },
    "74": {
        "start": 262.32,
        "end": 265.28,
        "ja_text": "wonderful new world"
    },
    "75": {
        "start": 281.24,
        "end": 282.18,
        "ja_text": "アマデウス"
    },
    "76": {
        "start": 284.78,
        "end": 286.36,
        "ja_text": "クレジットカードの番号"
    },
    "77": {
        "start": 286.92,
        "end": 288.4,
        "ja_text": "言うはずがありません"
    },
    "78": {
        "start": 289.312,
        "end": 291.06,
        "ja_text": "いつ頃までパパとお風呂に入っていた?"
    },
    "79": {
        "start": 292.06,
        "end": 293.64,
        "ja_text": "セクハラで訴えていいですか?"
    },
    "80": {
        "start": 294.848,
        "end": 297.44,
        "ja_text": "一週間前のパジャマの色なんて覚えていません"
    },
    "81": {
        "start": 298.44,
        "end": 298.94,
        "ja_text": "忘れました"
    },
    "82": {
        "start": 301.216,
        "end": 302.64,
        "ja_text": "AIであんなやりとりを"
    },
    "83": {
        "start": 303.7,
        "end": 304.0,
        "ja_text": "しかも"
    },
    "84": {
        "start": 304.64,
        "end": 305.74,
        "ja_text": "感情的な反応や"
    },
    "85": {
        "start": 306.3,
        "end": 308.04,
        "ja_text": "不必要な記憶の忘却まで"
    },
    "86": {
        "start": 308.94,
        "end": 309.76,
        "ja_text": "あれではまるで"
    },
    "87": {
        "start": 309.76,
        "end": 311.24,
        "ja_text": "あ、アインスタイン"
    },
    "88": {
        "start": 311.96,
        "end": 313.92,
        "ja_text": "アマデイス、どう思ったの?"
    },
    "89": {
        "start": 315.04,
        "end": 316.72,
        "ja_text": "あ、いや、ソリ"
    },
    "90": {
        "start": 318.78,
        "end": 321.06,
        "ja_text": "やっぱりこういうのには向かないな"
    },
    "91": {
        "start": 324.62,
        "end": 326.96,
        "ja_text": "あなた、受付で会った"
    },
    "92": {
        "start": 328.2,
        "end": 328.7,
        "ja_text": "えっと"
    },
    "93": {
        "start": 329.536,
        "end": 330.52,
        "ja_text": "岡部凛太郎です"
    },
    "94": {
        "start": 331.52,
        "end": 333.12,
        "ja_text": "冷谷城さんでしたよね"
    },
    "95": {
        "start": 333.856,
        "end": 335.1,
        "ja_text": "珍しい苗字でしょ"
    },
    "96": {
        "start": 336.032,
        "end": 337.62,
        "ja_text": "沖縄ではよくあるんだけれど"
    },
    "97": {
        "start": 338.272,
        "end": 339.28,
        "ja_text": "えっと…"
    },
    "98": {
        "start": 339.28,
        "end": 340.04,
        "ja_text": "おう…"
    },
    "99": {
        "start": 341.74,
        "end": 343.82,
        "ja_text": "ち、ちゃんとした服も持ってきた…"
    },
    "100": {
        "start": 344.82,
        "end": 346.42,
        "ja_text": "つもりだったのよ"
    },
    "101": {
        "start": 350.78,
        "end": 352.1,
        "ja_text": "今日は、すみませんでした"
    },
    "102": {
        "start": 352.5,
        "end": 352.86,
        "ja_text": "え?"
    },
    "103": {
        "start": 354.0,
        "end": 356.04,
        "ja_text": "いや、セミナーの途中で邪魔を…"
    },
    "104": {
        "start": 357.74,
        "end": 359.12,
        "ja_text": "気にすることないわ"
    },
    "105": {
        "start": 359.43,
        "end": 361.82,
        "ja_text": "あなたがもし声を上げてくれなかったら"
    },
    "106": {
        "start": 362.44,
        "end": 364.26,
        "ja_text": "もっとひどいことになっていたと思うし"
    },
    "107": {
        "start": 365.312,
        "end": 368.04,
        "ja_text": "それと無理に丁寧に喋らなくてもいいわよ"
    },
    "108": {
        "start": 370.592,
        "end": 371.52,
        "ja_text": "じゃあ遠慮なく"
    },
    "109": {
        "start": 372.86,
        "end": 374.4,
        "ja_text": "今日のセミナーは興味深かった"
    },
    "110": {
        "start": 375.38,
        "end": 378.24,
        "ja_text": "あんな人工知能が完成していただなんて"
    },
    "111": {
        "start": 379.58,
        "end": 381.56,
        "ja_text": "ありがとうと言いたいところだけれど"
    },
    "112": {
        "start": 382.624,
        "end": 384.56,
        "ja_text": "残念ながら完成には程遠いわ"
    },
    "113": {
        "start": 385.5,
        "end": 386.3,
        "ja_text": "そうなのか"
    },
    "114": {
        "start": 386.944,
        "end": 387.96,
        "ja_text": "課題は山積みね"
    },
    "115": {
        "start": 389.4,
        "end": 391.1,
        "ja_text": "例えば取り出した記憶データ"
    },
    "116": {
        "start": 391.1,
        "end": 392.72,
        "ja_text": "を脳に書き戻すことができても"
    },
    "117": {
        "start": 393.408,
        "end": 395.6,
        "ja_text": "脳がそれを利用できなければ意味がない"
    },
    "118": {
        "start": 396.64,
        "end": 399.32,
        "ja_text": "人間が記憶にアクセスしようとするとき"
    },
    "119": {
        "start": 399.54,
        "end": 402.48,
        "ja_text": "前頭腰から側頭腰へ信号が行く"
    },
    "120": {
        "start": 403.84,
        "end": 406.28,
        "ja_text": "トップダウン記憶検索信号"
    },
    "121": {
        "start": 406.42,
        "end": 406.94,
        "ja_text": "よ"
    },
    "122": {
        "start": 407.872,
        "end": 408.7,
        "ja_text": "く知ってるわね"
    },
    "123": {
        "start": 408.95,
        "end": 410.84,
        "ja_text": "外部から送られた信号を"
    },
    "124": {
        "start": 411.0,
        "end": 413.38,
        "ja_text": "側頭腰が認識するためには"
    },
    "125": {
        "start": 415.52,
        "end": 418.88,
        "ja_text": "でコピーした疑似パルスを前頭腰に送り込めば"
    },
    "126": {
        "start": 418.96,
        "end": 421.52,
        "ja_text": "記憶検索信号は働く"
    },
    "127": {
        "start": 422.18,
        "end": 423.02,
        "ja_text": "あってるか"
    },
    "128": {
        "start": 423.02,
        "end": 424.46,
        "ja_text": "あなた"
    },
    "129": {
        "start": 425.34,
        "end": 426.9,
        "ja_text": "これ自分で導き出したの"
    },
    "130": {
        "start": 427.54,
        "end": 427.9,
        "ja_text": "あ"
    },
    "131": {
        "start": 429.408,
        "end": 430.36,
        "ja_text": "なんか変か"
    },
    "132": {
        "start": 431.18,
        "end": 432.22,
        "ja_text": "私の後輩がね"
    },
    "133": {
        "start": 433.0,
        "end": 435.26,
        "ja_text": "全く同じ理論を提唱していたのよ"
    },
    "134": {
        "start": 436.32,
        "end": 436.86,
        "ja_text": "確かまだ"
    },
    "135": {
        "start": 437.58,
        "end": 439.66,
        "ja_text": "どこにも発表していなかったはずだけれど"
    },
    "136": {
        "start": 441.088,
        "end": 442.88,
        "ja_text": "脳科学専攻でもないあなたが"
    },
    "137": {
        "start": 443.52,
        "end": 444.72,
        "ja_text": "彼女と同じ結論に"
    },
    "138": {
        "start": 445.92,
        "end": 446.3,
        "ja_text": "偶然"
    },
    "139": {
        "start": 451.08,
        "end": 451.44,
        "ja_text": "違う"
    },
    "140": {
        "start": 452.84,
        "end": 456.26,
        "ja_text": "今の話はクリスからレクチャーされたんだ"
    },
    "141": {
        "start": 456.82,
        "end": 457.66,
        "ja_text": "クリスが?"
    },
    "142": {
        "start": 458.06,
        "end": 458.42,
        "ja_text": "いつ?"
    },
    "143": {
        "start": 458.58,
        "end": 459.14,
        "ja_text": "どこで?"
    },
    "144": {
        "start": 460.02,
        "end": 462.58,
        "ja_text": "彼女がこっちに留学していた時だよ"
    },
    "145": {
        "start": 463.44,
        "end": 465.88,
        "ja_text": "友達になってそういう話をよくした"
    },
    "146": {
        "start": 466.816,
        "end": 468.46,
        "ja_text": "彼女が友達?"
    },
    "147": {
        "start": 470.14,
        "end": 472.04,
        "ja_text": "そうだ隠していたみたいで悪かった"
    },
    "148": {
        "start": 472.62,
        "end": 476.14,
        "ja_text": "いえ、むしろ感謝するわ、"
    },
    "149": {
        "start": 477.08,
        "end": 478.72,
        "ja_text": "あの子と友達になってくれて"
    },
    "150": {
        "start": 479.648,
        "end": 481.4,
        "ja_text": "口喧嘩ばかりだったけどな"
    },
    "151": {
        "start": 482.4,
        "end": 486.2,
        "ja_text": "彼女らしいわ、絶対に負けを認めなかったでしょ"
    },
    "152": {
        "start": 487.75,
        "end": 489.44,
        "ja_text": "ああ、へりくつばかりこねていた"
    },
    "153": {
        "start": 489.92,
        "end": 493.26,
        "ja_text": "あんたの前頭葉を書き出してやろうか、とかな"
    },
    "154": {
        "start": 494.86,
        "end": 495.7,
        "ja_text": "言いそう"
    },
    "155": {
        "start": 495.91,
        "end": 496.56,
        "ja_text": "だろ、"
    },
    "156": {
        "start": 497.8,
        "end": 500.12,
        "ja_text": "後輩の教育はちゃんとしておいてほしかったな"
    },
    "157": {
        "start": 500.92,
        "end": 502.58,
        "ja_text": "その点については認めるわ"
    },
    "158": {
        "start": 503.36,
        "end": 504.26,
        "ja_text": "陳謝いたします"
    },
    "159": {
        "start": 516.96,
        "end": 518.46,
        "ja_text": "ごめんなさい"
    },
    "160": {
        "start": 518.46,
        "end": 519.86,
        "ja_text": "変よね"
    },
    "161": {
        "start": 520.96,
        "end": 522.08,
        "ja_text": "こんなところで急に"
    },
    "162": {
        "start": 523.36,
        "end": 523.96,
        "ja_text": "いや"
    },
    "163": {
        "start": 525.184,
        "end": 525.74,
        "ja_text": "仲良"
    },
    "164": {
        "start": 526.368,
        "end": 527.06,
        "ja_text": "かったんだな"
    },
    "165": {
        "start": 527.33,
        "end": 529.46,
        "ja_text": "そういうわけじゃない"
    },
    "166": {
        "start": 529.46,
        "end": 530.6,
        "ja_text": "…ない…けど…"
    },
    "167": {
        "start": 537.94,
        "end": 538.5,
        "ja_text": "花も…"
    },
    "168": {
        "start": 538.62,
        "end": 539.7,
        "ja_text": "言わなくていい"
    },
    "169": {
        "start": 544.26,
        "end": 545.28,
        "ja_text": "おー、マホー"
    },
    "170": {
        "start": 546.34,
        "end": 547.72,
        "ja_text": "このところにいたのですね"
    },
    "171": {
        "start": 549.04,
        "end": 551.6,
        "ja_text": "おー、君はミスター・アインシュテイン"
    },
    "172": {
        "start": 552.544,
        "end": 554.26,
        "ja_text": "パーティーに来てくれていたのですね"
    },
    "173": {
        "start": 556.74,
        "end": 558.76,
        "ja_text": "もしかしてジャパネイズシュラバーですか"
    },
    "174": {
        "start": 560.1,
        "end": 562.3,
        "ja_text": "ジャパネイズドギザ見れますか"
    },
    "175": {
        "start": 562.3,
        "end": 563.96,
        "ja_text": "いやこれは"
    },
    "176": {
        "start": 563.96,
        "end": 564.928,
        "ja_text": "違います"
    },
    "177": {
        "start": 566.5,
        "end": 570.7,
        "ja_text": "私が勝手にクリスの話になってつい"
    },
    "178": {
        "start": 571.488,
        "end": 572.14,
        "ja_text": "クリス"
    },
    "179": {
        "start": 572.9,
        "end": 576.42,
        "ja_text": "もしかして君はクリスと面識があるのかい"
    },
    "180": {
        "start": 577.16,
        "end": 577.56,
        "ja_text": "はい"
    },
    "181": {
        "start": 581.408,
        "end": 581.94,
        "ja_text": "そうですか"
    },
    "182": {
        "start": 582.58,
        "end": 585.02,
        "ja_text": "彼女が日本に滞在していた時に"
    },
    "183": {
        "start": 585.696,
        "end": 586.76,
        "ja_text": "岡部凛太郎と言います"
    },
    "184": {
        "start": 587.64,
        "end": 588.66,
        "ja_text": "電気代の学生です"
    },
    "185": {
        "start": 589.504,
        "end": 590.4,
        "ja_text": "それでセミナーに"
    },
    "186": {
        "start": 591.56,
        "end": 593.28,
        "ja_text": "もしかしてあの時声を上"
    },
    "187": {
        "start": 593.28,
        "end": 594.78,
        "ja_text": "げてくれたのはクリスの?"
    },
    "188": {
        "start": 595.1,
        "end": 596.5,
        "ja_text": "いや、あれは"
    },
    "189": {
        "start": 597.98,
        "end": 600.96,
        "ja_text": "いえ、そういう側面もあったかもしれません"
    },
    "190": {
        "start": 602.816,
        "end": 603.66,
        "ja_text": "そういうことなら"
    },
    "191": {
        "start": 604.34,
        "end": 604.84,
        "ja_text": "マホ"
    },
    "192": {
        "start": 605.76,
        "end": 609.22,
        "ja_text": "ミスター岡部を会わせてあげてはどうかな"
    },
    "193": {
        "start": 610.12,
        "end": 610.58,
        "ja_text": "彼女に"
    },
    "194": {
        "start": 612.704,
        "end": 613.02,
        "ja_text": "彼女"
    },
    "195": {
        "start": 613.696,
        "end": 616.84,
        "ja_text": "教授でも彼は部外者の学生ですよ"
    },
    "196": {
        "start": 617.38,
        "end": 620.42,
        "ja_text": "クリスの友人であれば部外者ではないよ"
    },
    "197": {
        "start": 621.08,
        "end": 624.0,
        "ja_text": "ここで出会った幸運を大切にしようじゃないか"
    },
    "198": {
        "start": 625.56,
        "end": 628.24,
        "ja_text": "待ってください話が見えないのですが"
    },
    "199": {
        "start": 628.9,
        "end": 629.86,
        "ja_text": "会うって誰と"
    },
    "200": {
        "start": 630.94,
        "end": 631.74,
        "ja_text": "人ではないわ"
    },
    "201": {
        "start": 632.54,
        "end": 633.98,
        "ja_text": "会うのはアマデウス"
    },
    "202": {
        "start": 634.784,
        "end": 636.48,
        "ja_text": "さっきのデモンストレーションの"
    },
    "203": {
        "start": 636.72,
        "end": 637.02,
        "ja_text": "ア"
    },
    "204": {
        "start": 637.536,
        "end": 638.86,
        "ja_text": "マデウスのサンプルとして"
    },
    "205": {
        "start": 638.86,
        "end": 642.0,
        "ja_text": "そして私のデータの他にもう一人"
    },
    "206": {
        "start": 642.0,
        "end": 643.92,
        "ja_text": "研究者のデータが存在しているの"
    },
    "207": {
        "start": 645.02,
        "end": 645.888,
        "ja_text": "研究…"
    },
    "208": {
        "start": 663.68,
        "end": 666.12,
        "ja_text": "アマデウスにクリスの記憶が…"
    },
    "209": {
        "start": 667.12,
        "end": 669.86,
        "ja_text": "今まで私とマホトで彼女と話して"
    },
    "210": {
        "start": 669.86,
        "end": 671.52,
        "ja_text": "ディーラーを取ってきたのだが"
    },
    "211": {
        "start": 671.67,
        "end": 673.7,
        "ja_text": "話題にも限界があってね"
    },
    "212": {
        "start": 674.84,
        "end": 675.2,
        "ja_text": "どうかな"
    },
    "213": {
        "start": 676.32,
        "end": 678.26,
        "ja_text": "よく考えた方がいいわ"
    },
    "214": {
        "start": 679.7,
        "end": 681.28,
        "ja_text": "クリスとどの程度親し"
    },
    "215": {
        "start": 681.28,
        "end": 682.7,
        "ja_text": "かったのかわからないけれど"
    },
    "216": {
        "start": 684.08,
        "end": 685.76,
        "ja_text": "彼女と親しければ親しいほど"
    },
    "217": {
        "start": 686.54,
        "end": 689.66,
        "ja_text": "アマデウスの存在は辛いものになるから"
    },
    "218": {
        "start": 691.072,
        "end": 693.36,
        "ja_text": "8ヶ月前のあいつの"
    },
    "219": {
        "start": 698.75,
        "end": 699.6,
        "ja_text": "いらっしゃい"
    },
    "220": {
        "start": 704.4,
        "end": 706.84,
        "ja_text": "各国の農科学研究者が連携して"
    },
    "221": {
        "start": 707.616,
        "end": 709.38,
        "ja_text": "新しい機構を作る予定なの"
    },
    "222": {
        "start": 710.28,
        "end": 712.42,
        "ja_text": "ここはまだあくまで準備室なんだけどね"
    },
    "223": {
        "start": 713.56,
        "end": 714.02,
        "ja_text": "教授は"
    },
    "224": {
        "start": 714.92,
        "end": 715.9,
        "ja_text": "今日は日曜だもの"
    },
    "225": {
        "start": 716.07,
        "end": 716.86,
        "ja_text": "オフよ"
    },
    "226": {
        "start": 718.6,
        "end": 719.56,
        "ja_text": "もう一度聞くけど"
    },
    "227": {
        "start": 720.76,
        "end": 721.48,
        "ja_text": "本当に会う?"
    },
    "228": {
        "start": 724.48,
        "end": 726.4,
        "ja_text": "思ったよりもずっと親しかったのね"
    },
    "229": {
        "start": 726.86,
        "end": 727.78,
        "ja_text": "あなたたち"
    },
    "230": {
        "start": 728.98,
        "end": 730.54,
        "ja_text": "ここにあるアマデウスは"
    },
    "231": {
        "start": 731.26,
        "end": 733.6,
        "ja_text": "話す声も言葉も彼女そのもの"
    },
    "232": {
        "start": 734.52,
        "end": 736.9,
        "ja_text": "普通なら錯覚に陥る"
    },
    "233": {
        "start": 737.78,
        "end": 740.86,
        "ja_text": "まるで本物の彼女が生きているかのように"
    },
    "234": {
        "start": 742.92,
        "end": 744.32,
        "ja_text": "でもこのアマデウスは"
    },
    "235": {
        "start": 744.52,
        "end": 746.26,
        "ja_text": "3月の時点でのクリスの記"
    },
    "236": {
        "start": 746.26,
        "end": 747.58,
        "ja_text": "憶をデータ化したシステム"
    },
    "237": {
        "start": 748.02,
        "end": 750.34,
        "ja_text": "あなたと友人だった彼女ではないし"
    },
    "238": {
        "start": 750.39,
        "end": 751.3,
        "ja_text": "生きてはいない"
    },
    "239": {
        "start": 752.064,
        "end": 753.4,
        "ja_text": "その事実は変わらない"
    },
    "240": {
        "start": 754.048,
        "end": 754.88,
        "ja_text": "残酷なほどに"
    },
    "241": {
        "start": 755.5,
        "end": 755.84,
        "ja_text": "ああ"
    },
    "242": {
        "start": 756.96,
        "end": 758.74,
        "ja_text": "アマデウスと話せば話すほど"
    },
    "243": {
        "start": 759.44,
        "end": 760.88,
        "ja_text": "その現実が突きつけられる"
    },
    "244": {
        "start": 761.6,
        "end": 763.06,
        "ja_text": "彼女がいないという事実が"
    },
    "245": {
        "start": 763.84,
        "end": 765.66,
        "ja_text": "動かせないことを思い知ってしまう"
    },
    "246": {
        "start": 766.656,
        "end": 767.34,
        "ja_text": "分かっている"
    },
    "247": {
        "start": 768.192,
        "end": 769.2,
        "ja_text": "その覚悟を決めて"
    },
    "248": {
        "start": 769.98,
        "end": 770.84,
        "ja_text": "ここに来たつもりだ"
    },
    "249": {
        "start": 772.52,
        "end": 772.86,
        "ja_text": "そう"
    },
    "250": {
        "start": 782.82,
        "end": 784.28,
        "ja_text": "そこの椅子に座ってて"
    },
    "251": {
        "start": 790.46,
        "end": 792.38,
        "ja_text": "パスワードは見ないでくれる?"
    },
    "252": {
        "start": 798.46,
        "end": 799.34,
        "ja_text": "いいわよ"
    },
    "253": {
        "start": 801.96,
        "end": 803.0,
        "ja_text": "あ、どうしたの?"
    },
    "254": {
        "start": 805.64,
        "end": 805.74,
        "ja_text": "いや、"
    },
    "255": {
        "start": 806.26,
        "end": 808.68,
        "ja_text": "今になって少しおじけづいてきた"
    },
    "256": {
        "start": 810.36,
        "end": 813.1,
        "ja_text": "まだ間に合うわよ今すぐここから出てけば"
    },
    "257": {
        "start": 813.1,
        "end": 814.44,
        "ja_text": "意地が悪いな"
    },
    "258": {
        "start": 814.76,
        "end": 816.24,
        "ja_text": "心配してあげてるのよ"
    },
    "259": {
        "start": 816.832,
        "end": 820.0,
        "ja_text": "だったらもう少しらしい言い方をした方がいい"
    },
    "260": {
        "start": 820.68,
        "end": 821.58,
        "ja_text": "クリスといい"
    },
    "261": {
        "start": 822.0,
        "end": 823.64,
        "ja_text": "これだから実験大好きっ子は"
    },
    "262": {
        "start": 824.88,
        "end": 825.5,
        "ja_text": "あいや"
    },
    "263": {
        "start": 826.66,
        "end": 829.76,
        "ja_text": "実験に明け暮ればかりの奴は可愛げがないってな"
    },
    "264": {
        "start": 830.72,
        "end": 833.08,
        "ja_text": "今の発言は明らかな誹謗中傷ね"
    },
    "265": {
        "start": 834.14,
        "end": 835.56,
        "ja_text": "侮辱罪で訴えてもいいわ"
    },
    "266": {
        "start": 836.48,
        "end": 837.02,
        "ja_text": "悪かった"
    },
    "267": {
        "start": 837.86,
        "end": 839.26,
        "ja_text": "ドクペをおごるから許してくれ"
    },
    "268": {
        "start": 840.928,
        "end": 841.72,
        "ja_text": "安い"
    },
    "269": {
        "start": 841.96,
        "end": 843.92,
        "ja_text": "何がおかしいんです 先輩"
    },
    "270": {
        "start": 850.96,
        "end": 853.3,
        "ja_text": "彼女がそこにいた"
    },
    "271": {
        "start": 855.4,
        "end": 857.4,
        "ja_text": "すぐそばに"
    },
    "272": {
        "start": 859.8,
        "end": 860.44,
        "ja_text": "あの声と"
    },
    "273": {
        "start": 862.56,
        "end": 863.34,
        "ja_text": "あの姿で"
    },
    "274": {
        "start": 866.8,
        "end": 867.16,
        "ja_text": "どうぞ"
    },
    "275": {
        "start": 876.192,
        "end": 877.4,
        "ja_text": "岡部凛太郎さん?"
    },
    "276": {
        "start": 878.06,
        "end": 878.66,
        "ja_text": "はじめまして"
    },
    "277": {
        "start": 881.28,
        "end": 882.04,
        "ja_text": "牧瀬クリスです"
    },
    "278": {
        "start": 882.96,
        "end": 883.78,
        "ja_text": "どうぞ、よろしく"
    },
    "279": {
        "start": 891.68,
        "end": 892.76,
        "ja_text": "岡部凛太郎さんよ"
    },
    "280": {
        "start": 893.86,
        "end": 895.82,
        "ja_text": "先日のセミナーで知り合ったのだけれど"
    },
    "281": {
        "start": 896.41,
        "end": 898.14,
        "ja_text": "アマデウスに興味があるみたい"
    },
    "282": {
        "start": 898.14,
        "end": 899.66,
        "ja_text": "だったので来てもらったの"
    },
    "283": {
        "start": 900.5,
        "end": 902.72,
        "ja_text": "へえ 先輩がそんなこと言"
    },
    "284": {
        "start": 902.72,
        "end": 904.18,
        "ja_text": "うなんて大したものですね"
    },
    "285": {
        "start": 905.504,
        "end": 907.28,
        "ja_text": "えっと 岡部さん?"
    },
    "286": {
        "start": 908.1,
        "end": 908.384,
        "ja_text": "え?"
    },
    "287": {
        "start": 908.72,
        "end": 908.98,
        "ja_text": "あ…"
    },
    "288": {
        "start": 909.18,
        "end": 911.6,
        "ja_text": "岡部さんも農科学専攻なんですか?"
    },
    "289": {
        "start": 912.28,
        "end": 912.46,
        "ja_text": "あ…"
    },
    "290": {
        "start": 913.14,
        "end": 913.38,
        "ja_text": "あ…"
    },
    "291": {
        "start": 913.57,
        "end": 916.74,
        "ja_text": "専攻は違うわ ただ彼は優秀よ"
    },
    "292": {
        "start": 917.34,
        "end": 919.2,
        "ja_text": "教授にも気に入られたみたいだし"
    },
    "293": {
        "start": 920.256,
        "end": 920.42,
        "ja_text": "はあ"
    },
    "294": {
        "start": 922.18,
        "end": 923.26,
        "ja_text": "あの先輩"
    },
    "295": {
        "start": 924.58,
        "end": 926.9,
        "ja_text": "ちょっとスピーカーに近づいてくれませんか"
    },
    "296": {
        "start": 927.36,
        "end": 927.76,
        "ja_text": "え"
    },
    "297": {
        "start": 927.76,
        "end": 929.78,
        "ja_text": "いいからお願いします"
    },
    "298": {
        "start": 930.84,
        "end": 931.64,
        "ja_text": "何よ"
    },
    "299": {
        "start": 933.28,
        "end": 934.26,
        "ja_text": "ひょっとして"
    },
    "300": {
        "start": 935.94,
        "end": 937.96,
        "ja_text": "はあそんなわけないでしょ"
    },
    "301": {
        "start": 938.528,
        "end": 939.82,
        "ja_text": "そんなに照れなくても"
    },
    "302": {
        "start": 939.82,
        "end": 942.26,
        "ja_text": "とにかくおかしなことを言うのはやめて"
    },
    "303": {
        "start": 942.976,
        "end": 943.92,
        "ja_text": "何の話だ"
    },
    "304": {
        "start": 943.92,
        "end": 945.16,
        "ja_text": "何でもないわ"
    },
    "305": {
        "start": 945.7,
        "end": 946.1,
        "ja_text": "はい"
    },
    "306": {
        "start": 946.23,
        "end": 948.96,
        "ja_text": "とにかくバカな話はおしまい"
    },
    "307": {
        "start": 949.05,
        "end": 951.06,
        "ja_text": "こんな中身のない話しをしに岡部さん"
    },
    "308": {
        "start": 951.06,
        "end": 952.54,
        "ja_text": "に来てもらったわけじゃないんだし"
    },
    "309": {
        "start": 952.94,
        "end": 955.42,
        "ja_text": "ごまかすところがますます怪しい"
    },
    "310": {
        "start": 955.42,
        "end": 956.86,
        "ja_text": "ウイルスぶち込むわよ"
    },
    "311": {
        "start": 957.26,
        "end": 958.72,
        "ja_text": "嘘ですもう言いません"
    },
    "312": {
        "start": 959.38,
        "end": 963.24,
        "ja_text": "ったくアマデウスの問題の一つよねこういうの"
    },
    "313": {
        "start": 963.71,
        "end": 966.26,
        "ja_text": "ごめんなさいじゃあ話して"
    },
    "314": {
        "start": 966.26,
        "end": 967.28,
        "ja_text": "みてもらっていいかしら"
    },
    "315": {
        "start": 967.68,
        "end": 967.968,
        "ja_text": "ああ"
    },
    "316": {
        "start": 969.5,
        "end": 970.08,
        "ja_text": "失礼しました"
    },
    "317": {
        "start": 971.16,
        "end": 972.94,
        "ja_text": "どうぞどんなことでも聞いてください"
    },
    "318": {
        "start": 974.04,
        "end": 975.48,
        "ja_text": "可能な範囲でお答えします"
    },
    "319": {
        "start": 977.984,
        "end": 978.7,
        "ja_text": "そうだな"
    },
    "320": {
        "start": 980.06,
        "end": 983.78,
        "ja_text": "タイムマシンは作れるだろうか"
    },
    "321": {
        "start": 984.04,
        "end": 985.92,
        "ja_text": "タイムマシンですか"
    },
    "322": {
        "start": 987.04,
        "end": 987.44,
        "ja_text": "ああ"
    },
    "323": {
        "start": 989.02,
        "end": 990.24,
        "ja_text": "どういう質問"
    },
    "324": {
        "start": 990.74,
        "end": 993.0,
        "ja_text": "いきなりタイムマシンなんて"
    },
    "325": {
        "start": 993.98,
        "end": 995.14,
        "ja_text": "単なる思考実験だ"
    },
    "326": {
        "start": 996.24,
        "end": 996.64,
        "ja_text": "そうですね"
    },
    "327": {
        "start": 998.48,
        "end": 1000.06,
        "ja_text": "結論から言ってしまうと"
    },
    "328": {
        "start": 1000.72,
        "end": 1002.58,
        "ja_text": "タイムマシンは可能ではない"
    },
    "329": {
        "start": 1003.456,
        "end": 1005.52,
        "ja_text": "けれど不可能とまでは言い切"
    },
    "330": {
        "start": 1005.52,
        "end": 1007.14,
        "ja_text": "れないといったところでしょうか"
    },
    "331": {
        "start": 1007.9,
        "end": 1009.26,
        "ja_text": "タイムマシーンなんてものは"
    },
    "332": {
        "start": 1009.46,
        "end": 1012.46,
        "ja_text": "馬鹿らしい代物ではないのか"
    },
    "333": {
        "start": 1013.152,
        "end": 1015.04,
        "ja_text": "そう決めつけるのは総計ですよ"
    },
    "334": {
        "start": 1015.552,
        "end": 1017.48,
        "ja_text": "様々な理論が提唱されているが"
    },
    "335": {
        "start": 1018.44,
        "end": 1019.86,
        "ja_text": "どれも仮説の域を出ない"
    },
    "336": {
        "start": 1020.68,
        "end": 1021.82,
        "ja_text": "現実的ではないのでは"
    },
    "337": {
        "start": 1023.06,
        "end": 1025.52,
        "ja_text": "それは私たちがまだ重大な何かを"
    },
    "338": {
        "start": 1025.52,
        "end": 1027.86,
        "ja_text": "発見できていないからでしょうね"
    },
    "339": {
        "start": 1028.74,
        "end": 1030.54,
        "ja_text": "だから可能ではないが"
    },
    "340": {
        "start": 1030.54,
        "end": 1033.33,
        "ja_text": "が、負荷のあとは言い切れない、が"
    },
    "341": {
        "start": 1033.36,
        "end": 1034.4,
        "ja_text": "うんうん"
    },
    "342": {
        "start": 1035.36,
        "end": 1035.72,
        "ja_text": "どう?"
    },
    "343": {
        "start": 1037.12,
        "end": 1040.34,
        "ja_text": "俺が話した彼女とは微妙に答えが違っている"
    },
    "344": {
        "start": 1043.31,
        "end": 1046.22,
        "ja_text": "これは、アルファとペータの世界線の差なのか?"
    },
    "345": {
        "start": 1057.3,
        "end": 1058.98,
        "ja_text": "ひどい発音ですね"
    },
    "346": {
        "start": 1060.61,
        "end": 1061.04,
        "ja_text": "黙れ!"
    },
    "347": {
        "start": 1061.14,
        "end": 1061.54,
        "ja_text": "クリスティーナ!"
    },
    "348": {
        "start": 1064.22,
        "end": 1066.64,
        "ja_text": "クリスティーナ?"
    },
    "349": {
        "start": 1068.48,
        "end": 1069.98,
        "ja_text": "いや、な、なんでもない"
    },
    "350": {
        "start": 1070.52,
        "end": 1071.42,
        "ja_text": "気になります?"
    },
    "351": {
        "start": 1072.0,
        "end": 1072.82,
        "ja_text": "なんでもない!"
    },
    "352": {
        "start": 1073.1,
        "end": 1073.9,
        "ja_text": "気にするな!"
    },
    "353": {
        "start": 1074.04,
        "end": 1075.78,
        "ja_text": "明らかに動揺してますよね?"
    },
    "354": {
        "start": 1076.14,
        "end": 1076.94,
        "ja_text": "クリスティーナ…"
    },
    "355": {
        "start": 1076.94,
        "end": 1077.38,
        "ja_text": "しつこいぞ!"
    },
    "356": {
        "start": 1077.48,
        "end": 1078.06,
        "ja_text": "クリスティーナ…"
    },
    "357": {
        "start": 1078.13,
        "end": 1079.52,
        "ja_text": "いや、クリス…"
    },
    "358": {
        "start": 1079.78,
        "end": 1081.36,
        "ja_text": "どうしてクリスティーナなの?"
    },
    "359": {
        "start": 1082.1,
        "end": 1083.98,
        "ja_text": "君までそこに食いつかないでくれ"
    },
    "360": {
        "start": 1083.98,
        "end": 1085.22,
        "ja_text": "答えてください"
    },
    "361": {
        "start": 1085.32,
        "end": 1086.28,
        "ja_text": "しつこいぞ!"
    },
    "362": {
        "start": 1086.7,
        "end": 1088.06,
        "ja_text": "いや、気になるわよ"
    },
    "363": {
        "start": 1090.54,
        "end": 1093.54,
        "ja_text": "アムデウスは面白いだろ、リン太郎"
    },
    "364": {
        "start": 1096.14,
        "end": 1097.06,
        "ja_text": "テスター?"
    },
    "365": {
        "start": 1098.02,
        "end": 1100.5,
        "ja_text": "そう、アムデウスと時々会話"
    },
    "366": {
        "start": 1100.5,
        "end": 1102.74,
        "ja_text": "してそのデータを取らせてほしい"
    },
    "367": {
        "start": 1103.12,
        "end": 1105.8,
        "ja_text": "期間は私がアメリカへ帰るまで"
    },
    "368": {
        "start": 1105.98,
        "end": 1108.84,
        "ja_text": "月に2回ほどここに結果を報"
    },
    "369": {
        "start": 1108.84,
        "end": 1110.94,
        "ja_text": "告しに来てくれればそれでいい"
    },
    "370": {
        "start": 1111.584,
        "end": 1112.76,
        "ja_text": "報告ですか?"
    },
    "371": {
        "start": 1113.5,
        "end": 1115.68,
        "ja_text": "特にノーマルのようなものはないよ"
    },
    "372": {
        "start": 1115.78,
        "end": 1118.22,
        "ja_text": "気が向いた時に彼女と話して"
    },
    "373": {
        "start": 1118.22,
        "end": 1121.5,
        "ja_text": "その反応を僕らに話してくれればいい"
    },
    "374": {
        "start": 1122.18,
        "end": 1122.8,
        "ja_text": "クリスト"
    },
    "375": {
        "start": 1125.44,
        "end": 1128.74,
        "ja_text": "もちろん乗り気でないなら断ってくれていい"
    },
    "376": {
        "start": 1129.22,
        "end": 1133.1,
        "ja_text": "失くした友人を再現したAIと話させることが"
    },
    "377": {
        "start": 1133.23,
        "end": 1135.86,
        "ja_text": "残酷なことは理解しているつもりだ"
    },
    "378": {
        "start": 1137.088,
        "end": 1137.48,
        "ja_text": "俺は"
    },
    "379": {
        "start": 1139.04,
        "end": 1140.18,
        "ja_text": "本当にいいんですか"
    },
    "380": {
        "start": 1140.86,
        "end": 1143.2,
        "ja_text": "僕や魔法との会話ではそろ"
    },
    "381": {
        "start": 1143.2,
        "end": 1145.08,
        "ja_text": "そろ限界が来ていたからね"
    },
    "382": {
        "start": 1145.824,
        "end": 1149.02,
        "ja_text": "それに外部の人間と接することでアム"
    },
    "383": {
        "start": 1149.02,
        "end": 1151.38,
        "ja_text": "デウスがどう変化するかも見えなかった"
    },
    "384": {
        "start": 1153.7,
        "end": 1155.44,
        "ja_text": "私はこうなると思ってました"
    },
    "385": {
        "start": 1156.672,
        "end": 1157.08,
        "ja_text": "そうかい"
    },
    "386": {
        "start": 1157.78,
        "end": 1158.18,
        "ja_text": "ええ"
    },
    "387": {
        "start": 1159.6,
        "end": 1162.02,
        "ja_text": "彼がクリスを知っていると聞いた時から"
    },
    "388": {
        "start": 1164.096,
        "end": 1166.62,
        "ja_text": "岡部凛太郎さんまた会いましょう"
    },
    "389": {
        "start": 1169.64,
        "end": 1172.53,
        "ja_text": "私の知らないクリスを知っている人か"
    },
    "390": {
        "start": 1173.92,
        "end": 1174.3,
        "ja_text": "先輩"
    },
    "391": {
        "start": 1175.48,
        "end": 1175.88,
        "ja_text": "先輩"
    },
    "392": {
        "start": 1178.08,
        "end": 1179.32,
        "ja_text": "あの取りましょうか"
    },
    "393": {
        "start": 1180.0,
        "end": 1182.34,
        "ja_text": "大丈夫よ別に困ってないから"
    },
    "394": {
        "start": 1182.86,
        "end": 1184.26,
        "ja_text": "困ってるじゃないですか"
    },
    "395": {
        "start": 1186.04,
        "end": 1186.368,
        "ja_text": "はい"
    },
    "396": {
        "start": 1190.8,
        "end": 1191.64,
        "ja_text": "先輩"
    },
    "397": {
        "start": 1191.64,
        "end": 1193.3,
        "ja_text": "先輩"
    },
    "398": {
        "start": 1193.74,
        "end": 1195.78,
        "ja_text": "口が悪いのは直した方がいいと思います"
    },
    "399": {
        "start": 1195.78,
        "end": 1196.88,
        "ja_text": "なんで"
    },
    "400": {
        "start": 1197.15,
        "end": 1198.46,
        "ja_text": "嫌われたらどうするんです"
    },
    "401": {
        "start": 1198.59,
        "end": 1201.06,
        "ja_text": "その話に戻るのはやめなさい"
    },
    "402": {
        "start": 1201.11,
        "end": 1203.72,
        "ja_text": "これが人生最後のチャンスかもしれないんです"
    },
    "403": {
        "start": 1206.5,
        "end": 1208.96,
        "ja_text": "あなたこそその口を改めなさい"
    },
    "404": {
        "start": 1212.16,
        "end": 1212.9,
        "ja_text": "オペレーション?"
    },
    "405": {
        "start": 1213.74,
        "end": 1216.16,
        "ja_text": "うん、ダル君と考えたスズ"
    },
    "406": {
        "start": 1216.16,
        "end": 1218.24,
        "ja_text": "さんを元気にしよう大作戦"
    },
    "407": {
        "start": 1218.256,
        "end": 1221.1,
        "ja_text": "え、そんなものを考えていたのか?"
    },
    "408": {
        "start": 1221.64,
        "end": 1224.54,
        "ja_text": "マユシーね、スズさんって普段は"
    },
    "409": {
        "start": 1224.54,
        "end": 1227.54,
        "ja_text": "怖いけど本当は優しい人なんだって"
    },
    "410": {
        "start": 1228.4,
        "end": 1229.92,
        "ja_text": "マユシーがうとうとしてると"
    },
    "411": {
        "start": 1229.92,
        "end": 1232.08,
        "ja_text": "こっそり毛布をかけてくれたり"
    },
    "412": {
        "start": 1232.56,
        "end": 1235.37,
        "ja_text": "ルカ君たちもいろいろ助けてもらってるみたいで"
    },
    "413": {
        "start": 1237.18,
        "end": 1237.54,
        "ja_text": "大丈夫?"
    },
    "414": {
        "start": 1240.44,
        "end": 1242.26,
        "ja_text": "だから元気になってもらうために"
    },
    "415": {
        "start": 1242.26,
        "end": 1244.12,
        "ja_text": "クリスマスパーティーをスズさん"
    },
    "416": {
        "start": 1244.12,
        "end": 1246.14,
        "ja_text": "にプレゼントしようと思うのです"
    },
    "417": {
        "start": 1246.5,
        "end": 1247.3,
        "ja_text": "パーティーか"
    },
    "418": {
        "start": 1247.94,
        "end": 1248.5,
        "ja_text": "ダメかな"
    },
    "419": {
        "start": 1248.5,
        "end": 1249.96,
        "ja_text": "ダメじゃないけど"
    },
    "420": {
        "start": 1250.82,
        "end": 1252.36,
        "ja_text": "スズはそういうの喜ぶか?"
    },
    "421": {
        "start": 1253.28,
        "end": 1254.4,
        "ja_text": "嫌がる気もするんだが"
    },
    "422": {
        "start": 1255.2,
        "end": 1256.72,
        "ja_text": "そんなことないと思うよ"
    },
    "423": {
        "start": 1257.472,
        "end": 1259.32,
        "ja_text": "スズさんもきっとオカリンと仲"
    },
    "424": {
        "start": 1259.32,
        "end": 1261.28,
        "ja_text": "直りしたいと思ってると思うし"
    },
    "425": {
        "start": 1265.46,
        "end": 1267.36,
        "ja_text": "出た方がいいと思うよ"
    },
    "426": {
        "start": 1268.12,
        "end": 1269.5,
        "ja_text": "マイシー待ってるから"
    },
    "427": {
        "start": 1270.816,
        "end": 1271.22,
        "ja_text": "悪い"
    },
    "428": {
        "start": 1275.98,
        "end": 1278.24,
        "ja_text": "まさか8回もイルス使わ"
    },
    "429": {
        "start": 1278.24,
        "end": 1279.56,
        "ja_text": "れるとは思いませんでした"
    },
    "430": {
        "start": 1280.54,
        "end": 1281.34,
        "ja_text": "いやそれは"
    },
    "431": {
        "start": 1282.02,
        "end": 1285.04,
        "ja_text": "まあ話す気がないならそれはそれでいいですが"
    },
    "432": {
        "start": 1285.792,
        "end": 1287.2,
        "ja_text": "はあ何よ"
    },
    "433": {
        "start": 1287.2,
        "end": 1289.46,
        "ja_text": "テストって言うから今まで以上に"
    },
    "434": {
        "start": 1289.46,
        "end": 1291.34,
        "ja_text": "人と話したりできると思ってたのに"
    },
    "435": {
        "start": 1293.14,
        "end": 1293.86,
        "ja_text": "ああこの"
    },
    "436": {
        "start": 1294.88,
        "end": 1296.24,
        "ja_text": "不機嫌で強がりで"
    },
    "437": {
        "start": 1297.32,
        "end": 1300.44,
        "ja_text": "人一倍好奇心が強くて負けず嫌いな"
    },
    "438": {
        "start": 1300.44,
        "end": 1302.06,
        "ja_text": "なんで黙ってるんですか"
    },
    "439": {
        "start": 1302.82,
        "end": 1303.44,
        "ja_text": "とにかく"
    },
    "440": {
        "start": 1304.0,
        "end": 1305.92,
        "ja_text": "気が向いたらどうぞ連絡してきてください"
    },
    "441": {
        "start": 1306.86,
        "end": 1308.84,
        "ja_text": "こっちも忙しいので出ら"
    },
    "442": {
        "start": 1308.84,
        "end": 1310.14,
        "ja_text": "れるかは分かりませんけど"
    },
    "443": {
        "start": 1319.936,
        "end": 1320.54,
        "ja_text": "紛れもない"
    },
    "444": {
        "start": 1322.368,
        "end": 1322.68,
        "ja_text": "負けて"
    },
    "445": {
        "start": 1323.64,
        "end": 1324.48,
        "ja_text": "クリスだ"
    },
    "446": {
        "start": 1347.2,
        "end": 1350.5,
        "ja_text": "realize there is peace"
    },
    "447": {
        "start": 1351.13,
        "end": 1353.7,
        "ja_text": "the truth we've lost"
    },
    "448": {
        "start": 1355.2,
        "end": 1356.72,
        "ja_text": "emptiness"
    },
    "449": {
        "start": 1358.2,
        "end": 1360.72,
        "ja_text": "roars your heart"
    },
    "450": {
        "start": 1360.97,
        "end": 1362.86,
        "ja_text": "cause you're"
    },
    "451": {
        "start": 1362.86,
        "end": 1364.72,
        "ja_text": "free from pain"
    },
    "452": {
        "start": 1364.72,
        "end": 1366.56,
        "ja_text": "and so"
    },
    "453": {
        "start": 1366.56,
        "end": 1371.14,
        "ja_text": "future is just a fight"
    },
    "454": {
        "start": 1371.14,
        "end": 1373.5,
        "ja_text": "to show your ways"
    },
    "455": {
        "start": 1373.97,
        "end": 1375.76,
        "ja_text": "wake up now"
    },
    "456": {
        "start": 1375.76,
        "end": 1377.72,
        "ja_text": "It's the truly"
    },
    "457": {
        "start": 1377.72,
        "end": 1379.4,
        "ja_text": "new source"
    },
    "458": {
        "start": 1380.62,
        "end": 1385.1,
        "ja_text": "Move it over to"
    },
    "459": {
        "start": 1385.1,
        "end": 1386.44,
        "ja_text": "the universe"
    },
    "460": {
        "start": 1388.22,
        "end": 1391.08,
        "ja_text": "I am just a"
    },
    "461": {
        "start": 1391.08,
        "end": 1393.0,
        "ja_text": "part of a song"
    },
    "462": {
        "start": 1394.46,
        "end": 1399.0,
        "ja_text": "目には見えない歪んでる空"
    },
    "463": {
        "start": 1400.08,
        "end": 1405.48,
        "ja_text": "人はどこへと歩いてゆくの"
    },
    "464": {
        "start": 1408.22,
        "end": 1410.6,
        "ja_text": "The last plane"
    },
    "465": {
        "start": 1434.68,
        "end": 1436.08,
        "ja_text": "ご視聴ありがとうございました"
    }
}