{
    "1": {
        "start": 1.696,
        "end": 2.0,
        "ja_text": "キモいは、"
    },
    "2": {
        "start": 30.0,
        "end": 31.04,
        "ja_text": "こいつと誰が"
    },
    "3": {
        "start": 61.2,
        "end": 66.78,
        "ja_text": "無限遠征 価値観を今 上"
    },
    "4": {
        "start": 66.78,
        "end": 70.76,
        "ja_text": "書きする 変哲のない宇宙"
    },
    "5": {
        "start": 71.18,
        "end": 76.28,
        "ja_text": "傲慢な神は 目に映らない"
    },
    "6": {
        "start": 76.42,
        "end": 81.38,
        "ja_text": "高速度で支配続けるならば"
    },
    "7": {
        "start": 81.38,
        "end": 88.36,
        "ja_text": "僕は 僕だけは 奇跡的で"
    },
    "8": {
        "start": 88.36,
        "end": 92.3,
        "ja_text": "致命的なマイノリティでいい"
    },
    "9": {
        "start": 93.376,
        "end": 95.38,
        "ja_text": "I can fly high あの"
    },
    "10": {
        "start": 95.38,
        "end": 99.96,
        "ja_text": "瞬間 あの場面が 君にとって特別なら"
    },
    "11": {
        "start": 100.1,
        "end": 105.5,
        "ja_text": "過去は離れてゆくものなんかじゃなくて"
    },
    "12": {
        "start": 105.5,
        "end": 108.16,
        "ja_text": "傷つつことの痛みより"
    },
    "13": {
        "start": 108.16,
        "end": 110.9,
        "ja_text": "大事な真相のすべての"
    },
    "14": {
        "start": 110.9,
        "end": 114.28,
        "ja_text": "光が今 全部を"
    },
    "15": {
        "start": 116.2,
        "end": 118.26,
        "ja_text": "There is no God"
    },
    "16": {
        "start": 118.78,
        "end": 121.34,
        "ja_text": "Wonderful New World"
    },
    "17": {
        "start": 123.98,
        "end": 126.26,
        "ja_text": "人間ではなく脳"
    },
    "18": {
        "start": 126.26,
        "end": 128.12,
        "ja_text": "一部頭部が欠損した"
    },
    "19": {
        "start": 128.48,
        "end": 130.46,
        "ja_text": "チンパンジーやオランウータンといった"
    },
    "20": {
        "start": 130.63,
        "end": 132.64,
        "ja_text": "猿の死体ということが分かりました"
    },
    "21": {
        "start": 132.64,
        "end": 132.8,
        "ja_text": "ん?"
    },
    "22": {
        "start": 134.74,
        "end": 135.08,
        "ja_text": "どうした?"
    },
    "23": {
        "start": 135.5,
        "end": 136.128,
        "ja_text": "お、い、"
    },
    "24": {
        "start": 136.82,
        "end": 139.28,
        "ja_text": "いや、落ち着け"
    },
    "25": {
        "start": 140.04,
        "end": 141.56,
        "ja_text": "ここはあの世界線じゃない"
    },
    "26": {
        "start": 142.3,
        "end": 144.04,
        "ja_text": "俺たちとセルンとはもう繋がりはない"
    },
    "27": {
        "start": 144.928,
        "end": 146.12,
        "ja_text": "萌花はマユリを殺さない"
    },
    "28": {
        "start": 146.62,
        "end": 147.74,
        "ja_text": "マユリを殺さない"
    },
    "29": {
        "start": 148.74,
        "end": 149.26,
        "ja_text": "殺さない"
    },
    "30": {
        "start": 149.66,
        "end": 151.76,
        "ja_text": "おじさん、顔色悪いよ"
    },
    "31": {
        "start": 153.46,
        "end": 154.08,
        "ja_text": "なんでもない"
    },
    "32": {
        "start": 155.16,
        "end": 156.28,
        "ja_text": "ダル、説明してくれ"
    },
    "33": {
        "start": 157.42,
        "end": 157.88,
        "ja_text": "この人は?"
    },
    "34": {
        "start": 158.64,
        "end": 161.58,
        "ja_text": "キリュウ氏、ヘンプロのライターさんだお"
    },
    "35": {
        "start": 162.54,
        "end": 163.2,
        "ja_text": "キリュウ、"
    },
    "36": {
        "start": 164.288,
        "end": 164.82,
        "ja_text": "萌花です"
    },
    "37": {
        "start": 165.92,
        "end": 169.92,
        "ja_text": "前に秋葉関係の都市伝説を扱った雑誌があって"
    },
    "38": {
        "start": 170.06,
        "end": 172.38,
        "ja_text": "その時に僕のバイトのこと"
    },
    "39": {
        "start": 172.38,
        "end": 174.28,
        "ja_text": "取材したいって連絡が来てさ"
    },
    "40": {
        "start": 174.28,
        "end": 175.2,
        "ja_text": "バイト?"
    },
    "41": {
        "start": 175.34,
        "end": 177.94,
        "ja_text": "ほら僕のバイトって大きな"
    },
    "42": {
        "start": 177.94,
        "end": 179.22,
        "ja_text": "声じゃ言えないやつっしょ"
    },
    "43": {
        "start": 179.49,
        "end": 182.18,
        "ja_text": "だからいつも足つかないようにしてたんだけど"
    },
    "44": {
        "start": 182.2,
        "end": 184.9,
        "ja_text": "桐生氏は僕のところまでたどり着いてさ"
    },
    "45": {
        "start": 185.44,
        "end": 187.64,
        "ja_text": "それで興味を持ったってわけか"
    },
    "46": {
        "start": 187.64,
        "end": 190.04,
        "ja_text": "人探しそう聞いた"
    },
    "47": {
        "start": 191.296,
        "end": 194.58,
        "ja_text": "実は12年前に秋葉でいなくな"
    },
    "48": {
        "start": 194.58,
        "end": 196.3,
        "ja_text": "った女の子を探してほしいんだ"
    },
    "49": {
        "start": 197.14,
        "end": 198.02,
        "ja_text": "12年前"
    },
    "50": {
        "start": 198.54,
        "end": 198.98,
        "ja_text": "うん"
    },
    "51": {
        "start": 199.94,
        "end": 202.2,
        "ja_text": "名前はシーナ・カガリ"
    },
    "52": {
        "start": 202.96,
        "end": 204.64,
        "ja_text": "12年前10歳だったから"
    },
    "53": {
        "start": 204.64,
        "end": 207.44,
        "ja_text": "今は22歳になっているはず"
    },
    "54": {
        "start": 208.64,
        "end": 209.3,
        "ja_text": "選手は"
    },
    "55": {
        "start": 209.78,
        "end": 212.4,
        "ja_text": "はっきりしないけどそれっぽ"
    },
    "56": {
        "start": 212.4,
        "end": 214.14,
        "ja_text": "い写真が最近見つかったんだ"
    },
    "57": {
        "start": 218.8,
        "end": 220.4,
        "ja_text": "本当に頼っていいのか"
    },
    "58": {
        "start": 221.16,
        "end": 222.6,
        "ja_text": "確かにこの世界戦では"
    },
    "59": {
        "start": 223.42,
        "end": 224.5,
        "ja_text": "萌えかとの接点はない"
    },
    "60": {
        "start": 225.54,
        "end": 226.94,
        "ja_text": "マユリを殺す理由もない"
    },
    "61": {
        "start": 228.128,
        "end": 228.52,
        "ja_text": "しかし"
    },
    "62": {
        "start": 228.77,
        "end": 231.26,
        "ja_text": "おそらくこの世界戦でもこいつはラウンダー"
    },
    "63": {
        "start": 231.58,
        "end": 233.72,
        "ja_text": "場合によっては平気で人を"
    },
    "64": {
        "start": 241.7,
        "end": 242.656,
        "ja_text": "やってみてもいい"
    },
    "65": {
        "start": 242.98,
        "end": 243.232,
        "ja_text": "うん"
    },
    "66": {
        "start": 243.88,
        "end": 244.18,
        "ja_text": "マジ?"
    },
    "67": {
        "start": 245.01,
        "end": 247.0,
        "ja_text": "でも、見つかるかわからない"
    },
    "68": {
        "start": 247.11,
        "end": 249.62,
        "ja_text": "いや、もちろん、その場合はしょうがないよ"
    },
    "69": {
        "start": 250.24,
        "end": 253.14,
        "ja_text": "報酬は成功報酬で、その他必要経"
    },
    "70": {
        "start": 253.14,
        "end": 254.84,
        "ja_text": "費はこっちが持つってことでOK?"
    },
    "71": {
        "start": 255.776,
        "end": 256.32,
        "ja_text": "問題ない"
    },
    "72": {
        "start": 256.9,
        "end": 258.34,
        "ja_text": "オカリンもそれでいいよね"
    },
    "73": {
        "start": 259.02,
        "end": 259.82,
        "ja_text": "あ、ああ"
    },
    "74": {
        "start": 260.32,
        "end": 262.7,
        "ja_text": "じゃ、契約成立ってことで"
    },
    "75": {
        "start": 264.05,
        "end": 265.14,
        "ja_text": "行くぞ、ナエ"
    },
    "76": {
        "start": 265.14,
        "end": 266.24,
        "ja_text": "はーい"
    },
    "77": {
        "start": 266.43,
        "end": 267.32,
        "ja_text": "よっしゃ"
    },
    "78": {
        "start": 269.92,
        "end": 271.48,
        "ja_text": "シートベルト忘れんなよ"
    },
    "79": {
        "start": 271.48,
        "end": 271.84,
        "ja_text": "うん"
    },
    "80": {
        "start": 274.016,
        "end": 274.54,
        "ja_text": "いいか?"
    },
    "81": {
        "start": 275.36,
        "end": 275.46,
        "ja_text": "うん!"
    },
    "82": {
        "start": 276.06,
        "end": 276.41,
        "ja_text": "出発!"
    },
    "83": {
        "start": 277.44,
        "end": 277.92,
        "ja_text": "出発!"
    },
    "84": {
        "start": 282.18,
        "end": 283.34,
        "ja_text": "で、誰なの?"
    },
    "85": {
        "start": 283.56,
        "end": 283.96,
        "ja_text": "え?"
    },
    "86": {
        "start": 284.84,
        "end": 286.42,
        "ja_text": "今の人、知ってるんでしょ?"
    },
    "87": {
        "start": 287.86,
        "end": 288.26,
        "ja_text": "え?"
    },
    "88": {
        "start": 290.28,
        "end": 291.62,
        "ja_text": "どうしてそう思うんだ?"
    },
    "89": {
        "start": 292.48,
        "end": 293.5,
        "ja_text": "見てればわかるよ"
    },
    "90": {
        "start": 294.06,
        "end": 295.04,
        "ja_text": "オカリン、知ってた?"
    },
    "91": {
        "start": 298.74,
        "end": 298.84,
        "ja_text": "いや、"
    },
    "92": {
        "start": 299.44,
        "end": 299.86,
        "ja_text": "知らない…"
    },
    "93": {
        "start": 299.86,
        "end": 300.94,
        "ja_text": "アルファ世界戦では?"
    },
    "94": {
        "start": 302.98,
        "end": 303.16,
        "ja_text": "ん?"
    },
    "95": {
        "start": 303.7,
        "end": 304.14,
        "ja_text": "ん?"
    },
    "96": {
        "start": 306.82,
        "end": 308.48,
        "ja_text": "ふぅ、分かった"
    },
    "97": {
        "start": 309.44,
        "end": 310.74,
        "ja_text": "これ以上は効かないけど、"
    },
    "98": {
        "start": 310.86,
        "end": 313.04,
        "ja_text": "私なりに警戒しておくから"
    },
    "99": {
        "start": 316.096,
        "end": 317.88,
        "ja_text": "それでいい、今はな"
    },
    "100": {
        "start": 318.88,
        "end": 319.42,
        "ja_text": "どういうこと?"
    },
    "101": {
        "start": 320.34,
        "end": 321.7,
        "ja_text": "緊張したってことさ"
    },
    "102": {
        "start": 322.8,
        "end": 325.54,
        "ja_text": "ああ、桐生氏美人でスタイル抜群"
    },
    "103": {
        "start": 325.54,
        "end": 327.62,
        "ja_text": "でメガネ属性まで持ってるもんな"
    },
    "104": {
        "start": 342.18,
        "end": 344.38,
        "ja_text": "やっぱりプロに頼んだ方がいいかしら"
    },
    "105": {
        "start": 348.832,
        "end": 349.4,
        "ja_text": "そうなんです"
    },
    "106": {
        "start": 349.82,
        "end": 352.66,
        "ja_text": "何度こちらから連絡しても全く反応なし"
    },
    "107": {
        "start": 353.32,
        "end": 353.84,
        "ja_text": "なんなのよ"
    },
    "108": {
        "start": 353.85,
        "end": 355.52,
        "ja_text": "テスターが聞いて呆れる"
    },
    "109": {
        "start": 356.2,
        "end": 358.18,
        "ja_text": "携帯が故障しているわけじゃなくて?"
    },
    "110": {
        "start": 358.4,
        "end": 360.24,
        "ja_text": "さあ、だったらいいんですけど"
    },
    "111": {
        "start": 363.64,
        "end": 364.6,
        "ja_text": "マキセ・クリスは"
    },
    "112": {
        "start": 365.2,
        "end": 365.8,
        "ja_text": "死んだの"
    },
    "113": {
        "start": 369.54,
        "end": 372.36,
        "ja_text": "君がそういう悩み方するのは珍しいね"
    },
    "114": {
        "start": 372.66,
        "end": 373.16,
        "ja_text": "教授!"
    },
    "115": {
        "start": 374.04,
        "end": 375.5,
        "ja_text": "いつの間に戻ったんですか"
    },
    "116": {
        "start": 375.67,
        "end": 376.78,
        "ja_text": "ついさっき"
    },
    "117": {
        "start": 378.6,
        "end": 381.68,
        "ja_text": "それにしても日本のコンビニは素晴らしいね"
    },
    "118": {
        "start": 381.68,
        "end": 384.12,
        "ja_text": "毎日違う弁当を食べても"
    },
    "119": {
        "start": 384.23,
        "end": 386.76,
        "ja_text": "一週間もすれば新しいのが出る"
    },
    "120": {
        "start": 386.88,
        "end": 390.44,
        "ja_text": "コンビニ弁当ばかりだと栄養が偏りますよ"
    },
    "121": {
        "start": 392.22,
        "end": 395.2,
        "ja_text": "マホに食事のことで説教は受けたくないな"
    },
    "122": {
        "start": 397.536,
        "end": 399.04,
        "ja_text": "それでどこに行くんだい"
    },
    "123": {
        "start": 399.56,
        "end": 402.26,
        "ja_text": "気分転換を兼ねて秋葉原に"
    },
    "124": {
        "start": 402.64,
        "end": 404.12,
        "ja_text": "リンターロに会いに行く"
    },
    "125": {
        "start": 404.12,
        "end": 405.96,
        "ja_text": "と素直に言えば許可しよう"
    },
    "126": {
        "start": 405.96,
        "end": 407.64,
        "ja_text": "そ、そんなんじゃ"
    },
    "127": {
        "start": 407.64,
        "end": 408.94,
        "ja_text": "違うのかい"
    },
    "128": {
        "start": 410.38,
        "end": 412.32,
        "ja_text": "ついでに会いに行ってもいいですけど"
    },
    "129": {
        "start": 413.01,
        "end": 413.52,
        "ja_text": "ついで?"
    },
    "130": {
        "start": 414.208,
        "end": 415.1,
        "ja_text": "何のついでに"
    },
    "131": {
        "start": 415.1,
        "end": 416.96,
        "ja_text": "だから気分転換です"
    },
    "132": {
        "start": 417.38,
        "end": 420.12,
        "ja_text": "気分転換にここから1時間"
    },
    "133": {
        "start": 420.12,
        "end": 421.82,
        "ja_text": "はかかる秋葉原まで行って"
    },
    "134": {
        "start": 421.82,
        "end": 424.24,
        "ja_text": "ついでにレンターロに会ってもいい?"
    },
    "135": {
        "start": 424.8,
        "end": 425.74,
        "ja_text": "というわけだね"
    },
    "136": {
        "start": 428.0,
        "end": 429.3,
        "ja_text": "許可しよう"
    },
    "137": {
        "start": 430.176,
        "end": 432.32,
        "ja_text": "言っときますけど違いますからね"
    },
    "138": {
        "start": 432.5,
        "end": 434.1,
        "ja_text": "そういうのじゃないですから"
    },
    "139": {
        "start": 434.41,
        "end": 435.16,
        "ja_text": "そういうの?"
    },
    "140": {
        "start": 435.28,
        "end": 435.66,
        "ja_text": "とは?"
    },
    "141": {
        "start": 435.92,
        "end": 437.98,
        "ja_text": "とにかく今日は作業は休みます"
    },
    "142": {
        "start": 437.98,
        "end": 438.56,
        "ja_text": "では"
    },
    "143": {
        "start": 441.26,
        "end": 442.6,
        "ja_text": "レンターロによろしく"
    },
    "144": {
        "start": 447.54,
        "end": 448.02,
        "ja_text": "これは?"
    },
    "145": {
        "start": 449.32,
        "end": 450.34,
        "ja_text": "報告書"
    },
    "146": {
        "start": 457.7,
        "end": 458.18,
        "ja_text": "どう?"
    },
    "147": {
        "start": 460.1,
        "end": 462.28,
        "ja_text": "やっぱりそう簡単に見つかるものじゃないな"
    },
    "148": {
        "start": 464.16,
        "end": 464.62,
        "ja_text": "そうか"
    },
    "149": {
        "start": 467.9,
        "end": 468.38,
        "ja_text": "ん?"
    },
    "150": {
        "start": 468.38,
        "end": 469.62,
        "ja_text": "なんか手がかり?"
    },
    "151": {
        "start": 469.72,
        "end": 471.94,
        "ja_text": "いや、そういうわけじゃないんだが"
    },
    "152": {
        "start": 472.56,
        "end": 472.96,
        "ja_text": "見せて"
    },
    "153": {
        "start": 472.96,
        "end": 474.54,
        "ja_text": "あ、おい"
    },
    "154": {
        "start": 477.0,
        "end": 480.36,
        "ja_text": "調査の中で一つ興味深い事実が浮かび上がった"
    },
    "155": {
        "start": 480.53,
        "end": 482.22,
        "ja_text": "この数ヶ月の間で"
    },
    "156": {
        "start": 482.22,
        "end": 485.18,
        "ja_text": "シーナカガリという女性を探している人物が"
    },
    "157": {
        "start": 485.18,
        "end": 487.3,
        "ja_text": "私たち以外にも存在している"
    },
    "158": {
        "start": 488.032,
        "end": 488.42,
        "ja_text": "どういうこと?"
    },
    "159": {
        "start": 489.888,
        "end": 490.52,
        "ja_text": "読んだ通り"
    },
    "160": {
        "start": 491.392,
        "end": 492.54,
        "ja_text": "誰が探してるん?"
    },
    "161": {
        "start": 493.46,
        "end": 494.14,
        "ja_text": "わからない"
    },
    "162": {
        "start": 495.328,
        "end": 497.04,
        "ja_text": "鈴葉のことという可能性は?"
    },
    "163": {
        "start": 497.18,
        "end": 498.54,
        "ja_text": "それは私も考えた"
    },
    "164": {
        "start": 498.54,
        "end": 500.2,
        "ja_text": "でもここを見て"
    },
    "165": {
        "start": 500.992,
        "end": 502.56,
        "ja_text": "探していたのが男の人"
    },
    "166": {
        "start": 503.64,
        "end": 505.06,
        "ja_text": "中には外国人も"
    },
    "167": {
        "start": 505.74,
        "end": 506.44,
        "ja_text": "外国人?"
    },
    "168": {
        "start": 508.8,
        "end": 510.36,
        "ja_text": "でももう12年になるんだろう"
    },
    "169": {
        "start": 511.28,
        "end": 513.08,
        "ja_text": "その間に知り合いができても"
    },
    "170": {
        "start": 514.17,
        "end": 517.54,
        "ja_text": "つーか子供だし知り合いがいな"
    },
    "171": {
        "start": 517.54,
        "end": 519.0,
        "ja_text": "かったり生きていけないっしょ"
    },
    "172": {
        "start": 519.42,
        "end": 520.44,
        "ja_text": "それはそうだけど"
    },
    "173": {
        "start": 521.696,
        "end": 523.74,
        "ja_text": "しかしこれで一つはっきりしたことがある"
    },
    "174": {
        "start": 524.3,
        "end": 524.66,
        "ja_text": "何"
    },
    "175": {
        "start": 525.9,
        "end": 529.42,
        "ja_text": "少なくともシーナかがりは今現在生きている"
    },
    "176": {
        "start": 530.7,
        "end": 531.7,
        "ja_text": "外国人か"
    },
    "177": {
        "start": 535.5,
        "end": 537.1,
        "ja_text": "確かこっちだったわよね"
    },
    "178": {
        "start": 541.12,
        "end": 546.08,
        "ja_text": "今秋葉原にいるのですが"
    },
    "179": {
        "start": 546.144,
        "end": 549.3,
        "ja_text": "これからラボに"
    },
    "180": {
        "start": 588.88,
        "end": 591.68,
        "ja_text": "おやすみ"
    },
    "181": {
        "start": 628.78,
        "end": 630.28,
        "ja_text": "もしもし岡部さん"
    },
    "182": {
        "start": 630.99,
        "end": 633.38,
        "ja_text": "今あなたのラボの近くまで来たの"
    },
    "183": {
        "start": 634.34,
        "end": 635.24,
        "ja_text": "冷や嬢さん"
    },
    "184": {
        "start": 635.4,
        "end": 636.24,
        "ja_text": "冷や嬢さん"
    },
    "185": {
        "start": 639.52,
        "end": 639.78,
        "ja_text": "岡部"
    },
    "186": {
        "start": 641.74,
        "end": 642.78,
        "ja_text": "冷や嬢さん"
    },
    "187": {
        "start": 644.22,
        "end": 645.12,
        "ja_text": "まさか"
    },
    "188": {
        "start": 645.52,
        "end": 646.78,
        "ja_text": "まさかそんなことが"
    },
    "189": {
        "start": 648.992,
        "end": 649.28,
        "ja_text": "嘘だ"
    },
    "190": {
        "start": 649.9,
        "end": 650.48,
        "ja_text": "嘘だ"
    },
    "191": {
        "start": 658.68,
        "end": 659.48,
        "ja_text": "ヒヤジョウさん"
    },
    "192": {
        "start": 660.08,
        "end": 660.98,
        "ja_text": "女"
    },
    "193": {
        "start": 663.22,
        "end": 665.6,
        "ja_text": "やめて離して"
    },
    "194": {
        "start": 665.6,
        "end": 669.14,
        "ja_text": "待てその子離せ"
    },
    "195": {
        "start": 669.14,
        "end": 670.1,
        "ja_text": "違うの"
    },
    "196": {
        "start": 670.83,
        "end": 674.32,
        "ja_text": "あなたはマホーの恋人ですか"
    },
    "197": {
        "start": 674.32,
        "end": 676.42,
        "ja_text": "ああはい"
    },
    "198": {
        "start": 676.42,
        "end": 677.1,
        "ja_text": "い、いえす"
    },
    "199": {
        "start": 677.1,
        "end": 677.376,
        "ja_text": "あ?"
    },
    "200": {
        "start": 678.73,
        "end": 680.96,
        "ja_text": "うわ、なんだ、ひ、ひやじょうさん"
    },
    "201": {
        "start": 681.15,
        "end": 681.7,
        "ja_text": "だから"
    },
    "202": {
        "start": 682.46,
        "end": 683.86,
        "ja_text": "違うって言ってるのに"
    },
    "203": {
        "start": 685.64,
        "end": 687.38,
        "ja_text": "I'm Judy Reyes"
    },
    "204": {
        "start": 687.38,
        "end": 688.8,
        "ja_text": "レイエス?"
    },
    "205": {
        "start": 689.64,
        "end": 690.84,
        "ja_text": "ジュディ・レイエス教授"
    },
    "206": {
        "start": 691.62,
        "end": 695.0,
        "ja_text": "今度日本で開かれるAI関係の学会"
    },
    "207": {
        "start": 695.0,
        "end": 697.24,
        "ja_text": "に出席するために来日したんですって"
    },
    "208": {
        "start": 698.176,
        "end": 701.28,
        "ja_text": "教授、じゃあビクトルコンドリア大学の?"
    },
    "209": {
        "start": 701.52,
        "end": 702.04,
        "ja_text": "イエス"
    },
    "210": {
        "start": 703.9,
        "end": 706.12,
        "ja_text": "あ、あ、あ、あ、あ、"
    },
    "211": {
        "start": 707.02,
        "end": 711.32,
        "ja_text": "ナイストゥーミーチュー、えっと、あ、あ、あい"
    },
    "212": {
        "start": 712.576,
        "end": 713.84,
        "ja_text": "日本語でいいわよ"
    },
    "213": {
        "start": 713.84,
        "end": 716.02,
        "ja_text": "あ、あ、あ、あ"
    },
    "214": {
        "start": 716.02,
        "end": 716.88,
        "ja_text": "びっくりした?"
    },
    "215": {
        "start": 717.24,
        "end": 720.32,
        "ja_text": "あなたが凛太郎ね、アレクシスから聞いてるわ"
    },
    "216": {
        "start": 720.33,
        "end": 723.58,
        "ja_text": "アレクシス、あ、レスキネン教授か"
    },
    "217": {
        "start": 723.84,
        "end": 726.08,
        "ja_text": "彼女の専門はサイコフィシオロジー"
    },
    "218": {
        "start": 726.624,
        "end": 729.32,
        "ja_text": "精神生理学、脳の活動によ"
    },
    "219": {
        "start": 729.32,
        "end": 731.28,
        "ja_text": "ってもたらされる心の働きとか"
    },
    "220": {
        "start": 731.31,
        "end": 733.44,
        "ja_text": "病気なんかについての研究ね"
    },
    "221": {
        "start": 734.14,
        "end": 735.02,
        "ja_text": "そういう意味では"
    },
    "222": {
        "start": 735.776,
        "end": 736.98,
        "ja_text": "私たちの研究より"
    },
    "223": {
        "start": 737.0,
        "end": 739.48,
        "ja_text": "ずっと役に立つ研究をしていると言っても"
    },
    "224": {
        "start": 739.48,
        "end": 740.6,
        "ja_text": "いいかもしれないわね"
    },
    "225": {
        "start": 741.28,
        "end": 742.36,
        "ja_text": "そんなことはないわ"
    },
    "226": {
        "start": 742.47,
        "end": 744.06,
        "ja_text": "あなたたちのアマデウスだって"
    },
    "227": {
        "start": 744.06,
        "end": 746.42,
        "ja_text": "十分役に立つ可能性があるわよ"
    },
    "228": {
        "start": 746.48,
        "end": 748.54,
        "ja_text": "そう言っていただけると嬉しいです"
    },
    "229": {
        "start": 749.504,
        "end": 751.0,
        "ja_text": "でも駅からつけるなんて"
    },
    "230": {
        "start": 751.05,
        "end": 752.68,
        "ja_text": "レイエス教授も人が悪い"
    },
    "231": {
        "start": 753.376,
        "end": 754.64,
        "ja_text": "駅からつける?"
    },
    "232": {
        "start": 755.424,
        "end": 755.92,
        "ja_text": "私が?"
    },
    "233": {
        "start": 756.16,
        "end": 756.26,
        "ja_text": "え?"
    },
    "234": {
        "start": 757.28,
        "end": 757.96,
        "ja_text": "違うんですか?"
    },
    "235": {
        "start": 758.56,
        "end": 760.62,
        "ja_text": "私はさっきの路地であなたを見かけて"
    },
    "236": {
        "start": 760.62,
        "end": 762.5,
        "ja_text": "って驚かそうと思っただけよ"
    },
    "237": {
        "start": 764.18,
        "end": 764.7,
        "ja_text": "じゃあ"
    },
    "238": {
        "start": 767.22,
        "end": 768.82,
        "ja_text": "気のせい"
    },
    "239": {
        "start": 772.78,
        "end": 774.46,
        "ja_text": "それじゃあ凛太郎もその"
    },
    "240": {
        "start": 774.46,
        "end": 776.1,
        "ja_text": "うちゆっくり話しましょう"
    },
    "241": {
        "start": 776.1,
        "end": 776.58,
        "ja_text": "バイ"
    },
    "242": {
        "start": 777.6,
        "end": 778.12,
        "ja_text": "いや"
    },
    "243": {
        "start": 779.2,
        "end": 781.3,
        "ja_text": "だからそういうのじゃなくて"
    },
    "244": {
        "start": 781.3,
        "end": 782.94,
        "ja_text": "なんだどうした"
    },
    "245": {
        "start": 782.94,
        "end": 783.58,
        "ja_text": "え"
    },
    "246": {
        "start": 783.58,
        "end": 783.872,
        "ja_text": "な、"
    },
    "247": {
        "start": 785.184,
        "end": 785.66,
        "ja_text": "なんでも"
    },
    "248": {
        "start": 786.32,
        "end": 787.5,
        "ja_text": "おかねー"
    },
    "249": {
        "start": 788.24,
        "end": 789.38,
        "ja_text": "どうしたの"
    },
    "250": {
        "start": 789.96,
        "end": 792.04,
        "ja_text": "あ、いや、大したことじゃない"
    },
    "251": {
        "start": 793.06,
        "end": 794.66,
        "ja_text": "おー、冷や上司"
    },
    "252": {
        "start": 797.376,
        "end": 798.86,
        "ja_text": "なんかこの前会った時より"
    },
    "253": {
        "start": 798.86,
        "end": 800.48,
        "ja_text": "一段と小さくなったような"
    },
    "254": {
        "start": 801.152,
        "end": 802.84,
        "ja_text": "ありえると思いますか、そんなこと"
    },
    "255": {
        "start": 803.3,
        "end": 806.28,
        "ja_text": "うーん、ロリっ子成分増し増し"
    },
    "256": {
        "start": 807.24,
        "end": 809.48,
        "ja_text": "ここで冷や上司がロリキャラ担当として"
    },
    "257": {
        "start": 809.48,
        "end": 812.22,
        "ja_text": "ラボのメンバーに加わる頂点会はありますか"
    },
    "258": {
        "start": 812.29,
        "end": 813.06,
        "ja_text": "ないだろう"
    },
    "259": {
        "start": 813.728,
        "end": 816.42,
        "ja_text": "じゃあせめて、マホタンと呼んでもいいですか"
    },
    "260": {
        "start": 816.42,
        "end": 817.34,
        "ja_text": "つーか呼ぶ"
    },
    "261": {
        "start": 818.432,
        "end": 819.84,
        "ja_text": "何ですか、それ"
    },
    "262": {
        "start": 822.22,
        "end": 823.6,
        "ja_text": "アマデウスが"
    },
    "263": {
        "start": 824.88,
        "end": 825.024,
        "ja_text": "ええ、"
    },
    "264": {
        "start": 825.58,
        "end": 828.416,
        "ja_text": "何度呼んでも岡部さんが応答してくれないって"
    },
    "265": {
        "start": 831.392,
        "end": 834.22,
        "ja_text": "その顔はわざと応答してないって顔ね"
    },
    "266": {
        "start": 840.26,
        "end": 842.44,
        "ja_text": "教授には私から話しておく"
    },
    "267": {
        "start": 843.94,
        "end": 845.22,
        "ja_text": "これはあくまでもテスト"
    },
    "268": {
        "start": 846.42,
        "end": 847.4,
        "ja_text": "続ける義務はない"
    },
    "269": {
        "start": 848.28,
        "end": 849.52,
        "ja_text": "報酬もないしね"
    },
    "270": {
        "start": 858.62,
        "end": 858.94,
        "ja_text": "でも"
    },
    "271": {
        "start": 858.94,
        "end": 861.0,
        "ja_text": "あなたにとって"
    },
    "272": {
        "start": 861.56,
        "end": 863.2,
        "ja_text": "クリスがそこまで大きな"
    },
    "273": {
        "start": 863.2,
        "end": 864.78,
        "ja_text": "存在だとは思わなかったの"
    },
    "274": {
        "start": 865.68,
        "end": 866.92,
        "ja_text": "だから何度も言ったろ"
    },
    "275": {
        "start": 867.09,
        "end": 868.06,
        "ja_text": "俺とクリスを"
    },
    "276": {
        "start": 868.06,
        "end": 868.96,
        "ja_text": "見てればわかる"
    },
    "277": {
        "start": 869.96,
        "end": 871.424,
        "ja_text": "大きい存在だって"
    },
    "278": {
        "start": 872.48,
        "end": 873.36,
        "ja_text": "だからあなたは"
    },
    "279": {
        "start": 873.98,
        "end": 876.2,
        "ja_text": "アマデウスに生きているクリスを投影し"
    },
    "280": {
        "start": 877.12,
        "end": 878.72,
        "ja_text": "その声に記憶を呼び起こし"
    },
    "281": {
        "start": 879.48,
        "end": 880.8,
        "ja_text": "システムに息吹を感じ"
    },
    "282": {
        "start": 881.48,
        "end": 883.1,
        "ja_text": "感情を勝手に保管していく"
    },
    "283": {
        "start": 884.416,
        "end": 884.96,
        "ja_text": "でもア"
    },
    "284": {
        "start": 885.68,
        "end": 887.58,
        "ja_text": "マデウスは現状システムに過ぎない"
    },
    "285": {
        "start": 888.512,
        "end": 890.06,
        "ja_text": "あるのはデータ化された記憶"
    },
    "286": {
        "start": 891.04,
        "end": 892.08,
        "ja_text": "そこに感情は"
    },
    "287": {
        "start": 893.44,
        "end": 894.04,
        "ja_text": "分かってる"
    },
    "288": {
        "start": 895.78,
        "end": 896.1,
        "ja_text": "でも"
    },
    "289": {
        "start": 897.84,
        "end": 898.16,
        "ja_text": "でも"
    },
    "290": {
        "start": 899.46,
        "end": 901.62,
        "ja_text": "その記憶は紛れもないクリスの記憶だ"
    },
    "291": {
        "start": 902.528,
        "end": 903.08,
        "ja_text": "岡部さん"
    },
    "292": {
        "start": 904.12,
        "end": 905.06,
        "ja_text": "分かっているんだ"
    },
    "293": {
        "start": 905.28,
        "end": 906.46,
        "ja_text": "クリスがいないことも"
    },
    "294": {
        "start": 907.34,
        "end": 909.3,
        "ja_text": "ここにあるのはシステムだということも"
    },
    "295": {
        "start": 910.28,
        "end": 910.68,
        "ja_text": "でも"
    },
    "296": {
        "start": 912.256,
        "end": 912.84,
        "ja_text": "それでも"
    },
    "297": {
        "start": 915.22,
        "end": 917.38,
        "ja_text": "少し考えさせてくれ"
    },
    "298": {
        "start": 922.39,
        "end": 924.52,
        "ja_text": "オカリンはお正月どうするの?"
    },
    "299": {
        "start": 925.02,
        "end": 926.32,
        "ja_text": "お正月パーティーか?"
    },
    "300": {
        "start": 926.9,
        "end": 927.3,
        "ja_text": "うん"
    },
    "301": {
        "start": 927.82,
        "end": 929.472,
        "ja_text": "みんなで初詣行って"
    },
    "302": {
        "start": 929.72,
        "end": 931.64,
        "ja_text": "それからおせち料理食べて"
    },
    "303": {
        "start": 931.64,
        "end": 933.1,
        "ja_text": "今年もよろしくって"
    },
    "304": {
        "start": 934.04,
        "end": 935.34,
        "ja_text": "まあ、いいんじゃないか"
    },
    "305": {
        "start": 936.576,
        "end": 937.5,
        "ja_text": "だよねだよね"
    },
    "306": {
        "start": 937.9,
        "end": 939.66,
        "ja_text": "みんなに後で聞いてみるね"
    },
    "307": {
        "start": 941.22,
        "end": 943.72,
        "ja_text": "じゃあ、まゆしはお買い物に行ってきます"
    },
    "308": {
        "start": 944.26,
        "end": 944.86,
        "ja_text": "小見間か?"
    },
    "309": {
        "start": 946.06,
        "end": 948.1,
        "ja_text": "うん、ふぶきちゃん用のコスでね"
    },
    "310": {
        "start": 948.1,
        "end": 950.48,
        "ja_text": "急に小物が必要になっちゃって"
    },
    "311": {
        "start": 950.74,
        "end": 952.44,
        "ja_text": "そうか、もうすぐだもんな"
    },
    "312": {
        "start": 953.68,
        "end": 953.78,
        "ja_text": "うん、"
    },
    "313": {
        "start": 954.3,
        "end": 956.44,
        "ja_text": "それが終わったら今年も終わりだね"
    },
    "314": {
        "start": 957.68,
        "end": 959.22,
        "ja_text": "あっという間だったな"
    },
    "315": {
        "start": 961.68,
        "end": 963.42,
        "ja_text": "あっという間か"
    },
    "316": {
        "start": 969.18,
        "end": 969.82,
        "ja_text": "あの夏から"
    },
    "317": {
        "start": 970.9,
        "end": 971.6,
        "ja_text": "何度俺は"
    },
    "318": {
        "start": 972.6,
        "end": 974.34,
        "ja_text": "あの夏を繰り返したのだろう"
    },
    "319": {
        "start": 975.37,
        "end": 977.36,
        "ja_text": "でもその年も終わる"
    },
    "320": {
        "start": 985.02,
        "end": 986.26,
        "ja_text": "雪だよ"
    },
    "321": {
        "start": 987.16,
        "end": 988.18,
        "ja_text": "積もるかな"
    },
    "322": {
        "start": 989.18,
        "end": 990.48,
        "ja_text": "時が進む"
    },
    "323": {
        "start": 991.74,
        "end": 993.3,
        "ja_text": "俺が選んだ時が"
    },
    "324": {
        "start": 994.88,
        "end": 995.78,
        "ja_text": "オカリン"
    },
    "325": {
        "start": 996.08,
        "end": 997.24,
        "ja_text": "じゃあ行ってくるね"
    },
    "326": {
        "start": 998.22,
        "end": 998.62,
        "ja_text": "ああ"
    },
    "327": {
        "start": 998.62,
        "end": 1002.5,
        "ja_text": "ああそうだ"
    },
    "328": {
        "start": 1003.72,
        "end": 1005.8,
        "ja_text": "ルカ君がオカリンに何か"
    },
    "329": {
        "start": 1005.8,
        "end": 1007.42,
        "ja_text": "相談があるみたいだったよ"
    },
    "330": {
        "start": 1007.81,
        "end": 1010.42,
        "ja_text": "一度連絡があったの忘れてた"
    },
    "331": {
        "start": 1011.08,
        "end": 1011.92,
        "ja_text": "俺から連絡する"
    },
    "332": {
        "start": 1011.92,
        "end": 1013.8,
        "ja_text": "うんよろしくね"
    },
    "333": {
        "start": 1036.74,
        "end": 1037.08,
        "ja_text": "ん"
    },
    "334": {
        "start": 1037.08,
        "end": 1039.44,
        "ja_text": "忙しいのか 年末で神社の"
    },
    "335": {
        "start": 1039.44,
        "end": 1040.78,
        "ja_text": "手伝いもあるだろうからな"
    },
    "336": {
        "start": 1043.39,
        "end": 1044.71,
        "ja_text": "ごめんくださーい"
    },
    "337": {
        "start": 1045.4,
        "end": 1046.18,
        "ja_text": "ルカコ?"
    },
    "338": {
        "start": 1046.7,
        "end": 1047.58,
        "ja_text": "開いてるぞ"
    },
    "339": {
        "start": 1049.376,
        "end": 1051.08,
        "ja_text": "よかったここで"
    },
    "340": {
        "start": 1051.19,
        "end": 1054.42,
        "ja_text": "すまないこの前のことだろすっか"
    },
    "341": {
        "start": 1054.42,
        "end": 1056.74,
        "ja_text": "り忘れてたんだ今連絡したんだが"
    },
    "342": {
        "start": 1057.82,
        "end": 1061.12,
        "ja_text": "本当だ僕の方こそごめんなさい気がつかなくて"
    },
    "343": {
        "start": 1061.39,
        "end": 1064.18,
        "ja_text": "気にするなそれで要件ってのは"
    },
    "344": {
        "start": 1066.34,
        "end": 1068.04,
        "ja_text": "はい実はですね"
    },
    "345": {
        "start": 1068.04,
        "end": 1073.1,
        "ja_text": "ねー あの実は会ってもらいた"
    },
    "346": {
        "start": 1073.1,
        "end": 1075.4,
        "ja_text": "い人がいて連れてきたんですけど"
    },
    "347": {
        "start": 1076.42,
        "end": 1077.22,
        "ja_text": "いいですか"
    },
    "348": {
        "start": 1078.86,
        "end": 1080.02,
        "ja_text": "終わってもらいたい人"
    },
    "349": {
        "start": 1108.28,
        "end": 1109.22,
        "ja_text": "クリス"
    },
    "350": {
        "start": 1111.04,
        "end": 1112.08,
        "ja_text": "どうぞ"
    },
    "351": {
        "start": 1113.32,
        "end": 1113.7,
        "ja_text": "どうも"
    },
    "352": {
        "start": 1115.36,
        "end": 1115.88,
        "ja_text": "似てる"
    },
    "353": {
        "start": 1116.86,
        "end": 1118.4,
        "ja_text": "しかし声は違う"
    },
    "354": {
        "start": 1119.06,
        "end": 1120.52,
        "ja_text": "他人の空にか"
    },
    "355": {
        "start": 1121.76,
        "end": 1122.28,
        "ja_text": "いやしかし"
    },
    "356": {
        "start": 1123.392,
        "end": 1123.98,
        "ja_text": "それでルカコ"
    },
    "357": {
        "start": 1124.6,
        "end": 1125.22,
        "ja_text": "この人は"
    },
    "358": {
        "start": 1125.22,
        "end": 1126.14,
        "ja_text": "ルカコ"
    },
    "359": {
        "start": 1126.62,
        "end": 1129.06,
        "ja_text": "あ、すみません、そう呼んでるんです"
    },
    "360": {
        "start": 1130.24,
        "end": 1131.82,
        "ja_text": "その、女の子みたいだから"
    },
    "361": {
        "start": 1135.08,
        "end": 1137.24,
        "ja_text": "前に話したことがありますよね"
    },
    "362": {
        "start": 1137.5,
        "end": 1139.54,
        "ja_text": "お父さんのお客さんが泊まるって"
    },
    "363": {
        "start": 1139.54,
        "end": 1141.58,
        "ja_text": "あ、じゃあ彼女が?"
    },
    "364": {
        "start": 1142.44,
        "end": 1145.38,
        "ja_text": "はい、お父さんの知人が連れてこられた方で"
    },
    "365": {
        "start": 1145.38,
        "end": 1146.44,
        "ja_text": "名前は?"
    },
    "366": {
        "start": 1150.02,
        "end": 1152.66,
        "ja_text": "実は、相談というのはそのことなんです"
    },
    "367": {
        "start": 1155.0,
        "end": 1156.96,
        "ja_text": "あのこの人が誰なのかを知"
    },
    "368": {
        "start": 1156.96,
        "end": 1158.74,
        "ja_text": "るにはどうしたらいいかって"
    },
    "369": {
        "start": 1158.74,
        "end": 1160.92,
        "ja_text": "どういうことだ"
    },
    "370": {
        "start": 1163.2,
        "end": 1165.08,
        "ja_text": "その記憶喪失なんです"
    },
    "371": {
        "start": 1168.06,
        "end": 1168.66,
        "ja_text": "名前も"
    },
    "372": {
        "start": 1169.34,
        "end": 1170.4,
        "ja_text": "どこから来たのかも"
    },
    "373": {
        "start": 1171.0,
        "end": 1172.32,
        "ja_text": "どうして記憶をなくした"
    },
    "374": {
        "start": 1172.32,
        "end": 1174.34,
        "ja_text": "のかも覚えてないみたいで"
    },
    "375": {
        "start": 1175.34,
        "end": 1176.5,
        "ja_text": "そうなのか"
    },
    "376": {
        "start": 1177.44,
        "end": 1179.48,
        "ja_text": "岡部さんなら記憶を取り戻すいい"
    },
    "377": {
        "start": 1179.48,
        "end": 1180.88,
        "ja_text": "方法を知ってるんじゃないかって"
    },
    "378": {
        "start": 1181.9,
        "end": 1183.98,
        "ja_text": "人の脳とか記憶とか難しい"
    },
    "379": {
        "start": 1183.98,
        "end": 1185.22,
        "ja_text": "話たくさんしていたから"
    },
    "380": {
        "start": 1185.22,
        "end": 1186.1,
        "ja_text": "なんでもいいんです"
    },
    "381": {
        "start": 1187.968,
        "end": 1190.62,
        "ja_text": "私は自分のことを思い出したい"
    },
    "382": {
        "start": 1190.62,
        "end": 1192.32,
        "ja_text": "ま、ま、待ってくれ"
    },
    "383": {
        "start": 1192.84,
        "end": 1196.12,
        "ja_text": "俺は確かに話はしたが専門的には何も"
    },
    "384": {
        "start": 1197.024,
        "end": 1199.94,
        "ja_text": "それに記憶を取り戻すのは容易じゃない"
    },
    "385": {
        "start": 1200.72,
        "end": 1202.8,
        "ja_text": "保存とかしておけるならともかく"
    },
    "386": {
        "start": 1204.28,
        "end": 1205.08,
        "ja_text": "そうですか"
    },
    "387": {
        "start": 1206.54,
        "end": 1210.44,
        "ja_text": "だったら何か身元を調べる方法はないでしょうか"
    },
    "388": {
        "start": 1211.3,
        "end": 1212.72,
        "ja_text": "カナさん、本当に辛そうで"
    },
    "389": {
        "start": 1212.72,
        "end": 1213.7,
        "ja_text": "カナ?"
    },
    "390": {
        "start": 1214.36,
        "end": 1214.76,
        "ja_text": "っていうのは?"
    },
    "391": {
        "start": 1216.032,
        "end": 1219.86,
        "ja_text": "仮の名前だから、カナだって、お父さんが"
    },
    "392": {
        "start": 1220.736,
        "end": 1221.8,
        "ja_text": "ずいぶん安直だな"
    },
    "393": {
        "start": 1222.92,
        "end": 1223.84,
        "ja_text": "なんでもいいの"
    },
    "394": {
        "start": 1224.82,
        "end": 1226.52,
        "ja_text": "どうせ仮の名前なんだから"
    },
    "395": {
        "start": 1227.776,
        "end": 1228.42,
        "ja_text": "それより"
    },
    "396": {
        "start": 1231.06,
        "end": 1233.1,
        "ja_text": "何か、手がかりになりそう"
    },
    "397": {
        "start": 1233.1,
        "end": 1234.02,
        "ja_text": "なものは持ってないのか?"
    },
    "398": {
        "start": 1234.32,
        "end": 1237.54,
        "ja_text": "その、財布とか定期とか、携帯とか"
    },
    "399": {
        "start": 1238.656,
        "end": 1239.54,
        "ja_text": "それが何も"
    },
    "400": {
        "start": 1240.448,
        "end": 1240.94,
        "ja_text": "何も?"
    },
    "401": {
        "start": 1241.84,
        "end": 1244.02,
        "ja_text": "それでどうやって今まで生きてきたんだ?"
    },
    "402": {
        "start": 1245.8,
        "end": 1248.9,
        "ja_text": "手がかりになりそうなものは一つだけで、"
    },
    "403": {
        "start": 1249.6,
        "end": 1250.02,
        "ja_text": "カナさん"
    },
    "404": {
        "start": 1250.58,
        "end": 1250.98,
        "ja_text": "はい"
    },
    "405": {
        "start": 1254.04,
        "end": 1254.44,
        "ja_text": "これ"
    },
    "406": {
        "start": 1258.2,
        "end": 1260.86,
        "ja_text": "トゥットゥルー、ただいまー"
    },
    "407": {
        "start": 1261.3,
        "end": 1262.58,
        "ja_text": "雪やんじゃったね"
    },
    "408": {
        "start": 1263.1,
        "end": 1263.5,
        "ja_text": "あれ?"
    },
    "409": {
        "start": 1263.66,
        "end": 1264.54,
        "ja_text": "お客さん?"
    },
    "410": {
        "start": 1266.42,
        "end": 1266.82,
        "ja_text": "これは"
    },
    "411": {
        "start": 1267.56,
        "end": 1268.78,
        "ja_text": "ウンパだー"
    },
    "412": {
        "start": 1269.952,
        "end": 1272.54,
        "ja_text": "ねえねえそのウーパーどうしたの"
    },
    "413": {
        "start": 1273.22,
        "end": 1277.152,
        "ja_text": "カナさんがずっと肌見放さず持っていたって"
    },
    "414": {
        "start": 1277.888,
        "end": 1280.5,
        "ja_text": "これもともとは緑色だったんじゃないかな"
    },
    "415": {
        "start": 1280.62,
        "end": 1283.22,
        "ja_text": "だって森の妖精さんバージョンだもん"
    },
    "416": {
        "start": 1283.904,
        "end": 1285.0,
        "ja_text": "森の妖精さん"
    },
    "417": {
        "start": 1285.0,
        "end": 1288.4,
        "ja_text": "うんこの前やってた映画に出てたんだ"
    },
    "418": {
        "start": 1289.96,
        "end": 1291.68,
        "ja_text": "ほらマユシーも持ってる"
    },
    "419": {
        "start": 1291.68,
        "end": 1293.48,
        "ja_text": "けどデザインが違うでしょ"
    },
    "420": {
        "start": 1294.24,
        "end": 1295.22,
        "ja_text": "羽が生えててね"
    },
    "421": {
        "start": 1296.84,
        "end": 1298.96,
        "ja_text": "でも、じゃあなんでこんなに古びてるんだ?"
    },
    "422": {
        "start": 1300.16,
        "end": 1301.1,
        "ja_text": "最近の映画なら"
    },
    "423": {
        "start": 1306.14,
        "end": 1307.08,
        "ja_text": "ただいま"
    },
    "424": {
        "start": 1312.28,
        "end": 1313.3,
        "ja_text": "おい、大丈夫か?"
    },
    "425": {
        "start": 1313.96,
        "end": 1314.36,
        "ja_text": "おい"
    },
    "426": {
        "start": 1316.3,
        "end": 1317.04,
        "ja_text": "カガリ"
    },
    "427": {
        "start": 1320.56,
        "end": 1322.32,
        "ja_text": "お前はカガリ"
    },
    "428": {
        "start": 1323.2,
        "end": 1324.9,
        "ja_text": "シーナカガリなのか?"
    },
    "429": {
        "start": 1355.22,
        "end": 1358.07,
        "ja_text": "エンティネス"
    },
    "430": {
        "start": 1358.08,
        "end": 1360.7,
        "ja_text": "Rose your heart"
    },
    "431": {
        "start": 1361.75,
        "end": 1363.04,
        "ja_text": "Cause you're free"
    },
    "432": {
        "start": 1363.04,
        "end": 1366.74,
        "ja_text": "from pain and sorrow"
    },
    "433": {
        "start": 1367.68,
        "end": 1371.1,
        "ja_text": "Future is just a fight"
    },
    "434": {
        "start": 1371.1,
        "end": 1373.5,
        "ja_text": "to show your ways"
    },
    "435": {
        "start": 1374.17,
        "end": 1376.98,
        "ja_text": "Wake up now and start"
    },
    "436": {
        "start": 1376.98,
        "end": 1379.36,
        "ja_text": "to lead new souls"
    },
    "437": {
        "start": 1386.74,
        "end": 1387.68,
        "ja_text": "I"
    },
    "438": {
        "start": 1388.224,
        "end": 1388.62,
        "ja_text": "am"
    },
    "439": {
        "start": 1390.528,
        "end": 1392.96,
        "ja_text": "just a part of a sun"
    },
    "440": {
        "start": 1394.4,
        "end": 1397.69,
        "ja_text": "目には見えない歪んです"
    },
    "441": {
        "start": 1400.14,
        "end": 1402.22,
        "ja_text": "人はどこへと"
    },
    "442": {
        "start": 1402.848,
        "end": 1405.4,
        "ja_text": "歩いてゆくの"
    },
    "443": {
        "start": 1407.96,
        "end": 1410.52,
        "ja_text": "The Last Game"
    },
    "444": {
        "start": 1435.4,
        "end": 1436.08,
        "ja_text": "ご視聴ありがとうございました"
    }
}