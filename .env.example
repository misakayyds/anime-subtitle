# DeepSeek API 密钥配置（必填）
# 请在 https://platform.deepseek.com/ 获取 API Key
DEEPSEEK_API_KEY=sk-your-api-key-here

# 设备配置（可选: auto/cuda/rocm/mps/cpu，默认 auto）
# auto - 自动检测，优先级: CUDA/ROCm > MPS > CPU
# cuda - 强制使用 NVIDIA GPU (需要安装 CUDA 版 PyTorch)
# rocm - 强制使用 AMD GPU (需要安装 ROCm 版 PyTorch，仅 Linux)
# mps  - 强制使用 Apple Silicon GPU (仅 macOS)
# cpu  - 强制使用 CPU (速度较慢，仅作为后备)
DEVICE=auto

# Whisper 模型大小（可选，默认根据设备自动选择）
# large-v3 - 最高精度，需要 10GB+ 显存
# medium   - 中等精度，需要 6GB+ 显存
# small    - 轻量模型，CPU 可用
# WHISPER_MODEL=large-v3

# 异步并发大模型翻译任务数（建议 3-5，过高可能被限流）
MAX_API_WORKERS=3

# 引擎常驻显存配置（设置几集清理一次模型显存，建议 1-5）
# 设为 1 即每集清理，最防崩溃但速度稍慢
ALIGNMENT_BATCH_SIZE=3

# 质检阈值（通常不需要修改）
NO_SPEECH_PROB_THRESHOLD=0.7
COMPRESSION_RATIO_THRESHOLD=2.8